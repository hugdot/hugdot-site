        {/* ── GALLERY PANEL ── */}
        {
          hasSections.gallery && (
            <section class="tab-panel hidden" id="panel-gallery" role="tabpanel" aria-labelledby="tab-btn-gallery">
              <div class="panel-header">
                <div class="panel-accent" aria-hidden="true" />
                <h2 class="panel-title">{labels.nav.gallery}</h2>
