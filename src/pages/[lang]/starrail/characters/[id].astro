        }
        {/* ── LIGHT CONES PANEL ── */}
        {
          hasSections.lightCones && (
            <section
              class="tab-panel hidden"
              id="panel-lightcones"
              role="tabpanel"
              aria-labelledby="tab-btn-lightcones"
            >
              <div class="panel-header">
                <div class="panel-accent" aria-hidden="true" />
                <h2 class="panel-title">{labels.nav.lightCones}</h2>
              </div>
              <LightConesTab char={char} lang={lang} allData={allData} labels={labels} />
