---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools, getToolHref } from '@data/tools/index'
import seoData from '@data/seo/en/lorem-ipsum-generator.json'

const relatedTools = tools.filter((t) => t.category === 'text' && t.id !== 'lorem-ipsum-generator' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="UtilitiesApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">

      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/text" class="breadcrumb-link hover:underline">Text Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Generate Lorem Ipsum placeholder text instantly. Perfect for design and development mockups.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:shield-check" size="0.875rem" class="text-[var(--action-color)]" />
            No Upload
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:user-x" size="0.875rem" class="text-[var(--action-color)]" />
            No Login
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:infinity" size="0.875rem" class="text-[var(--action-color)]" />
            No Limits
          </span>
        </div>
      </div>

      <!-- Tool -->
      <div class="flex flex-col gap-6 rounded-2xl border border-[var(--border-color-subtle)] p-6">

        <!-- Unit Selector -->
        <div class="flex items-center justify-between">
          <span class="text-sm font-medium">Generate by</span>
          <div class="flex rounded-full border border-[var(--border-color-subtle)] p-1">
            <button data-unit="paragraphs" class="unit-btn rounded-full px-4 py-1.5 text-xs font-medium transition-all">Paragraphs</button>
            <button data-unit="sentences" class="unit-btn rounded-full px-4 py-1.5 text-xs font-medium transition-all">Sentences</button>
            <button data-unit="words" class="unit-btn rounded-full px-4 py-1.5 text-xs font-medium transition-all">Words</button>
          </div>
        </div>

        <!-- Amount Slider -->
        <div class="flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <label class="text-sm font-medium" for="amount-slider">Amount</label>
            <span id="amount-value" class="text-lg font-bold text-[var(--action-color)]">3</span>
          </div>
          <input
            id="amount-slider"
            type="range"
            min="1"
            max="10"
            value="3"
            class="w-full accent-[var(--action-color)]"
          />
          <div class="flex justify-between text-xs opacity-40">
            <span id="slider-min">1</span>
            <span id="slider-max">10</span>
          </div>
        </div>

        <!-- HTML Tags Option -->
        <label class="flex cursor-pointer items-center gap-3">
          <input id="opt-html" type="checkbox" class="accent-[var(--action-color)]" />
          <div>
            <p class="text-sm font-medium">Include HTML tags</p>
            <p class="text-xs opacity-50">Wraps each paragraph in &lt;p&gt; tags</p>
          </div>
        </label>

        <!-- Result -->
        <div class="flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <span class="text-xs font-semibold uppercase tracking-widest opacity-40">Generated Text</span>
            <div class="flex gap-2">
              <button
                id="regenerate-btn"
                class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-4 py-1.5 text-xs font-medium transition-all hover:border-[var(--action-color)]"
              >
                <Icon aria-hidden="true" name="lucide:refresh-cw" size="0.75rem" />
                Regenerate
              </button>
              <button
                id="copy-btn"
                class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-4 py-1.5 text-xs font-medium transition-all hover:border-[var(--action-color)]"
              >
                <Icon aria-hidden="true" name="lucide:copy" size="0.75rem" />
                Copy
              </button>
            </div>
          </div>
          <div
            id="result-text"
            class="min-h-[160px] w-full rounded-2xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm leading-relaxed opacity-80"
          ></div>
        </div>

      </div>

      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="mt-12">
          <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {relatedTools.map((tool) => (
              <a href={getToolHref(tool.category, tool.slug)}
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]">
                {tool.label} →
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</DefaultLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const amountSlider = document.getElementById('amount-slider') as HTMLInputElement
    const amountValue = document.getElementById('amount-value') as HTMLElement
    const sliderMin = document.getElementById('slider-min') as HTMLElement
    const sliderMax = document.getElementById('slider-max') as HTMLElement
    const optHtml = document.getElementById('opt-html') as HTMLInputElement
    const resultText = document.getElementById('result-text') as HTMLElement
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement
    const regenerateBtn = document.getElementById('regenerate-btn') as HTMLButtonElement
    const unitBtns = document.querySelectorAll('.unit-btn') as NodeListOf<HTMLButtonElement>

    let currentUnit = 'paragraphs'

    const WORDS = [
      'lorem','ipsum','dolor','sit','amet','consectetur','adipiscing','elit','sed','do','eiusmod','tempor',
      'incididunt','ut','labore','et','dolore','magna','aliqua','enim','ad','minim','veniam','quis','nostrud',
      'exercitation','ullamco','laboris','nisi','aliquip','ex','ea','commodo','consequat','duis','aute','irure',
      'reprehenderit','voluptate','velit','esse','cillum','fugiat','nulla','pariatur','excepteur','sint','occaecat',
      'cupidatat','non','proident','sunt','culpa','qui','officia','deserunt','mollit','anim','id','est','laborum',
      'perspiciatis','unde','omnis','iste','natus','error','accusantium','doloremque','laudantium','totam','rem',
      'aperiam','eaque','ipsa','quae','ab','inventore','veritatis','quasi','architecto','beatae','vitae','dicta',
      'explicabo','nemo','ipsam','quia','voluptas','aspernatur','aut','odit','fugit','consequuntur','magni',
      'dolores','eos','ratione','sequi','nesciunt','neque','porro','quisquam','dolorem','adipisci','numquam',
    ]

    const rand = (min: number, max: number) => Math.floor(Math.random() * (max - min + 1)) + min

    const randomWord = () => WORDS[Math.floor(Math.random() * WORDS.length)]

    const generateSentence = (wordCount: number): string => {
      const words = Array.from({ length: wordCount }, randomWord)
      words[0] = words[0].charAt(0).toUpperCase() + words[0].slice(1)
      return words.join(' ') + '.'
    }

    const generateParagraph = (): string => {
      const sentenceCount = rand(4, 8)
      return Array.from({ length: sentenceCount }, () => generateSentence(rand(6, 12))).join(' ')
    }

    const generate = () => {
      const amount = parseInt(amountSlider.value)
      const useHtml = optHtml.checked
      let output = ''

      if (currentUnit === 'paragraphs') {
        const paragraphs = Array.from({ length: amount }, generateParagraph)
        output = useHtml
          ? paragraphs.map((p) => `<p>${p}</p>`).join('\n\n')
          : paragraphs.join('\n\n')
      } else if (currentUnit === 'sentences') {
        const sentences = Array.from({ length: amount }, () => generateSentence(rand(6, 12)))
        output = useHtml
          ? `<p>${sentences.join(' ')}</p>`
          : sentences.join(' ')
      } else {
        const words = Array.from({ length: amount }, randomWord)
        words[0] = words[0].charAt(0).toUpperCase() + words[0].slice(1)
        output = words.join(' ') + '.'
      }

      resultText.textContent = output
    }

    const setUnit = (unit: string) => {
      currentUnit = unit
      unitBtns.forEach((btn) => {
        btn.classList.toggle('active', btn.dataset.unit === unit)
      })

      // update slider range per unit
      if (unit === 'paragraphs') {
        amountSlider.min = '1'
        amountSlider.max = '10'
        amountSlider.value = '3'
        sliderMin.textContent = '1'
        sliderMax.textContent = '10'
      } else if (unit === 'sentences') {
        amountSlider.min = '1'
        amountSlider.max = '20'
        amountSlider.value = '5'
        sliderMin.textContent = '1'
        sliderMax.textContent = '20'
      } else {
        amountSlider.min = '10'
        amountSlider.max = '200'
        amountSlider.value = '50'
        sliderMin.textContent = '10'
        sliderMax.textContent = '200'
      }
      amountValue.textContent = amountSlider.value
      generate()
    }

    unitBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (btn.dataset.unit) setUnit(btn.dataset.unit)
      })
    })

    amountSlider.addEventListener('input', () => {
      amountValue.textContent = amountSlider.value
      generate()
    })

    optHtml.addEventListener('change', generate)
    regenerateBtn.addEventListener('click', generate)

    copyBtn.addEventListener('click', async () => {
      const text = resultText.textContent
      if (!text) return
      await navigator.clipboard.writeText(text)
      copyBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Copied!`
      copyBtn.style.borderColor = 'var(--action-color)'
      copyBtn.style.color = 'var(--action-color)'
      setTimeout(() => {
        copyBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy`
        copyBtn.style.borderColor = ''
        copyBtn.style.color = ''
      }, 2000)
    })

    // init
    setUnit('paragraphs')
  })
</script>

<style>
  .unit-btn.active {
    background-color: var(--action-color);
    color: white;
  }
</style>