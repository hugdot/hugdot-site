---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools, getToolHref } from '@data/tools/index'
import seoData from '@data/seo/en/password-generator.json'

const relatedTools = tools.filter((t) => t.category === 'generator' && t.id !== 'password-generator' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="UtilitiesApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">

      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/generator" class="breadcrumb-link hover:underline">Generator Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Generate strong, random passwords instantly. 100% private — passwords never leave your device.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:shield-check" size="0.875rem" class="text-[var(--action-color)]" />
            No Upload
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:user-x" size="0.875rem" class="text-[var(--action-color)]" />
            No Login
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:infinity" size="0.875rem" class="text-[var(--action-color)]" />
            No Limits
          </span>
        </div>
      </div>

      <!-- Tool -->
      <div class="flex flex-col gap-6 rounded-2xl border border-[var(--border-color-subtle)] p-6">

        <!-- Length Slider -->
        <div class="flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <label class="text-sm font-medium" for="length-slider">Password Length</label>
            <span id="length-value" class="text-lg font-bold text-[var(--action-color)]">16</span>
          </div>
          <input
            id="length-slider"
            type="range"
            min="6"
            max="64"
            value="16"
            class="w-full accent-[var(--action-color)]"
          />
          <div class="flex justify-between text-xs opacity-40">
            <span>6</span>
            <span>64</span>
          </div>
        </div>

        <!-- Character Options -->
        <div class="flex flex-col gap-3">
          <p class="text-sm font-medium">Include</p>
          <div class="grid grid-cols-2 gap-3">
            <label class="option-label flex cursor-pointer items-center gap-3 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 transition-all">
              <input id="opt-uppercase" type="checkbox" checked class="accent-[var(--action-color)]" />
              <div>
                <p class="text-sm font-medium">Uppercase</p>
                <p class="text-xs opacity-50">A B C D ...</p>
              </div>
            </label>
            <label class="option-label flex cursor-pointer items-center gap-3 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 transition-all">
              <input id="opt-lowercase" type="checkbox" checked class="accent-[var(--action-color)]" />
              <div>
                <p class="text-sm font-medium">Lowercase</p>
                <p class="text-xs opacity-50">a b c d ...</p>
              </div>
            </label>
            <label class="option-label flex cursor-pointer items-center gap-3 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 transition-all">
              <input id="opt-numbers" type="checkbox" checked class="accent-[var(--action-color)]" />
              <div>
                <p class="text-sm font-medium">Numbers</p>
                <p class="text-xs opacity-50">1 2 3 4 ...</p>
              </div>
            </label>
            <label class="option-label flex cursor-pointer items-center gap-3 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 transition-all">
              <input id="opt-symbols" type="checkbox" checked class="accent-[var(--action-color)]" />
              <div>
                <p class="text-sm font-medium">Symbols</p>
                <p class="text-xs opacity-50">! @ # $ ...</p>
              </div>
            </label>
          </div>
        </div>

        <!-- Strength -->
        <div class="flex flex-col gap-2">
          <div class="flex items-center justify-between">
            <p class="text-sm font-medium">Strength</p>
            <span id="strength-label" class="text-sm font-semibold"></span>
          </div>
          <div class="flex gap-1.5">
            <div id="bar-1" class="h-2 flex-1 rounded-full bg-[var(--border-color-subtle)] transition-all"></div>
            <div id="bar-2" class="h-2 flex-1 rounded-full bg-[var(--border-color-subtle)] transition-all"></div>
            <div id="bar-3" class="h-2 flex-1 rounded-full bg-[var(--border-color-subtle)] transition-all"></div>
            <div id="bar-4" class="h-2 flex-1 rounded-full bg-[var(--border-color-subtle)] transition-all"></div>
          </div>
        </div>

        <!-- Generated Passwords -->
        <div class="flex flex-col gap-2">
          <p class="text-sm font-medium">Tap to copy</p>
          <div id="passwords-list" class="flex flex-col gap-2"></div>
        </div>

        <!-- Regenerate Button -->
        <button
          id="regenerate-btn"
          class="flex items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
        >
          <Icon aria-hidden="true" name="lucide:refresh-cw" size="1rem" />
          Regenerate
        </button>

      </div>

      <!-- Privacy Badge -->
      <div class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60">
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Passwords are generated entirely in your browser using the Web Crypto API. Nothing is ever sent to a server.</span>
      </div>

      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="mt-12">
          <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {relatedTools.map((tool) => (
              <a href={getToolHref(tool.category, tool.slug)}
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]">
                {tool.label} →
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</DefaultLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const lengthSlider = document.getElementById('length-slider') as HTMLInputElement
    const lengthValue = document.getElementById('length-value') as HTMLElement
    const optUppercase = document.getElementById('opt-uppercase') as HTMLInputElement
    const optLowercase = document.getElementById('opt-lowercase') as HTMLInputElement
    const optNumbers = document.getElementById('opt-numbers') as HTMLInputElement
    const optSymbols = document.getElementById('opt-symbols') as HTMLInputElement
    const strengthLabel = document.getElementById('strength-label') as HTMLElement
    const passwordsList = document.getElementById('passwords-list') as HTMLElement
    const regenerateBtn = document.getElementById('regenerate-btn') as HTMLButtonElement

    const UPPERCASE = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'
    const LOWERCASE = 'abcdefghijklmnopqrstuvwxyz'
    const NUMBERS = '0123456789'
    const SYMBOLS = '!@#$%^&*+-=?@_[]()/'

    const generatePassword = (length: number, charset: string): string => {
      const array = new Uint32Array(length)
      crypto.getRandomValues(array)
      return Array.from(array).map((x) => charset[x % charset.length]).join('')
    }

    const getStrength = (length: number, charsetCount: number): { label: string; color: string; bars: number } => {
      const score = (length >= 16 ? 2 : length >= 12 ? 1 : 0) + (charsetCount >= 4 ? 2 : charsetCount >= 3 ? 1 : 0)
      if (score >= 4) return { label: 'Very Strong', color: '#22c55e', bars: 4 }
      if (score === 3) return { label: 'Strong', color: '#84cc16', bars: 3 }
      if (score === 2) return { label: 'Fair', color: '#f59e0b', bars: 2 }
      return { label: 'Weak', color: '#ef4444', bars: 1 }
    }

    const updateStrength = (length: number, charsetCount: number) => {
      const { label, color, bars } = getStrength(length, charsetCount)
      strengthLabel.textContent = label
      strengthLabel.style.color = color
      for (let i = 1; i <= 4; i++) {
        const bar = document.getElementById(`bar-${i}`) as HTMLElement
        bar.style.backgroundColor = i <= bars ? color : ''
        bar.style.opacity = i <= bars ? '1' : '0.2'
      }
    }

    const generateAll = () => {
      let charset = ''
      let charsetCount = 0
      const mustInclude: string[] = []

      if (optUppercase.checked) { charset += UPPERCASE; charsetCount++; mustInclude.push(UPPERCASE) }
      if (optLowercase.checked) { charset += LOWERCASE; charsetCount++; mustInclude.push(LOWERCASE) }
      if (optNumbers.checked) { charset += NUMBERS; charsetCount++; mustInclude.push(NUMBERS) }
      if (optSymbols.checked) { charset += SYMBOLS; charsetCount++; mustInclude.push(SYMBOLS) }

      if (!charset) return

      const length = parseInt(lengthSlider.value)
      updateStrength(length, charsetCount)

      passwordsList.innerHTML = ''
      for (let i = 0; i < 5; i++) {
        let pwd = generatePassword(length, charset)

        // ensure at least one char from each selected charset
        if (mustInclude.length > 0 && length >= mustInclude.length) {
          const arr = pwd.split('')
          mustInclude.forEach((set, idx) => {
            const randChar = set[Math.floor(Math.random() * set.length)]
            arr[idx] = randChar
          })
          // shuffle
          for (let j = arr.length - 1; j > 0; j--) {
            const k = Math.floor(Math.random() * (j + 1));
            [arr[j], arr[k]] = [arr[k], arr[j]]
          }
          pwd = arr.join('')
        }

        const item = document.createElement('button')
        item.className = 'group flex items-center justify-between gap-3 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-left transition-all hover:border-[var(--action-color)] w-full'
        item.innerHTML = `
          <span class="flex-1 break-all font-mono text-sm">${pwd}</span>
          <span class="copy-label shrink-0 text-xs opacity-40 group-hover:opacity-100 transition-opacity">Copy</span>
        `
        item.addEventListener('click', async () => {
          await navigator.clipboard.writeText(pwd)
          const label = item.querySelector('.copy-label') as HTMLElement
          label.textContent = 'Copied!'
          label.style.color = 'var(--action-color)'
          setTimeout(() => {
            label.textContent = 'Copy'
            label.style.color = ''
          }, 2000)
        })
        passwordsList.appendChild(item)
      }
    }

    lengthSlider.addEventListener('input', () => {
      lengthValue.textContent = lengthSlider.value
      generateAll()
    })

    optUppercase.addEventListener('change', generateAll)
    optLowercase.addEventListener('change', generateAll)
    optNumbers.addEventListener('change', generateAll)
    optSymbols.addEventListener('change', generateAll)
    regenerateBtn.addEventListener('click', generateAll)

    generateAll()
  })
</script>