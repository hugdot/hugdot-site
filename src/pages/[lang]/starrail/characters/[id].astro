        <!-- ── EIDOLONS PANEL ── -->
        {
          hasSections.eidolons && (
            <section class="tab-panel hidden" id="panel-eidolons" role="tabpanel" aria-labelledby="tab-btn-eidolons">
              <div class="panel-header">
                <div class="panel-accent" aria-hidden="true" />
                <h2 class="panel-title">{labels.eidolons}</h2>
