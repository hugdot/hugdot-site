---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools, getToolHref } from '@data/tools/index'
import seoData from '@data/seo/en/unit-converter.json'

const relatedTools = tools.filter((t) => t.category === 'calculator' && t.id !== 'unit-converter' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="UtilitiesApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">
      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/calculator" class="breadcrumb-link hover:underline">Calculator Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">Convert length, weight, temperature, volume, speed and more instantly.</p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span
            class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium"
          >
            <Icon aria-hidden="true" name="lucide:wifi-off" size="0.875rem" class="text-[var(--action-color)]" />
            Works Offline
          </span>
          <span
            class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium"
          >
            <Icon aria-hidden="true" name="lucide:zap" size="0.875rem" class="text-[var(--action-color)]" />
            Instant
          </span>
          <span
            class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium"
          >
            <Icon aria-hidden="true" name="lucide:infinity" size="0.875rem" class="text-[var(--action-color)]" />
            No Limits
          </span>
        </div>
      </div>

      <!-- Tool -->
      <div class="flex flex-col gap-6 rounded-2xl border border-[var(--border-color-subtle)] p-6">
        <!-- Category Tabs -->
        <div class="flex flex-wrap gap-2">
          {
            ['Length', 'Weight', 'Temperature', 'Volume', 'Speed', 'Area'].map((cat) => (
              <button
                data-category={cat}
                class="category-btn rounded-full border border-[var(--border-color-subtle)] px-4 py-1.5 text-xs font-medium transition-all hover:border-[var(--action-color)]"
              >
                {cat}
              </button>
            ))
          }
        </div>

        <!-- Input -->
        <div class="grid max-w-md grid-cols-12 gap-2 sm:gap-3">
          <input
            id="input-value"
            type="number"
            class="col-span-7 rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-3 py-3 text-lg font-semibold outline-none focus:border-[var(--action-color)] sm:px-4"
            placeholder="0"
          />

          <select
            id="input-unit"
            class="col-span-5 rounded-xl border border-[var(--border-color-subtle)] bg-[var(--background-color)] px-2 py-3 text-xs outline-none focus:border-[var(--action-color)] sm:px-4 sm:text-sm"
          >
          </select>
        </div>

        <!-- Results -->
        <div id="results-list" class="flex flex-col gap-2"></div>
      </div>

      <!-- Privacy Badge -->
      <div
        class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60"
      >
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>All calculations happen in your browser. No data is sent to any server.</span>
      </div>

      <!-- Related Tools -->
      {
        relatedTools.length > 0 && (
          <div class="mt-12">
            <Heading level="h2" size="h4" class="mb-6">
              Related Tools
            </Heading>
            <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
              {relatedTools.map((tool) => (
                <a
                  href={getToolHref(tool.category, tool.slug)}
                  class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]"
                >
                  {tool.label} →
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </section>
</DefaultLayout>

<style>
  .category-btn.active {
    border-color: var(--action-color);
    background-color: var(--action-color);
    color: white;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const inputValue = document.getElementById('input-value') as HTMLInputElement
    const inputUnit = document.getElementById('input-unit') as any as HTMLSelectElement
    const resultsList = document.getElementById('results-list') as HTMLElement
    const categoryBtns = document.querySelectorAll('.category-btn') as NodeListOf<HTMLButtonElement>

    type Unit = { label: string; factor?: number; toBase?: (v: number) => number; fromBase?: (v: number) => number }
    type Category = { units: Unit[] }

    const categories: Record<string, Category> = {
      Length: {
        units: [
          { label: 'Kilometer (km)', factor: 1000 },
          { label: 'Meter (m)', factor: 1 },
          { label: 'Centimeter (cm)', factor: 0.01 },
          { label: 'Millimeter (mm)', factor: 0.001 },
          { label: 'Mile (mi)', factor: 1609.344 },
          { label: 'Yard (yd)', factor: 0.9144 },
          { label: 'Foot (ft)', factor: 0.3048 },
          { label: 'Inch (in)', factor: 0.0254 },
          { label: 'Nautical Mile', factor: 1852 },
        ],
      },
      Weight: {
        units: [
          { label: 'Kilogram (kg)', factor: 1 },
          { label: 'Gram (g)', factor: 0.001 },
          { label: 'Milligram (mg)', factor: 0.000001 },
          { label: 'Pound (lb)', factor: 0.453592 },
          { label: 'Ounce (oz)', factor: 0.0283495 },
          { label: 'Ton (metric)', factor: 1000 },
          { label: 'Stone (st)', factor: 6.35029 },
        ],
      },
      Temperature: {
        units: [
          {
            label: 'Celsius (°C)',
            toBase: (v) => v,
            fromBase: (v) => v,
          },
          {
            label: 'Fahrenheit (°F)',
            toBase: (v) => ((v - 32) * 5) / 9,
            fromBase: (v) => (v * 9) / 5 + 32,
          },
          {
            label: 'Kelvin (K)',
            toBase: (v) => v - 273.15,
            fromBase: (v) => v + 273.15,
          },
        ],
      },
      Volume: {
        units: [
          { label: 'Liter (L)', factor: 1 },
          { label: 'Milliliter (mL)', factor: 0.001 },
          { label: 'Cubic Meter (m³)', factor: 1000 },
          { label: 'Gallon (US)', factor: 3.78541 },
          { label: 'Quart (US)', factor: 0.946353 },
          { label: 'Pint (US)', factor: 0.473176 },
          { label: 'Cup (US)', factor: 0.236588 },
          { label: 'Fluid Ounce (US)', factor: 0.0295735 },
          { label: 'Tablespoon', factor: 0.0147868 },
          { label: 'Teaspoon', factor: 0.00492892 },
        ],
      },
      Speed: {
        units: [
          { label: 'Meter/second (m/s)', factor: 1 },
          { label: 'Kilometer/hour (km/h)', factor: 0.277778 },
          { label: 'Mile/hour (mph)', factor: 0.44704 },
          { label: 'Knot (kn)', factor: 0.514444 },
          { label: 'Foot/second (ft/s)', factor: 0.3048 },
        ],
      },
      Area: {
        units: [
          { label: 'Square Meter (m²)', factor: 1 },
          { label: 'Square Kilometer (km²)', factor: 1000000 },
          { label: 'Square Mile (mi²)', factor: 2589988.11 },
          { label: 'Square Yard (yd²)', factor: 0.836127 },
          { label: 'Square Foot (ft²)', factor: 0.092903 },
          { label: 'Square Inch (in²)', factor: 0.00064516 },
          { label: 'Hectare (ha)', factor: 10000 },
          { label: 'Acre', factor: 4046.86 },
        ],
      },
    }

    let currentCategory = 'Length'

    const fmt = (n: number): string => {
      if (Math.abs(n) >= 1e9) return n.toExponential(4)
      if (Math.abs(n) < 0.000001 && n !== 0) return n.toExponential(4)
      const s = parseFloat(n.toPrecision(6)).toString()
      return s
    }

    const populateUnits = () => {
      const units = categories[currentCategory].units
      inputUnit.innerHTML = units.map((u) => `<option value="${u.label}">${u.label}</option>`).join('')
    }

    const convert = () => {
      const val = parseFloat(inputValue.value)
      if (isNaN(val)) {
        resultsList.innerHTML = ''
        return
      }

      const units = categories[currentCategory].units
      const selectedUnit = units.find((u) => u.label === inputUnit.value)
      if (!selectedUnit) return

      // Convert to base
      let baseValue: number
      if (selectedUnit.toBase) {
        baseValue = selectedUnit.toBase(val)
      } else {
        baseValue = val * (selectedUnit.factor ?? 1)
      }

      resultsList.innerHTML = ''
      units.forEach((unit) => {
        if (unit.label === inputUnit.value) return

        let result: number
        if (unit.fromBase) {
          result = unit.fromBase(baseValue)
        } else {
          result = baseValue / (unit.factor ?? 1)
        }

        const row = document.createElement('div')
        row.className =
          'flex items-center justify-between rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 cursor-pointer transition-all hover:border-[var(--action-color)]'
        row.innerHTML = `
          <span class="text-sm opacity-60">${unit.label}</span>
          <div class="flex items-center gap-2">
            <span class="font-semibold">${fmt(result)}</span>
            <svg class="copy-icon h-4 w-4 opacity-30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
            </svg>
          </div>
        `
        row.addEventListener('click', async () => {
          await navigator.clipboard.writeText(String(fmt(result)))
          const icon = row.querySelector('.copy-icon') as HTMLElement
          icon.style.opacity = '1'
          icon.style.stroke = 'var(--action-color)'
          setTimeout(() => {
            icon.style.opacity = '0.3'
            icon.style.stroke = ''
          }, 1500)
        })
        resultsList.appendChild(row)
      })
    }

    const setCategory = (cat: string) => {
      currentCategory = cat
      categoryBtns.forEach((btn) => {
        btn.classList.toggle('active', btn.dataset.category === cat)
      })
      populateUnits()
      convert()
    }

    categoryBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (btn.dataset.category) setCategory(btn.dataset.category)
      })
    })

    inputValue.addEventListener('input', convert)
    inputUnit.addEventListener('change', convert)

    setCategory('Length')
  })
</script>
