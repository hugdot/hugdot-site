---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import seoData from '@data/seo/en/image-to-pdf.json'
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  faq={seoData.faq}
  category="MultimediaApplication"
>
  <section class="py-12">
    <div class="container max-w-3xl">

      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/image" class="breadcrumb-link hover:underline">Image Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Convert one or more images into a PDF file.
          Your images never leave your device — 100% private.
        </p>
      </div>

      <!-- Drop Zone -->
      <div
        id="drop-zone"
        class="flex flex-col items-center justify-center gap-4 rounded-2xl border-2 border-dashed border-[var(--border-color-subtle)] p-12 text-center transition-all hover:border-[var(--action-color)] cursor-pointer"
      >
        <Icon aria-hidden="true" name="lucide:image-plus" size="3rem" class="opacity-30" />
        <div>
          <p class="font-semibold">Open images</p>
          <p class="text-sm opacity-50">or tap to choose</p>
        </div>
        <p class="text-xs opacity-40">Supports JPG, PNG, WebP — multiple files allowed</p>
        <input id="file-input" type="file" accept="image/*" multiple class="hidden" aria-label="Open images" />
      </div>

      <!-- Image List -->
      <div id="image-list" class="mt-6 hidden flex-col gap-2">
        <Heading level="h2" size="h6" class="mb-2 opacity-60">Images to convert</Heading>
        <div id="image-items" class="flex flex-col gap-2"></div>

        <!-- Page Size -->
        <div class="mt-4 flex flex-col gap-2">
          <label class="text-sm opacity-60">Page size</label>
          <div class="flex gap-2">
            {['A4', 'Letter', 'Fit to image'].map((size) => (
              <button
                class="page-size-btn flex-1 rounded-xl border-2 border-[var(--border-color-subtle)] px-3 py-2 text-sm font-medium transition-all hover:border-[var(--action-color)]"
                data-size={size}
              >
                {size}
              </button>
            ))}
          </div>
        </div>

        <!-- Convert Button -->
        <button
          id="convert-btn"
          class="mt-4 flex w-full items-center justify-center gap-2 rounded-2xl bg-[var(--action-color)] px-6 py-4 font-semibold text-white transition-opacity hover:opacity-80"
        >
          <Icon aria-hidden="true" name="lucide:file-output" size="1.25rem" />
          Convert to PDF
        </button>
      </div>

      <!-- Progress -->
      <div id="progress-wrap" class="mt-6 hidden">
        <div class="h-2 w-full overflow-hidden rounded-full bg-[var(--border-color-subtle)]">
          <div id="progress-bar" class="h-full w-0 rounded-full bg-[var(--action-color)] transition-all duration-300"></div>
        </div>
        <p id="progress-text" class="mt-2 text-center text-sm opacity-60">Converting...</p>
      </div>

      <!-- Privacy Badge -->
      <div class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60">
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Your images never leave your device. No data is sent to any server.</span>
      </div>
      
      <!-- How to Use -->
      <div class="mt-16">
        <Heading level="h2" size="h4" class="mb-6">How to Convert Images to PDF</Heading>
        <div class="flex flex-col gap-4">
          {seoData.howto.map((item, index) => (
            <div class="flex gap-4 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--action-color)] text-sm font-bold text-white">
                {index + 1}
              </span>
              <div>
                <p class="font-semibold">{item.step}</p>
                <p class="mt-1 text-sm opacity-60">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Why Use -->
      <div class="mt-12">
        <Heading level="h2" size="h4" class="mb-6">Why Use This Tool</Heading>
        <div class="flex flex-col gap-3">
          {seoData.why.map((reason) => (
            <div class="flex items-center gap-3 rounded-xl border border-[var(--border-color-subtle)] px-5 py-4">
              <Icon aria-hidden="true" name="lucide:check-circle" size="1.25rem" class="shrink-0 text-[var(--action-color)]" />
              <span class="text-sm">{reason}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- FAQ -->
      <div class="mt-12">
        <Heading level="h2" size="h4" class="mb-6">Frequently Asked Questions</Heading>
        <div class="flex flex-col gap-3">
          {seoData.faq.map((item) => (
            <details class="rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4">
              <summary class="cursor-pointer font-semibold">{item.q}</summary>
              <p class="mt-3 text-sm opacity-60">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
      
      <div class="mt-16 border-t border-[var(--border-color-subtle)] pt-8">
        <p class="mb-4 text-[10px] font-bold uppercase tracking-widest opacity-40">Related Keywords</p>
        <div class="flex flex-wrap gap-x-6 gap-y-3"> {seoData.keywords.map((tag) => (
            <span class="text-xs opacity-50">#{tag.toLowerCase()}</span> 
          ))}
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>

<script>
  import { PDFDocument, PageSizes } from 'pdf-lib'

  document.addEventListener('astro:page-load', () => {
    const dropZone = document.getElementById('drop-zone') as HTMLDivElement
    const fileInput = document.getElementById('file-input') as HTMLInputElement
    const imageList = document.getElementById('image-list') as HTMLDivElement
    const imageItems = document.getElementById('image-items') as HTMLDivElement
    const convertBtn = document.getElementById('convert-btn') as HTMLButtonElement
    const progressWrap = document.getElementById('progress-wrap') as HTMLDivElement
    const progressBar = document.getElementById('progress-bar') as HTMLDivElement
    const progressText = document.getElementById('progress-text') as HTMLParagraphElement

    let files: File[] = []
    let selectedSize = 'A4'

    // Page size buttons
    document.querySelectorAll<HTMLButtonElement>('.page-size-btn').forEach(btn => {
      if (btn.dataset.size === 'A4') {
        btn.classList.add('border-[var(--action-color)]', 'text-[var(--action-color)]')
      }
      btn.addEventListener('click', () => {
        selectedSize = btn.dataset.size ?? 'A4'
        document.querySelectorAll<HTMLButtonElement>('.page-size-btn').forEach(b => {
          const isActive = b.dataset.size === selectedSize
          b.classList.toggle('border-[var(--action-color)]', isActive)
          b.classList.toggle('text-[var(--action-color)]', isActive)
          b.classList.toggle('border-[var(--border-color-subtle)]', !isActive)
        })
      })
    })

    const formatSize = (bytes: number) => {
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB'
      return (bytes / (1024 * 1024)).toFixed(1) + ' MB'
    }

    const renderImages = () => {
      imageItems.innerHTML = ''
      if (files.length === 0) {
        imageList.classList.add('hidden')
        imageList.classList.remove('flex')
        return
      }
      imageList.classList.remove('hidden')
      imageList.classList.add('flex')

      files.forEach((file, index) => {
        const url = URL.createObjectURL(file)
        const item = document.createElement('div')
        item.className = 'flex items-center gap-3 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3'
        item.innerHTML = `
          <img src="${url}" alt="${file.name}" class="h-12 w-12 rounded-lg object-cover shrink-0" />
          <span class="flex-1 truncate text-sm">${file.name}</span>
          <span class="shrink-0 text-xs opacity-40">${formatSize(file.size)}</span>
          <div class="flex shrink-0 gap-1">
            <button data-action="up" data-index="${index}" class="rounded-lg p-1.5 opacity-40 hover:opacity-100 transition-opacity ${index === 0 ? 'invisible' : ''}" aria-label="Move up">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
            </button>
            <button data-action="down" data-index="${index}" class="rounded-lg p-1.5 opacity-40 hover:opacity-100 transition-opacity ${index === files.length - 1 ? 'invisible' : ''}" aria-label="Move down">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <button data-action="remove" data-index="${index}" class="rounded-lg p-1.5 opacity-40 hover:opacity-100 transition-opacity" aria-label="Remove">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>
        `
        imageItems.appendChild(item)
      })
    }

    const addFiles = (newFiles: FileList | null) => {
      if (!newFiles) return
      const images = Array.from(newFiles).filter(f => f.type.startsWith('image/'))
      files = [...files, ...images]
      renderImages()
    }

    dropZone.addEventListener('click', () => fileInput.click())
    fileInput.addEventListener('change', () => addFiles(fileInput.files))

    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault()
      dropZone.classList.add('border-[var(--action-color)]')
    })
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-[var(--action-color)]'))
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault()
      dropZone.classList.remove('border-[var(--action-color)]')
      addFiles(e.dataTransfer?.files ?? null)
    })

    imageItems.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button[data-action]') as HTMLButtonElement | null
      if (!btn) return
      const action = btn.dataset.action
      const index = parseInt(btn.dataset.index ?? '0')

      if (action === 'up' && index > 0) {
        [files[index - 1], files[index]] = [files[index], files[index - 1]]
      } else if (action === 'down' && index < files.length - 1) {
        [files[index], files[index + 1]] = [files[index + 1], files[index]]
      } else if (action === 'remove') {
        files.splice(index, 1)
      }
      renderImages()
    })

    convertBtn.addEventListener('click', async () => {
      if (files.length === 0) {
        alert('Please add at least one image.')
        return
      }

      convertBtn.disabled = true
      progressWrap.classList.remove('hidden')
      progressBar.style.width = '0%'
      progressText.textContent = 'Starting...'

      try {
        const pdf = await PDFDocument.create()

        for (let i = 0; i < files.length; i++) {
          progressText.textContent = `Processing image ${i + 1} of ${files.length}...`
          progressBar.style.width = `${((i / files.length) * 90)}%`

          const arrayBuffer = await files[i].arrayBuffer()
          const mimeType = files[i].type

          let image
          if (mimeType === 'image/png') {
            image = await pdf.embedPng(arrayBuffer)
          } else {
            image = await pdf.embedJpg(arrayBuffer)
          }

          let pageWidth: number
          let pageHeight: number

          if (selectedSize === 'A4') {
            ;[pageWidth, pageHeight] = PageSizes.A4
          } else if (selectedSize === 'Letter') {
            ;[pageWidth, pageHeight] = PageSizes.Letter
          } else {
            pageWidth = image.width
            pageHeight = image.height
          }

          const page = pdf.addPage([pageWidth, pageHeight])
          const scale = Math.min(pageWidth / image.width, pageHeight / image.height)
          const w = image.width * scale
          const h = image.height * scale
          const x = (pageWidth - w) / 2
          const y = (pageHeight - h) / 2

          page.drawImage(image, { x, y, width: w, height: h })
        }

        progressText.textContent = 'Saving...'
        progressBar.style.width = '95%'

        const pdfBytes = await pdf.save()
        const blob = new Blob([pdfBytes.buffer as ArrayBuffer], { type: 'application/pdf' })
        const url = URL.createObjectURL(blob)
        const a = document.createElement('a')
        a.href = url
        a.download = 'images.pdf'
        a.click()
        URL.revokeObjectURL(url)

        progressBar.style.width = '100%'
        progressText.textContent = 'Done! PDF saved.'
      } catch (err) {
        progressText.textContent = 'Something went wrong. Please try again.'
        console.error(err)
      } finally {
        convertBtn.disabled = false
      }
    })
  })
</script>