---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools } from '@data/tools'
import seoData from '@data/seo/en/tip-calculator.json'

const relatedTools = tools.filter((t) => t.category === 'calculator' && t.id !== 'tip-calculator' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="UtilitiesApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">

      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/calculator" class="breadcrumb-link hover:underline">Calculator tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Calculate tips and split bills instantly. Works offline — perfect for restaurants.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:wifi-off" size="0.875rem" class="text-[var(--action-color)]" />
            Works Offline
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:zap" size="0.875rem" class="text-[var(--action-color)]" />
            Instant
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:infinity" size="0.875rem" class="text-[var(--action-color)]" />
            No Limits
          </span>
        </div>
      </div>

      <!-- Tool -->
      <div class="flex flex-col gap-6 rounded-2xl border border-[var(--border-color-subtle)] p-6">

        <!-- Bill Amount -->
        <div class="flex flex-col gap-2">
          <label class="text-sm font-medium" for="input-bill">Bill Amount</label>
          <div class="flex items-center rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 focus-within:border-[var(--action-color)]">
            <span class="text-lg font-semibold opacity-40">$</span>
            <input
              id="input-bill"
              type="number"
              inputmode="decimal"
              placeholder="0.00"
              min="0"
              step="0.01"
              class="flex-1 bg-transparent pl-2 text-2xl font-bold outline-none"
            />
          </div>
        </div>

        <!-- Tip Percentage -->
        <div class="flex flex-col gap-3">
          <label class="text-sm font-medium">Tip Percentage</label>
          <div class="grid grid-cols-3 gap-2 sm:grid-cols-6">
            {[10, 15, 18, 20, 25].map((pct) => (
              <button
                data-tip={pct}
                class="tip-btn rounded-xl border border-[var(--border-color-subtle)] py-3 text-sm font-semibold transition-all hover:border-[var(--action-color)]"
              >
                {pct}%
              </button>
            ))}
            <button
              id="tip-custom-btn"
              class="tip-btn rounded-xl border border-[var(--border-color-subtle)] py-3 text-sm font-semibold transition-all hover:border-[var(--action-color)]"
            >
              Custom
            </button>
          </div>
          <div id="custom-tip-wrap" class="hidden">
            <div class="flex items-center rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 focus-within:border-[var(--action-color)]">
              <input
                id="input-custom-tip"
                type="number"
                inputmode="decimal"
                placeholder="Enter tip %"
                min="0"
                max="100"
                class="flex-1 bg-transparent text-sm outline-none"
              />
              <span class="opacity-40">%</span>
            </div>
          </div>
        </div>

        <!-- Number of People -->
        <div class="flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <label class="text-sm font-medium">Split Between</label>
            <span id="people-value" class="text-lg font-bold text-[var(--action-color)]">1 person</span>
          </div>
          <div class="flex items-center gap-4">
            <button id="btn-minus" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[var(--border-color-subtle)] text-lg font-bold transition-all hover:border-[var(--action-color)]">−</button>
            <input
              id="input-people"
              type="range"
              min="1"
              max="20"
              value="1"
              class="flex-1 accent-[var(--action-color)]"
            />
            <button id="btn-plus" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[var(--border-color-subtle)] text-lg font-bold transition-all hover:border-[var(--action-color)]">+</button>
          </div>
        </div>

        <!-- Results -->
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
          <div class="flex flex-col items-center rounded-2xl border border-[var(--border-color-subtle)] px-4 py-5">
            <span class="mb-1 text-xs font-medium opacity-50">Tip Amount</span>
            <span id="result-tip" class="text-2xl font-bold text-[var(--action-color)]">$0.00</span>
          </div>
          <div class="flex flex-col items-center rounded-2xl border border-[var(--border-color-subtle)] px-4 py-5">
            <span class="mb-1 text-xs font-medium opacity-50">Total Bill</span>
            <span id="result-total" class="text-2xl font-bold">$0.00</span>
          </div>
          <div class="flex flex-col items-center rounded-2xl border border-[var(--border-color-subtle)] px-4 py-5">
            <span class="mb-1 text-xs font-medium opacity-50">Per Person</span>
            <span id="result-per-person" class="text-2xl font-bold">$0.00</span>
          </div>
        </div>

        <!-- Reset -->
        <button
          id="reset-btn"
          class="flex items-center justify-center gap-2 rounded-full border border-[var(--border-color-subtle)] px-8 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]"
        >
          <Icon aria-hidden="true" name="lucide:refresh-cw" size="1rem" />
          Reset
        </button>

      </div>

      <!-- Privacy Badge -->
      <div class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60">
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>All calculations happen in your browser. No data is sent to any server.</span>
      </div>

      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="mt-12">
          <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {relatedTools.map((tool) => (
              <a href={tool.href}
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]">
                {tool.label} →
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</DefaultLayout>

<style>
  .tip-btn.active {
    background-color: var(--action-color);
    color: white;
    border-color: var(--action-color);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const inputBill = document.getElementById('input-bill') as HTMLInputElement
    const inputPeople = document.getElementById('input-people') as HTMLInputElement
    const inputCustomTip = document.getElementById('input-custom-tip') as HTMLInputElement
    const customTipWrap = document.getElementById('custom-tip-wrap') as HTMLElement
    const tipCustomBtn = document.getElementById('tip-custom-btn') as HTMLButtonElement
    const peopleValue = document.getElementById('people-value') as HTMLElement
    const btnMinus = document.getElementById('btn-minus') as HTMLButtonElement
    const btnPlus = document.getElementById('btn-plus') as HTMLButtonElement
    const resultTip = document.getElementById('result-tip') as HTMLElement
    const resultTotal = document.getElementById('result-total') as HTMLElement
    const resultPerPerson = document.getElementById('result-per-person') as HTMLElement
    const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement
    const tipBtns = document.querySelectorAll('.tip-btn:not(#tip-custom-btn)') as NodeListOf<HTMLButtonElement>

    let currentTip = 15
    let isCustom = false

    const fmt = (n: number) => `$${n.toFixed(2)}`

    const calculate = () => {
      const bill = parseFloat(inputBill.value) || 0
      const people = parseInt(inputPeople.value) || 1
      const tip = isCustom ? (parseFloat(inputCustomTip.value) || 0) : currentTip

      const tipAmount = bill * (tip / 100)
      const total = bill + tipAmount
      const perPerson = total / people

      resultTip.textContent = fmt(tipAmount)
      resultTotal.textContent = fmt(total)
      resultPerPerson.textContent = fmt(perPerson)
    }

    const setTip = (pct: number) => {
      currentTip = pct
      isCustom = false
      customTipWrap.style.display = 'none'
      tipBtns.forEach((btn) => {
        btn.classList.toggle('active', parseInt(btn.dataset.tip ?? '0') === pct)
      })
      tipCustomBtn.classList.remove('active')
      calculate()
    }

    const updatePeople = () => {
      const n = parseInt(inputPeople.value)
      peopleValue.textContent = n === 1 ? '1 person' : `${n} people`
      calculate()
    }

    // init
    setTip(15)

    tipBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        setTip(parseInt(btn.dataset.tip ?? '15'))
      })
    })

    tipCustomBtn.addEventListener('click', () => {
      isCustom = true
      customTipWrap.style.display = 'block'
      tipBtns.forEach((btn) => btn.classList.remove('active'))
      tipCustomBtn.classList.add('active')
      inputCustomTip.focus()
      calculate()
    })

    inputCustomTip.addEventListener('input', calculate)
    inputBill.addEventListener('input', calculate)

    inputPeople.addEventListener('input', updatePeople)

    btnMinus.addEventListener('click', () => {
      const val = Math.max(1, parseInt(inputPeople.value) - 1)
      inputPeople.value = String(val)
      updatePeople()
    })

    btnPlus.addEventListener('click', () => {
      const val = Math.min(20, parseInt(inputPeople.value) + 1)
      inputPeople.value = String(val)
      updatePeople()
    })

    resetBtn.addEventListener('click', () => {
      inputBill.value = ''
      inputPeople.value = '1'
      inputCustomTip.value = ''
      customTipWrap.style.display = 'none'
      peopleValue.textContent = '1 person'
      resultTip.textContent = '$0.00'
      resultTotal.textContent = '$0.00'
      resultPerPerson.textContent = '$0.00'
      setTip(15)
    })
  })
</script>