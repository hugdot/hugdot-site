---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools, getToolHref } from '@data/tools/index'
import seoData from '@data/seo/en/text-diff-checker.json'

const relatedTools = tools.filter((t) => t.category === 'text' && t.id !== 'text-diff-checker' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="UtilitiesApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">

      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/text" class="breadcrumb-link hover:underline">Text Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Compare two texts and instantly highlight what changed. 100% private — your text never leaves your device.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:shield-check" size="0.875rem" class="text-[var(--action-color)]" />
            No Upload
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:user-x" size="0.875rem" class="text-[var(--action-color)]" />
            No Login
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:infinity" size="0.875rem" class="text-[var(--action-color)]" />
            No Limits
          </span>
        </div>
      </div>

      <!-- Tool -->
      <div class="flex flex-col gap-4">

        <!-- Mode Toggle -->
        <div class="flex items-center justify-between">
          <span class="text-sm font-medium">Compare by</span>
          <div class="flex rounded-full border border-[var(--border-color-subtle)] p-1">
            <button id="mode-word" class="mode-btn active rounded-full px-4 py-1.5 text-xs font-medium transition-all">Word</button>
            <button id="mode-line" class="mode-btn rounded-full px-4 py-1.5 text-xs font-medium transition-all">Line</button>
          </div>
        </div>

        <!-- Input Boxes -->
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div class="flex flex-col gap-2">
            <label class="text-xs font-medium opacity-60" for="input-original">Original Text</label>
            <textarea
              id="input-original"
              rows="8"
              placeholder="Paste original text here..."
              class="w-full resize-none rounded-2xl border border-[var(--border-color-subtle)] bg-transparent px-4 py-3 text-sm outline-none focus:border-[var(--action-color)]"
            ></textarea>
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-xs font-medium opacity-60" for="input-modified">Modified Text</label>
            <textarea
              id="input-modified"
              rows="8"
              placeholder="Paste modified text here..."
              class="w-full resize-none rounded-2xl border border-[var(--border-color-subtle)] bg-transparent px-4 py-3 text-sm outline-none focus:border-[var(--action-color)]"
            ></textarea>
          </div>
        </div>

        <!-- Stats -->
        <div id="stats-panel" class="hidden grid-cols-3 gap-3">
          <div class="flex flex-col items-center rounded-xl border border-[var(--border-color-subtle)] px-4 py-3">
            <span id="stat-added" class="text-xl font-bold text-green-500">0</span>
            <span class="text-xs opacity-50">Added</span>
          </div>
          <div class="flex flex-col items-center rounded-xl border border-[var(--border-color-subtle)] px-4 py-3">
            <span id="stat-removed" class="text-xl font-bold text-red-500">0</span>
            <span class="text-xs opacity-50">Removed</span>
          </div>
          <div class="flex flex-col items-center rounded-xl border border-[var(--border-color-subtle)] px-4 py-3">
            <span id="stat-unchanged" class="text-xl font-bold opacity-40">0</span>
            <span class="text-xs opacity-50">Unchanged</span>
          </div>
        </div>

        <!-- Result -->
        <div id="result-panel" class="hidden flex-col gap-3">
          <div class="flex items-center justify-between">
            <span class="text-xs font-semibold uppercase tracking-widest opacity-40">Diff Result</span>
            <div class="flex gap-3 text-xs">
              <span class="flex items-center gap-1.5">
                <span class="inline-block h-3 w-3 rounded-sm bg-green-500 opacity-70"></span>
                Added
              </span>
              <span class="flex items-center gap-1.5">
                <span class="inline-block h-3 w-3 rounded-sm bg-red-500 opacity-70"></span>
                Removed
              </span>
            </div>
          </div>
          <div
            id="result-text"
            class="min-h-[120px] w-full rounded-2xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm leading-relaxed"
          ></div>
        </div>

        <!-- Empty State -->
        <div id="empty-state" class="flex flex-col items-center justify-center gap-2 rounded-2xl border border-dashed border-[var(--border-color-subtle)] py-12 text-center opacity-40">
          <Icon aria-hidden="true" name="lucide:diff" size="2rem" />
          <p class="text-sm">Paste text in both boxes to see differences</p>
        </div>

      </div>

      <!-- Privacy Badge -->
      <div class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60">
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Your text never leaves your device. No data is sent to any server.</span>
      </div>

      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="mt-12">
          <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {relatedTools.map((tool) => (
              <a href={getToolHref(tool.category, tool.slug)}
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]">
                {tool.label} →
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</DefaultLayout>

<style>
  .mode-btn.active {
    background-color: var(--action-color);
    color: white;
  }
  .diff-added {
    background-color: rgba(34, 197, 94, 0.2);
    color: rgb(21, 128, 61);
    border-radius: 2px;
    padding: 0 2px;
  }
  .diff-removed {
    background-color: rgba(239, 68, 68, 0.2);
    color: rgb(185, 28, 28);
    text-decoration: line-through;
    border-radius: 2px;
    padding: 0 2px;
  }
  :global(.dark) .diff-added {
    color: rgb(134, 239, 172);
  }
  :global(.dark) .diff-removed {
    color: rgb(252, 165, 165);
  }
</style>

<script>
  import * as Diff from 'diff'

  document.addEventListener('astro:page-load', () => {
    const inputOriginal = document.getElementById('input-original') as HTMLTextAreaElement
    const inputModified = document.getElementById('input-modified') as HTMLTextAreaElement
    const resultPanel = document.getElementById('result-panel') as HTMLElement
    const resultText = document.getElementById('result-text') as HTMLElement
    const emptyState = document.getElementById('empty-state') as HTMLElement
    const statsPanel = document.getElementById('stats-panel') as HTMLElement
    const statAdded = document.getElementById('stat-added') as HTMLElement
    const statRemoved = document.getElementById('stat-removed') as HTMLElement
    const statUnchanged = document.getElementById('stat-unchanged') as HTMLElement
    const modeBtns = document.querySelectorAll('.mode-btn') as NodeListOf<HTMLButtonElement>

    let currentMode = 'word'

    const setMode = (mode: string) => {
      currentMode = mode
      modeBtns.forEach((btn) => {
        btn.classList.toggle('active', btn.id === `mode-${mode}`)
      })
      runDiff()
    }

    const runDiff = () => {
      const original = inputOriginal.value
      const modified = inputModified.value

      if (!original && !modified) {
        emptyState.style.display = 'flex'
        resultPanel.style.display = 'none'
        statsPanel.style.display = 'none'
        return
      }

      emptyState.style.display = 'none'

      const diff = currentMode === 'word'
        ? Diff.diffWords(original, modified)
        : Diff.diffLines(original, modified)

      let addedCount = 0
      let removedCount = 0
      let unchangedCount = 0
      let html = ''

      diff.forEach((part) => {
        const escaped = part.value
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/\n/g, '<br>')

        if (part.added) {
          addedCount += currentMode === 'word'
            ? part.value.trim().split(/\s+/).filter(Boolean).length
            : part.count ?? 1
          html += `<span class="diff-added">${escaped}</span>`
        } else if (part.removed) {
          removedCount += currentMode === 'word'
            ? part.value.trim().split(/\s+/).filter(Boolean).length
            : part.count ?? 1
          html += `<span class="diff-removed">${escaped}</span>`
        } else {
          unchangedCount += currentMode === 'word'
            ? part.value.trim().split(/\s+/).filter(Boolean).length
            : part.count ?? 1
          html += `<span>${escaped}</span>`
        }
      })

      resultText.innerHTML = html
      statAdded.textContent = String(addedCount)
      statRemoved.textContent = String(removedCount)
      statUnchanged.textContent = String(unchangedCount)

      resultPanel.style.display = 'flex'
      statsPanel.style.display = 'grid'
    }

    modeBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const mode = btn.id.replace('mode-', '')
        setMode(mode)
      })
    })

    inputOriginal.addEventListener('input', runDiff)
    inputModified.addEventListener('input', runDiff)
  })
</script>