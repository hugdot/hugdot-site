---
// src/pages/[lang]/starrail/index.astro
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Icon } from 'astro-icon/components'

const allData = import.meta.glob('/src/data/starrail/**/*.json', { eager: true })

export async function getStaticPaths() {
  const languages = ['kr', 'en', 'jp', 'cn', 'cht', 'fr', 'de', 'es', 'id', 'pt', 'ru', 'th', 'vi']
  return languages.map(lang => ({ params: { lang } }))
}

const { lang } = Astro.params
const baseDir = `/src/data/starrail/${lang}`

const charsRaw:    Record<string, any> = (allData[`${baseDir}/characters.json`]   as any)?.default ?? {}
const elementsRaw: Record<string, any> = (allData[`${baseDir}/elements.json`]     as any)?.default ?? {}
const pathsRaw:    Record<string, any> = (allData[`${baseDir}/paths.json`]         as any)?.default ?? {}

const cleanText = (text: string) => {
  if (!text) return ''
  return text.replace(/\{RUBY_B#([^}]+)\}([^\{]+)\{RUBY_E\#\}/g,'$1').replace(/\{[^}]*\}/g,'').replace(/<[^>]*>/g,'').trim()
}

// 최신 5성 캐릭터 (ID 내림차순, 최대 8명)
const recentChars = Object.entries(charsRaw)
  .filter(([id, d]: [string, any]) => {
    if (id.startsWith('800')) return false
    return d.name && d.name.trim() !== '' && !d.name.includes('{NICKNAME}') && Number(d.rarity) === 5
  })
  .sort(([a], [b]) => Number(b) - Number(a))
  .slice(0, 8)
  .map(([id, d]: [string, any]) => ({
    id,
    name: cleanText(d.name ?? ''),
    element: d.element ?? '',
    path: d.path ?? '',
    rarity: d.rarity ?? 5,
  }))

// 언어별 UI
const T: Record<string, any> = {
  kr: {
    title: '붕괴: 스타레일 DB',
    subtitle: '캐릭터, 광추, 유물, 계획까지 — 한 곳에서',
    eyebrow: 'HugDot · 게임 데이터베이스',
    recentTitle: '최신 캐릭터',
    featuresTitle: '사이트 특징',
    navTitle: '바로가기',
    features: [
      { icon: 'lucide:globe', title: '13개 언어 지원', desc: '한국어, 영어, 일본어 등 13개 언어로 제공' },
      { icon: 'lucide:map-pin', title: '파밍 위치 정보', desc: '재료별 획득처와 드랍 몬스터를 한눈에' },
      { icon: 'lucide:calculator', title: '돌파 계획기', desc: '여러 캐릭터·광추의 재료를 한번에 계산' },
      { icon: 'lucide:database', title: '공식 데이터 기반', desc: 'Dimbreath 공식 데이터로 정확한 수치 제공' },
    ],
    sections: [
      { key:'characters',  label:'캐릭터',     desc:'스킬·행적·스탯·성혼',   href:`/${lang}/starrail/characters`,         icon:'lucide:users',       color:'#7c9dfc' },
      { key:'lightcones',  label:'광추',        desc:'운명의 길별 광추 목록',  href:`/${lang}/starrail/light-cones`,         icon:'lucide:zap',         color:'#fbbf24' },
      { key:'relics',      label:'유물',        desc:'세트 효과 및 어픽스',    href:`/${lang}/starrail/relics`,             icon:'lucide:gem',         color:'#a78bfa' },
      { key:'achievements',label:'업적',        desc:'전체 업적 목록 및 필터', href:`/${lang}/starrail/achievements`,       icon:'lucide:trophy',      color:'#f97316' },
      { key:'simulated',   label:'모의 우주',   desc:'축복·기물·구역 정보',    href:`/${lang}/starrail/simulated-universe`, icon:'lucide:sparkles',    color:'#34d399' },
      { key:'planner',     label:'계획',      desc:'돌파·스킬 재료 계산',    href:`/${lang}/starrail/planner`,            icon:'lucide:calendar',    color:'#f472b6' },
      { key:'items',       label:'재료',        desc:'파밍 재료 및 드랍처',    href:`/${lang}/starrail/items`,              icon:'lucide:package',     color:'#60a5fa' },
    ],
  },
  en: {
    title: 'Honkai: Star Rail DB',
    subtitle: 'Characters, Light Cones, Relics, Planner — all in one place',
    eyebrow: 'HugDot · Game Database',
    recentTitle: 'Recent Characters',
    featuresTitle: 'Why HugDot?',
    navTitle: 'Quick Access',
    features: [
      { icon: 'lucide:globe', title: '13 Languages', desc: 'Available in Korean, English, Japanese and 10 more' },
      { icon: 'lucide:map-pin', title: 'Farming Sources', desc: 'See where to farm each material and which monsters drop it' },
      { icon: 'lucide:calculator', title: 'Ascension Planner', desc: 'Calculate materials for multiple characters at once' },
      { icon: 'lucide:database', title: 'Official Data', desc: 'Accurate stats and values from official game data' },
    ],
    sections: [
      { key:'characters',  label:'Characters',       desc:'Skills, Traces, Stats, Eidolons', href:`/${lang}/starrail/characters`,         icon:'lucide:users',       color:'#7c9dfc' },
      { key:'lightcones',  label:'Light Cones',      desc:'Light Cones by Path',             href:`/${lang}/starrail/light-cones`,         icon:'lucide:zap',         color:'#fbbf24' },
      { key:'relics',      label:'Relics',            desc:'Set effects and affixes',         href:`/${lang}/starrail/relics`,             icon:'lucide:gem',         color:'#a78bfa' },
      { key:'achievements',label:'Achievements',     desc:'Full achievement list',            href:`/${lang}/starrail/achievements`,       icon:'lucide:trophy',      color:'#f97316' },
      { key:'simulated',   label:'Sim. Universe',    desc:'Blessings, Curios, Domains',      href:`/${lang}/starrail/simulated-universe`, icon:'lucide:sparkles',    color:'#34d399' },
      { key:'planner',     label:'Planner',           desc:'Ascension material calculator',   href:`/${lang}/starrail/planner`,            icon:'lucide:calendar',    color:'#f472b6' },
      { key:'items',       label:'Materials',         desc:'Farming materials & drop sources',href:`/${lang}/starrail/items`,              icon:'lucide:package',     color:'#60a5fa' },
      { key:'monsters',    label:'Achievement Track', desc:'Track achievement progress',      href:`/${lang}/starrail/achievements`,       icon:'lucide:list-checks', color:'#94a3b8' },
    ],
  },
}
const ui = T[lang] ?? T['en']

const EL_ICON: Record<string, string> = {
  Physical:  '/starrail/assets/icon/element/Physical.webp',
  Fire:      '/starrail/assets/icon/element/Fire.webp',
  Ice:       '/starrail/assets/icon/element/Ice.webp',
  Thunder:   '/starrail/assets/icon/element/Thunder.webp',
  Wind:      '/starrail/assets/icon/element/Wind.webp',
  Quantum:   '/starrail/assets/icon/element/Quantum.webp',
  Imaginary: '/starrail/assets/icon/element/Imaginary.webp',
}
---

<DefaultLayout
  title={`${ui.title} | HugDot`}
  description={ui.subtitle}
  useTitleTemplate={false}
>
<div class="sr-page">

  <!-- ── Hero ── -->
  <section class="sr-hero">
    <div class="hero-inner">
      <p class="eyebrow">{ui.eyebrow}</p>
      <h1 class="hero-title">{ui.title}</h1>
      <p class="hero-sub">{ui.subtitle}</p>
      <div class="hero-btns">
        <a href={`/${lang}/starrail/characters`} class="btn-primary">
          <Icon name="lucide:users" size="0.9rem"/>
          {T[lang]?.sections[0]?.label ?? 'Characters'}
        </a>
        <a href={`/${lang}/starrail/planner`} class="btn-secondary">
          <Icon name="lucide:calendar" size="0.9rem"/>
          {T[lang]?.sections[5]?.label ?? 'Planner'}
        </a>
      </div>
    </div>
    <div class="hero-bg" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>
  </section>

  <!-- ── 바로가기 ── -->
  <section class="sr-section">
    <div class="sw">
      <h2 class="section-title">{ui.navTitle}</h2>
      <div class="nav-grid">
        {ui.sections.map((s: any) => (
          <a href={s.href} class="nav-card" style={`--nc:${s.color}`}>
            <div class="nc-glow"></div>
            <div class="nc-icon">
              <Icon name={s.icon} size="1.2rem"/>
            </div>
            <div class="nc-body">
              <p class="nc-label">{s.label}</p>
              <p class="nc-desc">{s.desc}</p>
            </div>
            <Icon name="lucide:chevron-right" size="0.9rem" class="nc-arrow"/>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 최신 캐릭터 ── -->
  {recentChars.length > 0 && (
    <section class="sr-section">
      <div class="sw">
        <div class="section-hd">
          <h2 class="section-title">{ui.recentTitle}</h2>
          <a href={`/${lang}/starrail/characters`} class="see-all">
            {lang === 'kr' ? '전체 보기' : 'View all'}
            <Icon name="lucide:arrow-right" size="0.8rem"/>
          </a>
        </div>
        <div class="char-grid">
          {recentChars.map(c => (
            <a href={`/${lang}/starrail/characters/${c.id}`} class="char-card">
              <div class="cc-img-wrap">
                <img
                  src={`/starrail/assets/icon/character/${c.id}.webp`}
                  alt={c.name}
                  width="80" height="80"
                  loading="lazy"
                  class="cc-img"
                />
                {c.element && EL_ICON[c.element] && (
                  <img
                    src={EL_ICON[c.element]}
                    alt={c.element}
                    width="18" height="18"
                    loading="lazy"
                    class="cc-el"
                  />
                )}
              </div>
              <p class="cc-name">{c.name}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── 사이트 특징 ── -->
  <section class="sr-section sr-section--features">
    <div class="sw">
      <h2 class="section-title">{ui.featuresTitle}</h2>
      <div class="feat-grid">
        {ui.features.map((f: any) => (
          <div class="feat-card">
            <div class="feat-icon">
              <Icon name={f.icon} size="1.4rem"/>
            </div>
            <div>
              <p class="feat-title">{f.title}</p>
              <p class="feat-desc">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</div>

<script is:inline define:vars={{ lang }}>
try { localStorage.setItem('hd-lang', lang) } catch(e){}
</script>
</DefaultLayout>

<style>
.sr-page { min-height:100vh; background:var(--c-bg); color:var(--foreground-color); }
.sw { max-width:1200px; margin:0 auto; padding:0 1.5rem; }

/* ── Hero ── */
.sr-hero {
  position:relative; overflow:hidden;
  padding:6rem 1.5rem 5rem;
  border-bottom:1px solid var(--c-border);
}
.hero-inner {
  position:relative; z-index:1;
  max-width:1200px; margin:0 auto;
  display:flex; flex-direction:column; gap:1.25rem;
}
.eyebrow { font-size:.68rem; font-weight:900; letter-spacing:.14em; text-transform:uppercase; color:var(--c-accent); }
.hero-title {
  font-family:var(--font-display);
  font-size:clamp(2.2rem,6vw,4rem);
  font-weight:700; letter-spacing:-.03em; line-height:1.1;
  word-break:keep-all;
}
.hero-sub { font-size:1rem; color:var(--c-muted); line-height:1.7; max-width:560px; word-break:keep-all; }
.hero-btns { display:flex; gap:.75rem; flex-wrap:wrap; margin-top:.5rem; }
.btn-primary {
  display:inline-flex; align-items:center; gap:.5rem;
  padding:.7rem 1.4rem; border-radius:var(--radius-md);
  background:var(--c-accent); color:#fff;
  font-size:.85rem; font-weight:700; text-decoration:none;
  transition:opacity var(--anim-fast),transform var(--anim-fast);
}
.btn-primary:hover { opacity:.9; transform:translateY(-1px); }
.btn-secondary {
  display:inline-flex; align-items:center; gap:.5rem;
  padding:.7rem 1.4rem; border-radius:var(--radius-md);
  border:1px solid var(--c-border); background:var(--c-surface);
  color:var(--foreground-color);
  font-size:.85rem; font-weight:700; text-decoration:none;
  transition:border-color var(--anim-fast),transform var(--anim-fast);
}
.btn-secondary:hover { border-color:var(--c-accent); transform:translateY(-1px); }

.hero-bg { position:absolute; inset:0; pointer-events:none; }
.orb { position:absolute; border-radius:50%; filter:blur(80px); opacity:.15; }
.orb-1 { width:500px; height:500px; top:-150px; right:-100px; background:radial-gradient(circle,#7c9dfc,transparent 70%); }
.orb-2 { width:300px; height:300px; bottom:0; left:20%; background:radial-gradient(circle,#a78bfa,transparent 70%); }
.orb-3 { width:200px; height:200px; top:30%; left:-50px; background:radial-gradient(circle,#34d399,transparent 70%); }

/* ── 섹션 공통 ── */
.sr-section { padding:3rem 0; border-bottom:1px solid var(--c-border); }
.sr-section--features { border-bottom:none; padding-bottom:5rem; }
.section-hd { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; }
.section-title { font-family:var(--font-display); font-size:1.3rem; font-weight:700; letter-spacing:.03em; text-transform:uppercase; margin-bottom:1.5rem; }
.section-hd .section-title { margin-bottom:0; }
.see-all { display:inline-flex; align-items:center; gap:.35rem; font-size:.75rem; font-weight:700; color:var(--c-accent); text-decoration:none; transition:gap var(--anim-fast); }
.see-all:hover { gap:.55rem; }

/* ── 바로가기 그리드 ── */
.nav-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:.6rem; }
.nav-card {
  position:relative; display:flex; align-items:center; gap:.85rem;
  padding:1rem 1rem 1rem .9rem;
  border:1px solid color-mix(in srgb,var(--nc) 20%,transparent);
  border-radius:var(--radius-md); background:var(--c-surface);
  text-decoration:none; color:var(--foreground-color); overflow:hidden;
  transition:border-color var(--anim-fast),transform var(--anim-fast),box-shadow var(--anim-fast);
}
.nav-card:hover { border-color:var(--nc); transform:translateY(-2px); box-shadow:0 8px 24px color-mix(in srgb,var(--nc) 12%,transparent); }
.nav-card:hover .nc-label { color:var(--nc); }
.nav-card:hover .nc-arrow { color:var(--nc); transform:translateX(3px); }
.nc-glow { position:absolute; inset:0; background:radial-gradient(ellipse at left,color-mix(in srgb,var(--nc) 8%,transparent),transparent 60%); pointer-events:none; }
.nc-icon { flex-shrink:0; width:40px; height:40px; border-radius:var(--radius-sm); background:color-mix(in srgb,var(--nc) 12%,transparent); border:1px solid color-mix(in srgb,var(--nc) 25%,transparent); display:flex; align-items:center; justify-content:center; color:var(--nc); position:relative; z-index:1; }
.nc-body { flex:1; min-width:0; position:relative; z-index:1; }
.nc-label { font-size:.88rem; font-weight:700; font-family:var(--font-display); transition:color var(--anim-fast); line-height:1.2; }
.nc-desc { font-size:.65rem; color:var(--c-muted); margin-top:.15rem; word-break:keep-all; }
.nc-arrow { flex-shrink:0; color:var(--c-muted); position:relative; z-index:1; transition:color var(--anim-fast),transform var(--anim-fast); }

/* ── 최신 캐릭터 ── */
.char-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(88px,1fr)); gap:.5rem; }
.char-card { display:flex; flex-direction:column; align-items:center; gap:.35rem; padding:.5rem .3rem; border:1px solid var(--c-border); border-radius:var(--radius-md); background:var(--c-surface); text-decoration:none; color:var(--foreground-color); transition:border-color var(--anim-fast),transform var(--anim-fast); }
.char-card:hover { border-color:var(--c-accent); transform:translateY(-2px); }
.cc-img-wrap { position:relative; width:64px; height:64px; border-radius:var(--radius-sm); overflow:hidden; background:linear-gradient(135deg,#1a1428,#2a1f3d); }
.cc-img { width:100%; height:100%; object-fit:contain; }
.cc-el { position:absolute; top:2px; left:2px; width:16px; height:16px; object-fit:contain; filter:drop-shadow(0 1px 2px rgba(0,0,0,.6)); }
.cc-name { font-size:.6rem; font-weight:700; text-align:center; color:var(--c-muted); line-height:1.2; word-break:keep-all; max-width:80px; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; }
.char-card:hover .cc-name { color:var(--c-accent); }

/* ── 특징 ── */
.feat-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:.75rem; }
.feat-card { display:flex; align-items:flex-start; gap:.85rem; padding:1.1rem 1.1rem; border:1px solid var(--c-border); border-radius:var(--radius-md); background:var(--c-surface); }
.feat-icon { flex-shrink:0; width:42px; height:42px; border-radius:var(--radius-sm); background:var(--c-accent-glow); border:1px solid color-mix(in srgb,var(--c-accent) 25%,transparent); display:flex; align-items:center; justify-content:center; color:var(--c-accent); }
.feat-title { font-size:.88rem; font-weight:700; margin-bottom:.3rem; }
.feat-desc { font-size:.72rem; color:var(--c-muted); line-height:1.6; word-break:keep-all; }

h1,h2,p { word-break:keep-all; }
</style>