---
// src/pages/[lang]/starrail/characters/[id].astro
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Icon } from 'astro-icon/components'
import { Heading } from 'accessible-astro-components'
import { maxCharacterLevel, terminalBaseStat } from '@utils/characterLevelStats'
import LightConesTab from '@components/starrail/LightConesTab.astro'
import RelicSetsTab from '@components/starrail/RelicSetsTab.astro'
import SkillMatsTab from '@components/starrail/SkillMatsTab.astro'
import GalleryTab from '@components/starrail/GalleryTab.astro'

const allData = import.meta.glob('/src/data/starrail/**/*.json', { eager: true })

const toAssetUrl = (rel: string) => {
  if (!rel) return ''

  // 1. 경로 정리 (슬래시 및 중복 제거)
  let cleanPath = rel.replace(/^\//, '').replace(/^starrail\/assets\//, '')

  // 2. 🔍 파일명 추출
  const fileName = cleanPath.split('/').pop() || ''

  // 3. 🔍 스탯 아이콘 교정 (Icon으로 시작하는 모든 파일)
  if (fileName.includes('Icon')) {
    cleanPath = `icon/property/${fileName}`
  }
  // 4. 🔍 유물 아이콘 교정
  else if (cleanPath.includes('icon/character/')) {
    cleanPath = cleanPath.replace('icon/character/', 'icon/relic/')
  }

  return `/starrail/assets/${cleanPath}`
}

export async function getStaticPaths() {
  const languages = ['kr', 'en', 'jp', 'cn', 'fr', 'de', 'es', 'id', 'pt', 'ru', 'th', 'vi', 'cht']
  const allData = import.meta.glob('/src/data/starrail/**/*.json', { eager: true })
  const krCharModule = allData['/src/data/starrail/kr/characters.json'] as any
  const charData = krCharModule?.default || krCharModule
  const validIds = Object.entries(charData)
    .filter(([id, data]: [string, any]) => {
      if (id.startsWith('800')) return true
      return data.name && data.name.trim() !== '' && !data.name.includes('{NICKNAME}')
    })
    .map(([id]) => id)
  return languages.flatMap((lang) => validIds.map((id) => ({ params: { lang, id } })))
}

const { lang, id } = Astro.params

const cleanText = (text: string) => {
  if (!text) return ''
  return text
    .replace(/\{RUBY_B#([^}]+)\}([^\{]+)\{RUBY_E\#\}/g, '$1')
    .replace(/\{F#([^}]*)\}\{M#([^}]*)\}/g, '$2')
    .replace(/\{NICKNAME\}/g, 'Trailblazer')
    .trim()
}

const wrapHighlight = (val: string) => `<span class="hl-num">${val}</span>`

const formatGameDesc = (desc: string, paramRow: number[] | undefined) => {
  const row = paramRow ?? []
  if (!desc) return ''
  let t = desc.replace(/\{RUBY_B#([^}]+)\}([^\{]+)\{RUBY_E\#\}/g, '$1')
  t = t.replace(/\{F#([^}]*)\}\{M#([^}]*)\}/g, '$2')
  t = t.replace(/\{NICKNAME\}/g, 'Trailblazer')
  t = t.replace(/#(\d+)\[(i|f1|f)\](%?)/g, (_m, nStr, fmt, pct) => {
    const idx = parseInt(String(nStr), 10) - 1
    const v = row[idx]
    if (v === undefined || Number.isNaN(v)) return '…'
    let res = ''
    if (pct) {
      if (fmt === 'f1') {
        const x = v * 100
        const rounded = Math.round(x)
        res = (Math.abs(x - rounded) < 0.06 ? String(rounded) : x.toFixed(1)) + '%'
      } else {
        res = Math.round(v * 100) + '%'
      }
    } else {
      if (fmt === 'f1' || fmt === 'f') {
        const x = v > 0 && v <= 1 ? v * 100 : v
        const rounded = Math.round(x)
        res = Math.abs(x - rounded) < 0.01 ? String(rounded) : (Math.round(x * 10) / 10).toString()
      } else {
        const asInt = Math.abs(v - Math.round(v)) < 1e-9
        res = asInt || Math.abs(v) > 1 ? String(Math.round(v)) : String(Math.round(v * 100))
      }
    }
    return wrapHighlight(res)
  })
  return t.trim()
}

const aggregateMaterialRows = (rows: { id: string; num: number }[][]) => {
  const map = new Map<string, number>()
  for (const row of rows) {
    for (const m of row) {
      map.set(m.id, (map.get(m.id) || 0) + m.num)
    }
  }
  return [...map.entries()]
    .map(([mid, num]) => ({ id: mid, num }))
    .sort((a, b) => (a.id === '2' ? -1 : b.id === '2' ? 1 : a.id.localeCompare(b.id)))
}

const sumMinorTraceProps = (
  trees: Record<string, any>,
  treeIds: string[],
  charId: string,
): { type: string; value: number }[] => {
  const minorPrefix = new RegExp(`^${charId}82\\d{2}$`)
  const sums = new Map<string, number>()
  for (const tid of treeIds) {
    if (!minorPrefix.test(tid)) continue
    const node = trees[tid]
    if (!node?.levels) continue
    for (const lv of node.levels) {
      for (const p of lv.properties || []) {
        sums.set(p.type, (sums.get(p.type) || 0) + (p.value || 0))
      }
    }
  }
  return [...sums.entries()].map(([type, value]) => ({ type, value }))
}

const labels =
  lang === 'kr'
    ? {
        intro: '소개',
        rarity: '희귀도',
        path: '운명의 길',
        element: '속성',
        resource: '전투 자원',
        skills: '전투 스킬',
        maxLv: '최대 레벨',
        targeting: '범위',
        majorTraces: '주요 행적',
        minorTraces: '특성 행적',
        eidolons: '성혼',
        stats80: '기본 스탯',
        lightCones: '광추',
        relics: '유물',
        skillMats: '행적 재료',
        gallery: '갤러리',
        charLevel: '캐릭터 레벨',
        skillLevel: '스킬 레벨',
        ascensionMats: '승급 재료 (누적)',
        ascensionStep: '승급 단계',
        statsCurveNote: '중간 레벨 HP·ATK·DEF는 Lv.1과 최대 레벨 사이를 선형 보간한 값입니다.',
        nav: {
          skills: '스킬',
          traces: '행적',
          eidolons: '성혼',
          stats: '스탯',
          lightCones: '광추',
          relics: '유물',
          skillMats: '재료',
          gallery: '갤러리',
        },
      }
    : {
        intro: 'Introduction',
        rarity: 'Rarity',
        path: 'Path',
        element: 'Element',
        resource: 'Combat resource',
        skills: 'Skills',
        maxLv: 'Max Lv',
        targeting: 'Targeting',
        majorTraces: 'Major Traces',
        minorTraces: 'Minor Traces',
        eidolons: 'Eidolons',
        stats80: 'Base Stats',
        lightCones: 'Light Cones',
        relics: 'Relics',
        skillMats: 'Skill Mats',
        gallery: 'Gallery',
        charLevel: 'Character Level',
        skillLevel: 'Skill Level',
        ascensionMats: 'Ascension Materials (cumulative)',
        ascensionStep: 'Ascension Step',
        statsCurveNote: 'HP, ATK, DEF between Lv.1 and max level are linearly interpolated.',
        footnote: 'Data is processed locally based on official resources.',
        nav: {
          skills: 'Skills',
          traces: 'Traces',
          eidolons: 'Eidolons',
          stats: 'Stats',
          lightCones: 'Light Cones',
          relics: 'Relics',
          skillMats: 'Skill Mats',
          gallery: 'Gallery',
        },
      }

const skillTypeOrder: Record<string, number> = {
  Normal: 0,
  BPSkill: 1,
  Ultra: 2,
  Talent: 3,
  Maze: 4,
}

let char: any = null
let activeSkills: any[] = []
let eidolons: any[] = []
let promotion: any = null
let descriptions: any = {}
let statsArray: any[] = []
let majorTraces: any[] = []
let minorTraceSummary: { type: string; value: number; name: string; icon?: string }[] = []
let ascensionMaterials: { id: string; num: number; name: string; icon: string }[] = []
let characterBio = ''
let itemsMap: Record<string, any> = {}
let propertiesMap: Record<string, any> = {}
let pathsData: Record<string, any> = {}
let maxCharLevel = 80
let statsCurveJson = ''
let skillsInteractiveJson = ''
let ascensionTiersJson = ''
let ascensionTierCount = 0

try {
  const baseDir = `/src/data/starrail/${lang}`
  const charModule = allData[`${baseDir}/characters.json`] as any
  const pathsModule = allData[`${baseDir}/paths.json`] as any
  const skillModule = allData[`${baseDir}/character_skills.json`] as any
  const rankModule = allData[`${baseDir}/character_ranks.json`] as any
  const descModule = allData[`${baseDir}/descriptions.json`] as any
  const promoModule = allData[`${baseDir}/character_promotions.json`] as any
  const skillTreeModule = allData[`${baseDir}/character_skill_trees.json`] as any
  const itemsModule = allData[`${baseDir}/items.json`] as any
  const propsModule = allData[`${baseDir}/properties.json`] as any

  char = charModule?.default?.[id as string]
  pathsData = pathsModule?.default
  descriptions = descModule?.default
  itemsMap = itemsModule?.default
  propertiesMap = propsModule?.default

  if (char) {
    const pathData = descriptions?.[char.path]
    const officialPathName = pathData?.title || pathData?.name || char.path

    if (id?.startsWith('800')) {
      const baseName = lang === 'kr' ? '개척자' : 'Trailblazer'
      char.name = `${baseName} • ${officialPathName}`
    } else {
      const rawName = cleanText(char.name)
      for (const v of Object.values(descriptions)) {
        if (v && typeof v === 'object' && 'title' in v && 'desc' in v && v.title === rawName) {
          characterBio = cleanText(String((v as any).desc))
          break
        }
      }
    }

    const rawSkills = (char.skills || []).map((sId: string) => skillModule.default[sId]).filter((s: any) => s && s.name)
    const uniqueByName = rawSkills.filter(
      (skill: any, index: number, self: any[]) => index === self.findIndex((t: any) => t.name === skill.name),
    )
    let ultimateKept = false
    activeSkills = uniqueByName
      .filter((s: any) => {
        if (s.type === 'MazeNormal') return false
        if (s.type === 'Ultra') {
          if (ultimateKept) return false
          ultimateKept = true
        }
        return true
      })
      .sort((a: any, b: any) => (skillTypeOrder[a.type] ?? 99) - (skillTypeOrder[b.type] ?? 99))

    eidolons = (char.ranks || []).map((rId: string) => rankModule.default[rId]).filter(Boolean)

    const trees = skillTreeModule.default
    const majorRe = new RegExp(`^${id}81\\d{2}$`)
    majorTraces = (char.skill_trees || [])
      .filter((tid: string) => majorRe.test(tid))
      .map((tid: string) => trees[tid])
      .filter((n: any) => n && n.name && n.desc)
      .sort((a: any, b: any) => (a.levels?.[0]?.promotion ?? 0) - (b.levels?.[0]?.promotion ?? 0))

    const minorSums = sumMinorTraceProps(trees, char.skill_trees || [], id as string)
    minorTraceSummary = minorSums
      .map((row) => {
        const prop = propertiesMap[row.type]
        return { ...row, name: prop?.name || row.type, icon: prop?.icon }
      })
      .filter((row) => row.value !== 0)

    promotion = promoModule.default[id as string]
    maxCharLevel = maxCharacterLevel(char.rarity)

    if (promotion?.values?.length) {
      const v0 = promotion.values[0]
      const maxPromo = promotion.values[promotion.values.length - 1]
      const hp = terminalBaseStat(maxPromo.hp, maxCharLevel)
      const atk = terminalBaseStat(maxPromo.atk, maxCharLevel)
      const def = terminalBaseStat(maxPromo.def, maxCharLevel)
      const spd =
        maxPromo.spd?.step && maxPromo.spd.step !== 0
          ? terminalBaseStat(maxPromo.spd, maxCharLevel)
          : (maxPromo.spd?.base ?? 0)
      const taunt = maxPromo.taunt?.base ?? maxPromo.taunt ?? 0
      const critRate = (maxPromo.crit_rate?.base ?? 0) * 100
      const critDmg = (maxPromo.crit_dmg?.base ?? 0) * 100

      statsArray = [
        { key: 'hp', label: 'HP', val: hp, icon: 'lucide:heart', color: '#f87171' },
        { key: 'atk', label: 'ATK', val: atk, icon: 'lucide:swords', color: '#fbbf24' },
        { key: 'def', label: 'DEF', val: def, icon: 'lucide:shield', color: '#60a5fa' },
        { key: 'spd', label: 'SPD', val: spd, icon: 'lucide:zap', color: '#34d399' },
        { key: 'taunt', label: 'Taunt', val: taunt, icon: 'lucide:target', color: '#a78bfa' },
        { key: 'critRate', label: 'CRIT Rate', val: critRate, icon: 'lucide:crosshair', color: '#fb923c', suffix: '%' },
        { key: 'critDmg', label: 'CRIT DMG', val: critDmg, icon: 'lucide:flame', color: '#f43f5e', suffix: '%' },
      ]

      statsCurveJson = JSON.stringify({
        maxLevel: maxCharLevel,
        hpStart: v0.hp.base,
        hpEnd: hp,
        atkStart: v0.atk.base,
        atkEnd: atk,
        defStart: v0.def.base,
        defEnd: def,
        spd,
        taunt,
        critRate,
        critDmg,
      })
    }

    skillsInteractiveJson = JSON.stringify(
      activeSkills.map((s: any) => ({
        desc: s.desc || '',
        params: s.params || [],
        maxLevel: Math.max(1, s.max_level || 1),
      })),
    )

    if (promotion?.materials?.length) {
      ascensionMaterials = aggregateMaterialRows(promotion.materials).map((m) => {
        const item = itemsMap[m.id]
        let finalIcon = item?.icon || ''
        if (finalIcon.includes('icon/character/')) finalIcon = finalIcon.replace('icon/character/', 'icon/item/')
        return { ...m, name: item?.name || `Item ${m.id}`, icon: finalIcon ? toAssetUrl(finalIcon) : '' }
      })

      const tiers: { step: number; items: { name: string; num: number; icon: string }[] }[] = []
      const matRows = promotion.materials as { id: string; num: number }[][]
      for (let i = 0; i < matRows.length; i++) {
        const agg = aggregateMaterialRows(matRows.slice(0, i + 1))
        tiers.push({
          step: i + 1,
          items: agg.map((m) => {
            const item = itemsMap[m.id]
            let rawIcon = item?.icon || ''
            if (m.id === '2') rawIcon = 'icon/item/2.webp'
            else if (rawIcon.includes('icon/character/')) rawIcon = rawIcon.replace('icon/character/', 'icon/item/')
            return {
              name: item?.name || `Item ${m.id}`,
              num: m.num,
              icon: rawIcon && rawIcon.includes('.') ? toAssetUrl(rawIcon) : '',
            }
          }),
        })
      }
      ascensionTiersJson = JSON.stringify(tiers)
      ascensionTierCount = tiers.length
    }
  }
} catch (e) {
  console.error(`Error loading data for ${lang}/${id}:`, e)
}

const elementInfo = descriptions?.[char?.element] || { name: char?.element }
const pathInfo = descriptions?.[char?.path] || { title: char?.path }
const pRow = char ? pathsData[char.path] : null

const elementIconUrl = toAssetUrl(`icon/element/${char?.element}.webp`)
const pathIconUrl = pRow?.icon_small
  ? toAssetUrl(pRow.icon_small)
  : pRow?.name
    ? toAssetUrl(`icon/path/${pRow.name}Small.webp`)
    : toAssetUrl(`icon/path/${char?.path}.webp`)

const rarityCount = char?.rarity ?? 0

const skillParamIndex = (skill: any) =>
  Math.max(0, Math.min((skill.params?.length || 1) - 1, (skill.max_level || 1) - 1))

// 섹션 가시성 플래그 (서버사이드 - 초기 탭 결정용)
const hasSections = {
  skills: activeSkills.length > 0,
  traces: majorTraces.length > 0 || minorTraceSummary.length > 0,
  eidolons: eidolons.length > 0,
  stats: statsArray.length > 0,
  lightCones: true, // 광추는 항상 존재
  relics: true, // 유물 세트도 항상 존재
  skillMats: (char?.skill_trees?.length ?? 0) > 0,
  gallery: !!(char?.preview || char?.portrait || char?.icon),
}
---

<DefaultLayout
  title={`${cleanText(char?.name)} | Star Rail DB`}
  description={`${cleanText(char?.name)} — ${pathInfo.title} · ${elementInfo.name}. Skills, traces, stats, and eidolons.`}
  useTitleTemplate={false}
>
  <!-- ══════════════════════════════════════════════
       HERO SECTION
  ══════════════════════════════════════════════ -->
  <div class="char-page">
    <!-- Ambient background glow (CSS only, no JS, GPU-composited) -->
    <div class="ambient-bg" aria-hidden="true">
      <div class="ambient-orb orb-1"></div>
      <div class="ambient-orb orb-2"></div>
    </div>

    <div class="page-inner">
      <!-- ── BREADCRUMB ── -->
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href={`/${lang}`}>Home</a>
        <span class="sep" aria-hidden="true">/</span>
        <a href={`/${lang}/starrail/characters`}>Characters</a>
        <span class="sep" aria-hidden="true">/</span>
        <span class="current">{cleanText(char?.name)}</span>
      </nav>

      <!-- ── HERO GRID ── -->
      <div class="hero-grid">
        <!-- LEFT: Portrait -->
        <div class="portrait-col">
          <div class="portrait-frame">
            <!-- Rarity bar on the left edge -->
            <div class="rarity-bar" aria-hidden="true">
              {
                Array.from({ length: rarityCount }).map((_, i) => (
                  <span class="rarity-pip" style={`animation-delay:${i * 60}ms`}>
                    ★
                  </span>
                ))
              }
            </div>

            <img
              src={toAssetUrl(char?.preview)}
              alt={cleanText(char?.name)}
              class="portrait-img"
              loading="eager"
              decoding="async"
              width="400"
              height="560"
            />

            <!-- Element badge overlay -->
            <div class="element-badge">
              <img src={elementIconUrl} alt={elementInfo.name} width="28" height="28" loading="lazy" decoding="async" />
            </div>
          </div>

          <!-- Bio card (below portrait on mobile) -->
          {
            characterBio && (
              <div class="bio-card">
                <span class="section-eyebrow">{labels.intro}</span>
                <p class="bio-text">{characterBio}</p>
              </div>
            )
          }
        </div>

        <!-- RIGHT: Identity -->
        <div class="identity-col">
          <!-- Tag watermark -->
          <span class="tag-watermark" aria-hidden="true">{char?.tag}</span>

          <!-- Name -->
          <h1 class="char-name">{cleanText(char?.name)}</h1>

          <!-- Chips row -->
          <div class="chips-row">
            <div class="chip">
              <img src={elementIconUrl} alt="" width="18" height="18" loading="lazy" decoding="async" />
              <span>{elementInfo.name}</span>
            </div>
            <div class="chip">
              <img src={pathIconUrl} alt="" class="path-icon" width="18" height="18" loading="lazy" decoding="async" />
              <span>{pathInfo.title}</span>
            </div>
            {
              rarityCount > 0 && (
                <div class="chip chip-rarity">
                  <span class="rarity-stars" aria-label={`${rarityCount}-star`}>
                    {'★'.repeat(rarityCount)}
                  </span>
                </div>
              )
            }
            {
              char?.max_sp != null && (
                <div class="chip chip-sp">
                  <Icon name="lucide:bolt" size="0.8rem" />
                  <span>SP {char.max_sp}</span>
                </div>
              )
            }
          </div>

          <!-- Stats quick card (always visible on desktop) -->
          {
            statsArray.length > 0 && statsCurveJson && (
              <div class="stats-card" id="stats-card">
                <div class="stats-card-header">
                  <span class="section-eyebrow">{labels.stats80}</span>
                  <label class="lv-control" for="char-level-range">
                    <span class="lv-label">{labels.charLevel}</span>
                    <span class="lv-val" id="char-level-value">
                      {maxCharLevel}
                    </span>
                    <input
                      id="char-level-range"
                      type="range"
                      min="1"
                      max={maxCharLevel}
                      value={maxCharLevel}
                      class="range-input"
                    />
                  </label>
                </div>
                <div class="stats-grid">
                  {statsArray.map((stat) => (
                    <div class="stat-row">
                      <span class="stat-icon" style={`color:${stat.color}`}>
                        <Icon name={stat.icon} size="0.85rem" />
                      </span>
                      <span class="stat-label">{stat.label}</span>
                      <span
                        class="stat-val"
                        id={`stat-out-${stat.key}`}
                        data-suffix={stat.suffix || ''}
                        style={`color:${stat.color}`}
                      >
                        {stat.suffix
                          ? `${stat.val % 1 === 0 ? Math.round(stat.val) : stat.val.toFixed(1)}${stat.suffix}`
                          : Math.floor(stat.val)}
                      </span>
                    </div>
                  ))}
                </div>
                <p class="stats-note">{labels.statsCurveNote}</p>
              </div>
            )
          }

          <!-- Ascension card (desktop) -->
          {
            ascensionMaterials.length > 0 && ascensionTiersJson && ascensionTierCount > 0 && (
              <div class="asc-card" id="asc-card">
                <div class="asc-header">
                  <span class="section-eyebrow">{labels.ascensionMats}</span>
                  <label class="lv-control" for="ascension-range">
                    <span class="lv-label">{labels.ascensionStep}</span>
                    <span class="lv-val" id="ascension-step-value">
                      {ascensionTierCount}
                    </span>
                    <input
                      id="ascension-range"
                      type="range"
                      min="1"
                      max={ascensionTierCount}
                      value={ascensionTierCount}
                      class="range-input"
                    />
                  </label>
                </div>
                <ul class="mat-list" id="ascension-mats-list">
                  {ascensionMaterials.map((m) => (
                    <li class="mat-row">
                      <div class="mat-icon-wrap">
                        {m.icon ? (
                          <img
                            src={m.icon}
                            alt={m.name}
                            width="36"
                            height="36"
                            loading="lazy"
                            decoding="async"
                            class="mat-icon-img"
                          />
                        ) : (
                          <Icon name="lucide:package" size="1.2rem" class="mat-placeholder" />
                        )}
                      </div>
                      <span class="mat-name">{m.name}</span>
                      <span class="mat-num">×{m.num}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )
          }
        </div>
      </div>

      <!-- ══════════════════════════════════════════════
           STICKY TAB NAV
      ══════════════════════════════════════════════ -->
      <div class="tab-nav-wrap" id="tab-nav">
        <nav class="tab-nav" role="tablist" aria-label="Character sections">
          {
            hasSections.skills && (
              <button class="tab-btn active" role="tab" aria-selected="true" data-tab="skills" id="tab-btn-skills">
                <Icon name="lucide:sparkles" size="0.85rem" />
                <span>{labels.nav.skills}</span>
              </button>
            )
          }
          {
            hasSections.traces && (
              <button class="tab-btn" role="tab" aria-selected="false" data-tab="traces" id="tab-btn-traces">
