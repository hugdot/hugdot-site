---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools } from '@data/tools'
import seoData from '@data/seo/en/tweet-generator.json'

const relatedTools = tools.filter((t) => t.category === 'sns' && t.id !== 'tweet-generator' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="SocialNetworkingApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">
      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/sns" class="breadcrumb-link hover:underline">SNS Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Create realistic-looking fake tweets instantly. 100% private — your data never leaves your device.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:shield-check" size="0.875rem" class="text-[var(--action-color)]" />
            No Upload
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:user-x" size="0.875rem" class="text-[var(--action-color)]" />
            No Login
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:infinity" size="0.875rem" class="text-[var(--action-color)]" />
            No Limits
          </span>
        </div>
      </div>

      <!-- Tool -->
      <div class="flex flex-col gap-8">

        <!-- Controls -->
        <div class="flex flex-col gap-4 rounded-2xl border border-[var(--border-color-subtle)] p-6">

          <!-- Theme Toggle -->
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium">Theme</span>
            <div class="flex rounded-full border border-[var(--border-color-subtle)] p-1">
              <button id="theme-light" class="theme-btn rounded-full px-4 py-1.5 text-xs font-medium transition-all">Light</button>
              <button id="theme-dark" class="theme-btn rounded-full px-4 py-1.5 text-xs font-medium transition-all">Dark</button>
            </div>
          </div>

          <!-- Name + Username -->
          <div class="grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium opacity-60" for="input-name">Name</label>
              <input id="input-name" type="text" value="John Doe" maxlength="50"
                class="rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-3 py-2 text-sm outline-none focus:border-[var(--action-color)]" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium opacity-60" for="input-username">Username</label>
              <div class="flex items-center rounded-xl border border-[var(--border-color-subtle)] px-3 py-2 text-sm focus-within:border-[var(--action-color)]">
                <span class="opacity-40">@</span>
                <input id="input-username" type="text" value="johndoe" maxlength="15"
                  class="flex-1 bg-transparent outline-none" />
              </div>
            </div>
          </div>

          <!-- Verified -->
          <div class="flex items-center justify-between">
            <span class="text-xs font-medium opacity-60">Verified Badge</span>
            <button id="toggle-verified"
              class="flex h-8 w-8 items-center justify-center rounded-xl border border-[var(--border-color-subtle)] transition-all">
              <Icon aria-hidden="true" name="lucide:badge-check" size="1rem" />
            </button>
          </div>

          <!-- Tweet Text -->
          <div class="flex flex-col gap-1.5">
            <div class="flex items-center justify-between">
              <label class="text-xs font-medium opacity-60" for="input-tweet">Tweet</label>
              <span id="char-count" class="text-xs opacity-40">0 / 280</span>
            </div>
            <textarea id="input-tweet" rows="3" maxlength="280"
              placeholder="What's happening? #hashtags @mentions supported"
              class="resize-none rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-3 py-2 text-sm outline-none focus:border-[var(--action-color)]"></textarea>
          </div>

          <!-- Date -->
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-medium opacity-60" for="input-date">Date</label>
            <input id="input-date" type="text" value="10:30 AM · Jan 1, 2025" maxlength="40"
              class="rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-3 py-2 text-sm outline-none focus:border-[var(--action-color)]" />
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium opacity-60" for="input-replies">Replies</label>
              <input id="input-replies" type="number" value="42" min="0" max="9999999"
                class="rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-3 py-2 text-sm outline-none focus:border-[var(--action-color)]" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium opacity-60" for="input-retweets">Reposts</label>
              <input id="input-retweets" type="number" value="128" min="0" max="9999999"
                class="rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-3 py-2 text-sm outline-none focus:border-[var(--action-color)]" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium opacity-60" for="input-likes">Likes</label>
              <input id="input-likes" type="number" value="1234" min="0" max="9999999"
                class="rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-3 py-2 text-sm outline-none focus:border-[var(--action-color)]" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium opacity-60" for="input-views">Views</label>
              <input id="input-views" type="number" value="50000" min="0" max="999999999"
                class="rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-3 py-2 text-sm outline-none focus:border-[var(--action-color)]" />
            </div>
          </div>

          <!-- Avatar -->
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-medium opacity-60">Avatar (optional)</label>
            <label for="input-avatar"
              class="flex cursor-pointer items-center gap-3 rounded-xl border border-dashed border-[var(--border-color-subtle)] px-4 py-3 text-sm opacity-50 transition-all hover:border-[var(--action-color)] hover:opacity-100">
              <Icon aria-hidden="true" name="lucide:user-round" size="1.25rem" />
              <span>Open avatar image</span>
            </label>
            <input id="input-avatar" type="file" accept="image/*" class="hidden" />
          </div>

        </div>

        <!-- Preview -->
        <div>
          <p class="mb-3 text-sm font-medium opacity-60">Preview</p>
          <div id="tweet-card" class="tweet-light mx-auto w-full max-w-sm overflow-hidden rounded-2xl border p-4 font-sans">

            <!-- User Info -->
            <div class="flex items-start gap-3">
              <div id="tweet-avatar" class="h-10 w-10 shrink-0 overflow-hidden rounded-full bg-gray-400">
                <img id="tweet-avatar-img" src="" alt="" class="hidden h-full w-full object-cover" />
              </div>
              <div class="flex flex-1 flex-col">
                <div class="flex items-center gap-1">
                  <span id="tweet-name" class="text-sm font-bold">John Doe</span>
                  <svg id="tweet-verified" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="#1d9bf0">
                    <path d="M22.25 12c0-1.43-.88-2.67-2.19-3.34.46-1.39.2-2.9-.81-3.91s-2.52-1.27-3.91-.81c-.66-1.31-1.91-2.19-3.34-2.19s-2.67.88-3.33 2.19c-1.4-.46-2.91-.2-3.92.81s-1.26 2.52-.8 3.91c-1.31.67-2.2 1.91-2.2 3.34s.89 2.67 2.2 3.34c-.46 1.39-.21 2.9.8 3.91s2.52 1.26 3.91.8c.67 1.31 1.91 2.19 3.34 2.19s2.68-.88 3.34-2.19c1.39.46 2.9.21 3.91-.8s1.27-2.52.81-3.91c1.31-.67 2.19-1.91 2.19-3.34zm-11.71 4.2L6.8 12.46l1.41-1.42 2.26 2.26 4.8-5.23 1.47 1.36-6.2 6.77z"/>
                  </svg>
                </div>
                <span id="tweet-username" class="text-sm opacity-50">@johndoe</span>
              </div>
              <!-- X Logo -->
              <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.776-8.906L2.25 2.25h6.919l4.265 5.634L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
              </svg>
            </div>

            <!-- Tweet Text -->
            <p id="tweet-text" class="mt-3 text-sm leading-relaxed"></p>

            <!-- Date -->
            <p id="tweet-date" class="mt-3 border-t pt-3 text-xs opacity-50">10:30 AM · Jan 1, 2025</p>

            <!-- Stats -->
            <div id="tweet-stats" class="mt-3 flex gap-4 border-t pt-3 text-xs">
              <span><strong id="tweet-replies">42</strong> <span class="opacity-50">Replies</span></span>
              <span><strong id="tweet-retweets">128</strong> <span class="opacity-50">Reposts</span></span>
              <span><strong id="tweet-likes">1,234</strong> <span class="opacity-50">Likes</span></span>
              <span><strong id="tweet-views">50K</strong> <span class="opacity-50">Views</span></span>
            </div>

            <!-- Action Icons -->
            <div class="mt-3 flex justify-between border-t pt-3 opacity-40">
              <!-- Reply -->
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
              <!-- Repost -->
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>
              </svg>
              <!-- Like -->
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
              <!-- Bookmark -->
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
              </svg>
              <!-- Share -->
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
            </div>

          </div>
        </div>

        <!-- Save Button -->
        <button id="save-btn"
          class="flex items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90">
          <Icon aria-hidden="true" name="lucide:save" size="1rem" />
          Save as Image
        </button>

      </div>

      <!-- Privacy Badge -->
      <div class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60">
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Your photos never leave your device. No data is sent to any server.</span>
      </div>

      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="mt-12">
          <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {relatedTools.map((tool) => (
              <a href={tool.href}
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]">
                {tool.label} →
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</DefaultLayout>

<style>
  .tweet-light {
    background: #ffffff;
    color: #0f1419;
    border-color: #eff3f4;
  }
  .tweet-dark {
    background: #000000;
    color: #e7e9ea;
    border-color: #2f3336;
  }
  .tweet-light .border-t {
    border-color: #eff3f4;
  }
  .tweet-dark .border-t {
    border-color: #2f3336;
  }
  .theme-btn.active {
    background-color: var(--action-color);
    color: white;
  }
</style>

<script>
  import { toPng } from 'html-to-image'

  document.addEventListener('astro:page-load', () => {
    const inputName = document.getElementById('input-name') as HTMLInputElement
    const inputUsername = document.getElementById('input-username') as HTMLInputElement
    const inputTweet = document.getElementById('input-tweet') as HTMLTextAreaElement
    const inputDate = document.getElementById('input-date') as HTMLInputElement
    const inputReplies = document.getElementById('input-replies') as HTMLInputElement
    const inputRetweets = document.getElementById('input-retweets') as HTMLInputElement
    const inputLikes = document.getElementById('input-likes') as HTMLInputElement
    const inputViews = document.getElementById('input-views') as HTMLInputElement
    const inputAvatar = document.getElementById('input-avatar') as HTMLInputElement
    const toggleVerified = document.getElementById('toggle-verified') as HTMLButtonElement
    const charCount = document.getElementById('char-count') as HTMLElement
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement

    const tweetCard = document.getElementById('tweet-card') as HTMLElement
    const tweetName = document.getElementById('tweet-name') as HTMLElement
    const tweetUsername = document.getElementById('tweet-username') as HTMLElement
    const tweetVerified = document.getElementById('tweet-verified') as HTMLElement
    const tweetAvatarImg = document.getElementById('tweet-avatar-img') as HTMLImageElement
    const tweetText = document.getElementById('tweet-text') as HTMLElement
    const tweetDate = document.getElementById('tweet-date') as HTMLElement
    const tweetReplies = document.getElementById('tweet-replies') as HTMLElement
    const tweetRetweets = document.getElementById('tweet-retweets') as HTMLElement
    const tweetLikes = document.getElementById('tweet-likes') as HTMLElement
    const tweetViews = document.getElementById('tweet-views') as HTMLElement
    const themeBtns = document.querySelectorAll('.theme-btn') as NodeListOf<HTMLButtonElement>

    let isVerified = false

    const formatNum = (n: number): string => {
      if (n >= 1000000) return `${(n / 1000000).toFixed(1)}M`
      if (n >= 1000) return `${(n / 1000).toFixed(1)}K`
      return n.toLocaleString()
    }

    const formatTweet = (text: string): string => {
      return text
        .replace(/#(\w+)/g, '<span style="color:#1d9bf0">#$1</span>')
        .replace(/@(\w+)/g, '<span style="color:#1d9bf0">@$1</span>')
        .replace(/(https?:\/\/[^\s]+)/g, '<span style="color:#1d9bf0">$1</span>')
    }

    const setTheme = (theme: string) => {
      tweetCard.classList.remove('tweet-light', 'tweet-dark')
      tweetCard.classList.add(`tweet-${theme}`)
      themeBtns.forEach((btn) => {
        btn.classList.toggle('active', btn.id === `theme-${theme}`)
      })
    }

    setTheme('light')

    document.getElementById('theme-light')?.addEventListener('click', () => setTheme('light'))
    document.getElementById('theme-dark')?.addEventListener('click', () => setTheme('dark'))

    inputName.addEventListener('input', () => {
      tweetName.textContent = inputName.value || 'John Doe'
    })

    inputUsername.addEventListener('input', () => {
      tweetUsername.textContent = `@${inputUsername.value || 'johndoe'}`
    })

    inputTweet.addEventListener('input', () => {
      tweetText.innerHTML = formatTweet(inputTweet.value)
      charCount.textContent = `${inputTweet.value.length} / 280`
    })

    inputDate.addEventListener('input', () => {
      tweetDate.textContent = inputDate.value
    })

    inputReplies.addEventListener('input', () => {
      tweetReplies.textContent = formatNum(parseInt(inputReplies.value) || 0)
    })

    inputRetweets.addEventListener('input', () => {
      tweetRetweets.textContent = formatNum(parseInt(inputRetweets.value) || 0)
    })

    inputLikes.addEventListener('input', () => {
      tweetLikes.textContent = formatNum(parseInt(inputLikes.value) || 0)
    })

    inputViews.addEventListener('input', () => {
      tweetViews.textContent = formatNum(parseInt(inputViews.value) || 0)
    })

    toggleVerified.addEventListener('click', () => {
      isVerified = !isVerified
      tweetVerified.classList.toggle('hidden', !isVerified)
      toggleVerified.style.borderColor = isVerified ? 'var(--action-color)' : ''
    })

    inputAvatar.addEventListener('change', () => {
      const file = inputAvatar.files?.[0]
      if (file) {
        const url = URL.createObjectURL(file)
        tweetAvatarImg.src = url
        tweetAvatarImg.classList.remove('hidden')
      }
    })

    saveBtn.addEventListener('click', async () => {
      try {
        saveBtn.textContent = 'Saving...'
        const dataUrl = await toPng(tweetCard, { cacheBust: true, pixelRatio: 2 })
        const link = document.createElement('a')
        link.download = 'tweet.png'
        link.href = dataUrl
        link.click()
      } catch (e) {
        console.error('Failed to save', e)
      } finally {
        saveBtn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Save as Image`
      }
    })
  })
</script>