  <!-- ══════════════════════════════════════════════
       INLINE SCRIPT — MINIMAL, PASSIVE, rAF-GUARDED
  ══════════════════════════════════════════════ -->
  <script is:inline define:vars={{ statsCurveJson, skillsInteractiveJson, ascensionTiersJson }}>
    ;(function () {
      'use strict'

      /* ── tiny helpers ── */
      function hl(val) {
        return '<span class="hl-num">' + val + '</span>'
      }

      function fmtDesc(desc, row) {
        row = row || []
        if (!desc) return ''
        var t = desc
          .replace(/\{RUBY_B#([^}]+)\}([^{]+)\{RUBY_E#\}/g, '$1')
          .replace(/\{F#([^}]*)\}\{M#([^}]*)\}/g, '$2')
          .replace(/\{NICKNAME\}/g, 'Trailblazer')
        t = t.replace(/#(\d+)\[(i|f1|f)\](%?)/g, function (_m, nStr, fmt, pct) {
          var idx = parseInt(nStr, 10) - 1
          var v = row[idx]
          if (v === undefined || isNaN(v)) return '…'
          var res = ''
          if (pct) {
            if (fmt === 'f1') {
              var x = v * 100
              var r = Math.round(x)
              res = (Math.abs(x - r) < 0.06 ? String(r) : x.toFixed(1)) + '%'
            } else res = Math.round(v * 100) + '%'
          } else {
            if (fmt === 'f1' || fmt === 'f') {
              var x2 = v > 0 && v <= 1 ? v * 100 : v
              var r2 = Math.round(x2)
              res = Math.abs(x2 - r2) < 0.01 ? String(r2) : (Math.round(x2 * 10) / 10).toString()
            } else {
              res =
                Math.abs(v - Math.round(v)) < 1e-9 || Math.abs(v) > 1
                  ? String(Math.round(v))
                  : String(Math.round(v * 100))
            }
          }
          return hl(res)
        })
        return t.trim()
      }

      function lin(a, b, L, maxL) {
        return maxL <= 1 ? a : a + ((b - a) * (L - 1)) / (maxL - 1)
      }

      /* rAF-debounced setter */
      var rafPending = false
      var rafCallbacks = []
      function schedRaf(fn) {
        rafCallbacks.push(fn)
        if (!rafPending) {
          rafPending = true
          requestAnimationFrame(function () {
            rafPending = false
            var cbs = rafCallbacks.splice(0)
            for (var i = 0; i < cbs.length; i++) cbs[i]()
          })
        }
      }

      function setText(id, val, suffix) {
        schedRaf(function () {
          var el = document.getElementById(id)
          if (!el) return
          var s = suffix !== undefined ? suffix : el.getAttribute('data-suffix') || ''
          if (s) {
            var n = Math.round(val * 10) / 10
            el.textContent = (Math.abs(n - Math.round(n)) < 0.05 ? Math.round(n) : n.toFixed(1)) + s
          } else {
            el.textContent = String(Math.floor(val))
          }
        })
      }

      function setTextPair(keys, val, suffix) {
        setText(keys[0], val, suffix)
        if (keys[1]) setText(keys[1], val, suffix)
      }

      /* ── TAB SWITCHING ── */
      function initTabs() {
        var nav = document.getElementById('tab-nav')
        if (!nav) return
        var btns = nav.querySelectorAll('.tab-btn')
        var panels = document.querySelectorAll('.tab-panel')

        btns.forEach(function (btn) {
          btn.addEventListener(
            'click',
            function () {
              var target = btn.getAttribute('data-tab')
              btns.forEach(function (b) {
                b.classList.remove('active')
                b.setAttribute('aria-selected', 'false')
              })
              btn.classList.add('active')
              btn.setAttribute('aria-selected', 'true')
              panels.forEach(function (p) {
                var show = p.id === 'panel-' + target
                p.classList.toggle('hidden', !show)
              })
            },
            { passive: true },
          )
        })
      }

      /* ── STAT CURVE ── */
      function initStats(curve, suffix) {
        var prefix = suffix ? 'm-' : ''
        var rangeId = suffix ? 'char-level-range-m' : 'char-level-range'
        var range = document.getElementById(rangeId)
        if (!curve || !range) return
        var maxL = curve.maxLevel

        function apply() {
          var L = parseInt(range.value, 10) || 1
          schedRaf(function () {
            var lv = document.getElementById(suffix ? 'char-level-value-m' : 'char-level-value')
            if (lv) lv.textContent = String(L)
          })
          setText('stat-out-' + prefix + 'hp', lin(curve.hpStart, curve.hpEnd, L, maxL), '')
          setText('stat-out-' + prefix + 'atk', lin(curve.atkStart, curve.atkEnd, L, maxL), '')
          setText('stat-out-' + prefix + 'def', lin(curve.defStart, curve.defEnd, L, maxL), '')
          setText('stat-out-' + prefix + 'spd', curve.spd, '')
          setText('stat-out-' + prefix + 'taunt', curve.taunt, '')
          setText('stat-out-' + prefix + 'critRate', curve.critRate, '%')
          setText('stat-out-' + prefix + 'critDmg', curve.critDmg, '%')
        }
        range.addEventListener('input', apply, { passive: true })
        range.addEventListener('change', apply, { passive: true })
        apply()
      }

      /* ── SKILLS ── */
      function initSkills(skills) {
        document.querySelectorAll('.skill-level-range').forEach(function (input) {
          var idx = parseInt(input.getAttribute('data-skill-index'), 10)
          if (isNaN(idx) || !skills[idx]) return
          var s = skills[idx]
          function apply() {
            var lv = parseInt(input.value, 10) || 1
            schedRaf(function () {
              var label = document.getElementById('skill-lv-label-' + idx)
              if (label) label.textContent = String(lv)
              var maxPi = s.params && s.params.length ? s.params.length - 1 : 0
              var pi = Math.max(0, Math.min(lv - 1, maxPi))
              var row = s.params && s.params.length ? s.params[pi] : []
              var out = document.getElementById('skill-desc-' + idx)
              if (out) out.innerHTML = fmtDesc(s.desc, row)
            })
          }
          input.addEventListener('input', apply, { passive: true })
          input.addEventListener('change', apply, { passive: true })
        })
      }

      /* ── ASCENSION ── */
      function initAscension(tiers, listId, stepValId, rangeId) {
        var range = document.getElementById(rangeId)
        var list = document.getElementById(listId)
        var stepVal = document.getElementById(stepValId)
        if (!range || !list || !tiers.length) return

        function render(step) {
          var t = tiers[step - 1]
          if (!t || !t.items) return
          schedRaf(function () {
            if (stepVal) stepVal.textContent = String(step)
            list.replaceChildren()
            t.items.forEach(function (it) {
              var li = document.createElement('li')
              li.className = 'mat-row'
              var wrap = document.createElement('div')
              wrap.className = 'mat-icon-wrap'
              if (it.icon) {
                var img = document.createElement('img')
                img.src = it.icon
                img.alt = it.name
                img.width = 36
                img.height = 36
                img.loading = 'lazy'
                img.decoding = 'async'
                img.className = 'mat-icon-img'
                wrap.appendChild(img)
              }
              var name = document.createElement('span')
              name.className = 'mat-name'
              name.textContent = it.name
              var num = document.createElement('span')
              num.className = 'mat-num'
              num.textContent = '×' + it.num
              li.appendChild(wrap)
              li.appendChild(name)
              li.appendChild(num)
              list.appendChild(li)
            })
          })
        }

        range.addEventListener(
          'input',
          function () {
            render(parseInt(range.value, 10) || 1)
          },
          { passive: true },
        )
        range.addEventListener(
          'change',
          function () {
            render(parseInt(range.value, 10) || 1)
          },
          { passive: true },
        )
        render(parseInt(range.value, 10) || tiers.length)
      }

      /* ── STICKY NAV ── */
      function initStickyNav() {
        var nav = document.getElementById('tab-nav')
        if (!nav) return
        var sentinel = document.createElement('div')
        sentinel.style.cssText = 'height:1px;pointer-events:none'
        nav.parentNode.insertBefore(sentinel, nav)
        var io = new IntersectionObserver(
          function (entries) {
            nav.classList.toggle('stuck', !entries[0].isIntersecting)
          },
          { threshold: 0 },
        )
        io.observe(sentinel)
      }

      /* ── BOOT ── */
      
        function init() {
          initTabs()
          initStickyNav()

          var curve = null
          try {
            curve = statsCurveJson ? JSON.parse(statsCurveJson) : null
          } catch (e) {}
          initStats(curve, '') /* desktop */
          initStats(curve, 'm') /* mobile panel */

          var skills = []
          try {
            skills = skillsInteractiveJson ? JSON.parse(skillsInteractiveJson) : []
          } catch (e) {}
          initSkills(skills)

          var tiers = []
          try {
            tiers = ascensionTiersJson ? JSON.parse(ascensionTiersJson) : []
          } catch (e) {}
          initAscension(tiers, 'ascension-mats-list', 'ascension-step-value', 'ascension-range')
          initAscension(tiers, 'ascension-mats-list-m', 'ascension-step-value-m', 'ascension-range-m')
        }
        document.addEventListener('DOMContentLoaded', init)
        document.addEventListener('astro:page-load', init)
 
    })()
  </script>
</DefaultLayout>

<style>
  /* ══════════════════════════════════════════════════════════
   DESIGN SYSTEM — SF 터미널 × 동양 미학 크로스오버
   모든 애니메이션: transform/opacity (GPU compositor only)
   content-visibility: auto → 저사양 기기 렌더 절약
══════════════════════════════════════════════════════════ */

  /* ── Google Fonts (선택적 — Astro font 설정에서 처리 시 제거) ── */
  @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Noto+Sans+KR:wght@400;700;900&family=JetBrains+Mono:wght@400;700&display=swap');

  /* ── Design tokens ── */
  :root {
    --c-bg: #09090f;
    --c-surface: #0f101a;
    --c-surface2: #161724;
    --c-border: rgba(255, 255, 255, 0.07);
    --c-border-hi: rgba(255, 255, 255, 0.16);
    --c-text: #e2e4f0;
    --c-muted: rgba(226, 228, 240, 0.45);
    --c-accent: var(--action-color, #7c9dfc);
    --c-accent-glow: color-mix(in srgb, var(--c-accent) 30%, transparent);

    --radius-sm: 8px;
    --radius-md: 14px;
    --radius-lg: 22px;
    --radius-xl: 32px;

    --font-display: 'Rajdhani', 'Noto Sans KR', sans-serif;
    --font-body: 'Noto Sans KR', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;

    --anim-fast: 140ms cubic-bezier(0.4, 0, 0.2, 1);
    --anim-med: 260ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Light mode overrides */
  :root[data-theme='light'],
  .light {
    --c-bg: #f2f3f7;
    --c-surface: #ffffff;
    --c-surface2: #eaecf5;
    --c-border: rgba(0, 0, 0, 0.08);
    --c-border-hi: rgba(0, 0, 0, 0.18);
    --c-text: #18192a;
    --c-muted: rgba(24, 25, 42, 0.5);
    --c-accent-glow: color-mix(in srgb, var(--c-accent) 18%, transparent);
  }

  /* ── Page shell ── */
  .char-page {
    position: relative;
    background: var(--c-bg);
    min-height: 100vh;
    overflow-x: hidden;
    color: var(--c-text);
    font-family: var(--font-body);
  }

  .page-inner {
    margin: 0 auto;
    padding: 1.5rem 1rem 4rem;
    max-width: 1100px;
  }
  @media (min-width: 768px) {
    .page-inner {
      padding: 2rem 2rem 5rem;
    }
  }

  /* ── Ambient background (CSS only, no JS, only opacity/transform) ── */
  .ambient-bg {
    position: fixed;
    z-index: 0;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .ambient-orb {
    position: absolute;
    opacity: 0;
    filter: blur(80px);
    animation: orb-fade 1.4s ease forwards;
    border-radius: 50%;
  }
  .orb-1 {
    top: -200px;
    left: -150px;
    animation-delay: 0.1s;
    background: radial-gradient(circle, color-mix(in srgb, var(--c-accent) 20%, transparent), transparent 70%);
    width: 600px;
    height: 600px;
  }
  .orb-2 {
    right: -100px;
    bottom: 10%;
    animation-delay: 0.4s;
    background: radial-gradient(circle, color-mix(in srgb, #a78bfa 15%, transparent), transparent 70%);
    width: 400px;
    height: 400px;
  }
  @keyframes orb-fade {
    to {
      opacity: 1;
    }
  }

  .page-inner {
    position: relative;
    z-index: 1;
  }

  /* ── Breadcrumb ── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 2rem;
    color: var(--c-muted);
    font-weight: 700;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .breadcrumb a {
    transition: color var(--anim-fast);
    color: inherit;
    text-decoration: none;
  }
  .breadcrumb a:hover {
    color: var(--c-accent);
  }
  .breadcrumb .sep {
    opacity: 0.4;
  }
  .breadcrumb .current {
    color: var(--c-accent);
  }

  /* ── Hero grid ── */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  @media (min-width: 768px) {
    .hero-grid {
      grid-template-columns: 240px 1fr;
      align-items: start;
      gap: 2.5rem;
    }
  }

  /* ── Portrait column ── */
  .portrait-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .portrait-frame {
    position: relative;
    /* GPU-only: no layout-triggering props */
    contain: layout paint;
    box-shadow: 0 0 40px -10px var(--c-accent-glow);
    border: 1px solid var(--c-border-hi);
    border-radius: var(--radius-xl);
    background: linear-gradient(160deg, var(--c-surface2), var(--c-surface));
    overflow: hidden;
  }

  .portrait-img {
    display: block;
    /* subtle scale on load via CSS — no JS */
    animation: img-reveal 0.6s ease both;
    width: 100%;
    height: auto;
    object-fit: cover;
  }
  @keyframes img-reveal {
    from {
      transform: scale(1.04);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .rarity-bar {
    display: flex;
    position: absolute;
    top: 50%;
    left: 0.6rem;
    flex-direction: column;
    gap: 0.15rem;
    transform: translateY(-50%);
    z-index: 2;
  }
  .rarity-pip {
    display: block;
    opacity: 0;
    animation: pip-in 0.4s ease forwards;
    color: #fbbf24;
    font-size: 0.7rem;
    text-shadow: 0 0 6px rgba(251, 191, 36, 0.6);
  }
  @keyframes pip-in {
    to {
      opacity: 1;
    }
  }

  .element-badge {
    display: flex;
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    justify-content: center;
    align-items: center;
    backdrop-filter: blur(6px);
    border: 1px solid var(--c-border-hi);
    border-radius: var(--radius-md);
    background: rgba(0, 0, 0, 0.55);
    width: 40px;
    height: 40px;
  }
  .element-badge img {
    width: 22px;
    height: 22px;
    object-fit: contain;
  }

  /* ── Bio card ── */
  .bio-card {
    content-visibility: auto;
    contain-intrinsic-size: 0 120px;
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    background: var(--c-surface);
    padding: 1.1rem 1.2rem;
  }
  .bio-text {
    margin-top: 0.5rem;
    color: var(--c-muted);
    font-size: 0.78rem;
    line-height: 1.8;
    white-space: pre-line;
    word-break: keep-all;
  }

  /* ── Identity column ── */
  .identity-col {
    display: flex;
    position: relative;
    flex-direction: column;
    gap: 1.2rem;
  }

  .tag-watermark {
    position: absolute;
    top: -0.5rem;
    right: 0;
    opacity: 0.04;
    pointer-events: none;
    color: var(--c-text);
    font-weight: 900;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1;
    font-family: var(--font-display);
    letter-spacing: -0.04em;
    user-select: none;
    text-transform: uppercase;
  }

  .char-name {
    animation: name-in 0.5s 0.1s ease both;
    color: var(--c-text);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1.1;
    font-family: var(--font-display);
    letter-spacing: -0.02em;
    text-transform: uppercase;
    word-break: keep-all;
  }
  @keyframes name-in {
    from {
      transform: translateY(8px);
      opacity: 0;
    }
    to {
      transform: none;
      opacity: 1;
    }
  }

  /* ── Chips ── */
  .chips-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition:
      border-color var(--anim-fast),
      color var(--anim-fast);
    border: 1px solid var(--c-border-hi);
    border-radius: var(--radius-sm);
    background: var(--c-surface);
    padding: 0.3rem 0.7rem;
    color: var(--c-muted);
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .chip img {
    width: 16px;
    height: 16px;
    object-fit: contain;
  }
  .chip:hover {
    border-color: var(--c-accent);
    color: var(--c-text);
  }
  .path-icon {
    { filter: brightness(0) invert(1); };
  }
  :root[data-theme='light'] .path-icon,
  .light .path-icon {
    filter: none;
  }
  .chip-rarity {
    border-color: transparent;
    background: rgba(251, 191, 36, 0.08);
  }
  .rarity-stars {
    color: #fbbf24;
    letter-spacing: 0.02em;
  }
  .chip-sp {
    border-color: transparent;
    background: var(--c-accent-glow);
    color: var(--c-accent);
  }

  /* ── Stats card (desktop identity column) ── */
  .stats-card,
  .asc-card {
    content-visibility: auto;
    contain-intrinsic-size: 0 260px;
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    background: var(--c-surface);
    padding: 1.1rem 1.2rem;
  }

  .stats-card-header,
  .asc-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    margin-bottom: 0.9rem;
  }

  /* ── Level/ascension control ── */
  .lv-control {
    display: flex;
    flex: 1;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }
  .lv-label {
    color: var(--c-muted);
    font-weight: 700;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .lv-val {
    min-width: 2ch;
    color: var(--c-accent);
    font-weight: 700;
    font-size: 0.75rem;
    font-family: var(--font-mono);
  }
  .range-input {
    flex: 1;
    /* iOS needs explicit appearance */
    -webkit-appearance: none;
    appearance: none;
    cursor: pointer;
    outline: none;
    border-radius: 99px;
    background: var(--c-border-hi);
    min-width: 80px;
    height: 3px;
    accent-color: var(--c-accent);
  }
  .range-input::-webkit-slider-thumb {
    -webkit-appearance: none;
    cursor: pointer;
    box-shadow: 0 0 0 3px var(--c-accent-glow);
    border-radius: 50%;
    background: var(--c-accent);
    width: 14px;
    height: 14px;
  }

  /* ── Stats grid ── */
  .stats-grid,
  .stats-grid-m {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .stat-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: background var(--anim-fast);
    border-radius: var(--radius-sm);
    background: var(--c-surface2);
    padding: 0.45rem 0.6rem;
  }
  .stat-row:hover {
    background: color-mix(in srgb, var(--c-accent) 8%, var(--c-surface2));
  }
  .stat-icon {
    display: flex;
    flex-shrink: 0;
    align-items: center;
  }
  .stat-label {
    flex: 1;
    color: var(--c-muted);
    font-weight: 700;
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .stat-val {
    font-weight: 700;
    font-size: 0.85rem;
    font-family: var(--font-mono);
  }

  .stats-note {
    opacity: 0.7;
    margin-top: 0.6rem;
    color: var(--c-muted);
    font-size: 0.62rem;
    line-height: 1.5;
  }

  /* ── Ascension material list ── */
  .mat-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0.5rem 0 0;
    padding: 0;
    list-style: none;
  }
  .mat-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .mat-icon-wrap {
    display: flex;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    border: 1px solid var(--c-border-hi);
    border-radius: var(--radius-sm);
    background: var(--c-surface2);
    padding: 3px;
    width: 38px;
    height: 38px;
    overflow: hidden;
  }
  .mat-icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .mat-placeholder {
    color: var(--c-muted);
  }
  .mat-name {
    flex: 1;
    font-weight: 600;
    font-size: 0.76rem;
    line-height: 1.4;
    word-break: keep-all;
  }
  .mat-num {
    flex-shrink: 0;
    color: var(--c-muted);
    font-size: 0.68rem;
    font-family: var(--font-mono);
  }

  /* ── Section eyebrow ── */
  .section-eyebrow {
    display: block;
    color: var(--c-muted);
    font-weight: 900;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* ══════════════════════════════════════════════
   STICKY TAB NAV
══════════════════════════════════════════════ */
  .tab-nav-wrap {
    position: sticky;
    top: 0;
    z-index: 50;
    transition:
      background var(--anim-med),
      box-shadow var(--anim-med);
    margin: 0 -1rem 1.5rem;
    background: transparent;
    padding: 0 1rem;
  }
  .tab-nav-wrap.stuck {
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 1px 0 var(--c-border);
    background: color-mix(in srgb, var(--c-bg) 85%, transparent);
  }
  @media (min-width: 768px) {
    .tab-nav-wrap {
      margin: 0 -2rem 2rem;
      padding: 0 2rem;
    }
  }

  .tab-nav {
    display: flex;
    gap: 0.25rem;
    padding: 0.5rem 0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .tab-nav::-webkit-scrollbar {
    display: none;
  }

  .tab-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition:
      color var(--anim-fast),
      border-color var(--anim-fast),
      background var(--anim-fast);
    cursor: pointer;
    border: 1px solid var(--c-border);
    border-radius: var(--radius-sm);
    background: var(--c-surface);
    padding: 0.45rem 1rem;
    /* Touch target ≥ 44px */
    min-height: 36px;
    color: var(--c-muted);
    font-weight: 700;
    font-size: 0.72rem;
    font-family: var(--font-display);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .tab-btn:hover {
    border-color: var(--c-border-hi);
    color: var(--c-text);
  }
  .tab-btn.active {
    border-color: var(--c-accent);
    background: var(--c-accent-glow);
    color: var(--c-accent);
  }

  /* On mobile, hide the "Stats" tab content from the desktop sidebar by toggling.
   The stats-mobile panel tab is hidden on desktop. */
  @media (min-width: 768px) {
    .tab-btn-mobile-stats {
      display: none;
    }
  }

  /* ══════════════════════════════════════════════
   TAB PANELS
══════════════════════════════════════════════ */
  .tab-panels {
    position: relative;
  }

  .tab-panel {
    content-visibility: auto;
    animation: panel-in 0.22s ease both;
  }
  .tab-panel.hidden {
    display: none;
  }

  @keyframes panel-in {
    from {
      transform: translateY(6px);
      opacity: 0;
    }
    to {
      transform: none;
      opacity: 1;
    }
  }

  /* ── Panel header ── */
  .panel-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.2rem;
  }
  .panel-accent {
    flex-shrink: 0;
    border-radius: 99px;
    background: var(--c-accent);
    width: 3px;
    height: 1.4rem;
  }
  .panel-title {
    font-weight: 700;
    font-size: 1.1rem;
    line-height: 1;
    font-family: var(--font-display);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* ── Sub-section ── */
  .sub-section {
    margin-bottom: 2.5rem;
  }

  /* ══════════════════════════════════════════════
   SKILLS
══════════════════════════════════════════════ */
  .skills-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skill-card {
    display: flex;
    gap: 1rem;
    content-visibility: auto;
    transition: border-color var(--anim-fast);
    contain-intrinsic-size: 0 160px;
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    background: var(--c-surface);
    padding: 1rem 1.1rem;
  }
  .skill-card:hover {
    border-color: var(--c-border-hi);
  }

  .skill-icon-wrap {
    display: flex;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    transition: transform var(--anim-fast);
    box-shadow: inset 0 0 12px rgba(0, 0, 0, 0.4);
    border: 1px solid var(--c-border-hi);
    border-radius: var(--radius-md);
    background: #1a1a2e;
    padding: 5px;
    width: 56px;
    height: 56px;
    overflow: hidden;
  }
  .skill-card:hover .skill-icon-wrap {
    transform: rotate(6deg) scale(1.05);
  }
  .skill-icon {
    filter: none;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .skill-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.6rem;
    min-width: 0;
  }

  .skill-meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .skill-name {
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.1;
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    word-break: keep-all;
  }
  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .tag {
    border: 1px solid var(--c-border);
    border-radius: 4px;
    padding: 0.15rem 0.4rem;
    color: var(--c-muted);
    font-weight: 800;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .skill-lv-ctrl {
    flex-direction: row;
    align-items: center;
  }

  .skill-simple {
    color: var(--c-muted);
    font-weight: 600;
    font-size: 0.72rem;
    line-height: 1.5;
    word-break: keep-all;
  }

  .skill-desc {
    color: var(--c-muted);
    font-size: 0.8rem;
    line-height: 1.8;
    white-space: pre-line;
    word-break: keep-all;
  }

  /* Highlight spans injected by JS/server */
  :global(.hl-num) {
    display: inline-block;
    vertical-align: baseline;
    border-radius: 5px;
    background: color-mix(in srgb, var(--c-accent) 15%, transparent);
    padding: 0.05em 0.4em;
    color: var(--c-accent);
    font-weight: 700;
    font-size: 0.88em;
    line-height: 1.4;
    font-family: var(--font-mono);
  }

  /* ══════════════════════════════════════════════
   TRACES
══════════════════════════════════════════════ */
  .traces-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .trace-card {
    display: flex;
    gap: 1rem;
    content-visibility: auto;
    transition: border-color var(--anim-fast);
    contain-intrinsic-size: 0 120px;
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    background: var(--c-surface);
    padding: 0.9rem 1rem;
  }
  .trace-card:hover {
    border-color: var(--c-accent);
  }

  .trace-icon-wrap {
    position: relative;
    flex-shrink: 0;
    width: 46px;
    height: 46px;
  }
  .trace-icon {
    filter: invert(1);
    border: 1px solid var(--c-border-hi);
    border-radius: var(--radius-sm);
    background: var(--c-surface2);
    padding: 5px;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  :root[data-theme='light'] .trace-icon,
  .light .trace-icon {
    filter: none;
  }
  .trace-unlock {
    position: absolute;
    right: -6px;
    bottom: -4px;
    border-radius: 4px;
    background: var(--c-accent);
    padding: 0.1em 0.35em;
    color: #fff;
    font-weight: 900;
    font-size: 0.55rem;
    line-height: 1.4;
    letter-spacing: 0.05em;
  }

  .trace-body {
    flex: 1;
    min-width: 0;
  }
  .trace-name {
    margin-bottom: 0.35rem;
    font-weight: 700;
    font-size: 0.95rem;
    font-family: var(--font-display);
    word-break: keep-all;
  }
  .trace-desc {
    color: var(--c-muted);
    font-size: 0.78rem;
    line-height: 1.75;
    white-space: pre-line;
    word-break: keep-all;
  }

  /* ── Minor traces ── */
  .minor-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.6rem;
  }
  .minor-chip {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    border: 1px solid var(--c-border);
    border-radius: var(--radius-md);
    background: var(--c-surface2);
    padding: 0.6rem 0.8rem;
  }
