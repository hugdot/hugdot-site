---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import seoData from '@data/seo/en/pdf-to-image.json'
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  faq={seoData.faq}
  howto={seoData.howto}
  category="MultimediaApplication"
>
  <section class="py-12">
    <div class="container max-w-3xl">
      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/pdf" class="breadcrumb-link hover:underline">PDF Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Convert PDF pages to JPG or PNG images. Your files never leave your device — 100% private.
        </p>
      </div>

      <!-- Drop Zone -->
      <div
        id="drop-zone"
        class="flex cursor-pointer flex-col items-center justify-center gap-4 rounded-2xl border-2 border-dashed border-[var(--border-color-subtle)] p-12 text-center transition-all hover:border-[var(--action-color)]"
      >
        <Icon aria-hidden="true" name="lucide:file-image" size="3rem" class="opacity-30" />
        <div>
          <p class="font-semibold">Open a PDF file</p>
          <p class="text-sm opacity-50">or tap to choose</p>
        </div>
        <input id="file-input" type="file" accept=".pdf" class="hidden" aria-label="Open PDF" />
      </div>

      <!-- File Info -->
      <div
        id="file-info"
        class="mt-4 hidden items-center gap-3 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3"
      >
        <Icon aria-hidden="true" name="lucide:file-text" size="1.25rem" class="shrink-0 opacity-40" />
        <span id="file-name" class="flex-1 truncate text-sm"></span>
        <span id="file-pages" class="shrink-0 text-xs opacity-40"></span>
        <button
          id="clear-file"
          class="shrink-0 rounded-lg p-1.5 opacity-40 transition-opacity hover:opacity-100"
          aria-label="Remove file"
        >
          <Icon aria-hidden="true" name="lucide:x" size="1rem" />
        </button>
      </div>

      <!-- Options -->
      <div id="options-panel" class="mt-6 hidden flex-col gap-4">
        <Heading level="h2" size="h6" class="opacity-60">Options</Heading>

        <!-- Format -->
        <div class="flex flex-col gap-2">
          <label class="text-sm opacity-60">Output format</label>
          <div class="flex gap-2">
            {
              ['JPG', 'PNG'].map((fmt) => (
                <button
                  class="format-btn flex-1 rounded-xl border-2 border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]"
                  data-format={fmt}
                >
                  {fmt}
                </button>
              ))
            }
          </div>
        </div>

        <!-- Quality -->
        <div class="flex flex-col gap-2">
          <div class="flex items-center justify-between">
            <label class="text-sm opacity-60">Resolution</label>
            <span id="dpi-value" class="text-sm font-bold text-[var(--action-color)]">150 DPI</span>
          </div>
          <input
            id="dpi-slider"
            type="range"
            min="72"
            max="300"
            step="1"
            value="150"
            class="w-full accent-[var(--action-color)]"
          />
          <div class="flex justify-between text-xs opacity-40">
            <span>72 DPI (fast)</span>
            <span>300 DPI (high quality)</span>
          </div>
        </div>

        <!-- Convert Button -->
        <button
          id="convert-btn"
          class="mt-2 flex w-full items-center justify-center gap-2 rounded-2xl bg-[var(--action-color)] px-6 py-4 font-semibold text-white transition-opacity hover:opacity-80"
        >
          <Icon aria-hidden="true" name="lucide:image" size="1.25rem" />
          Convert to Images
        </button>
      </div>

      <!-- Progress -->
      <div id="progress-wrap" class="mt-6 hidden">
        <div class="h-2 w-full overflow-hidden rounded-full bg-[var(--border-color-subtle)]">
          <div id="progress-bar" class="h-full w-0 rounded-full bg-[var(--action-color)] transition-all duration-300">
          </div>
        </div>
        <p id="progress-text" class="mt-2 text-center text-sm opacity-60">Converting...</p>
      </div>

      <!-- Preview Grid -->
      <div id="preview-grid" class="mt-6 hidden flex-col gap-4">
        <div class="flex items-center justify-between">
          <Heading level="h2" size="h6" class="opacity-60">Preview</Heading>
          <button
            id="save-all-btn"
            class="flex items-center gap-2 rounded-xl bg-[var(--action-color)] px-4 py-2 text-sm font-semibold text-white transition-opacity hover:opacity-80"
          >
            <Icon aria-hidden="true" name="lucide:save" size="1rem" />
            Save All as ZIP
          </button>
        </div>
        <div id="preview-items" class="grid grid-cols-2 gap-4 sm:grid-cols-3"></div>
      </div>

      <!-- Privacy Badge -->
      <div
        class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60"
      >
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Your files never leave your device. No data is sent to any server.</span>
      </div>

      <!-- How to Use -->
      <div class="mt-16">
        <Heading level="h2" size="h4" class="mb-6">How to Convert PDF to Image</Heading>
        <div class="flex flex-col gap-4">
          {
            seoData.howto.map((item, index) => (
              <div class="flex gap-4 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--action-color)] text-sm font-bold text-white">
                  {index + 1}
                </span>
                <div>
                  <p class="font-semibold">{item.step}</p>
                  <p class="mt-1 text-sm opacity-60">{item.description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Why Use -->
      <div class="mt-12">
        <Heading level="h2" size="h4" class="mb-6">Why Use This Tool</Heading>
        <div class="flex flex-col gap-3">
          {
            seoData.why.map((reason) => (
              <div class="flex items-center gap-3 rounded-xl border border-[var(--border-color-subtle)] px-5 py-4">
                <Icon
                  aria-hidden="true"
                  name="lucide:check-circle"
                  size="1.25rem"
                  class="shrink-0 text-[var(--action-color)]"
                />
                <span class="text-sm">{reason}</span>
              </div>
            ))
          }
        </div>
      </div>

      <!-- FAQ -->
      <div class="mt-12">
        <Heading level="h2" size="h4" class="mb-6">Frequently Asked Questions</Heading>
        <div class="flex flex-col gap-3">
          {
            seoData.faq.map((item) => (
              <details class="rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4">
                <summary class="cursor-pointer font-semibold">{item.q}</summary>
                <p class="mt-3 text-sm opacity-60">{item.a}</p>
              </details>
            ))
          }
        </div>
      </div>

      <div class="mt-16 border-t border-[var(--border-color-subtle)] pt-8">
        <p class="mb-4 text-[10px] font-bold tracking-widest uppercase opacity-40">Related Keywords</p>
        <div class="flex flex-wrap gap-x-6 gap-y-3">
          {seoData.keywords.map((tag) => <span class="text-xs opacity-50">#{tag.toLowerCase()}</span>)}
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>
<script>
  import * as pdfjsLib from 'pdfjs-dist'
  import JSZip from 'jszip'

  import pdfWorker from 'pdfjs-dist/build/pdf.worker.mjs?url'
  pdfjsLib.GlobalWorkerOptions.workerSrc = pdfWorker

  document.addEventListener('astro:page-load', () => {
    const dropZone = document.getElementById('drop-zone') as HTMLDivElement
    const fileInput = document.getElementById('file-input') as HTMLInputElement
    const fileInfo = document.getElementById('file-info') as HTMLDivElement
    const fileName = document.getElementById('file-name') as HTMLSpanElement
    const filePages = document.getElementById('file-pages') as HTMLSpanElement
    const clearFile = document.getElementById('clear-file') as HTMLButtonElement
    const optionsPanel = document.getElementById('options-panel') as HTMLDivElement
    const convertBtn = document.getElementById('convert-btn') as HTMLButtonElement
    const progressWrap = document.getElementById('progress-wrap') as HTMLDivElement
    const progressBar = document.getElementById('progress-bar') as HTMLDivElement
    const progressText = document.getElementById('progress-text') as HTMLParagraphElement
    const previewGrid = document.getElementById('preview-grid') as HTMLDivElement
    const previewItems = document.getElementById('preview-items') as HTMLDivElement
    const saveAllBtn = document.getElementById('save-all-btn') as HTMLButtonElement
    const dpiSlider = document.getElementById('dpi-slider') as HTMLInputElement
    const dpiValue = document.getElementById('dpi-value') as HTMLSpanElement

    let currentFile: File | null = null
    let totalPages = 0
    let selectedFormat = 'JPG'
    let renderedBlobs: { blob: Blob; name: string }[] = []
    let objectUrls: string[] = []

    // Format buttons
    document.querySelectorAll<HTMLButtonElement>('.format-btn').forEach((btn) => {
      if (btn.dataset.format === 'JPG') {
        btn.classList.add('border-[var(--action-color)]', 'text-[var(--action-color)]')
      }
      btn.addEventListener('click', () => {
        selectedFormat = btn.dataset.format ?? 'JPG'
        document.querySelectorAll<HTMLButtonElement>('.format-btn').forEach((b) => {
          const isActive = b.dataset.format === selectedFormat
          b.classList.toggle('border-[var(--action-color)]', isActive)
          b.classList.toggle('text-[var(--action-color)]', isActive)
          b.classList.toggle('border-[var(--border-color-subtle)]', !isActive)
        })
      })
    })

    // DPI slider
    dpiSlider.addEventListener('input', () => {
      dpiValue.textContent = `${dpiSlider.value} DPI`
    })

    // Load file
    const loadFile = async (file: File) => {
      if (!file.name.endsWith('.pdf') && file.type !== 'application/pdf') return
      currentFile = file
      try {
        const arrayBuffer = await file.arrayBuffer()
        const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise
        totalPages = pdf.numPages
        fileName.textContent = file.name
        filePages.textContent = `${totalPages} pages`
        fileInfo.classList.remove('hidden')
        fileInfo.classList.add('flex')
        optionsPanel.classList.remove('hidden')
        optionsPanel.classList.add('flex')
        previewGrid.classList.add('hidden')
        previewGrid.classList.remove('flex')
        previewItems.innerHTML = ''
        renderedBlobs = []
      } catch {
        alert('Could not read this PDF. It may be encrypted or corrupted.')
        currentFile = null
      }
    }
    const clearMemory = () => {
      objectUrls.forEach((url) => URL.revokeObjectURL(url))
      objectUrls = []
    }
    const resetFile = () => {
      clearMemory();
      currentFile = null
      totalPages = 0
      fileInput.value = ''
      fileInfo.classList.add('hidden')
      fileInfo.classList.remove('flex')
      optionsPanel.classList.add('hidden')
      optionsPanel.classList.remove('flex')
      progressWrap.classList.add('hidden')
      previewGrid.classList.add('hidden')
      previewGrid.classList.remove('flex')
      previewItems.innerHTML = ''
      renderedBlobs = []
    }

    dropZone.addEventListener('click', () => fileInput.click())
    fileInput.addEventListener('change', () => {
      if (fileInput.files?.[0]) loadFile(fileInput.files[0])
    })
    clearFile.addEventListener('click', resetFile)

    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault()
      dropZone.classList.add('border-[var(--action-color)]')
    })
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-[var(--action-color)]'))
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault()
      dropZone.classList.remove('border-[var(--action-color)]')
      if (e.dataTransfer?.files?.[0]) loadFile(e.dataTransfer.files[0])
    })

    // Convert
    convertBtn.addEventListener('click', async () => {
      if (!currentFile) return

      convertBtn.disabled = true
      progressWrap.classList.remove('hidden')
      clearMemory()
      progressBar.style.width = '0%'
      progressText.textContent = 'Starting...'
      previewItems.innerHTML = ''
      renderedBlobs = []

      try {
        const arrayBuffer = await currentFile.arrayBuffer()
        const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise
        const dpi = parseInt(dpiSlider.value)
        const scale = dpi / 96
        const mimeType = selectedFormat === 'PNG' ? 'image/png' : 'image/jpeg'
        const ext = selectedFormat.toLowerCase()
        const baseName = currentFile.name.replace(/\.pdf$/i, '')

        for (let i = 1; i <= pdf.numPages; i++) {
          progressText.textContent = `Converting page ${i} of ${pdf.numPages}...`
          progressBar.style.width = `${((i - 1) / pdf.numPages) * 90}%`

          const page = await pdf.getPage(i)
          const viewport = page.getViewport({ scale })
          const canvas = document.createElement('canvas')
          canvas.width = viewport.width
          canvas.height = viewport.height
          const ctx = canvas.getContext('2d')!
          await page.render({ canvasContext: ctx, viewport, canvas }).promise

          const blob = await new Promise<Blob>((resolve) => canvas.toBlob((b) => resolve(b!), mimeType, 0.92))
          const name = `${baseName}_p${String(i).padStart(3, '0')}.${ext}`
          renderedBlobs.push({ blob, name })

          // Preview
          const url = URL.createObjectURL(blob)
          objectUrls.push(url);
          const item = document.createElement('div')
          item.className = 'flex flex-col gap-2'
          item.innerHTML = `
            <img src="${url}" alt="Page ${i}" class="w-full rounded-xl border border-[var(--border-color-subtle)] object-cover" />
            <div class="flex items-center justify-between">
              <span class="text-xs opacity-50">Page ${i}</span>
              <button data-index="${i - 1}" class="save-one-btn rounded-lg border border-[var(--border-color-subtle)] px-2 py-1 text-xs transition-all hover:border-[var(--action-color)]">Save</button>
            </div>
          `
          previewItems.appendChild(item)
        }

        progressBar.style.width = '100%'
        progressText.textContent = 'Done!'
        previewGrid.classList.remove('hidden')
        previewGrid.classList.add('flex')
      } catch (err) {
        progressText.textContent = 'Something went wrong. Please try again.'
        console.error(err)
      } finally {
        convertBtn.disabled = false
      }
    })

    // Save individual
    previewItems.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.save-one-btn') as HTMLButtonElement | null
      if (!btn) return
      const index = parseInt(btn.dataset.index ?? '0')
      const { blob, name } = renderedBlobs[index]
      const url = URL.createObjectURL(blob)
      const a = document.createElement('a')
      a.href = url
      a.download = name
      a.click()
      URL.revokeObjectURL(url)
    })

    // Save all as ZIP
    saveAllBtn.addEventListener('click', async () => {
      if (renderedBlobs.length === 0) return
      const zip = new JSZip()
      renderedBlobs.forEach(({ blob, name }) => zip.file(name, blob))
      const zipBlob = await zip.generateAsync({ type: 'blob' })
      const url = URL.createObjectURL(zipBlob)
      const a = document.createElement('a')
      a.href = url
      a.download = `${currentFile?.name.replace(/\.pdf$/i, '') ?? 'pdf'}_images.zip`
      a.click()
      URL.revokeObjectURL(url)
    })
  })
</script>
