        {/* ── SKILL MATS PANEL ── */}
        {
          hasSections.skillMats && (
            <section class="tab-panel hidden" id="panel-skillmats" role="tabpanel" aria-labelledby="tab-btn-skillmats">
              <div class="panel-header">
                <div class="panel-accent" aria-hidden="true" />
                <h2 class="panel-title">{labels.nav.skillMats}</h2>
              </div>
