---
// src/pages/[lang]/starrail/profile.astro
import DefaultLayout from '@layouts/DefaultLayout.astro'

export async function getStaticPaths() {
  const languages = ['kr', 'en', 'jp', 'cn', 'cht', 'fr', 'de', 'es', 'id', 'pt', 'ru', 'th', 'vi']
  return languages.map((lang) => ({ params: { lang } }))
}

const { lang = 'en' } = Astro.params
const MIHOMO_LANG: Record<string, string> = {
  kr:'kr', en:'en', jp:'jp', cn:'cn', cht:'cht',
  fr:'fr', de:'de', es:'es', id:'id', pt:'pt', ru:'ru', th:'th', vi:'vi',
}
const mihomoLang = MIHOMO_LANG[lang as string] ?? 'en'

// 성혼 설명 로드
const allData = import.meta.glob('/src/data/starrail/**/*.json', { eager: true })
const ranksRaw: Record<string, any> = (allData[`/src/data/starrail/${lang}/character_ranks.json`] as any)?.default ?? {}
// id → { name, rank, desc } 맵
const rankDescMap: Record<string, any> = {}
Object.values(ranksRaw).forEach((d: any) => {
  const charId = String(d.id).slice(0, 4)  // "101401" → "1014"
  if (!rankDescMap[charId]) rankDescMap[charId] = []
  rankDescMap[charId].push({ rank: d.rank, name: d.name, desc: d.desc })
})
const rankDescJSON = JSON.stringify(rankDescMap).replace(/</g, '\\u003c')

const T: Record<string, any> = {
  kr: {
    pageTitle: 'UID 프로필',
    placeholder: '',
    search: '조회',
    loading: '불러오는 중...',
    errorEmpty: '전시대에 캐릭터가 없거나 비공개 상태입니다.',
    errorInvalid: 'UID를 확인해주세요.',
    relicSlots: ['머리','손','몸통','발','구체','끈'],
    noRelic: '없음', lv: 'Lv.', refine: 'S',
  },
  en: {
    pageTitle: 'UID Profile',
    placeholder: 'Enter UID',
    search: 'Search',
    loading: 'Loading...',
    errorEmpty: 'No characters in showcase or showcase is private.',
    errorInvalid: 'Please check your UID.',
    relicSlots: ['Head','Hands','Body','Feet','Sphere','Rope'],
    noRelic: 'Empty', lv: 'Lv.', refine: 'S',
  },
}
const t = T[lang] ?? T['en']
const tJSON        = JSON.stringify(t).replace(/</g, '\\u003c')
const mihomoLangJS = JSON.stringify(mihomoLang)
---

<DefaultLayout
  title={`${t.pageTitle} | Star Rail DB | HugDot`}
  description="UID로 스타레일 캐릭터 빌드와 유물 점수를 확인하세요."
>

<!-- 페이지 헤더 -->
<div class="prof-header">
  <div class="prof-header-inner">
    <div class="prof-title-row">
      <div>
        <h1 class="prof-title">{t.pageTitle}</h1>
        <p class="prof-subtitle">{t.placeholder}</p>
      </div>
      <div class="uid-form">
        <input type="text" id="uid-input" class="uid-input"
          placeholder={t.placeholder} maxlength="10" inputmode="numeric"/>
        <button class="uid-btn" id="uid-btn">{t.search}</button>
      </div>
    </div>
  </div>
</div>

<div class="profile-page">
  <div class="sw">
    <div id="profile-result"></div>
  </div>
</div>

<script is:inline define:vars={{ tJSON, mihomoLangJS, rankDescJSON }}>
;(function() {
  var t          = JSON.parse(tJSON)
  var mihomoLang = JSON.parse(mihomoLangJS)
  var rankDescs  = JSON.parse(rankDescJSON)
  var SLOT_NAMES = t.relicSlots

  function localImg(p) {
    if (!p) return ''
    return '/starrail/assets/' + p.replace(/\.png$/, '.webp')
  }
  function mihomoImg(p) {
    if (!p) return ''
    return '/api/mihomo-img/' + p
  }
  function img(path, w, h, cls) {
    if (!path) return ''
    var local  = esc(localImg(path))
    var remote = esc(mihomoImg(path))
    // 로컬 우선, 실패하면 MiHoMo CDN으로 폴백
    return '<img src="' + local + '" width="' + w + '" height="' + h + '" loading="lazy"' +
      (cls ? ' class="' + cls + '"' : '') +
      ' onerror="this.src=\'' + remote + '\';this.onerror=null">'
  }

  var WEIGHTS = {
    CriticalChanceBase:2.0, CriticalChance:2.0,
    CriticalDamageBase:1.0, CriticalDamage:1.0,
    SpeedDelta:2.5, SpeedBase:2.5,
    AttackAddedRatio:1.5, HPAddedRatio:0.5, DefenceAddedRatio:0.5,
    BreakDamageAddedRatioBase:1.0, BreakDamageAddedRatio:1.0,
    StatusProbabilityBase:0.5, StatusProbability:0.5,
    StatusResistanceBase:0.5, StatusResistance:0.5,
    AttackDelta:0.3, HPDelta:0.1, DefenceDelta:0.1,
  }
  var STAT_ORDER = ['hp','atk','def','spd','crit_rate','crit_dmg','break_dmg','heal_rate','energy_regen','effect_hit','effect_res','wind_dmg','fire_dmg','ice_dmg','thunder_dmg','quantum_dmg','imaginary_dmg','physical_dmg']
  var SKILL_ORDER = ['Normal','BPSkill','Ultra','Talent','Technique']

  function esc(s) {
    return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')
  }

  function scoreRelic(relic) {
    return (relic.sub_affix || []).reduce(function(sum, s) {
      var w = WEIGHTS[s.type] || 0
      return w ? sum + w * (s.percent ? s.value * 100 : s.value) : sum
    }, 0)
  }

  function getRank(score) {
    if (score >= 18) return { label:'SSS', color:'#f87171' }
    if (score >= 14) return { label:'SS',  color:'#fb923c' }
    if (score >= 10) return { label:'S',   color:'#fbbf24' }
    if (score >= 6)  return { label:'A',   color:'#4ade80' }
    return                 { label:'B',   color:'#9ca3af' }
  }

  function cleanName(name) {
    // "기초 HP" → "HP", "Base HP" → "HP" 등 접두어 제거
    return (name || '').replace(/^(기초|Base|Basiswert|Base|Base|Baza|Cơ bản|Base|Temel|आधार)\s+/i, '')
  }

  function mergeStats(attributes, additions) {
    var map = {}
    ;(attributes || []).forEach(function(a) {
      map[a.field] = { field: a.field, name: cleanName(a.name), display: a.display, percent: a.percent, value: a.value, base: a.value, bonus: 0, icon: a.icon }
    })
    ;(additions || []).forEach(function(a) {
      if (map[a.field]) {
        map[a.field].name   = cleanName(a.name)
        map[a.field].value += a.value
        map[a.field].bonus  = (map[a.field].bonus || 0) + a.value
        map[a.field].display = a.percent
          ? (map[a.field].value * 100).toFixed(1) + '%'
          : Math.round(map[a.field].value).toString()
      } else {
        map[a.field] = { field: a.field, name: cleanName(a.name), display: a.display, percent: a.percent, value: a.value, base: 0, bonus: a.value, icon: a.icon }
      }
    })
    var result = []
    STAT_ORDER.forEach(function(f) { if (map[f]) result.push(map[f]) })
    Object.keys(map).forEach(function(f) { if (STAT_ORDER.indexOf(f) === -1) result.push(map[f]) })
    return result
  }

  // ── 유물 카드 (엔카 스타일 - 컴팩트)
  function renderRelicCard(relic) {
    if (!relic) {
      return '<div class="rc rc--empty"><span>' + esc(t.noRelic) + '</span></div>'
    }
    var slotName = SLOT_NAMES[(relic.type||1)-1] || ''
    var score    = scoreRelic(relic)
    var rank     = getRank(score)
    var mainName = relic.main_affix ? relic.main_affix.name : ''
    var lv       = relic.level || 0

    // 서브스탯 (롤 마커)
    var subsHtml = (relic.sub_affix || []).map(function(s) {
      var w        = WEIGHTS[s.type] || 0
      var rolls    = (s.count || 1) + (s.step || 0)
      var hiColor  = w >= 1.5 ? 'var(--c-accent)' : w >= 0.5 ? '#fbbf24' : 'var(--c-muted)'
      var barColor = w >= 1.5 ? 'var(--c-accent)' : w >= 0.5 ? '#fbbf24' : 'var(--c-border-hi)'
      var dots = ''
      for (var i = 0; i < 5; i++) {
        dots += '<span class="rdot' + (i < rolls ? ' rdot--on" style="background:' + barColor + '"' : '"') + '></span>'
      }
      // field 매핑 (type → field)
      var field = s.type.replace('Base','').replace('AddedRatio','AddedRatio')
      return '<div class="rc-sub" data-type="' + esc(s.type) + '">' +
        '<span class="rc-sub-name" style="color:' + hiColor + '">' + esc(s.name) + '</span>' +
        '<div class="rc-sub-dots">' + dots + '</div>' +
        '<span class="rc-sub-val" style="color:' + hiColor + '">' + esc(s.display) + '</span>' +
      '</div>'
    }).join('')

    return '<div class="rc">' +
      '<div class="rc-head">' +
        '<div class="rc-img-wrap">' + img(relic.icon, 42, 42) + '</div>' +
        '<div class="rc-meta">' +
          '<div class="rc-top-row">' +
            '<span class="rc-slot-main">' + esc(slotName) + ' · ' + esc(mainName) + '</span>' +
            '<span class="rc-lv">+' + lv + '</span>' +
          '</div>' +
          '<span class="rc-setname">' + esc(relic.set_name || '') + '</span>' +
        '</div>' +
        '<div class="rc-score-col">' +
          '<span class="rc-rank" style="color:' + rank.color + '">' + rank.label + '</span>' +
          '<span class="rc-score-num">' + score.toFixed(1) + '</span>' +
        '</div>' +
      '</div>' +
      '<div class="rc-subs">' + subsHtml + '</div>' +
    '</div>'
  }

  // ── 메인 캐릭터 패널 (엔카 레이아웃)
  function renderCharPanel(char) {
    var elColor = (char.element && char.element.color) ? char.element.color : '#9ca3af'
    var lc = char.light_cone || null

    // 성혼 (로컬 rank 설명 데이터 활용)
    var charRankDescs = rankDescs[String(char.id)] || []
    var rankHtml = char.rank_icons ? char.rank_icons.map(function(icon, i) {
      var active  = i < char.rank
      var rankNum = i + 1
      var rd      = charRankDescs.find(function(r) { return r.rank === rankNum }) || {}
      var tooltip = 'E' + rankNum + (rd.name ? ' ' + rd.name : '') + (rd.desc ? '\n' + rd.desc : '')
      return '<div class="ei' + (active ? ' ei--on' : '') + '" data-tooltip="' + esc(tooltip) + '" onmouseenter="showSkillTip(event,this)" onmouseleave="hideSkillTip()">' +
        img(icon, 26, 26) +
      '</div>'
    }).join('') : ''

    // 스킬
    var skills = (char.skills || []).filter(function(s) {
      return s.level > 0 // 레벨 0인 스킬(Technique 등) 제외
    }).slice().sort(function(a, b) {
      return SKILL_ORDER.indexOf(a.type) - SKILL_ORDER.indexOf(b.type)
    })
    var skillsHtml = skills.map(function(s) {
      var isMax = s.level >= s.max_level
      var desc  = esc(s.name||'') + ' Lv.' + s.level + (s.simple_desc ? '\n' + esc(s.simple_desc) : '')
      return '<div class="sk-item" data-tooltip="' + desc + '" onmouseenter="showSkillTip(event,this)" onmouseleave="hideSkillTip()">' +
        '<div class="sk-icon' + (isMax ? ' sk-icon--max' : '') + '">' + img(s.icon, 32, 32) + '</div>' +
        '<span class="sk-lv' + (isMax ? ' sk-lv--max' : '') + '">' + s.level + '</span>' +
      '</div>'
    }).join('')

    // 광추 — 세로형 큰 카드 (위: 이름/레벨, 아래: 스탯)
    var lcHtml = ''
    if (lc) {
      var rc = lc.rarity === 5 ? '#fbbf24' : lc.rarity === 4 ? '#a78bfa' : '#60a5fa'
      var lcPreviewPath = 'image/light_cone_preview/' + lc.id + '.png'
      var lcProps = (lc.properties || []).map(function(p) {
        return '<div class="lc-stat-row"><span class="lc-stat-name">' + esc(p.name) + '</span><span class="lc-stat-val">' + esc(p.display) + '</span></div>'
      }).join('')
      lcHtml = '<div class="lc-card" style="--rc:' + rc + '">' +
        '<div class="lc-card-top">' +
          '<div class="lc-big-img">' + img(lcPreviewPath, 110, 110) + '</div>' +
          '<div class="lc-head">' +
            '<p class="lc-name">' + esc(lc.name || '') + '</p>' +
            '<p class="lc-meta">' + t.lv + (lc.level||'') + (lc.rank ? ' · ' + t.refine + lc.rank : '') + '</p>' +
          '</div>' +
        '</div>' +
        (lcProps ? '<div class="lc-stats">' + lcProps + '</div>' : '') +
      '</div>'
    }

    // 스탯 (icon/property 로컬 아이콘, hover 시 field 기반 하이라이트)
    var stats = mergeStats(char.attributes, char.additions)
    var statsHtml = stats.map(function(s) {
      var propIcon = s.icon ? localImg(s.icon) : ''
      var iconHtml = propIcon ? '<img src="' + esc(propIcon) + '" width="14" height="14" class="stat-icon" onerror="this.onerror=null;this.src=\'' + esc(mihomoImg(s.icon)) + '\'">' : ''
      // 기초+추가 분리 표시
      var bonusHtml = ''
      if (s.bonus && s.bonus > 0) {
        var baseDisp = s.percent ? (s.base * 100).toFixed(0) : Math.round(s.base).toString()
        var bonusDisp = s.percent ? '+' + (s.bonus * 100).toFixed(1) + '%' : '+' + Math.round(s.bonus)
        bonusHtml = '<span class="stat-split">' + baseDisp + ' <span class="stat-bonus">' + bonusDisp + '</span></span>'
      }
      return '<div class="stat-row" data-field="' + esc(s.field||'') + '" onmouseenter="highlightField(this)" onmouseleave="clearHighlight()">' +
        '<span class="stat-name">' + iconHtml + esc(s.name) + '</span>' +
        '<div class="stat-right">' +
          (bonusHtml ? bonusHtml : '') +
          '<span class="stat-val' + (s.percent ? ' stat-val--pct' : '') + '">' + esc(s.display) + '</span>' +
        '</div>' +
      '</div>'
    }).join('')

    // 유물
    var relicBySlot = {}
    ;(char.relics || []).forEach(function(r) { relicBySlot[r.type] = r })
    var relicsHtml = [1,2,3,4,5,6].map(function(slot) {
      return renderRelicCard(relicBySlot[slot] || null)
    }).join('')

    // 세트 조합
    var setCounts = {}
    ;(char.relics || []).forEach(function(r) {
      if (!r.set_id) return
      if (!setCounts[r.set_id]) setCounts[r.set_id] = { name: r.set_name, count: 0 }
      setCounts[r.set_id].count++
    })
    var setCombos = Object.values(setCounts).filter(function(s) { return s.count >= 2 })
      .sort(function(a, b) { return b.count - a.count })
      .map(function(s) {
        return '<span class="set-tag set-tag--' + s.count + '">' + s.count + 'x ' + esc(s.name) + '</span>'
      }).join('')

    return '<div class="char-panel" style="--el:' + esc(elColor) + '">' +

      // 1열: 풀샷 (성혼 세로 오버레이 포함)
      '<div class="col-portrait">' +
        '<div class="portrait-wrap">' +
          img(char.portrait, 240, 240, 'portrait-img') +
          // 성혼 — 풀샷 왼쪽에 세로로
          '<div class="ei-col">' + rankHtml + '</div>' +
          '<div class="portrait-overlay">' +
            '<p class="portrait-name">' + esc(char.name||'') + '</p>' +
            '<p class="portrait-sub">' + t.lv + (char.level||'') +
              (char.path ? ' · ' + esc(char.path.name||'') : '') + ' · E' + (char.rank||0) +
            '</p>' +
          '</div>' +
        '</div>' +
      '</div>' +

      // 2열: 스킬(가로) + 광추
      '<div class="col-info">' +
        '<div class="sk-row">' + skillsHtml + '</div>' +
        lcHtml +
      '</div>' +

      // 3열: 스탯
      '<div class="col-stats">' +
        '<div class="stat-list">' + statsHtml + '</div>' +
      '</div>' +

      // 4열: 유물
      '<div class="col-relics">' +
        (setCombos ? '<div class="set-combos">' + setCombos + '</div>' : '') +
        '<div class="relics-grid">' + relicsHtml + '</div>' +
      '</div>' +

    '</div>'
  }

  // ── 캐릭터 선택 탭
  function renderCharTabs(chars) {
    return '<div class="char-tabs">' +
      chars.map(function(c, i) {
        var elColor = (c.element && c.element.color) ? c.element.color : '#9ca3af'
        var iconSrc = '/starrail/assets/icon/character/' + c.id + '.webp'
        var ts = (c.relics || []).reduce(function(sum, r) { return sum + scoreRelic(r) }, 0).toFixed(1)
        return '<button class="char-tab' + (i === 0 ? ' char-tab--active' : '') + '" data-idx="' + i + '" style="--el:' + esc(elColor) + '">' +
          '<div class="tab-img-wrap"><img src="' + esc(iconSrc) + '" width="50" height="50" loading="lazy" onerror="this.style.display=\'none\'"></div>' +
          '<span class="tab-name">' + esc(c.name||'') + '</span>' +
          '<span class="tab-score">' + ts + '</span>' +
        '</button>'
      }).join('') +
    '</div>'
  }

  // stat hover → 유물 서브스탯 하이라이트
  var TYPE_BY_FIELD = {
    hp: ['HPDelta','HPAddedRatio'],
    atk: ['AttackDelta','AttackAddedRatio'],
    def: ['DefenceDelta','DefenceAddedRatio'],
    spd: ['SpeedDelta','SpeedBase'],
    crit_rate: ['CriticalChance','CriticalChanceBase'],
    crit_dmg: ['CriticalDamage','CriticalDamageBase'],
    break_dmg: ['BreakDamageAddedRatio','BreakDamageAddedRatioBase'],
    effect_hit: ['StatusProbability','StatusProbabilityBase'],
    effect_res: ['StatusResistance','StatusResistanceBase'],
    heal_rate: ['HealRatioBase'],
  }
  window.highlightField = function(row) {
    var field = row.dataset.field
    var types = TYPE_BY_FIELD[field] || []
    if (!types.length) return
    document.querySelectorAll('.rc-sub').forEach(function(sub) {
      var match = types.indexOf(sub.dataset.type) !== -1
      sub.style.opacity = match ? '1' : '0.25'
      if (match) sub.style.background = 'color-mix(in srgb,var(--c-accent) 8%,transparent)'
    })
    document.querySelectorAll('.stat-row').forEach(function(r) {
      r.style.background = r === row ? 'color-mix(in srgb,var(--c-accent) 8%,transparent)' : ''
    })
  }
  window.clearHighlight = function() {
    document.querySelectorAll('.rc-sub').forEach(function(sub) {
      sub.style.opacity = ''
      sub.style.background = ''
    })
    document.querySelectorAll('.stat-row').forEach(function(r) {
      r.style.background = ''
    })
  }

  // 스킬 툴팁
  var _tipEl = null
  window.showSkillTip = function(e, el) {
    if (!_tipEl) {
      _tipEl = document.createElement('div')
      _tipEl.className = 'skill-tooltip'
      document.body.appendChild(_tipEl)
    }
    var lines = (el.dataset.tooltip || '').split('\n')
    _tipEl.innerHTML = lines.map(function(l, i) {
      return i === 0
        ? '<strong>' + l.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</strong>'
        : '<span>' + l.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</span>'
    }).join('')
    _tipEl.style.display = 'block'
    var r = el.getBoundingClientRect()
    var left = Math.min(r.left, window.innerWidth - 280)
    _tipEl.style.left = Math.max(8, left) + 'px'
    _tipEl.style.top  = (r.bottom + window.scrollY + 6) + 'px'
  }
  window.hideSkillTip = function() {
    if (_tipEl) _tipEl.style.display = 'none'
  }

  var currentChars = []

  function showResult(data) {
    var el = document.getElementById('profile-result')
    if (!el) return
    var player = data.player
    var chars  = data.characters || []
    if (!chars.length) { showError(t.errorEmpty); return }
    currentChars = chars

    el.innerHTML =
      '<div class="player-header">' +
        '<p class="player-name">' + esc(player.nickname||'') + '</p>' +
        '<p class="player-meta">' + t.lv + (player.level||'') + (player.signature ? ' · ' + esc(player.signature) : '') + '</p>' +
      '</div>' +
      renderCharTabs(chars) +
      '<div class="profile-panel-scroll"><div id="char-panel-wrap">' + renderCharPanel(chars[0]) + '</div></div>'

    el.querySelectorAll('.char-tab').forEach(function(btn) {
      btn.onclick = function() {
        var idx = parseInt(btn.dataset.idx)
        el.querySelectorAll('.char-tab').forEach(function(b) { b.classList.remove('char-tab--active') })
        btn.classList.add('char-tab--active')
        document.getElementById('char-panel-wrap').innerHTML = renderCharPanel(currentChars[idx])
      }
    })
  }

  function showLoading() {
    var el = document.getElementById('profile-result')
    if (el) el.innerHTML = '<div class="p-loading">' + esc(t.loading) + '</div>'
  }

  function showError(msg) {
    var el = document.getElementById('profile-result')
    if (el) el.innerHTML = '<div class="p-error">' + esc(msg) + '</div>'
  }

  async function fetchProfile(uid) {
    showLoading()
    try {
      var res  = await fetch('/api/mihomo?uid=' + encodeURIComponent(uid) + '&lang=' + mihomoLang)
      var data = await res.json()
      if (!res.ok || data.detail) { showError(data.detail || t.errorInvalid); return }
      showResult(data)
    } catch(e) { showError(t.errorInvalid) }
  }

  function init() {
    var btn   = document.getElementById('uid-btn')
    var input = document.getElementById('uid-input')
    if (!btn || !input) return
    var params  = new URLSearchParams(location.search)
    var initUid = params.get('uid')
    if (initUid) { input.value = initUid; fetchProfile(initUid) }
    btn.onclick = function() {
      var uid = input.value.trim()
      if (!uid) return
      history.replaceState(null, '', '?uid=' + encodeURIComponent(uid))
      fetchProfile(uid)
    }
    input.addEventListener('keydown', function(e) { if (e.key === 'Enter') btn.click() })
  }

  var _initialized = false
  function safeInit() { if (_initialized) return; _initialized = true; init() }
  document.readyState === 'loading'
