                ))}
              </div>
            </section>
          )
        }

        <!-- ── STATS MOBILE PANEL (mobile only, desktop shows inline) ── -->
        {
          hasSections.stats && (
            <section
              class="tab-panel stats-mobile-panel hidden"
              id="panel-stats-mobile"
              role="tabpanel"
              aria-labelledby="tab-btn-stats-mobile"
            >
              <div class="panel-header">
                <div class="panel-accent" aria-hidden="true" />
                <h2 class="panel-title">{labels.stats80}</h2>
              </div>

              {statsArray.length > 0 && statsCurveJson && (
                <div class="stats-panel-inner">
                  <label class="lv-control" for="char-level-range-m">
                    <span class="lv-label">{labels.charLevel}</span>
                    <span class="lv-val" id="char-level-value-m">
