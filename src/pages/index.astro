---
// src/pages/index.astro
// 브라우저 언어 감지 후 해당 언어 홈으로 리다이렉트
// Astro SSG이므로 클라이언트 JS로 처리
---

<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HugDot | Game Database</title>
    <meta name="description" content="Honkai: Star Rail Game Database" />
    <!-- 기본 리다이렉트 (JS 비활성화 대비) -->
    <meta http-equiv="refresh" content="0;url=/kr/starrail" />
    <style>
      body {
        margin: 0;
        background: #09090f;
        color: #e2e4f0;
        font-family: sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
      }
    </style>
  </head>
  <body>
    <script is:inline>
    ;(function () {
      var langMap = {
        'ko': 'kr', 'ko-KR': 'kr',
        'en': 'en', 'en-US': 'en', 'en-GB': 'en',
        'ja': 'jp', 'ja-JP': 'jp',
        'zh': 'cn', 'zh-CN': 'cn', 'zh-SG': 'cn',
        'zh-TW': 'cht', 'zh-HK': 'cht',
        'fr': 'fr', 'fr-FR': 'fr',
        'de': 'de', 'de-DE': 'de',
        'es': 'es', 'es-ES': 'es', 'es-MX': 'es',
        'id': 'id', 'id-ID': 'id',
        'pt': 'pt', 'pt-BR': 'pt', 'pt-PT': 'pt',
        'ru': 'ru', 'ru-RU': 'ru',
        'th': 'th', 'th-TH': 'th',
        'vi': 'vi', 'vi-VN': 'vi',
      }

      var supported = ['kr','en','jp','cn','cht','fr','de','es','id','pt','ru','th','vi']

      function detectLang() {
        var langs = navigator.languages || [navigator.language || 'en']
        for (var i = 0; i < langs.length; i++) {
          var l = langs[i]
          // 정확히 매칭
          if (langMap[l]) return langMap[l]
          // 앞 2자리로 매칭
          var short = l.split('-')[0]
          if (langMap[short]) return langMap[short]
        }
        return 'en'
      }

      // localStorage에 저장된 언어 우선
      var saved = localStorage.getItem('hd-lang')
      var lang = (saved && supported.includes(saved)) ? saved : detectLang()

      window.location.replace('/' + lang + '/starrail')
    })()
    </script>
  </body>
</html>
