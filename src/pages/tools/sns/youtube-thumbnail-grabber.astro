---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools, getToolHref } from '@data/tools/index'
import seoData from '@data/seo/en/youtube-thumbnail-grabber.json'

const relatedTools = tools.filter((t) => t.category === 'sns' && t.id !== 'youtube-thumbnail-grabber' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="SocialNetworkingApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">

      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/sns" class="breadcrumb-link hover:underline">SNS Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Paste any YouTube URL and download the thumbnail instantly. No login required.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:shield-check" size="0.875rem" class="text-[var(--action-color)]" />
            No Login
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:zap" size="0.875rem" class="text-[var(--action-color)]" />
            Instant
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:infinity" size="0.875rem" class="text-[var(--action-color)]" />
            No Limits
          </span>
        </div>
      </div>

      <!-- Tool -->
      <div class="flex flex-col gap-6">

        <!-- URL Input -->
        <div class="flex flex-col gap-2">
          <label class="text-sm font-medium" for="url-input">YouTube URL</label>
          <div class="flex gap-2">
            <input
              id="url-input"
              type="url"
              placeholder="https://www.youtube.com/watch?v=..."
              class="flex-1 rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-4 py-3 text-sm outline-none focus:border-[var(--action-color)]"
            />
            <button
              id="clear-btn"
              class="hidden rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm transition-all hover:border-[var(--action-color)]"
            >
              <Icon aria-hidden="true" name="lucide:x" size="1rem" />
            </button>
          </div>
        </div>

        <!-- Error -->
        <div id="error-panel" class="hidden items-center gap-2 rounded-xl border border-red-400 px-4 py-3 text-sm text-red-400">
          <Icon aria-hidden="true" name="lucide:alert-circle" size="1rem" />
          <span id="error-text">Invalid YouTube URL. Please check and try again.</span>
        </div>

        <!-- Results -->
        <div id="result-panel" class="hidden flex-col gap-4">

          <!-- Thumbnails Grid -->
          <div id="thumbnails-grid" class="flex flex-col gap-4"></div>

        </div>

      </div>

      <!-- Privacy Badge -->
      <div class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60">
        <Icon aria-hidden="true" name="lucide:info" size="1rem" />
        <span>Thumbnails are fetched directly from YouTube's servers. Please respect copyright when using downloaded images.</span>
      </div>

      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="mt-12">
          <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {relatedTools.map((tool) => (
              <a href={getToolHref(tool.category, tool.slug)}
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]">
                {tool.label} →
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</DefaultLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const urlInput = document.getElementById('url-input') as HTMLInputElement
    const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement
    const errorPanel = document.getElementById('error-panel') as HTMLElement
    const errorText = document.getElementById('error-text') as HTMLElement
    const resultPanel = document.getElementById('result-panel') as HTMLElement
    const thumbnailsGrid = document.getElementById('thumbnails-grid') as HTMLElement

    const extractVideoId = (url: string): string | null => {
      const patterns = [
        /(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/|youtube\.com\/v\/)([a-zA-Z0-9_-]{11})/,
        /youtube\.com\/watch\?.*v=([a-zA-Z0-9_-]{11})/,
      ]
      for (const pattern of patterns) {
        const match = url.match(pattern)
        if (match) return match[1]
      }
      return null
    }

    const resolutions = [
      { label: 'Max Resolution', key: 'maxresdefault', size: '1280×720' },
      { label: 'HD', key: 'sddefault', size: '640×480' },
      { label: 'High Quality', key: 'hqdefault', size: '480×360' },
      { label: 'Medium Quality', key: 'mqdefault', size: '320×180' },
    ]

    const downloadImage = async (url: string, filename: string) => {
      try {
        const response = await fetch(url)
        const blob = await response.blob()
        const blobUrl = URL.createObjectURL(blob)
        const link = document.createElement('a')
        link.href = blobUrl
        link.download = filename
        link.click()
        URL.revokeObjectURL(blobUrl)
      } catch {
        // fallback: open in new tab
        window.open(url, '_blank')
      }
    }

    const checkImageExists = (url: string): Promise<boolean> => {
      return new Promise((resolve) => {
        const img = new Image()
        img.onload = () => resolve(img.width > 120)
        img.onerror = () => resolve(false)
        img.src = url
      })
    }

    const grabThumbnails = async (videoId: string) => {
      thumbnailsGrid.innerHTML = ''
      resultPanel.style.display = 'flex'
      errorPanel.style.display = 'none'

      // loading placeholders
      resolutions.forEach(() => {
        const placeholder = document.createElement('div')
        placeholder.className = 'animate-pulse rounded-2xl border border-[var(--border-color-subtle)] overflow-hidden'
        placeholder.innerHTML = `<div class="aspect-video w-full bg-[var(--border-color-subtle)]"></div><div class="p-4 flex justify-between items-center"><div class="h-4 w-24 rounded bg-[var(--border-color-subtle)]"></div><div class="h-8 w-20 rounded-full bg-[var(--border-color-subtle)]"></div></div>`
        thumbnailsGrid.appendChild(placeholder)
      })

      const results = await Promise.all(
        resolutions.map(async (res) => {
          const url = `https://img.youtube.com/vi/${videoId}/${res.key}.jpg`
          const exists = await checkImageExists(url)
          return { ...res, url, exists }
        })
      )

      thumbnailsGrid.innerHTML = ''

      let anyFound = false
      results.forEach((res) => {
        if (!res.exists) return
        anyFound = true

        const card = document.createElement('div')
        card.className = 'overflow-hidden rounded-2xl border border-[var(--border-color-subtle)]'
        card.innerHTML = `
          <img src="${res.url}" alt="${res.label} thumbnail" class="w-full object-cover" loading="lazy" />
          <div class="flex items-center justify-between px-4 py-3">
            <div>
              <p class="text-sm font-medium">${res.label}</p>
              <p class="text-xs opacity-50">${res.size}</p>
            </div>
            <button
              class="save-btn flex items-center gap-1.5 rounded-full bg-[var(--action-color)] px-4 py-2 text-xs font-semibold text-white transition-opacity hover:opacity-90"
              data-url="${res.url}"
              data-filename="thumbnail-${videoId}-${res.key}.jpg"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Save
            </button>
          </div>
        `
        thumbnailsGrid.appendChild(card)
      })

      if (!anyFound) {
        resultPanel.style.display = 'none'
        errorText.textContent = 'No thumbnails found for this video.'
        errorPanel.style.display = 'flex'
      }

      // save button listeners
      thumbnailsGrid.querySelectorAll('.save-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const url = (btn as HTMLElement).dataset.url!
          const filename = (btn as HTMLElement).dataset.filename!
          downloadImage(url, filename)
        })
      })
    }

    const handleInput = () => {
      const url = urlInput.value.trim()
      errorPanel.style.display = 'none'

      if (!url) {
        resultPanel.style.display = 'none'
        clearBtn.style.display = 'none'
        return
      }

      clearBtn.style.display = 'flex'
      const videoId = extractVideoId(url)

      if (!videoId) {
        resultPanel.style.display = 'none'
        errorText.textContent = 'Invalid YouTube URL. Please check and try again.'
        errorPanel.style.display = 'flex'
        return
      }

      grabThumbnails(videoId)
    }

    urlInput.addEventListener('input', handleInput)
    urlInput.addEventListener('paste', () => setTimeout(handleInput, 50))

    clearBtn.addEventListener('click', () => {
      urlInput.value = ''
      resultPanel.style.display = 'none'
      errorPanel.style.display = 'none'
      clearBtn.style.display = 'none'
      urlInput.focus()
    })
  })
</script>