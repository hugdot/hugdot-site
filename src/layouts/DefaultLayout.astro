---
// src/layouts/DefaultLayout.astro
import '../styles/tailwind.css'
import '../assets/scss/index.scss'
import { ClientRouter } from 'astro:transitions'
import Header from '@components/Header.astro'
import Footer from '@components/Footer.astro'

interface Props {
  title?: string
  description?: string
  url?: string
  image?: string | null
  author?: string
  type?: 'website' | 'article'
  useTitleTemplate?: boolean
}

const {
  title = 'HugDot | Game Database',
  description = 'Honkai: Star Rail character database.',
  url = Astro.url.href,
  image = null,
  author = 'HugDot',
  type = 'website',
  useTitleTemplate = true,
} = Astro.props

const imageUrl = new URL(image ?? '/social-preview-image.png', Astro.site).href
---

<html lang="ko" dir="ltr" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Noto+Sans+KR:wght@400;700;900&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- 다크모드 전용 CSS 변수 -->
    <style>

      @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Noto+Sans+KR:wght@400;700;900&family=JetBrains+Mono:wght@400;700&display=swap');
      :root {
        color-scheme: dark;

        /* 브랜드 */
        --action-color: #7c9dfc;
        --action-color-subtle: rgba(124, 157, 252, 0.15);

        /* 배경 */
        --c-bg: #09090f;
        --c-surface: #0f101a;
        --c-surface2: #161724;

        /* 테두리 */
        --c-border: rgba(255, 255, 255, 0.07);
        --c-border-hi: rgba(255, 255, 255, 0.14);

        /* 텍스트 */
        --foreground-color: #e2e4f0;
        --c-muted: rgba(226, 228, 240, 0.45);

        /* 기타 */
        --border-color-subtle: rgba(255, 255, 255, 0.07);
        --link-color: #7c9dfc;

        /* 반경 */
        --radius-sm: 8px;
        --radius-md: 14px;
        --radius-lg: 22px;
        --radius-xl: 32px;

        /* 폰트 */
        --font-display: 'Rajdhani', 'Noto Sans KR', sans-serif;
        --font-body: 'Noto Sans KR', sans-serif;
        --font-mono: 'JetBrains Mono', monospace;

        /* 애니메이션 */
        --anim-fast: 140ms cubic-bezier(0.4, 0, 0.2, 1);
        --anim-med: 260ms cubic-bezier(0.4, 0, 0.2, 1);

        /* accent glow */
        --c-accent: var(--action-color);
        --c-accent-glow: rgba(124, 157, 252, 0.18);
      }

      /* 구글 폰트 */
    
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html,
      body {
        background: var(--c-bg);
        height: 100%;
        color: var(--foreground-color);
        font-family: var(--font-body);
        -webkit-font-smoothing: antialiased;
      }

      body {
        display: flex;
        flex-direction: column;
        overflow-x: clip;
      }

      main {
        flex: 1 0 auto;
      }
      footer {
        flex-shrink: 0;
      }

      /* 하이라이트 숫자 (스킬 설명용) */
      .hl-num {
        display: inline-block;
        padding: 0.05em 0.4em;
        border-radius: 5px;
        background: var(--c-accent-glow);
        color: var(--c-accent) !important;
        font-family: var(--font-mono) !important;
        font-size: 0.88em;
        font-weight: 700 !important;
        line-height: 1.4;
      }

      /* range input 전역 스타일 */
      input[type='range'].range-input {
        -webkit-appearance: none;
        appearance: none;
        cursor: pointer;
        outline: none;
        border-radius: 99px;
        background: var(--c-border-hi);
        height: 3px;
        accent-color: var(--c-accent);
      }
      input[type='range'].range-input::-webkit-slider-thumb {
        -webkit-appearance: none;
        cursor: pointer;
        box-shadow: 0 0 0 3px var(--c-accent-glow);
        border-radius: 50%;
        background: var(--c-accent);
        width: 14px;
        height: 14px;
      }

      /* prefers-reduced-motion */
      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>

    <title>{useTitleTemplate ? `${title} | HugDot` : (title || 'HugDot | Game Database')}</title>
    <meta name="description" content={description || 'Honkai: Star Rail game database'} />
    <meta name="author" content={author} />
    <link rel="canonical" href={url} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description || ''} />
    <meta property="og:image" content={imageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description || ''} />
    <meta name="twitter:image" content={imageUrl} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'HugDot Game Database',
        url: Astro.site?.href ?? 'https://hugdot.com',
        description,
        inLanguage: 'ko',
      })}
    />

    <ClientRouter />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-S9T7556CP8"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || []
      function gtag() {
        dataLayer.push(arguments)
      }
      gtag('js', new Date())
      gtag('config', 'G-S9T7556CP8')
    </script>
  </head>

  <body>
    <Header />
    <main id="main-content" transition:animate="fade">
      <slot />
    </main>
    <Footer />
  </body>
</html>
