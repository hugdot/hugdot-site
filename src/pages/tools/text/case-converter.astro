---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools, getToolHref } from '@data/tools/index'
import seoData from '@data/seo/en/case-converter.json'

const relatedTools = tools.filter((t) => t.category === 'text' && t.id !== 'case-converter' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="UtilitiesApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">

      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/text" class="breadcrumb-link hover:underline">Text Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Convert text to any case instantly. 100% private — your text never leaves your device.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:shield-check" size="0.875rem" class="text-[var(--action-color)]" />
            No Upload
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:user-x" size="0.875rem" class="text-[var(--action-color)]" />
            No Login
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:infinity" size="0.875rem" class="text-[var(--action-color)]" />
            No Limits
          </span>
        </div>
      </div>

      <!-- Tool -->
      <div class="flex flex-col gap-4">

        <!-- Input -->
        <textarea
          id="input-text"
          rows="5"
          placeholder="Type or paste your text here..."
          class="w-full resize-none rounded-2xl border border-[var(--border-color-subtle)] bg-transparent px-4 py-3 text-sm outline-none focus:border-[var(--action-color)]"
        ></textarea>

        <!-- Case Buttons -->
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-3">
          <button data-case="sentence" class="case-btn rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]">
            Sentence case
          </button>
          <button data-case="upper" class="case-btn rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]">
            UPPER CASE
          </button>
          <button data-case="lower" class="case-btn rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]">
            lower case
          </button>
          <button data-case="title" class="case-btn rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]">
            Title Case
          </button>
          <button data-case="camel" class="case-btn rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]">
            camelCase
          </button>
          <button data-case="pascal" class="case-btn rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]">
            PascalCase
          </button>
          <button data-case="snake" class="case-btn rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]">
            snake_case
          </button>
          <button data-case="kebab" class="case-btn rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]">
            kebab-case
          </button>
          <button data-case="mixed" class="case-btn rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]">
            MiXeD CaSe
          </button>
          <button data-case="inverse" class="case-btn rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]">
            iNvErSe CaSe
          </button>
        </div>

        <!-- Result -->
        <div id="result-panel" class="hidden flex-col gap-3">
          <div class="flex items-center justify-between">
            <span id="result-label" class="text-xs font-semibold uppercase tracking-widest opacity-40"></span>
            <button id="copy-btn" class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-4 py-1.5 text-xs font-medium transition-all hover:border-[var(--action-color)]">
              <Icon aria-hidden="true" name="lucide:copy" size="0.75rem" />
              Copy
            </button>
          </div>
          <div
            id="result-text"
            class="min-h-[80px] w-full rounded-2xl border border-[var(--border-color-subtle)] bg-transparent px-4 py-3 text-sm"
          ></div>
        </div>

      </div>

      <!-- Privacy Badge -->
      <div class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60">
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Your text never leaves your device. No data is sent to any server.</span>
      </div>

      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="mt-12">
          <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {relatedTools.map((tool) => (
              <a href={getToolHref(tool.category, tool.slug)}
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]">
                {tool.label} →
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</DefaultLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const inputText = document.getElementById('input-text') as HTMLTextAreaElement
    const resultPanel = document.getElementById('result-panel') as HTMLElement
    const resultText = document.getElementById('result-text') as HTMLElement
    const resultLabel = document.getElementById('result-label') as HTMLElement
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement
    const caseBtns = document.querySelectorAll('.case-btn') as NodeListOf<HTMLButtonElement>

    const toWords = (text: string): string[] =>
      text.trim().split(/[\s\-_]+/).filter(Boolean)

    const converters: Record<string, (t: string) => string> = {
      sentence: (t) => t.toLowerCase().replace(/(^\s*\w|[.!?]\s*\w)/g, (c) => c.toUpperCase()),
      upper: (t) => t.toUpperCase(),
      lower: (t) => t.toLowerCase(),
      title: (t) => t.toLowerCase().replace(/\b\w/g, (c) => c.toUpperCase()),
      camel: (t) => {
        const words = toWords(t.toLowerCase())
        return words.map((w, i) => i === 0 ? w : w[0].toUpperCase() + w.slice(1)).join('')
      },
      pascal: (t) => toWords(t.toLowerCase()).map((w) => w[0].toUpperCase() + w.slice(1)).join(''),
      snake: (t) => toWords(t.toLowerCase()).join('_'),
      kebab: (t) => toWords(t.toLowerCase()).join('-'),
      mixed: (t) => t.split('').map((c, i) => i % 2 === 0 ? c.toUpperCase() : c.toLowerCase()).join(''),
      inverse: (t) => t.split('').map((c) => c === c.toUpperCase() ? c.toLowerCase() : c.toUpperCase()).join(''),
    }

    const labels: Record<string, string> = {
      sentence: 'Sentence case',
      upper: 'UPPER CASE',
      lower: 'lower case',
      title: 'Title Case',
      camel: 'camelCase',
      pascal: 'PascalCase',
      snake: 'snake_case',
      kebab: 'kebab-case',
      mixed: 'MiXeD CaSe',
      inverse: 'iNvErSe CaSe',
    }

    let currentCase = ''

    const convert = (caseType: string) => {
      const text = inputText.value
      if (!text.trim()) return

      currentCase = caseType
      const converted = converters[caseType](text)
      resultText.textContent = converted
      resultLabel.textContent = labels[caseType]
      resultPanel.style.display = 'flex'

      caseBtns.forEach((btn) => {
        btn.style.borderColor = btn.dataset.case === caseType ? 'var(--action-color)' : ''
        btn.style.color = btn.dataset.case === caseType ? 'var(--action-color)' : ''
      })
    }

    caseBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const caseType = btn.dataset.case
        if (caseType) convert(caseType)
      })
    })

    inputText.addEventListener('input', () => {
      if (currentCase) convert(currentCase)
    })

    copyBtn.addEventListener('click', async () => {
      const text = resultText.textContent
      if (!text) return
      await navigator.clipboard.writeText(text)
      copyBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Copied!`
      copyBtn.style.borderColor = 'var(--action-color)'
      copyBtn.style.color = 'var(--action-color)'
      setTimeout(() => {
        copyBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy`
        copyBtn.style.borderColor = ''
        copyBtn.style.color = ''
      }, 2000)
    })
  })
</script>