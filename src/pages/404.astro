---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Icon } from 'astro-icon/components'
---

<DefaultLayout title="404 | HugDot" description="Page not found.">
<div class="nf-page">
  <div class="nw">

    <div class="nf-code">404</div>
    <h1 class="nf-title">Page Not Found</h1>
    <p class="nf-desc">The page you're looking for doesn't exist or has been moved.</p>

    <div class="nf-links">
      <a href="/" class="nf-btn nf-btn--primary">
        <Icon name="lucide:home" size="0.9rem"/>
        Home
      </a>
      <a href="/kr/starrail" class="nf-btn nf-btn--secondary">
        <Icon name="lucide:star" size="0.9rem"/>
        Star Rail DB
      </a>
      <a href="/kr/starrail/characters" class="nf-btn nf-btn--secondary">
        <Icon name="lucide:users" size="0.9rem"/>
        Characters
      </a>
      <a href="/kr/starrail/planner" class="nf-btn nf-btn--secondary">
        <Icon name="lucide:calendar" size="0.9rem"/>
        Planner
      </a>
    </div>

  </div>
</div>
</DefaultLayout>

<style>
.nf-page { min-height:80vh; display:flex; align-items:center; justify-content:center; background:var(--c-bg); color:var(--foreground-color); padding:4rem 1.5rem; }
.nw { text-align:center; display:flex; flex-direction:column; align-items:center; gap:1.25rem; }
.nf-code { font-family:var(--font-mono); font-size:6rem; font-weight:900; line-height:1; color:var(--c-accent); opacity:.15; letter-spacing:-.05em; }
.nf-title { font-family:var(--font-display); font-size:clamp(1.5rem,4vw,2.5rem); font-weight:700; letter-spacing:-.02em; margin-top:-2rem; }
.nf-desc { font-size:.88rem; color:var(--c-muted); max-width:360px; line-height:1.7; }
.nf-links { display:flex; flex-wrap:wrap; gap:.5rem; justify-content:center; margin-top:.5rem; }
.nf-btn { display:inline-flex; align-items:center; gap:.45rem; padding:.6rem 1.1rem; border-radius:var(--radius-sm); font-size:.8rem; font-weight:700; text-decoration:none; transition:opacity var(--anim-fast),transform var(--anim-fast); }
.nf-btn:hover { opacity:.85; transform:translateY(-1px); }
.nf-btn--primary { background:var(--c-accent); color:#fff; }
.nf-btn--secondary { border:1px solid var(--c-border); background:var(--c-surface); color:var(--foreground-color); }
.nf-btn--secondary:hover { border-color:var(--c-accent); color:var(--c-accent); }
</style>