---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools, getToolHref } from '@data/tools/index'
import seoData from '@data/seo/en/pdf-redact.json'

const relatedTools = tools.filter((t) => t.category === 'pdf' && t.id !== 'pdf-redact' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="MultimediaApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">
      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/pdf" class="breadcrumb-link hover:underline">PDF Tools</a>
          <span>/</span>
          <span>PDF Redact</span>
        </div>
        <Heading level="h1" size="h2">PDF Redact</Heading>
        <p class="mt-2 opacity-60">
          Permanently redact sensitive information from PDFs. Each page is converted to an image — the original text
          layer is completely destroyed.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span
            class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium"
          >
            <Icon aria-hidden="true" name="lucide:shield-check" size="0.875rem" class="text-[var(--action-color)]" />
            No Upload
          </span>
          <span
            class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium"
          >
            <Icon aria-hidden="true" name="lucide:user-x" size="0.875rem" class="text-[var(--action-color)]" />
            No Login
          </span>
          <span
            class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium"
          >
            <Icon aria-hidden="true" name="lucide:lock" size="0.875rem" class="text-[var(--action-color)]" />
            Secure Redaction
          </span>
        </div>
      </div>

      <!-- Security Notice -->
      <div class="mb-6 flex items-start gap-3 rounded-2xl border border-blue-500/30 bg-blue-500/10 px-5 py-4 text-sm">
        <Icon aria-hidden="true" name="lucide:info" size="1.25rem" class="mt-0.5 shrink-0 text-blue-500" />
        <div>
          <p class="font-semibold text-blue-500">Secure Redaction Method</p>
          <p class="mt-1 opacity-70">
            Each PDF page is rendered as a high-resolution image. Your redaction boxes are burned into the image. The
            result is a new PDF with no original text layer — making data recovery impossible.
          </p>
        </div>
      </div>

      <!-- Tool -->
      <div class="flex flex-col gap-6">
        <!-- Drop Zone -->
        <div
          id="drop-zone"
          class="flex cursor-pointer flex-col items-center justify-center gap-4 rounded-2xl border-2 border-dashed border-[var(--border-color-subtle)] p-12 text-center transition-all hover:border-[var(--action-color)]"
        >
          <Icon aria-hidden="true" name="lucide:file-up" size="3rem" class="opacity-30" />
          <div>
            <p class="font-semibold">Open a PDF</p>
            <p class="text-sm opacity-50">or drag & drop here</p>
          </div>
          <p class="text-xs opacity-40">PDF files only</p>
          <input id="file-input" type="file" accept=".pdf,application/pdf" class="hidden" />
        </div>

        <!-- Loading PDF -->
        <div id="loading-pdf" class="hidden flex-col items-center gap-3">
          <div
            class="h-8 w-8 animate-spin rounded-full border-4 border-[var(--border-color-subtle)] border-t-[var(--action-color)]"
          >
          </div>
          <p id="loading-pdf-text" class="text-sm opacity-50">Loading PDF...</p>
        </div>

        <!-- Editor Panel -->
        <div id="editor-panel" class="hidden flex-col gap-4">
          <!-- Page Navigation -->
          <div
            class="flex items-center justify-between rounded-xl border border-[var(--border-color-subtle)] px-4 py-3"
          >
            <button
              id="prev-page"
              class="flex items-center gap-1.5 rounded-lg border border-[var(--border-color-subtle)] px-3 py-1.5 text-sm transition-all hover:border-[var(--action-color)] disabled:opacity-30"
            >
              <Icon aria-hidden="true" name="lucide:chevron-left" size="1rem" />
              Prev
            </button>
            <span id="page-info" class="text-sm font-medium"></span>
            <button
              id="next-page"
              class="flex items-center gap-1.5 rounded-lg border border-[var(--border-color-subtle)] px-3 py-1.5 text-sm transition-all hover:border-[var(--action-color)] disabled:opacity-30"
            >
              Next
              <Icon aria-hidden="true" name="lucide:chevron-right" size="1rem" />
            </button>
          </div>

          <!-- Canvas Container -->
          <div class="flex flex-col gap-2">
            <p class="text-xs font-medium opacity-60">Drag to redact areas — click a box to remove it</p>
            <div
              id="canvas-container"
              class="relative w-full overflow-hidden rounded-2xl border border-[var(--border-color-subtle)]"
              style="cursor: crosshair;"
            >
              <canvas id="pdf-canvas" class="block w-full"></canvas>
              <canvas id="overlay-canvas" class="absolute inset-0 block w-full" style="cursor: crosshair;"></canvas>
            </div>
          </div>

          <!-- Redaction Controls -->
          <div class="flex flex-wrap gap-3">
            <button
              id="clear-page-btn"
              class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-4 py-2 text-sm font-medium transition-all hover:border-red-500 hover:text-red-500"
            >
              <Icon aria-hidden="true" name="lucide:trash-2" size="1rem" />
              Clear This Page
            </button>
            <div
              class="flex items-center gap-2 rounded-xl border border-[var(--border-color-subtle)] px-4 py-2 text-sm"
            >
              <span id="redaction-count" class="font-bold text-[var(--action-color)]">0</span>
              <span class="opacity-60">redaction(s) on this page</span>
            </div>
          </div>

          <!-- Page Summary -->
          <div
            id="page-summary"
            class="flex flex-col gap-2 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3"
          >
            <p class="text-xs font-medium opacity-60">Redaction Summary</p>
            <div id="summary-list" class="flex flex-col gap-1"></div>
          </div>

          <!-- Apply Button -->
          <button
            id="apply-btn"
            class="flex items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
          >
            <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
            Apply Redactions & Save PDF
          </button>

          <!-- Reset -->
          <button
            id="reset-btn"
            class="flex items-center justify-center gap-2 rounded-full border border-[var(--border-color-subtle)] px-8 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]"
          >
            <Icon aria-hidden="true" name="lucide:refresh-cw" size="1rem" />
            Open Another PDF
          </button>
        </div>

        <!-- Processing -->
        <div id="processing" class="hidden flex-col items-center gap-3">
          <div
            class="h-8 w-8 animate-spin rounded-full border-4 border-[var(--border-color-subtle)] border-t-[var(--action-color)]"
          >
          </div>
          <p id="processing-text" class="text-sm opacity-50">Applying redactions...</p>
          <p class="text-xs opacity-40">This may take a moment for large PDFs</p>
        </div>
      </div>

      <!-- Privacy Badge -->
      <div
        class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60"
      >
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Your PDF never leaves your device. All processing happens in your browser.</span>
      </div>

      <!-- Related Tools -->
      {
        relatedTools.length > 0 && (
          <div class="mt-12">
            <Heading level="h2" size="h4" class="mb-6">
              Related Tools
            </Heading>
            <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
              {relatedTools.map((tool) => (
                <a
                  href={getToolHref(tool.category, tool.slug)}
                  class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]"
                >
                  {tool.label} →
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </section>
</DefaultLayout>

<script>
  import * as pdfjs from 'pdfjs-dist'

  // ─── pdfjs Worker 설정 ───────────────────────────────────────────────────────
  // Astro 빌드 환경에서 workerSrc가 깨지는 것을 방지하기 위해
  // CDN URL을 직접 지정합니다 (버전 고정 필수)
  pdfjs.GlobalWorkerOptions.workerSrc = `https://unpkg.com/pdfjs-dist@${pdfjs.version}/build/pdf.worker.min.js`

  // ─── pdf-lib 동적 로드 ──────────────────────────────────────────────────────
  // 유저가 파일을 업로드할 때만 로드 (메인 스레드 점유 최소화)
  // SRI 해시로 무결성 검증
  let pdfLibLoaded = false

  const loadPdfLib = (): Promise<void> => {
    return new Promise((resolve, reject) => {
      if (pdfLibLoaded) {
        resolve()
        return
      }
      const script = document.createElement('script')
      script.src = 'https://unpkg.com/pdf-lib/dist/pdf-lib.min.js'
      // SRI - sha384 해시 (pdf-lib@1.17.1)
      script.integrity = 'sha384-flbZn59Actq96thAipi+IPBKeP/Q+CVq5O4thSn9xA8pIW3GolGfQ1E4I6Ip+BuE'
      script.crossOrigin = 'anonymous'
      script.onload = () => {
        pdfLibLoaded = true
        resolve()
      }
      script.onerror = () => reject(new Error('Failed to load pdf-lib'))
      document.head.appendChild(script)
    })
  }

  // ─── 타입 선언 ──────────────────────────────────────────────────────────────
  type Rect = { x: number; y: number; w: number; h: number }
  type PageRedactions = Map<number, Rect[]>

  // ─── 전역 상태 ──────────────────────────────────────────────────────────────
  let pdfDoc: pdfjs.PDFDocumentProxy | null = null
  let currentPage = 1
  let totalPages = 0
  let scale = 2 // 고해상도 렌더링 (2배수)
  let pageRedactions: PageRedactions = new Map()
  let isDragging = false
  let dragStart = { x: 0, y: 0 }
  let originalFile: File | null = null

  let cleanupFn: (() => void) | null = null

  document.addEventListener('astro:page-load', () => {
    cleanupFn?.()
    cleanupFn = initRedact()
  })

  function initRedact(): () => void {
    const dropZone = document.getElementById('drop-zone') as HTMLElement
    const fileInput = document.getElementById('file-input') as HTMLInputElement
    const loadingPdf = document.getElementById('loading-pdf') as HTMLElement
    const loadingPdfText = document.getElementById('loading-pdf-text') as HTMLElement
    const editorPanel = document.getElementById('editor-panel') as HTMLElement
    const processing = document.getElementById('processing') as HTMLElement
    const processingText = document.getElementById('processing-text') as HTMLElement
    const pdfCanvas = document.getElementById('pdf-canvas') as HTMLCanvasElement
    const overlayCanvas = document.getElementById('overlay-canvas') as HTMLCanvasElement
    const canvasContainer = document.getElementById('canvas-container') as HTMLElement
    const prevPageBtn = document.getElementById('prev-page') as HTMLButtonElement
    const nextPageBtn = document.getElementById('next-page') as HTMLButtonElement
    const pageInfo = document.getElementById('page-info') as HTMLElement
    const clearPageBtn = document.getElementById('clear-page-btn') as HTMLButtonElement
    const redactionCount = document.getElementById('redaction-count') as HTMLElement
    const summaryList = document.getElementById('summary-list') as HTMLElement
    const applyBtn = document.getElementById('apply-btn') as HTMLButtonElement
    const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement

    const show = (el: HTMLElement) => (el.style.display = 'flex')
    const hide = (el: HTMLElement) => (el.style.display = 'none')

    // ─── Canvas 유틸 ──────────────────────────────────────────────────────────
    const clearCanvas = (canvas: HTMLCanvasElement) => {
      const ctx = canvas.getContext('2d')
      if (ctx) ctx.clearRect(0, 0, canvas.width, canvas.height)
    }

    // 캔버스 메모리 해제 (대용량 PDF 처리 시 중요)
    const releaseCanvas = (canvas: HTMLCanvasElement) => {
      canvas.width = 1
      canvas.height = 1
      const ctx = canvas.getContext('2d')
      if (ctx) ctx.clearRect(0, 0, 1, 1)
    }

    // ─── 오버레이에 현재 페이지 레덱션 박스 그리기 ────────────────────────────
    const drawRedactions = () => {
      const ctx = overlayCanvas.getContext('2d')!
      clearCanvas(overlayCanvas)
      const rects = pageRedactions.get(currentPage) ?? []
      redactionCount.textContent = String(rects.length)

      rects.forEach((rect, idx) => {
        // 검은 박스
        ctx.fillStyle = '#000000'
        ctx.fillRect(rect.x, rect.y, rect.w, rect.h)
        // 삭제 힌트 (X 표시)
        ctx.fillStyle = 'rgba(255,255,255,0.4)'
        ctx.font = `${Math.min(rect.w, rect.h) * 0.4}px sans-serif`
        ctx.textAlign = 'center'
        ctx.textBaseline = 'middle'
        ctx.fillText('✕', rect.x + rect.w / 2, rect.y + rect.h / 2)
      })
    }

    // ─── 요약 업데이트 ────────────────────────────────────────────────────────
    const updateSummary = () => {
      summaryList.innerHTML = ''
      let total = 0
      pageRedactions.forEach((rects, page) => {
        if (rects.length === 0) return
        total += rects.length
        const row = document.createElement('div')
        row.className = 'flex items-center justify-between text-xs'
        row.innerHTML = `
          <span class="opacity-60">Page ${page}</span>
          <span class="font-medium text-[var(--action-color)]">${rects.length} area(s)</span>
        `
        summaryList.appendChild(row)
      })
      if (total === 0) {
        summaryList.innerHTML = '<p class="text-xs opacity-40">No redactions yet. Drag on the PDF to mark areas.</p>'
      }
    }

    // ─── PDF 페이지 렌더링 ────────────────────────────────────────────────────
    const renderPage = async (pageNum: number) => {
      if (!pdfDoc) return
      const page = await pdfDoc.getPage(pageNum)
      const viewport = page.getViewport({ scale })

      // PDF canvas 설정
      pdfCanvas.width = viewport.width
      pdfCanvas.height = viewport.height
      overlayCanvas.width = viewport.width
      overlayCanvas.height = viewport.height

      // 컨테이너 비율 맞추기
      const displayW = canvasContainer.clientWidth
      const cssScale = displayW / viewport.width
      pdfCanvas.style.height = `${viewport.height * cssScale}px`
      overlayCanvas.style.height = `${viewport.height * cssScale}px`

      const ctx = pdfCanvas.getContext('2d')!
      await page.render({ canvasContext: ctx, viewport, canvas: pdfCanvas }).promise

      // 메모리 절약: 렌더링 완료 후 page 객체 cleanup
      page.cleanup()

      drawRedactions()
      updateSummary()
      pageInfo.textContent = `Page ${pageNum} / ${totalPages}`
      prevPageBtn.toggleAttribute('disabled', pageNum <= 1)
      nextPageBtn.toggleAttribute('disabled', pageNum >= totalPages)
    }

    // ─── 마우스 좌표 → Canvas 좌표 변환 ──────────────────────────────────────
    const getCanvasCoords = (e: MouseEvent) => {
      const rect = overlayCanvas.getBoundingClientRect()
      const scaleX = overlayCanvas.width / rect.width
      const scaleY = overlayCanvas.height / rect.height
      return {
        x: (e.clientX - rect.left) * scaleX,
        y: (e.clientY - rect.top) * scaleY,
      }
    }

    // ─── 드래그로 레덱션 영역 지정 ───────────────────────────────────────────
    const onMouseDown = (e: MouseEvent) => {
      isDragging = true
      const coords = getCanvasCoords(e)
      dragStart = coords
    }

    const onMouseMove = (e: MouseEvent) => {
      if (!isDragging) return
      const coords = getCanvasCoords(e)
      drawRedactions()
      const ctx = overlayCanvas.getContext('2d')!
      // 드래그 중인 박스 미리보기
      ctx.fillStyle = 'rgba(0,0,0,0.6)'
      ctx.strokeStyle = '#ff0000'
      ctx.lineWidth = 2
      const x = Math.min(dragStart.x, coords.x)
      const y = Math.min(dragStart.y, coords.y)
      const w = Math.abs(coords.x - dragStart.x)
      const h = Math.abs(coords.y - dragStart.y)
      ctx.fillRect(x, y, w, h)
      ctx.strokeRect(x, y, w, h)
    }

    const onMouseUp = (e: MouseEvent) => {
      if (!isDragging) return
      isDragging = false
      const coords = getCanvasCoords(e)
      const x = Math.min(dragStart.x, coords.x)
      const y = Math.min(dragStart.y, coords.y)
      const w = Math.abs(coords.x - dragStart.x)
      const h = Math.abs(coords.y - dragStart.y)

      // 너무 작은 드래그는 무시 (클릭으로 박스 삭제)
      if (w < 10 || h < 10) {
        handleClickRemove(e)
        return
      }

      addRedaction(currentPage, { x, y, w, h })
    }

    // ─── 레덱션 추가 ──────────────────────────────────────────────────────────
    const addRedaction = (page: number, rect: Rect) => {
      if (!pageRedactions.has(page)) pageRedactions.set(page, [])
      pageRedactions.get(page)!.push(rect)
      drawRedactions()
      updateSummary()
    }

    // ─── 클릭으로 박스 삭제 ───────────────────────────────────────────────────
    const handleClickRemove = (e: MouseEvent) => {
      const coords = getCanvasCoords(e)
      const rects = pageRedactions.get(currentPage) ?? []
      const idx = rects.findIndex(
        (r) => coords.x >= r.x && coords.x <= r.x + r.w && coords.y >= r.y && coords.y <= r.y + r.h,
      )
      if (idx !== -1) {
        rects.splice(idx, 1)
        pageRedactions.set(currentPage, rects)
        drawRedactions()
        updateSummary()
      }
    }

    // 터치 지원 (모바일)
    const onTouchStart = (e: TouchEvent) => {
      e.preventDefault()
      const touch = e.touches[0]
      isDragging = true
      const rect = overlayCanvas.getBoundingClientRect()
      const scaleX = overlayCanvas.width / rect.width
      const scaleY = overlayCanvas.height / rect.height
      dragStart = {
        x: (touch.clientX - rect.left) * scaleX,
        y: (touch.clientY - rect.top) * scaleY,
      }
    }

    const onTouchMove = (e: TouchEvent) => {
      e.preventDefault()
      if (!isDragging) return
      const touch = e.touches[0]
      const rect = overlayCanvas.getBoundingClientRect()
      const scaleX = overlayCanvas.width / rect.width
      const scaleY = overlayCanvas.height / rect.height
      const coords = {
        x: (touch.clientX - rect.left) * scaleX,
        y: (touch.clientY - rect.top) * scaleY,
      }
      drawRedactions()
      const ctx = overlayCanvas.getContext('2d')!
      ctx.fillStyle = 'rgba(0,0,0,0.6)'
      const x = Math.min(dragStart.x, coords.x)
      const y = Math.min(dragStart.y, coords.y)
      const w = Math.abs(coords.x - dragStart.x)
      const h = Math.abs(coords.y - dragStart.y)
      ctx.fillRect(x, y, w, h)
    }

    const onTouchEnd = (e: TouchEvent) => {
      e.preventDefault()
      if (!isDragging) return
      isDragging = false
      const touch = e.changedTouches[0]
      const rect = overlayCanvas.getBoundingClientRect()
      const scaleX = overlayCanvas.width / rect.width
      const scaleY = overlayCanvas.height / rect.height
      const coords = {
        x: (touch.clientX - rect.left) * scaleX,
        y: (touch.clientY - rect.top) * scaleY,
      }
      const x = Math.min(dragStart.x, coords.x)
      const y = Math.min(dragStart.y, coords.y)
      const w = Math.abs(coords.x - dragStart.x)
      const h = Math.abs(coords.y - dragStart.y)
      if (w > 10 && h > 10) addRedaction(currentPage, { x, y, w, h })
    }

    // ─── Secure Redaction 핵심 함수 ──────────────────────────────────────────
    // x, y, width, height 좌표를 받아 해당 영역을 Canvas에서 검은색으로 burn-in
    const applyRedactionToCanvas = (ctx: CanvasRenderingContext2D, rects: Rect[]) => {
      ctx.fillStyle = '#000000'
      rects.forEach(({ x, y, w, h }) => {
        ctx.fillRect(x, y, w, h)
      })
    }

    // ─── PDF 생성 (Secure Redaction) ──────────────────────────────────────────
    const applyAndSave = async () => {
      if (!pdfDoc) return

      const totalRedactions = Array.from(pageRedactions.values()).reduce((sum, r) => sum + r.length, 0)
      if (totalRedactions === 0) {
        alert('Please add at least one redaction area before saving.')
        return
      }

      show(processing)
      hide(editorPanel)

      try {
        // pdf-lib 동적 로드 (아직 로드 안 됐을 경우)
        await loadPdfLib()
        const { PDFDocument } = (window as any).PDFLib

        const newPdfDoc = await PDFDocument.create()

        for (let pageNum = 1; pageNum <= totalPages; pageNum++) {
          processingText.textContent = `Processing page ${pageNum} of ${totalPages}...`

          const page = await pdfDoc.getPage(pageNum)
          const viewport = page.getViewport({ scale })

          // 각 페이지를 고해상도 Canvas로 렌더링
          const canvas = document.createElement('canvas')
          canvas.width = viewport.width
          canvas.height = viewport.height
          const ctx = canvas.getContext('2d')!

          await page.render({ canvasContext: ctx, viewport, canvas }).promise

          // 해당 페이지의 레덱션 박스를 Canvas에 burn-in
          const rects = pageRedactions.get(pageNum) ?? []
          if (rects.length > 0) {
            applyRedactionToCanvas(ctx, rects)
          }

          // Canvas → PNG 이미지 데이터
          const imageDataUrl = canvas.toDataURL('image/png')
          const imageBytes = await fetch(imageDataUrl).then((r) => r.arrayBuffer())

          // pdf-lib에 이미지 추가
          const pngImage = await newPdfDoc.embedPng(imageBytes)
          const { width, height } = pngImage.scale(1 / scale)

          const newPage = newPdfDoc.addPage([width, height])
          newPage.drawImage(pngImage, {
            x: 0,
            y: 0,
            width,
            height,
          })

          // 메모리 절약: 사용 완료된 Canvas 즉시 해제
          // 대용량 PDF에서 Canvas를 계속 쌓으면 메모리 부족 발생
          releaseCanvas(canvas)
          page.cleanup()
        }

        processingText.textContent = 'Saving PDF...'
        const pdfBytes = await newPdfDoc.save()
        const blob = new Blob([pdfBytes], { type: 'application/pdf' })
        const url = URL.createObjectURL(blob)
        const link = document.createElement('a')
        link.href = url
        const originalName = originalFile?.name.replace(/\.pdf$/i, '') ?? 'document'
        link.download = `${originalName}-redacted.pdf`
        link.click()
        URL.revokeObjectURL(url)

        hide(processing)
        show(editorPanel)

        alert(`✅ Done! ${totalRedactions} redaction(s) applied across ${totalPages} page(s).`)
      } catch (err) {
        console.error('Redaction failed:', err)
        hide(processing)
        show(editorPanel)
        alert('Something went wrong. Please try again.')
      }
    }

    // ─── 파일 로드 ────────────────────────────────────────────────────────────
    const handleFile = async (file: File) => {
      if (!file.type.includes('pdf') && !file.name.endsWith('.pdf')) return

      originalFile = file
      pageRedactions = new Map()
      currentPage = 1

      hide(dropZone)
      show(loadingPdf)

      try {
        // pdf-lib 미리 로드 시작 (백그라운드)
        loadPdfLib().catch(() => {})

        const arrayBuffer = await file.arrayBuffer()
        pdfDoc = await pdfjs.getDocument({ data: arrayBuffer }).promise
        totalPages = pdfDoc.numPages

        hide(loadingPdf)
        show(editorPanel)
        await renderPage(1)
        updateSummary()
      } catch (err) {
        console.error('PDF load failed:', err)
        hide(loadingPdf)
        show(dropZone)
        alert('Failed to load PDF. Please try another file.')
      }
    }

    // ─── 이벤트 바인딩 ────────────────────────────────────────────────────────
    overlayCanvas.addEventListener('mousedown', onMouseDown)
    overlayCanvas.addEventListener('mousemove', onMouseMove)
    overlayCanvas.addEventListener('mouseup', onMouseUp)
    overlayCanvas.addEventListener('mouseleave', () => {
      if (isDragging) {
        isDragging = false
        drawRedactions()
      }
    })

    overlayCanvas.addEventListener('touchstart', onTouchStart, { passive: false })
    overlayCanvas.addEventListener('touchmove', onTouchMove, { passive: false })
    overlayCanvas.addEventListener('touchend', onTouchEnd, { passive: false })

    prevPageBtn.addEventListener('click', async () => {
      if (currentPage > 1) {
        currentPage--
        await renderPage(currentPage)
      }
    })

    nextPageBtn.addEventListener('click', async () => {
      if (currentPage < totalPages) {
        currentPage++
        await renderPage(currentPage)
      }
    })

    clearPageBtn.addEventListener('click', () => {
      pageRedactions.set(currentPage, [])
      drawRedactions()
      updateSummary()
    })

    applyBtn.addEventListener('click', applyAndSave)

    resetBtn.addEventListener('click', () => {
      if (pdfDoc) {
        pdfDoc.destroy()
        pdfDoc = null
      }
      pageRedactions = new Map()
      currentPage = 1
      totalPages = 0
      originalFile = null
      releaseCanvas(pdfCanvas)
      releaseCanvas(overlayCanvas)
      hide(editorPanel)
      hide(processing)
      show(dropZone)
    })

    dropZone.addEventListener('click', () => fileInput.click())
    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault()
      dropZone.classList.add('border-[var(--action-color)]')
    })
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-[var(--action-color)]'))
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault()
      dropZone.classList.remove('border-[var(--action-color)]')
      if (e.dataTransfer?.files[0]) handleFile(e.dataTransfer.files[0])
    })
    fileInput.addEventListener('change', () => {
      if (fileInput.files?.[0]) handleFile(fileInput.files[0])
    })

    return () => {
      if (pdfDoc) {
        pdfDoc.destroy()
        pdfDoc = null
      }
      releaseCanvas(pdfCanvas)
      releaseCanvas(overlayCanvas)
    }
  }
</script>
