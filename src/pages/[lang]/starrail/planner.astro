---
// src/pages/[lang]/starrail/planner.astro
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Icon } from 'astro-icon/components'

const allData = import.meta.glob('/src/data/starrail/**/*.json', { eager: true })

export async function getStaticPaths() {
  const languages = ['kr', 'en', 'jp', 'cn', 'fr', 'de', 'es', 'id', 'pt', 'ru', 'th', 'vi', 'cht']
  return languages.map((lang) => ({ params: { lang } }))
}

const { lang } = Astro.params
const baseDir = `/src/data/starrail/${lang}`

const cleanText = (text: string) => {
  if (!text) return ''
  return text.replace(/\{RUBY_B#([^}]+)\}([^\{]+)\{RUBY_E\#\}/g,'$1').replace(/\{[^}]*\}/g,'').replace(/<[^>]*>/g,'').trim()
}
const toItemIcon = (icon: string) => {
  if (!icon) return ''
  let p = icon.replace(/^\//, '').replace(/^starrail\/assets\//, '')
  if (p.includes('icon/character/')) p = p.replace('icon/character/', 'icon/item/')
  return `/starrail/assets/${p}`
}
const toSkillIcon = (icon: string) => {
  if (!icon) return ''
  let p = icon.replace(/^\//, '').replace(/^starrail\/assets\//, '')
  const fn = p.split('/').pop() || ''
  if (/^\d{4}/.test(fn) && fn.includes('_')) return `/starrail/assets/icon/skill/${fn}`
  return `/starrail/assets/${p}`
}

// ── 데이터 로드 ──
const charsRaw:   Record<string, any> = (allData[`${baseDir}/characters.json`]            as any)?.default ?? {}
const promoRaw:   Record<string, any> = (allData[`${baseDir}/character_promotions.json`]  as any)?.default ?? {}
const treeRaw:    Record<string, any> = (allData[`${baseDir}/character_skill_trees.json`] as any)?.default ?? {}
const skillsRaw:  Record<string, any> = (allData[`${baseDir}/character_skills.json`]      as any)?.default ?? {}
const pathsRaw:   Record<string, any> = (allData[`${baseDir}/paths.json`]                 as any)?.default ?? {}
const itemsRaw:   Record<string, any> = (allData[`${baseDir}/items.json`]                 as any)?.default ?? {}
const lcRaw:      Record<string, any> = (allData[`${baseDir}/light_cones.json`]           as any)?.default ?? {}
const lcPromoRaw: Record<string, any> = (allData[`${baseDir}/light_cone_promotions.json`] as any)?.default ?? {}

// ── 캐릭터 목록 ──
const characters = Object.entries(charsRaw)
  .filter(([id, d]: [string, any]) => {
    if (id.startsWith('800')) return true
    return d.name && d.name.trim() !== '' && !d.name.includes('{NICKNAME}')
  })
  .map(([id, d]: [string, any]) => {
    let name = cleanText(d.name ?? '')
    if (id.startsWith('800')) {
      const pathName = pathsRaw[d.path]?.text || pathsRaw[d.path]?.name || d.path
      name = `${lang === 'kr' ? '개척자' : 'Trailblazer'} · ${pathName}`
    }
    return { id, name, rarity: Number(d.rarity) || 5, element: d.element ?? '', skillTrees: d.skill_trees ?? [] }
  })
  .sort((a, b) => b.rarity - a.rarity || a.name.localeCompare(b.name))

// ── 캐릭터 플래너 데이터 ──
const plannerData: Record<string, any> = {}
for (const char of characters) {
  const promo   = promoRaw[char.id]
  const majorRe = new RegExp(`^${char.id}81\\d{2}$`)
  const minorRe = new RegExp(`^${char.id}82\\d{2}$`)
  const ascMats = (promo?.materials ?? []).map((step: any[]) => (step ?? []).map((m: any) => ({ id: m.id, num: m.num })))
  const skills: { name: string; icon: string; maxLv: number; mats: any[][] }[] = []
  const seen = new Set<string>()
  for (const tid of char.skillTrees) {
    const node = treeRaw[tid]
    if (!node || majorRe.test(tid) || minorRe.test(tid)) continue
    if (!node.level_up_skills?.length) continue
    const sid = node.level_up_skills[0].id
    if (seen.has(sid)) continue
    seen.add(sid)
    const sk = skillsRaw[sid]
    const mats = (node.levels ?? []).filter((lv: any) => lv.materials?.length).map((lv: any) => lv.materials.map((m: any) => ({ id: m.id, num: m.num })))
    skills.push({ name: cleanText(sk?.name ?? ''), icon: toSkillIcon(node.icon ?? ''), maxLv: mats.length + 1, mats })
  }
  const traceMats: any[][] = []
  for (const tid of char.skillTrees) {
    const node = treeRaw[tid]
    if (!node || (!majorRe.test(tid) && !minorRe.test(tid))) continue
    for (const lv of node.levels ?? []) {
      if (lv.materials?.length) traceMats.push(lv.materials.map((m: any) => ({ id: m.id, num: m.num })))
    }
  }
  plannerData[char.id] = { ascMats, skills, traceMats }
}

// ── 광추 목록 ──
const lightCones = Object.entries(lcRaw)
  .filter(([, d]: [string, any]) => d.name && d.name.trim() !== '')
  .map(([id, d]: [string, any]) => ({
    id, name: cleanText(d.name ?? ''), rarity: Number(d.rarity) || 3,
    path: d.path ?? '', icon: d.icon ?? `/starrail/assets/icon/light_cone/${id}.webp`,
  }))
  .sort((a, b) => b.rarity - a.rarity || a.name.localeCompare(b.name))

// ── 광추 플래너 데이터 ──
const lcPlannerData: Record<string, any> = {}
for (const lc of lightCones) {
  const promo = lcPromoRaw[lc.id]
  const ascMats = (promo?.materials ?? []).map((step: any[]) => (step ?? []).map((m: any) => ({ id: m.id, num: m.num })))
  lcPlannerData[lc.id] = { ascMats }
}

// ── 아이템 맵 ──
const itemsMap: Record<string, any> = {}
for (const [id, item] of Object.entries(itemsRaw) as any[]) {
  itemsMap[id] = { name: cleanText(item.name ?? ''), icon: toItemIcon(item.icon ?? ''), rarity: item.rarity ?? 1, come_from: item.come_from ?? [] }
}
itemsMap['2'] = { name: lang === 'kr' ? '크레딧' : 'Credits', icon: '/starrail/assets/icon/item/2.webp', rarity: 1, come_from: [] }

const L = lang === 'kr'
  ? { title:'돌파 계획', subtitle:'캐릭터 돌파 · 스킬 · 광추 재료 계획',
      tabChar:'캐릭터', tabLC:'광추',
      searchChar:'캐릭터 검색…', searchLC:'광추 검색…',
      selected:'선택됨', noSelected:'왼쪽에서 선택하세요',
      result:'필요 재료', noResult:'항목을 선택하고 목표를 설정하면 재료가 계산됩니다.',
      asc:'돌파', skills:'스킬', traces:'행적 포함', from:'획득처', clear:'전체 초기화' }
  : { title:'Planner', subtitle:'Character ascension · skills · light cone material planner',
      tabChar:'Characters', tabLC:'Light Cones',
      searchChar:'Search character…', searchLC:'Search light cone…',
      selected:'Selected', noSelected:'Select from the left',
      result:'Required Materials', noResult:'Select items and set goals to calculate.',
      asc:'Ascension', skills:'Skills', traces:'Include Traces', from:'Source', clear:'Clear All' }

const charList = characters.map(c => ({ id: c.id, name: c.name, rarity: c.rarity, element: c.element, icon: `/starrail/assets/icon/character/${c.id}.webp`, elIcon: c.element ? `/starrail/assets/icon/element/${c.element}.webp` : '' }))
const lcList = lightCones.map(lc => ({ id: lc.id, name: lc.name, rarity: lc.rarity, path: lc.path, icon: lc.icon }))
---

<DefaultLayout title={`${L.title} | Star Rail DB`} description="Honkai: Star Rail ascension and skill material planner.">
<div class="pl-page">

  <!-- 헤더 -->
  <div class="pl-header">
    <div class="pw">
      <nav class="bc">
        <a href={`/${lang}`}>Home</a><span>/</span>
        <a href={`/${lang}/starrail`}>Star Rail</a><span>/</span>
        <span class="bc-cur">{L.title}</span>
      </nav>
      <div class="hd-row">
        <div><h1 class="pl-title">{L.title}</h1><p class="pl-sub">{L.subtitle}</p></div>
        <button class="clear-btn" id="clearAll" type="button">
          <Icon name="lucide:trash-2" size="0.8rem"/>{L.clear}
        </button>
      </div>

      <!-- 메인 탭 -->
      <div class="main-tabs">
        <button class="mtab mtab--on" data-mode="char" type="button">
          <Icon name="lucide:users" size="0.8rem"/>{L.tabChar}
        </button>
        <button class="mtab" data-mode="lc" type="button">
          <Icon name="lucide:zap" size="0.8rem"/>{L.tabLC}
        </button>
      </div>
    </div>
  </div>

  <div class="pl-body pw">

    <!-- 왼쪽 -->
    <div class="pl-left">
      <!-- 캐릭터 검색 -->
      <div class="sw" id="charSearchWrap">
        <Icon name="lucide:search" size="0.85rem" class="si"/>
        <input type="search" id="charSearch" placeholder={L.searchChar} autocomplete="off" class="sinput"/>
      </div>
      <!-- 광추 검색 -->
      <div class="sw hidden" id="lcSearchWrap">
        <Icon name="lucide:search" size="0.85rem" class="si"/>
        <input type="search" id="lcSearch" placeholder={L.searchLC} autocomplete="off" class="sinput"/>
      </div>

      <!-- 캐릭터 그리드 -->
      <div class="cgrid" id="charGrid">
        {characters.map(c => (
          <button class="cbtn" data-cid={c.id} data-cname={c.name.toLowerCase()} title={c.name} type="button">
            <div class={`cimg-wrap r${c.rarity}`}>
              <img src={`/starrail/assets/icon/character/${c.id}.webp`} alt={c.name} width="56" height="56" loading="lazy" class="cimg"/>
              {c.element && <img src={`/starrail/assets/icon/element/${c.element}.webp`} alt="" width="14" height="14" loading="lazy" class="cel"/>}
            </div>
            <p class="cname">{c.name}</p>
          </button>
        ))}
      </div>

      <!-- 광추 그리드 -->
      <div class="cgrid hidden" id="lcGrid">
        {lightCones.map(lc => (
          <button class="cbtn lc-btn" data-lcid={lc.id} data-lcname={lc.name.toLowerCase()} title={lc.name} type="button">
            <div class={`cimg-wrap r${lc.rarity}`}>
              <img src={lc.icon} alt={lc.name} width="56" height="56" loading="lazy" class="cimg lc-img"/>
            </div>
            <p class="cname">{lc.name}</p>
          </button>
        ))}
      </div>
    </div>

    <!-- 오른쪽 -->
    <div class="pl-right">
      <div class="section">
        <p class="slabel">{L.selected}</p>
        <div id="selList"><p class="empty" id="noSelMsg">{L.noSelected}</p></div>
      </div>
      <div class="section">
        <p class="slabel">{L.result}</p>
        <div id="resultArea"><p class="empty">{L.noResult}</p></div>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ charList, lcList, plannerData, lcPlannerData, itemsMap, L, lang }}>
;(function(){
  var mode = 'char' // 'char' | 'lc'
  var selChar = {}, selLC = {}
  try { var sc=localStorage.getItem('hsr-pl-char-'+lang); if(sc) selChar=JSON.parse(sc) } catch(e){}
  try { var sl=localStorage.getItem('hsr-pl-lc-'+lang); if(sl) selLC=JSON.parse(sl) } catch(e){}

  function saveChar(){ try{localStorage.setItem('hsr-pl-char-'+lang,JSON.stringify(selChar))}catch(e){} }
  function saveLC(){   try{localStorage.setItem('hsr-pl-lc-'+lang,  JSON.stringify(selLC))}catch(e){} }

  var inventory = {}
  try { var iv=localStorage.getItem('hsr-inventory'); if(iv) inventory=JSON.parse(iv) } catch(e){}
  function saveInventory(){ try{localStorage.setItem('hsr-inventory',JSON.stringify(inventory))}catch(e){} }

  // ── 재료 계산 ──
  function calcChar(){
    var tot={}
    function add(id,num){ var info=itemsMap[id]; if(!info) return; if(!tot[id]) tot[id]={name:info.name,icon:info.icon,rarity:info.rarity,come_from:info.come_from,num:0}; tot[id].num+=num }
    Object.keys(selChar).forEach(function(cid){
      var s=selChar[cid]; var pd=plannerData[cid]; if(!pd) return
      if(s.asc){ var c=s.asc.cur||0,t=s.asc.tgt||0; for(var i=c;i<t&&i<pd.ascMats.length;i++) pd.ascMats[i].forEach(function(m){add(m.id,m.num)}) }
      if(s.skills) s.skills.forEach(function(sk,idx){ var skill=pd.skills[idx]; if(!skill) return; var c=(sk.cur||1)-1,t=(sk.tgt||1)-1; for(var i=c;i<t&&i<skill.mats.length;i++) skill.mats[i].forEach(function(m){add(m.id,m.num)}) })
      if(s.trace&&pd.traceMats) pd.traceMats.forEach(function(step){step.forEach(function(m){add(m.id,m.num)})})
    })
    return tot
  }

  function calcLC(){
    var tot={}
    function add(id,num){ var info=itemsMap[id]; if(!info) return; if(!tot[id]) tot[id]={name:info.name,icon:info.icon,rarity:info.rarity,come_from:info.come_from,num:0}; tot[id].num+=num }
    Object.keys(selLC).forEach(function(lid){
      var s=selLC[lid]; var pd=lcPlannerData[lid]; if(!pd) return
      if(s.asc){ var c=s.asc.cur||0,t=s.asc.tgt||0; for(var i=c;i<t&&i<pd.ascMats.length;i++) pd.ascMats[i].forEach(function(m){add(m.id,m.num)}) }
    })
    return tot
  }

  // ── 버튼 상태 ──
  function updCharBtns(){ document.querySelectorAll('.cbtn:not(.lc-btn)').forEach(function(b){ b.classList.toggle('cbtn--on',!!selChar[b.dataset.cid]) }) }
  function updLCBtns(){   document.querySelectorAll('.lc-btn').forEach(function(b){            b.classList.toggle('cbtn--on',!!selLC[b.dataset.lcid])  }) }

  // ── select 헬퍼 ──
  function mkSel(mn,mx,val,cb){
    var el=document.createElement('select'); el.className='nsel'
    for(var i=mn;i<=mx;i++){var o=document.createElement('option');o.value=i;o.textContent=i;if(i===val)o.selected=true;el.appendChild(o)}
    el.addEventListener('change',function(){cb(parseInt(el.value))}); return el
  }

  // ── 재료 결과 렌더 ──
  function renderResult(){
  var area=document.getElementById('resultArea'); if(!area) return
  var tot=mode==='char' ? calcChar() : calcLC()
  var keys=Object.keys(tot)
  if(!keys.length){ area.innerHTML='<p class="empty">'+L.noResult+'</p>'; return }
  keys.sort(function(a,b){ if(a==='2')return -1;if(b==='2')return 1;return (tot[b].rarity-tot[a].rarity)||a.localeCompare(b) })
  var grid=document.createElement('div'); grid.className='mat-grid'
  keys.forEach(function(id){
    var m=tot[id]
    var have=inventory[id]||0
    var need=Math.max(0,m.num-have)
    var done=need===0

    var card=document.createElement('div'); card.className='mat-card r'+Math.min(m.rarity,5)+(done?' mat-card--done':'')
    var top=document.createElement('div'); top.className='mat-top'
    var iw=document.createElement('div'); iw.className='mat-iw'
    if(m.icon){var img=document.createElement('img');img.src=m.icon;img.alt=m.name;img.width=44;img.height=44;img.loading='lazy';img.className='mat-img';iw.appendChild(img)}
    top.appendChild(iw)
    var info=document.createElement('div'); info.className='mat-info'
    var mn=document.createElement('p'); mn.className='mat-name'; mn.textContent=m.name; info.appendChild(mn)

    // 필요량
    var mnum=document.createElement('p'); mnum.className='mat-num'+(done?' mat-num--done':'')
    mnum.textContent='필요: × '+m.num.toLocaleString(); info.appendChild(mnum)

    // 보유/부족 행
    var invRow=document.createElement('div'); invRow.className='inv-row'
    var invLbl=document.createElement('span'); invLbl.className='inv-lbl'; invLbl.textContent='보유'
    var invInput=document.createElement('input'); invInput.type='number'; invInput.min='0'; invInput.className='inv-input'
    invInput.value=have; invInput.dataset.id=id
    invInput.addEventListener('input',function(){
      var v=parseInt(invInput.value)||0
      inventory[id]=v; saveInventory()
      // 해당 카드의 부족 수량만 업데이트
      var need=Math.max(0,m.num-v)
      var done=need===0
      var needEl=card.querySelector('.need-lbl')
      if(needEl){
        needEl.textContent=done ? '✓ 완료' : '부족: × '+need.toLocaleString()
        needEl.className='need-lbl'+(done?' need-lbl--done':'')
      }
      card.classList.toggle('mat-card--done', done)
      var mnumEl=card.querySelector('.mat-num')
      if(mnumEl) mnumEl.className='mat-num'+(done?' mat-num--done':'')
    })
    var needLbl=document.createElement('span'); needLbl.className='need-lbl'+(done?' need-lbl--done':'')
    needLbl.textContent=done ? '✓ 완료' : '부족: × '+need.toLocaleString()
    invRow.appendChild(invLbl); invRow.appendChild(invInput); invRow.appendChild(needLbl)
    info.appendChild(invRow)

    top.appendChild(info); card.appendChild(top)
    if(m.come_from&&m.come_from.length){
      var fr=document.createElement('div'); fr.className='mat-from'
      var lbl=document.createElement('span'); lbl.className='from-lbl'; lbl.textContent=L.from; fr.appendChild(lbl)
      m.come_from.forEach(function(f){var s=document.createElement('span');s.className='from-tag';s.textContent=f;fr.appendChild(s)})
      card.appendChild(fr)
    }
    grid.appendChild(card)
  })
  area.innerHTML=''; area.appendChild(grid)
}

  // ── 캐릭터 선택 목록 렌더 ──
  function renderCharSel(){
    var list=document.getElementById('selList'); var noMsg=document.getElementById('noSelMsg'); if(!list) return
    list.querySelectorAll('.scard').forEach(function(e){e.remove()})
    var ids=Object.keys(selChar)
    if(!ids.length){ if(noMsg) noMsg.style.display=''; renderResult(); return }
    if(noMsg) noMsg.style.display='none'
    ids.forEach(function(cid){
      var ch=charList.find(function(c){return c.id===cid}); var s=selChar[cid]; var pd=plannerData[cid]; if(!ch||!pd) return
      var card=document.createElement('div'); card.className='scard'
      // 헤더
      var hd=document.createElement('div'); hd.className='scard-hd'
      var img=document.createElement('img'); img.src=ch.icon; img.alt=ch.name; img.width=36; img.height=36; img.className='sc-img'; hd.appendChild(img)
      var nm=document.createElement('p'); nm.className='sc-name'; nm.textContent=ch.name; hd.appendChild(nm)
      var rb=document.createElement('button'); rb.className='rm-btn'; rb.type='button'; rb.innerHTML='&times;'
      rb.addEventListener('click',function(){delete selChar[cid];saveChar();updCharBtns();renderCharSel()})
      hd.appendChild(rb); card.appendChild(hd)
      // 바디
      var body=document.createElement('div'); body.className='scard-body'
      // 돌파
      var arow=document.createElement('div'); arow.className='srow'
      var albl=document.createElement('span'); albl.className='srow-lbl'; albl.textContent=L.asc; arow.appendChild(albl)
      var actl=document.createElement('div'); actl.className='srow-ctl'
      var acs=mkSel(0,6,s.asc?.cur||0,function(v){if(!selChar[cid].asc)selChar[cid].asc={cur:0,tgt:6};selChar[cid].asc.cur=v;if(selChar[cid].asc.tgt<v)selChar[cid].asc.tgt=v;saveChar();renderResult()})
      acs.className+=' cur-sel'
      var arr=document.createElement('span'); arr.className='arr'; arr.textContent='→'
      var ats=mkSel(0,6,s.asc?.tgt??6,function(v){if(!selChar[cid].asc)selChar[cid].asc={cur:0,tgt:6};selChar[cid].asc.tgt=v;if(selChar[cid].asc.cur>v)selChar[cid].asc.cur=v;saveChar();renderResult()})
      actl.appendChild(acs); actl.appendChild(arr); actl.appendChild(ats); arow.appendChild(actl); body.appendChild(arow)
      // 스킬
      pd.skills.forEach(function(skill,idx){
        if(!selChar[cid].skills) selChar[cid].skills=[]
        if(!selChar[cid].skills[idx]) selChar[cid].skills[idx]={cur:1,tgt:skill.maxLv}
        var srow=document.createElement('div'); srow.className='srow'
        var slbl=document.createElement('div'); slbl.className='srow-lbl skill-lbl'
        if(skill.icon){var si=document.createElement('img');si.src=skill.icon;si.alt=skill.name;si.width=18;si.height=18;si.className='sk-icon';slbl.appendChild(si)}
        var sn=document.createElement('span'); sn.className='sk-name'; sn.textContent=skill.name; slbl.appendChild(sn)
        srow.appendChild(slbl)
        var sctl=document.createElement('div'); sctl.className='srow-ctl'
        var scs=mkSel(1,skill.maxLv,selChar[cid].skills[idx].cur,function(v){selChar[cid].skills[idx].cur=v;if(selChar[cid].skills[idx].tgt<v)selChar[cid].skills[idx].tgt=v;saveChar();renderResult()})
        scs.className+=' cur-sel'
        var sarr=document.createElement('span'); sarr.className='arr'; sarr.textContent='→'
        var sts=mkSel(1,skill.maxLv,selChar[cid].skills[idx].tgt,function(v){selChar[cid].skills[idx].tgt=v;if(selChar[cid].skills[idx].cur>v)selChar[cid].skills[idx].cur=v;saveChar();renderResult()})
        sctl.appendChild(scs); sctl.appendChild(sarr); sctl.appendChild(sts); srow.appendChild(sctl); body.appendChild(srow)
      })
      // 행적
      if(pd.traceMats.length){
        var trow=document.createElement('div'); trow.className='srow'
        var tlbl=document.createElement('span'); tlbl.className='srow-lbl'; tlbl.textContent=L.traces; trow.appendChild(tlbl)
        var chk=document.createElement('input'); chk.type='checkbox'; chk.className='trace-chk'; chk.checked=!!s.trace
        chk.addEventListener('change',function(){selChar[cid].trace=chk.checked;saveChar();renderResult()})
        trow.appendChild(chk); body.appendChild(trow)
      }
      card.appendChild(body); list.appendChild(card)
    })
    renderResult()
  }

  // ── 광추 선택 목록 렌더 ──
  function renderLCSel(){
    var list=document.getElementById('selList'); var noMsg=document.getElementById('noSelMsg'); if(!list) return
    list.querySelectorAll('.scard').forEach(function(e){e.remove()})
    var ids=Object.keys(selLC)
    if(!ids.length){ if(noMsg) noMsg.style.display=''; renderResult(); return }
    if(noMsg) noMsg.style.display='none'
    ids.forEach(function(lid){
      var lc=lcList.find(function(l){return l.id===lid}); var s=selLC[lid]; var pd=lcPlannerData[lid]; if(!lc||!pd) return
      var card=document.createElement('div'); card.className='scard'
      // 헤더
      var hd=document.createElement('div'); hd.className='scard-hd'
      var img=document.createElement('img'); img.src=lc.icon; img.alt=lc.name; img.width=36; img.height=36; img.className='sc-img lc-img'; hd.appendChild(img)
      var nm=document.createElement('p'); nm.className='sc-name'; nm.textContent=lc.name; hd.appendChild(nm)
      var rb=document.createElement('button'); rb.className='rm-btn'; rb.type='button'; rb.innerHTML='&times;'
      rb.addEventListener('click',function(){delete selLC[lid];saveLC();updLCBtns();renderLCSel()})
      hd.appendChild(rb); card.appendChild(hd)
      // 바디: 돌파만
      var body=document.createElement('div'); body.className='scard-body'
      var arow=document.createElement('div'); arow.className='srow'
      var albl=document.createElement('span'); albl.className='srow-lbl'; albl.textContent=L.asc; arow.appendChild(albl)
      var actl=document.createElement('div'); actl.className='srow-ctl'
      var acs=mkSel(0,6,s.asc?.cur||0,function(v){if(!selLC[lid].asc)selLC[lid].asc={cur:0,tgt:6};selLC[lid].asc.cur=v;if(selLC[lid].asc.tgt<v)selLC[lid].asc.tgt=v;saveLC();renderResult()})
      acs.className+=' cur-sel'
      var arr=document.createElement('span'); arr.className='arr'; arr.textContent='→'
      var ats=mkSel(0,6,s.asc?.tgt??6,function(v){if(!selLC[lid].asc)selLC[lid].asc={cur:0,tgt:6};selLC[lid].asc.tgt=v;if(selLC[lid].asc.cur>v)selLC[lid].asc.cur=v;saveLC();renderResult()})
      actl.appendChild(acs); actl.appendChild(arr); actl.appendChild(ats); arow.appendChild(actl); body.appendChild(arow)
      card.appendChild(body); list.appendChild(card)
    })
    renderResult()
  }

  function renderSel(){ if(mode==='char') renderCharSel(); else renderLCSel() }

  // ── 모드 전환 ──
  function switchMode(m){
    mode=m
    var mtabs=document.querySelectorAll('.mtab')
    mtabs.forEach(function(t){ t.classList.toggle('mtab--on', t.dataset.mode===m) })
    // 그리드/검색 전환
    var cg=document.getElementById('charGrid'), lg=document.getElementById('lcGrid')
    var csw=document.getElementById('charSearchWrap'), lsw=document.getElementById('lcSearchWrap')
    if(m==='char'){ cg&&cg.classList.remove('hidden'); lg&&lg.classList.add('hidden'); csw&&csw.classList.remove('hidden'); lsw&&lsw.classList.add('hidden') }
    else {          cg&&cg.classList.add('hidden'); lg&&lg.classList.remove('hidden'); csw&&csw.classList.add('hidden'); lsw&&lsw.classList.remove('hidden') }
    renderSel()
  }

  // ── 이벤트 ──
  function init(){
    // 메인 탭
    document.querySelectorAll('.mtab').forEach(function(btn){
      btn.addEventListener('click',function(){ switchMode(btn.dataset.mode) },{passive:true})
    })

    // 캐릭터 버튼
    document.querySelectorAll('.cbtn:not(.lc-btn)').forEach(function(btn){
      btn.addEventListener('click',function(){
        var cid=btn.dataset.cid; var pd=plannerData[cid]; if(!pd) return
        if(selChar[cid]){ delete selChar[cid] } else { selChar[cid]={ asc:{cur:0,tgt:6}, skills:pd.skills.map(function(sk){return{cur:1,tgt:sk.maxLv}}), trace:true } }
        saveChar(); updCharBtns(); renderCharSel()
      },{passive:true})
    })

    // 광추 버튼
    document.querySelectorAll('.lc-btn').forEach(function(btn){
      btn.addEventListener('click',function(){
        var lid=btn.dataset.lcid; var pd=lcPlannerData[lid]; if(!pd) return
        if(selLC[lid]){ delete selLC[lid] } else { selLC[lid]={ asc:{cur:0,tgt:6} } }
        saveLC(); updLCBtns(); renderLCSel()
      },{passive:true})
    })

    // 캐릭터 검색
    var csi=document.getElementById('charSearch')
    if(csi) csi.addEventListener('input',function(){
      var q=csi.value.trim().toLowerCase()
      document.querySelectorAll('.cbtn:not(.lc-btn)').forEach(function(b){ b.classList.toggle('hidden',q!==''&&b.dataset.cname.indexOf(q)===-1) })
    },{passive:true})

    // 광추 검색
    var lsi=document.getElementById('lcSearch')
    if(lsi) lsi.addEventListener('input',function(){
      var q=lsi.value.trim().toLowerCase()
      document.querySelectorAll('.lc-btn').forEach(function(b){ b.classList.toggle('hidden',q!==''&&b.dataset.lcname.indexOf(q)===-1) })
    },{passive:true})

    // 전체 초기화
    var cb=document.getElementById('clearAll')
    if(cb) cb.addEventListener('click',function(){
      if(mode==='char'){ selChar={}; saveChar(); updCharBtns(); renderCharSel() }
      else {             selLC={}; saveLC(); updLCBtns(); renderLCSel() }
    },{passive:true})

    // 초기 렌더
    updCharBtns(); updLCBtns(); renderSel()
  }
  document.addEventListener('DOMContentLoaded', init)
  document.addEventListener('astro:page-load', init)
  
})()

</script>
</DefaultLayout>

