---
// src/components/Footer.astro
import { Icon } from 'astro-icon/components'

const currentYear = new Date().getFullYear()

const pathname = Astro.url.pathname
const langMatch = pathname.match(/^\/(kr|en|jp|cn|fr|de|es|id|pt|ru|th|vi|cht)\//)
const lang = langMatch?.[1] ?? 'kr'

const isKr = lang === 'kr'

const links = {
  starrail: [
    { label: isKr ? 'мЇРл¶≠нД∞'    : 'Characters',    href: `/${lang}/starrail/characters` },
    { label: isKr ? 'кіСмґФ'      : 'Light Cones',   href: `/${lang}/starrail/light-cones` },
    { label: isKr ? 'мЬ†лђЉ'      : 'Relics',        href: `/${lang}/starrail/relics` },
    { label: isKr ? 'мЧЕм†Б'      : 'Achievements',  href: `/${lang}/starrail/achievements` },
    { label: isKr ? 'л™®мЭШ мЪ∞м£Љ' : 'Sim. Universe', href: `/${lang}/starrail/simulated-universe` },
    { label: isKr ? 'к≥ДнЪНкЄ∞'    : 'Planner',       href: `/${lang}/starrail/planner` },
    { label: isKr ? 'мЮђл£М'      : 'Materials',     href: `/${lang}/starrail/items` },
  ],
  site: [
    { label: 'About',          href: '/about' },
    { label: 'Contact',        href: '/contact' },
    { label: 'Privacy Policy', href: '/privacy-policy' },
    { label: 'Terms',          href: '/terms' },
  ],
}
---

<footer class="site-footer">
  <div class="footer-inner">

    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="HugDot">
        <span class="logo-mark">H</span><span class="logo-text">ugDot</span>
      </a>
      <p class="footer-desc">
        {isKr ? 'к≤МмЮД лН∞мЭінД∞л≤†мЭімК§ вАФ к≥µмЛЭ л¶ђмЖМмК§ кЄ∞л∞Ш' : 'Game Database вАФ Based on official resources'}
      </p>
      <p class="footer-disclaimer">
        {isKr
          ? 'HugDotлКФ HoYoverseмЩА лђікіАнХЬ нМђ мВђмЭінКЄмЮЕлЛИлЛ§.'
          : 'HugDot is a fan site not affiliated with HoYoverse.'}
      </p>
    </div>

    <div class="footer-links">
      <div class="footer-col">
        <p class="footer-col-title">Honkai: Star Rail</p>
        {links.starrail.map(l => (
          <a href={l.href} class="footer-link">{l.label}</a>
        ))}
      </div>
      <div class="footer-col">
        <p class="footer-col-title">Site</p>
        {links.site.map(l => (
          <a href={l.href} class="footer-link">{l.label}</a>
        ))}
      </div>
    </div>

  </div>

  <div class="footer-bottom">
    <p>¬© {currentYear} HugDot. All rights reserved.</p>
    
  </div>
</footer>

<style>
.site-footer {
  border-top: 1px solid var(--c-border);
  background: var(--c-surface);
  margin-top: 4rem;
}
.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2.5rem 1.25rem;
  display: flex;
  gap: 3rem;
  flex-wrap: wrap;
  justify-content: space-between;
}
.footer-brand { display:flex; flex-direction:column; gap:0.6rem; max-width:260px; }
.footer-logo { display:inline-flex; align-items:baseline; text-decoration:none; }
.logo-mark { font-family:var(--font-display); font-size:1.2rem; font-weight:900; color:var(--c-accent); letter-spacing:-0.03em; }
.logo-text { font-family:var(--font-display); font-size:1.2rem; font-weight:700; color:var(--foreground-color); letter-spacing:-0.03em; opacity:0.85; }
.footer-desc { font-size:0.78rem; color:var(--c-muted); line-height:1.6; }
.footer-disclaimer { font-size:0.68rem; color:var(--c-muted); opacity:0.6; line-height:1.5; }
.footer-links { display:flex; gap:2.5rem; flex-wrap:wrap; }
.footer-col { display:flex; flex-direction:column; gap:0.5rem; }
.footer-col-title { font-size:0.62rem; font-weight:900; letter-spacing:0.1em; text-transform:uppercase; color:var(--c-muted); margin-bottom:0.25rem; }
.footer-link { font-size:0.78rem; font-weight:500; color:var(--c-muted); text-decoration:none; transition:color 140ms; }
.footer-link:hover { color:var(--foreground-color); }
.footer-bottom {
  border-top:1px solid var(--c-border);
  max-width:1200px;
  margin:0 auto;
  padding:1rem 1.25rem;
  display:flex;
  align-items:center;
  justify-content:space-between;
  flex-wrap:wrap;
  gap:0.5rem;
  font-size:0.68rem;
  color:var(--c-muted);
  opacity:0.7;
}
.footer-data-credit a { color:var(--c-accent); text-decoration:none; opacity:0.8; }
.footer-data-credit a:hover { opacity:1; }
</style>