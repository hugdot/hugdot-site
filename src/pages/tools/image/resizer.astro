---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools } from '@data/tools'
import seoData from '@data/seo/en/image-resizer.json'

const presets = [
  { label: 'Custom', w: 0, h: 0, icon: 'lucide:settings' },
  { label: 'Insta', w: 1080, h: 1080, icon: 'lucide:instagram' },
  { label: 'X', w: 1200, h: 675, icon: 'lucide:twitter' },
  { label: 'TikTok', w: 1080, h: 1920, icon: 'lucide:music' },
  { label: 'YouTube', w: 1280, h: 720, icon: 'lucide:youtube' },
  { label: 'Fbook', w: 1200, h: 630, icon: 'lucide:facebook' },
  { label: 'LinkedIn', w: 1200, h: 627, icon: 'lucide:linkedin' },
]

const relatedTools = tools.filter((t) => t.category === 'image' && t.id !== 'image-resizer' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="MultimediaApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">

      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/image" class="breadcrumb-link hover:underline">Image Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Resize images for any platform instantly. Batch process up to 20 images at once.
          Your images never leave your device — 100% private.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:shield-check" size="0.875rem" class="text-[var(--action-color)]" />
            No Upload
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:user-x" size="0.875rem" class="text-[var(--action-color)]" />
            No Login
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:layers" size="0.875rem" class="text-[var(--action-color)]" />
            Batch up to 20
          </span>
        </div>
      </div>

      <!-- Drop Zone -->
      <div
        id="drop-zone"
        class="flex cursor-pointer flex-col items-center justify-center gap-4 rounded-2xl border-2 border-dashed border-[var(--border-color-subtle)] p-12 text-center transition-all hover:border-[var(--action-color)]"
      >
        <Icon aria-hidden="true" name="lucide:image-plus" size="3rem" class="opacity-30" />
        <div>
          <p class="font-semibold">Open images</p>
          <p class="text-sm opacity-50">or drag & drop here</p>
        </div>
        <p class="text-xs opacity-40">JPG, PNG, WebP — up to 20 files</p>
        <input id="file-input" type="file" accept="image/*" multiple class="hidden" aria-label="Open images" />
      </div>

      <!-- Settings Panel -->
      <div id="settings-panel" class="mt-6 hidden flex-col gap-6">

        <!-- Mode Badge -->
        <div id="mode-badge" class="flex items-center gap-2 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm">
          <Icon aria-hidden="true" name="lucide:info" size="1rem" class="shrink-0 opacity-40" />
          <span id="mode-text" class="opacity-60"></span>
        </div>

        <!-- Presets -->
        <div class="flex flex-col gap-3">
          <p class="text-sm font-medium">Choose a preset</p>
          <div class="flex flex-col gap-3">
            <button
              class="preset-btn flex w-full items-center justify-center gap-2 rounded-full border border-[var(--border-color-subtle)] px-4 py-2 text-sm transition-all hover:border-[var(--action-color)]"
              data-w={presets[0].w}
              data-h={presets[0].h}
              data-label={presets[0].label}
            >
              <Icon aria-hidden="true" name={presets[0].icon} size="1rem" class="opacity-60" />
              {presets[0].label}
            </button>
            <div class="grid grid-cols-2 gap-2">
              {presets.slice(1).map((preset) => (
                <button
                  class="preset-btn flex items-center gap-2 rounded-full border border-[var(--border-color-subtle)] px-4 py-2.5 text-sm transition-all hover:border-[var(--action-color)]"
                  data-w={preset.w}
                  data-h={preset.h}
                  data-label={preset.label}
                >
                  <Icon aria-hidden="true" name={preset.icon} size="1rem" class="opacity-60 shrink-0" />
                  <span class="font-medium">{preset.label}</span>
                  <span class="ml-auto text-xs opacity-40">{preset.w}×{preset.h}</span>
                </button>
              ))}
            </div>
          </div>
        </div>

        <!-- Custom Dimensions -->
        <div class="flex flex-col gap-3">
          <p class="text-sm font-medium">Or set custom size</p>
          <div class="flex items-center gap-3">
            <div class="flex flex-col gap-1">
              <label class="text-xs opacity-50" for="input-width">Width (px)</label>
              <input
                id="input-width"
                type="number"
                min="1"
                placeholder="Width"
                class="w-28 rounded-xl border border-[var(--border-color-subtle)] bg-[var(--background-color)] px-3 py-2 text-sm outline-none focus:border-[var(--action-color)]"
              />
            </div>
            <button
              id="lock-ratio-btn"
              class="mt-4 rounded-full border border-[var(--border-color-subtle)] p-2 transition-all hover:border-[var(--action-color)]"
              aria-label="Lock aspect ratio"
            >
              <Icon aria-hidden="true" name="lucide:lock" size="1rem" id="lock-icon" />
            </button>
            <div class="flex flex-col gap-1">
              <label class="text-xs opacity-50" for="input-height">Height (px)</label>
              <input
                id="input-height"
                type="number"
                min="1"
                placeholder="Height"
                class="w-28 rounded-xl border border-[var(--border-color-subtle)] bg-[var(--background-color)] px-3 py-2 text-sm outline-none focus:border-[var(--action-color)]"
              />
            </div>
          </div>
        </div>

        <!-- Resize Button -->
        <button
          id="resize-btn"
          class="flex items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
        >
          <Icon aria-hidden="true" name="lucide:maximize" size="1rem" />
          Resize
        </button>
      </div>

      <!-- Loading -->
      <div id="loading" class="mt-8 hidden flex-col items-center gap-3">
        <div class="h-8 w-8 animate-spin rounded-full border-4 border-[var(--border-color-subtle)] border-t-[var(--action-color)]"></div>
        <p id="loading-text" class="text-sm opacity-50">Resizing...</p>
      </div>

      <!-- Result Panel -->
      <div id="result-panel" class="mt-8 hidden flex-col gap-6">

        <!-- Single Preview -->
        <div id="single-preview" class="hidden flex-col gap-3">
          <p class="text-sm font-medium opacity-60">Result</p>
          <img id="preview-result" src="" alt="Resized image" class="w-full rounded-2xl border border-[var(--border-color-subtle)] object-contain" />
          <p id="result-info" class="text-sm opacity-50"></p>
        </div>

        <!-- Batch List -->
        <div id="batch-list" class="hidden flex-col gap-3">
          <p class="text-sm font-medium opacity-60">Results</p>
          <div id="batch-items" class="flex flex-col gap-2"></div>
        </div>

        <!-- Actions -->
        <div class="flex gap-3">
          <button
            id="save-btn"
            class="flex flex-1 items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
          >
            <Icon aria-hidden="true" name="lucide:save" size="1rem" />
            <span id="save-btn-text">Save Image</span>
          </button>
          <button
            id="reset-btn"
            class="flex items-center justify-center gap-2 rounded-full border border-[var(--border-color-subtle)] px-6 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]"
          >
            <Icon aria-hidden="true" name="lucide:refresh-cw" size="1rem" />
            Reset
          </button>
        </div>

      </div>

      <!-- Privacy Badge -->
      <div class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60">
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Your images never leave your device. No data is sent to any server.</span>
      </div>

      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="mt-12">
          <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {relatedTools.map((tool) => (
              <a href={tool.href}
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]">
                {tool.label} →
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</DefaultLayout>

<script>
  // @ts-ignore
  import Pica from 'pica'
  import JSZip from 'jszip'

  let cleanupFn: (() => void) | null = null

  document.addEventListener('astro:page-load', () => {
    cleanupFn?.()
    cleanupFn = initResizer()
  })

  function initResizer(): () => void {
    const MAX_FILES = 20
    const CONCURRENCY = navigator.hardwareConcurrency <= 4 ? 2 : 3

    let originalFiles: File[] = []
    let resizedBlobs: Blob[] = []
    let targetW = 0
    let targetH = 0
    let ratioLocked = true
    let jobToken = 0
    let isBatchMode = false

    // Single mode state
    let singleOriginalWidth = 0
    let singleOriginalHeight = 0
    let singleAspectRatio = 1

    const dropZone = document.getElementById('drop-zone') as HTMLElement
    const fileInput = document.getElementById('file-input') as HTMLInputElement
    const settingsPanel = document.getElementById('settings-panel') as HTMLElement
    const resultPanel = document.getElementById('result-panel') as HTMLElement
    const loading = document.getElementById('loading') as HTMLElement
    const loadingText = document.getElementById('loading-text') as HTMLElement
    const modeBadge = document.getElementById('mode-badge') as HTMLElement
    const modeText = document.getElementById('mode-text') as HTMLElement
    const inputWidth = document.getElementById('input-width') as HTMLInputElement
    const inputHeight = document.getElementById('input-height') as HTMLInputElement
    const lockRatioBtn = document.getElementById('lock-ratio-btn') as HTMLButtonElement
    const lockIcon = document.getElementById('lock-icon') as HTMLElement
    const resizeBtn = document.getElementById('resize-btn') as HTMLButtonElement
    const previewResult = document.getElementById('preview-result') as HTMLImageElement
    const resultInfo = document.getElementById('result-info') as HTMLElement
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement
    const saveBtnText = document.getElementById('save-btn-text') as HTMLElement
    const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement
    const singlePreview = document.getElementById('single-preview') as HTMLElement
    const batchList = document.getElementById('batch-list') as HTMLElement
    const batchItems = document.getElementById('batch-items') as HTMLElement
    const presetBtns = document.querySelectorAll<HTMLButtonElement>('.preset-btn')

    const picaInstance = new Pica()

    const formatSize = (bytes: number) =>
      bytes < 1024 * 1024
        ? `${(bytes / 1024).toFixed(1)} KB`
        : `${(bytes / 1024 / 1024).toFixed(2)} MB`

    const show = (el: HTMLElement) => (el.style.display = 'flex')
    const hide = (el: HTMLElement) => (el.style.display = 'none')

    const updateLockBtn = () => {
      lockRatioBtn.classList.toggle('border-[var(--action-color)]', ratioLocked)
    }

    const clearPresetSelection = () => {
      presetBtns.forEach((btn) => btn.classList.remove('border-[var(--action-color)]', 'font-bold'))
    }

    // Contain resize: fit within target dimensions while preserving aspect ratio
    const containResize = (srcW: number, srcH: number, dstW: number, dstH: number) => {
      const ratio = Math.min(dstW / srcW, dstH / srcH)
      return {
        w: Math.round(srcW * ratio),
        h: Math.round(srcH * ratio),
      }
    }

    const resizeSingle = async (file: File, tw: number, th: number): Promise<Blob> => {
      return new Promise((resolve, reject) => {
        const img = new Image()
        const url = URL.createObjectURL(file)
        img.onload = async () => {
          try {
            // Use contain mode for batch, exact for single
            const { w, h } = isBatchMode
              ? containResize(img.width, img.height, tw, th)
              : { w: tw, h: th }

            const srcCanvas = document.createElement('canvas')
            srcCanvas.width = img.width
            srcCanvas.height = img.height
            srcCanvas.getContext('2d')!.drawImage(img, 0, 0)

            const dstCanvas = document.createElement('canvas')
            dstCanvas.width = w
            dstCanvas.height = h

            await picaInstance.resize(srcCanvas, dstCanvas, { quality: 3, alpha: true })

            const mimeType = file.type || 'image/jpeg'
            dstCanvas.toBlob(
              (blob) => {
                URL.revokeObjectURL(url)
                if (blob) resolve(blob)
                else reject(new Error('toBlob failed'))
              },
              mimeType,
              0.92
            )
          } catch (e) {
            URL.revokeObjectURL(url)
            reject(e)
          }
        }
        img.onerror = () => { URL.revokeObjectURL(url); reject(new Error('Image load failed')) }
        img.src = url
      })
    }

    const runResize = async () => {
      const tw = parseInt(inputWidth.value)
      const th = parseInt(inputHeight.value)
      if (!tw || !th) return

      targetW = tw
      targetH = th

      const currentToken = ++jobToken
      resizedBlobs = []

      hide(resultPanel)
      show(loading)

      if (!isBatchMode) {
        // Single mode
        try {
          loadingText.textContent = 'Resizing...'
          const blob = await resizeSingle(originalFiles[0], tw, th)
          if (currentToken !== jobToken) return
          resizedBlobs = [blob]
          previewResult.src = URL.createObjectURL(blob)
          resultInfo.textContent = `${tw} × ${th}px — ${formatSize(blob.size)}`
          show(singlePreview)
          hide(batchList)
          saveBtnText.textContent = 'Save Image'
          hide(loading)
          show(resultPanel)
        } catch (e) {
          console.error(e)
          hide(loading)
        }
      } else {
        // Batch mode
        batchItems.innerHTML = ''
        const results: { blob: Blob | null; file: File }[] = []

        for (let i = 0; i < originalFiles.length; i += CONCURRENCY) {
          if (currentToken !== jobToken) return
          const chunk = originalFiles.slice(i, i + CONCURRENCY)
          const chunkResults = await Promise.all(
            chunk.map(async (file) => {
              try {
                const blob = await resizeSingle(file, tw, th)
                return { blob, file }
              } catch {
                return { blob: null, file }
              }
            })
          )
          if (currentToken !== jobToken) return
          results.push(...chunkResults)
          const processed = Math.min(i + CONCURRENCY, originalFiles.length)
          loadingText.textContent = `Resizing... (${processed}/${originalFiles.length})`
        }

        results.forEach(({ blob, file }) => {
          if (blob) resizedBlobs.push(blob)
          const img = new Image()
          const previewUrl = blob ? URL.createObjectURL(blob) : ''
          if (blob) img.src = previewUrl

          // Get actual dimensions
          const item = document.createElement('div')
          item.className = 'flex items-center gap-3 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3'
          item.innerHTML = `
            ${blob ? `<img src="${previewUrl}" alt="${file.name}" class="h-12 w-12 shrink-0 rounded-lg object-cover" />` : `<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg border border-red-500/30 bg-red-500/10 text-red-500 text-xs">ERR</div>`}
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm font-medium">${file.name}</p>
              <p class="text-xs opacity-50">${blob ? formatSize(blob.size) : 'Failed'}</p>
            </div>
            <span class="shrink-0 rounded-full px-3 py-1 text-xs font-medium ${blob ? 'bg-green-500/10 text-green-500' : 'bg-red-500/10 text-red-500'}">
              ${blob ? '✓ Done' : '✗ Failed'}
            </span>
          `
          batchItems.appendChild(item)
        })

        show(batchList)
        hide(singlePreview)
        saveBtnText.textContent = `Download All (ZIP)`
        hide(loading)
        show(resultPanel)
      }
    }

    const downloadAll = async () => {
      if (!resizedBlobs.length) return

      if (!isBatchMode && resizedBlobs.length === 1) {
        const file = originalFiles[0]
        const ext = file.name.split('.').pop() ?? 'jpg'
        const name = file.name.replace(/\.[^/.]+$/, '')
        const link = document.createElement('a')
        link.download = `${name}-${targetW}x${targetH}.${ext}`
        link.href = URL.createObjectURL(resizedBlobs[0])
        link.click()
        return
      }

      const zip = new JSZip()
      resizedBlobs.forEach((blob, i) => {
        const file = originalFiles[i]
        const ext = file.name.split('.').pop() ?? 'jpg'
        const name = file.name.replace(/\.[^/.]+$/, '')
        zip.file(`${name}-${targetW}x${targetH}.${ext}`, blob)
      })
      const blob = await zip.generateAsync({ type: 'blob' })
      const url = URL.createObjectURL(blob)
      const link = document.createElement('a')
      link.href = url
      link.download = `hugdot-resized-${targetW}x${targetH}.zip`
      link.click()
      URL.revokeObjectURL(url)
    }

    const handleFiles = (files: FileList) => {
      originalFiles = Array.from(files)
        .filter((f) => f.type.startsWith('image/'))
        .slice(0, MAX_FILES)
      if (!originalFiles.length) return

      isBatchMode = originalFiles.length > 1

      if (!isBatchMode) {
        // Single mode — load original dimensions
        const img = new Image()
        const url = URL.createObjectURL(originalFiles[0])
        img.onload = () => {
          singleOriginalWidth = img.width
          singleOriginalHeight = img.height
          singleAspectRatio = img.width / img.height
          inputWidth.value = String(img.width)
          inputHeight.value = String(img.height)
          ratioLocked = true
          updateLockBtn()
          modeText.textContent = `${img.width} × ${img.height}px — ${formatSize(originalFiles[0].size)}`
          URL.revokeObjectURL(url)
        }
        img.src = url
      } else {
        // Batch mode
        inputWidth.value = '1080'
        inputHeight.value = '1080'
        ratioLocked = false
        updateLockBtn()
        modeText.textContent = `Batch mode — ${originalFiles.length} images selected. Each image will be scaled to fit (Contain).`
      }

      hide(dropZone)
      show(settingsPanel)
    }

    // Preset buttons
    presetBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const w = parseInt(btn.dataset.w ?? '0')
        const h = parseInt(btn.dataset.h ?? '0')
        clearPresetSelection()
        btn.classList.add('border-[var(--action-color)]', 'font-bold')

        if (w === 0 && h === 0) {
          if (!isBatchMode) {
            inputWidth.value = String(singleOriginalWidth)
            inputHeight.value = String(singleOriginalHeight)
          }
          ratioLocked = true
        } else {
          inputWidth.value = String(w)
          inputHeight.value = String(h)
          ratioLocked = false
        }
        updateLockBtn()
      })
    })

    // Width/height inputs
    inputWidth.addEventListener('input', () => {
      if (ratioLocked && !isBatchMode && inputWidth.value) {
        const w = parseInt(inputWidth.value)
        inputHeight.value = String(Math.round(w / singleAspectRatio))
      }
      clearPresetSelection()
    })

    inputHeight.addEventListener('input', () => {
      if (ratioLocked && !isBatchMode && inputHeight.value) {
        const h = parseInt(inputHeight.value)
        inputWidth.value = String(Math.round(h * singleAspectRatio))
      }
      clearPresetSelection()
    })

    lockRatioBtn.addEventListener('click', () => {
      if (!isBatchMode) {
        ratioLocked = !ratioLocked
        updateLockBtn()
      }
    })

    resizeBtn.addEventListener('click', runResize)
    saveBtn.addEventListener('click', downloadAll)

    dropZone.addEventListener('click', () => fileInput.click())
    dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-[var(--action-color)]') })
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-[var(--action-color)]'))
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault()
      dropZone.classList.remove('border-[var(--action-color)]')
      if (e.dataTransfer?.files) handleFiles(e.dataTransfer.files)
    })
    fileInput.addEventListener('change', () => { if (fileInput.files) handleFiles(fileInput.files) })

    resetBtn.addEventListener('click', () => {
      jobToken++
      originalFiles = []
      resizedBlobs = []
      fileInput.value = ''
      ratioLocked = true
      isBatchMode = false
      batchItems.innerHTML = ''
      hide(resultPanel)
      hide(settingsPanel)
      hide(loading)
      show(dropZone)
      updateLockBtn()
    })

    updateLockBtn()
    return () => { jobToken++ }
  }
</script>