---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools, getToolHref } from '@data/tools/index'
import seoData from '@data/seo/en/heic-converter.json'

const relatedTools = tools.filter((t) => t.category === 'image' && t.id !== 'heic-converter' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="MultimediaApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">
      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/image" class="breadcrumb-link hover:underline">Image Tools</a>
          <span>/</span>
          <span>HEIC Converter</span>
        </div>
        <Heading level="h1" size="h2">HEIC Converter</Heading>
        <p class="mt-2 opacity-60">
          Convert iPhone HEIC photos to JPG, PNG, or WebP instantly. Batch convert up to 20 files at once.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span
            class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium"
          >
            <Icon aria-hidden="true" name="lucide:shield-check" size="0.875rem" class="text-[var(--action-color)]" />
            No Upload
          </span>
          <span
            class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium"
          >
            <Icon aria-hidden="true" name="lucide:user-x" size="0.875rem" class="text-[var(--action-color)]" />
            No Login
          </span>
          <span
            class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium"
          >
            <Icon aria-hidden="true" name="lucide:layers" size="0.875rem" class="text-[var(--action-color)]" />
            Batch up to 20
          </span>
        </div>
      </div>

      <!-- iPhone Notice -->
      <div class="mb-6 flex items-start gap-3 rounded-2xl border border-blue-500/30 bg-blue-500/10 px-5 py-4 text-sm">
        <Icon aria-hidden="true" name="lucide:smartphone" size="1.25rem" class="mt-0.5 shrink-0 text-blue-500" />
        <div>
          <p class="font-semibold text-blue-500">iPhone Photo Format</p>
          <p class="mt-1 opacity-70">
            HEIC is Apple's default photo format since iOS 11. Convert to JPG or PNG for universal compatibility.
          </p>
        </div>
      </div>

      <!-- Tool -->
      <div class="flex flex-col gap-6">
        <!-- Drop Zone -->
        <div
          id="drop-zone"
          class="flex cursor-pointer flex-col items-center justify-center gap-4 rounded-2xl border-2 border-dashed border-[var(--border-color-subtle)] p-12 text-center transition-all hover:border-[var(--action-color)]"
        >
          <Icon aria-hidden="true" name="lucide:file-image" size="3rem" class="opacity-30" />
          <div>
            <p class="font-semibold">Open HEIC files</p>
            <p class="text-sm opacity-50">or drag & drop here</p>
          </div>
          <p class="text-xs opacity-40">HEIC, HEIF — up to 20 files</p>
          <input
            id="file-input"
            type="file"
            accept=".heic,.heif,.HEIC,.HEIF,image/heic,image/heif,image/heic-sequence,image/heif-sequence"
            multiple
            class="hidden"
          />
        </div>

        <!-- Settings Panel -->
        <div
          id="settings-panel"
          class="hidden flex-col gap-6 rounded-2xl border border-[var(--border-color-subtle)] p-6"
        >
          <!-- File Count -->
          <div class="flex items-center gap-2 text-sm opacity-60">
            <Icon aria-hidden="true" name="lucide:images" size="1rem" />
            <span id="file-count"></span>
          </div>

          <!-- Output Format -->
          <div class="flex flex-col gap-3">
            <p class="text-sm font-medium">Output Format</p>
            <div class="grid grid-cols-3 gap-2">
              {
                ['JPG', 'PNG', 'WebP'].map((fmt) => (
                  <button
                    data-format={fmt}
                    class="format-btn rounded-xl border border-[var(--border-color-subtle)] py-3 text-sm font-semibold transition-all hover:border-[var(--action-color)]"
                  >
                    {fmt}
                  </button>
                ))
              }
            </div>
          </div>

          <!-- Quality -->
          <div id="quality-wrap" class="flex flex-col gap-3">
            <div class="flex items-center justify-between">
              <label class="text-sm font-medium">Quality</label>
              <span id="quality-value" class="text-lg font-bold text-[var(--action-color)]">90%</span>
            </div>
            <input
              id="quality-slider"
              type="range"
              min="10"
              max="100"
              value="90"
              class="w-full accent-[var(--action-color)]"
            />
            <div class="flex justify-between text-xs opacity-40">
              <span>Smaller file</span>
              <span>Better quality</span>
            </div>
          </div>

          <!-- Convert Button -->
          <button
            id="convert-btn"
            class="flex items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
          >
            <Icon aria-hidden="true" name="lucide:repeat" size="1rem" />
            Convert
          </button>
        </div>

        <!-- Engine Loading -->
        <div
          id="engine-loading"
          class="hidden flex-col items-center gap-4 rounded-2xl border border-[var(--border-color-subtle)] p-8"
        >
          <div
            class="h-8 w-8 animate-spin rounded-full border-4 border-[var(--border-color-subtle)] border-t-[var(--action-color)]"
          >
          </div>
          <div class="text-center">
            <p class="font-medium">Loading HEIC Engine...</p>
            <p class="mt-1 text-sm opacity-50">First-time load takes a few seconds (~1.5MB)</p>
          </div>
          <!-- Progress Bar -->
          <div class="w-full rounded-full bg-[var(--border-color-subtle)]" style="height: 4px;">
            <div
              id="engine-progress"
              class="h-full rounded-full bg-[var(--action-color)] transition-all"
              style="width: 0%"
            >
            </div>
          </div>
          <p id="engine-status" class="text-xs opacity-50">Initializing...</p>
        </div>

        <!-- Converting Progress -->
        <div id="converting" class="hidden flex-col items-center gap-3">
          <div
            class="h-8 w-8 animate-spin rounded-full border-4 border-[var(--border-color-subtle)] border-t-[var(--action-color)]"
          >
          </div>
          <p id="converting-text" class="text-sm opacity-50">Converting...</p>
        </div>

        <!-- Result Panel -->
        <div id="result-panel" class="hidden flex-col gap-4">
          <div id="result-list" class="flex flex-col gap-3"></div>
          <div class="flex gap-3">
            <button
              id="save-btn"
              class="flex flex-1 items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
            >
              <Icon aria-hidden="true" name="lucide:save" size="1rem" />
              <span id="save-btn-text">Save</span>
            </button>
            <button
              id="reset-btn"
              class="flex items-center justify-center gap-2 rounded-full border border-[var(--border-color-subtle)] px-6 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]"
            >
              <Icon aria-hidden="true" name="lucide:refresh-cw" size="1rem" />
              Reset
            </button>
          </div>
        </div>
      </div>

      <!-- Privacy Badge -->
      <div
        class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60"
      >
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Your photos never leave your device. All processing happens locally in your browser.</span>
      </div>

      <!-- Related Tools -->
      {
        relatedTools.length > 0 && (
          <div class="mt-12">
            <Heading level="h2" size="h4" class="mb-6">
              Related Tools
            </Heading>
            <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
              {relatedTools.map((tool) => (
                <a
                  href={getToolHref(tool.category, tool.slug)}
                  class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]"
                >
                  {tool.label} →
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </section>
</DefaultLayout>

<style>
  .format-btn.active {
    border-color: var(--action-color);
    background-color: var(--action-color);
    color: white;
  }
</style>

<script>
  import JSZip from 'jszip'

  let cleanupFn: (() => void) | null = null

  document.addEventListener('astro:page-load', () => {
    cleanupFn?.()
    cleanupFn = initHeicConverter()
  })

  function initHeicConverter(): () => void {
    const MAX_FILES = 20

    let originalFiles: File[] = []
    let resultBlobs: { blob: Blob; name: string; previewUrl: string }[] = []
    let selectedFormat = 'JPG'
    let worker: Worker | null = null
    let workerReady = false

    const dropZone = document.getElementById('drop-zone') as HTMLElement
    const fileInput = document.getElementById('file-input') as HTMLInputElement
    const settingsPanel = document.getElementById('settings-panel') as HTMLElement
    const engineLoading = document.getElementById('engine-loading') as HTMLElement
    const engineProgress = document.getElementById('engine-progress') as HTMLElement
    const engineStatus = document.getElementById('engine-status') as HTMLElement
    const converting = document.getElementById('converting') as HTMLElement
    const convertingText = document.getElementById('converting-text') as HTMLElement
    const resultPanel = document.getElementById('result-panel') as HTMLElement
    const resultList = document.getElementById('result-list') as HTMLElement
    const fileCount = document.getElementById('file-count') as HTMLElement
    const qualitySlider = document.getElementById('quality-slider') as HTMLInputElement
    const qualityValue = document.getElementById('quality-value') as HTMLElement
    const qualityWrap = document.getElementById('quality-wrap') as HTMLElement
    const convertBtn = document.getElementById('convert-btn') as HTMLButtonElement
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement
    const saveBtnText = document.getElementById('save-btn-text') as HTMLElement
    const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement
    const formatBtns = document.querySelectorAll('.format-btn') as NodeListOf<HTMLButtonElement>

    const show = (el: HTMLElement) => (el.style.display = 'flex')
    const hide = (el: HTMLElement) => (el.style.display = 'none')

    const formatSize = (bytes: number) =>
      bytes < 1024 * 1024 ? `${(bytes / 1024).toFixed(1)} KB` : `${(bytes / 1024 / 1024).toFixed(2)} MB`

    const getExt = (fmt: string) => ({ JPG: 'jpg', PNG: 'png', WebP: 'webp' })[fmt] ?? 'jpg'

    const setFormat = (fmt: string) => {
      selectedFormat = fmt
      formatBtns.forEach((btn) => btn.classList.toggle('active', btn.dataset.format === fmt))
      qualityWrap.style.display = fmt === 'PNG' ? 'none' : 'flex'
    }

    // ─── Web Worker 초기화 ────────────────────────────────────────────────────
    // Worker는 파일 업로드 시점에 생성 (Lazy)
    const initWorker = (): Promise<void> => {
      return new Promise((resolve, reject) => {
        if (workerReady && worker) {
          resolve()
          return
        }

        show(engineLoading)
        hide(settingsPanel)

        // 엔진 로딩 진행바 애니메이션
        let progress = 0
        const progressTimer = setInterval(() => {
          progress = Math.min(progress + Math.random() * 15, 85)
          engineProgress.style.width = `${progress}%`
          engineStatus.textContent =
            progress < 30
              ? 'Downloading HEIC engine...'
              : progress < 60
                ? 'Initializing WASM module...'
                : 'Almost ready...'
        }, 300)

        worker = new Worker('/heic.worker.js')

        // Worker 준비 완료 감지 (첫 메시지 수신)
        const onReady = (e: MessageEvent) => {
          if (e.data.type === 'ready') {
            clearInterval(progressTimer)
            engineProgress.style.width = '100%'
            engineStatus.textContent = 'Engine ready!'
            setTimeout(() => {
              workerReady = true
              hide(engineLoading)
              show(settingsPanel)
              resolve()
            }, 400)
            worker!.removeEventListener('message', onReady)
          }
        }

        worker.addEventListener('message', onReady)

        worker.onerror = (err) => {
          clearInterval(progressTimer)
          console.error('Worker error:', err)
          hide(engineLoading)
          show(settingsPanel)
          workerReady = false
          reject(err)
        }

        // Worker가 로드되면 준비 신호 보내기
        // (heic.worker.js에서 importScripts 완료 후 'ready' 메시지 전송)
        setTimeout(() => {
          if (!workerReady) {
            clearInterval(progressTimer)
            engineProgress.style.width = '100%'
            workerReady = true
            hide(engineLoading)
            show(settingsPanel)
            resolve()
          }
        }, 5000) // 5초 타임아웃
      })
    }

    // ─── 변환 실행 ────────────────────────────────────────────────────────────
    const convertFiles = async () => {
      if (!worker || !originalFiles.length) return

      // 기존 preview URL 해제 (메모리 누수 방지)
      resultBlobs.forEach(({ previewUrl }) => URL.revokeObjectURL(previewUrl))
      resultBlobs = []
      resultList.innerHTML = ''

      hide(settingsPanel)
      show(converting)

      const quality = parseInt(qualitySlider.value)
      const results: { success: boolean; blob?: Blob; name: string; originalSize: number }[] = []

      // 파일을 순차적으로 처리 (WASM은 메모리 집약적 — 병렬 처리 시 크래시 위험)
      for (let i = 0; i < originalFiles.length; i++) {
        const file = originalFiles[i]
        convertingText.textContent = `Converting ${i + 1} of ${originalFiles.length}... (${file.name})`

        try {
          const blob = await new Promise<Blob>((resolve, reject) => {
            const msgId = `${Date.now()}-${i}`

            const onMessage = (e: MessageEvent) => {
              if (e.data.id !== msgId) return

              if (e.data.type === 'done') {
                worker!.removeEventListener('message', onMessage)
                // ArrayBuffer → Blob 복원
                const blob = new Blob([e.data.arrayBuffer], { type: e.data.mimeType })
                resolve(blob)
              } else if (e.data.type === 'error') {
                worker!.removeEventListener('message', onMessage)
                reject(new Error(e.data.message))
              }
            }

            worker!.addEventListener('message', onMessage)

            // File 객체를 직접 전송 (Transferable 불가 — 복사로 전달)
            worker!.postMessage({
              id: msgId,
              file: file,
              format: selectedFormat,
              quality,
            })
          })

          results.push({ success: true, blob, name: file.name, originalSize: file.size })
        } catch (err) {
          console.error(`Failed to convert ${file.name}:`, err)
          results.push({ success: false, name: file.name, originalSize: file.size })
        }
      }

      // 결과 렌더링
      results.forEach(({ success, blob, name, originalSize }) => {
        const ext = getExt(selectedFormat)
        const outputName = `${name.replace(/\.(heic|heif)$/i, '')}.${ext}`

        if (success && blob) {
          // URL.createObjectURL으로 즉시 다운로드 가능한 URL 생성
          const previewUrl = URL.createObjectURL(blob)
          resultBlobs.push({ blob, name: outputName, previewUrl })

          const item = document.createElement('div')
          item.className = 'flex items-center gap-3 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3'
          item.innerHTML = `
            <img src="${previewUrl}" alt="${outputName}" class="h-14 w-14 shrink-0 rounded-lg object-cover" />
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm font-medium">${outputName}</p>
              <p class="text-xs opacity-50">${formatSize(originalSize)} → ${formatSize(blob.size)}</p>
            </div>
            
              href="${previewUrl}"
              download="${outputName}"
              class="shrink-0 rounded-full bg-[var(--action-color)] px-3 py-1.5 text-xs font-semibold text-white"
            >
              Save
            </a>
          `
          resultList.appendChild(item)
        } else {
          const item = document.createElement('div')
          item.className = 'flex items-center gap-3 rounded-xl border border-red-500/20 px-4 py-3'
          item.innerHTML = `
            <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-lg bg-red-500/10 text-xs text-red-500">ERR</div>
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm font-medium">${name}</p>
              <p class="text-xs text-red-500">Conversion failed</p>
            </div>
          `
          resultList.appendChild(item)
        }
      })

      saveBtnText.textContent = resultBlobs.length === 1 ? 'Save Image' : 'Download All (ZIP)'
      hide(converting)
      show(resultPanel)
    }

    // ─── ZIP 다운로드 ─────────────────────────────────────────────────────────
    const downloadAll = async () => {
      if (!resultBlobs.length) return

      if (resultBlobs.length === 1) {
        const { previewUrl, name } = resultBlobs[0]
        const link = document.createElement('a')
        link.href = previewUrl
        link.download = name
        link.click()
        return
      }

      const zip = new JSZip()
      resultBlobs.forEach(({ blob, name }) => zip.file(name, blob))
      const zipBlob = await zip.generateAsync({ type: 'blob' })
      const url = URL.createObjectURL(zipBlob)
      const link = document.createElement('a')
      link.href = url
      link.download = 'hugdot-converted.zip'
      link.click()
      // ZIP URL 즉시 해제
      URL.revokeObjectURL(url)
    }

    // ─── 파일 핸들링 ──────────────────────────────────────────────────────────
    const handleFiles = async (files: FileList) => {
      originalFiles = Array.from(files)
        .filter((f) => {
          const name = f.name.toLowerCase()
          const type = f.type.toLowerCase()

          // 1. 기본 확장자 체크
          const isHeifExtension = name.endsWith('.heic') || name.endsWith('.heif')

          // 2. MIME 타입 체크
          const isHeifMime =
            type === 'image/heic' ||
            type === 'image/heif' ||
            type === 'image/heic-sequence' ||
            type === 'image/heif-sequence'

          // 3. 타입이 불분명할 때(빈값/octet-stream)는 확장자가 맞을 때만 통과
          const isUnknownButHeif = (type === '' || type === 'application/octet-stream') && isHeifExtension

          return isHeifExtension || isHeifMime || isUnknownButHeif
        })
        .slice(0, MAX_FILES)

      if (!originalFiles.length) {
        alert('Please select HEIC or HEIF files.')
        return
      }

      hide(dropZone)
      fileCount.textContent = `${originalFiles.length} file${originalFiles.length > 1 ? 's' : ''} selected`

      // Worker 초기화 (Lazy — 파일 업로드 시점에만 로드)
      try {
        await initWorker()
      } catch {
        alert('Failed to load HEIC engine. Please refresh and try again.')
        show(dropZone)
      }
    }

    // ─── 이벤트 바인딩 ────────────────────────────────────────────────────────
    formatBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (btn.dataset.format) setFormat(btn.dataset.format)
      })
    })

    qualitySlider.addEventListener('input', () => {
      qualityValue.textContent = `${qualitySlider.value}%`
    })

    convertBtn.addEventListener('click', convertFiles)
    saveBtn.addEventListener('click', downloadAll)

    dropZone.addEventListener('click', () => fileInput.click())
    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault()
      dropZone.classList.add('border-[var(--action-color)]')
    })
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-[var(--action-color)]'))
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault()
      dropZone.classList.remove('border-[var(--action-color)]')
      if (e.dataTransfer?.files) handleFiles(e.dataTransfer.files)
    })
    fileInput.addEventListener('change', () => {
      if (fileInput.files) handleFiles(fileInput.files)
    })

    resetBtn.addEventListener('click', () => {
      // 메모리 누수 방지 — 모든 preview URL 해제
      resultBlobs.forEach(({ previewUrl }) => URL.revokeObjectURL(previewUrl))
      resultBlobs = []
      originalFiles = []
      fileInput.value = ''
      resultList.innerHTML = ''
      workerReady = false
      if (worker) {
        worker.terminate()
        worker = null
      }
      hide(resultPanel)
      hide(converting)
      hide(engineLoading)
      hide(settingsPanel)
      show(dropZone)
    })

    // init
    setFormat('JPG')

    return () => {
      resultBlobs.forEach(({ previewUrl }) => URL.revokeObjectURL(previewUrl))
      if (worker) {
        worker.terminate()
        worker = null
      }
    }
  }
</script>
