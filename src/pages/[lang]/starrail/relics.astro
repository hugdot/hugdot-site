---
// src/pages/[lang]/starrail/relics.astro
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Icon } from 'astro-icon/components'

const allData = import.meta.glob('/src/data/starrail/**/*.json', { eager: true })

export async function getStaticPaths() {
  const languages = ['kr', 'en', 'jp', 'cn', 'fr', 'de', 'es', 'id', 'pt', 'ru', 'th', 'vi', 'cht']
  return languages.map((lang) => ({ params: { lang } }))
}

const { lang } = Astro.params

const cleanText = (text: string) => {
  if (!text) return ''
  return text
    .replace(/\{RUBY_B#([^}]+)\}([^\{]+)\{RUBY_E\#\}/g, '$1')
    .replace(/\{F#([^}]*)\}\{M#([^}]*)\}/g, '$2')
    .replace(/\{NICKNAME\}/g, 'Trailblazer')
    .trim()
}

const highlightNumbers = (text: string) => {
  if (!text) return ''
  return cleanText(text).replace(/(\d+(\.\d+)?%?)/g, (m) =>
    `<span class="hl-num">${m}</span>`
  )
}

const toAssetUrl = (rel: string) => {
  if (!rel) return ''
  let p = rel.replace(/^\//, '').replace(/^starrail\/assets\//, '')
  if (p.includes('icon/character/')) p = p.replace('icon/character/', 'icon/relic/')
  return `/starrail/assets/${p}`
}

let relicSets: any[] = []

try {
  const baseDir = `/src/data/starrail/${lang}`
  const setsModule = allData[`${baseDir}/relic_sets.json`] as any
  const setsRaw = setsModule?.default || {}

  relicSets = Object.entries(setsRaw)
    .map(([id, data]: [string, any]) => {
      const isPlanar = parseInt(id) >= 300
      return {
        id,
        ...data,
        name: cleanText(data.name),
        isPlanar,
      }
    })
    .filter((s) => s.name && s.name.trim() !== '' && !s.name.includes('{NICKNAME}'))
    .sort((a, b) => parseInt(b.id) - parseInt(a.id))
} catch (e) {
  console.error(`Error loading relics for ${lang}:`, e)
}

const totalCount = relicSets.length

const labels = lang === 'kr'
  ? {
      title: '유물',
      subtitle: '붕괴: 스타레일의 모든 유물 및 차원 장신구 세트',
      search: '유물 이름 검색…',
      filterAll: '전체',
      reset: '초기화',
      showing: '{v}개 표시',
      total: '전체 {t}개',
      noMatch: '조건에 맞는 유물이 없습니다.',
      filterCategory: '분류',
      pc2: '2세트',
      pc4: '4세트',
      relic: '터널 유물',
      planar: '차원 장신구',
    }
  : {
      title: 'Relics',
      subtitle: 'All relic and planar ornament sets in Honkai: Star Rail',
      search: 'Search set name…',
      filterAll: 'All',
      reset: 'Reset',
      showing: '{v} shown',
      total: '{t} total',
      noMatch: 'No relics match your filters.',
      filterCategory: 'Category',
      pc2: '2pc',
      pc4: '4pc',
      relic: 'Relics',
      planar: 'Planar',
    }
---

<DefaultLayout
  title={`${labels.title} | Star Rail DB`}
  description="Honkai: Star Rail relic and planar ornament set effects."
>
  <div class="relics-page">

    <!-- ── 헤더 ── -->
    <div class="relics-header">
      <div class="relics-header-inner">
        <nav class="breadcrumb" aria-label="breadcrumb">
          <a href={`/${lang}`}>Home</a>
          <span class="sep" aria-hidden="true">/</span>
          <a href={`/${lang}/starrail`}>Star Rail</a>
          <span class="sep" aria-hidden="true">/</span>
          <span class="current">{labels.title}</span>
        </nav>
        <div class="relics-title-row">
          <div>
            <h1 class="relics-title">{labels.title}</h1>
            <p class="relics-subtitle">{labels.subtitle}</p>
          </div>
          <p class="relics-count-badge" id="relic-count-badge">{totalCount}</p>
        </div>
      </div>
    </div>

    <div class="relics-body">

      <!-- ── 필터 사이드바 ── -->
      <aside class="filter-panel" aria-label={labels.filterCategory}>

        <!-- 검색 -->
        <div class="filter-group">
          <div class="search-wrap">
            <Icon name="lucide:search" size="0.85rem" class="search-icon" />
            <input
              type="search"
              id="relicSearch"
              placeholder={labels.search}
              autocomplete="off"
              class="search-input"
            />
          </div>
        </div>

        <!-- 분류 -->
        <div class="filter-group">
          <p class="filter-label">{labels.filterCategory}</p>
          <div class="filter-chips">
            <button class="fchip fchip--active" data-category-filter="all" aria-pressed="true">
              {labels.filterAll}
            </button>
            <button class="fchip" data-category-filter="relic" aria-pressed="false">
              {labels.relic}
            </button>
            <button class="fchip" data-category-filter="planar" aria-pressed="false">
              {labels.planar}
            </button>
          </div>
        </div>

        <!-- 초기화 -->
        <button class="reset-btn" id="relic-filter-reset" type="button">
          <Icon name="lucide:rotate-ccw" size="0.75rem" />
          {labels.reset}
        </button>

        <!-- 결과 수 -->
        <p class="filter-result" id="relic-count-line" aria-live="polite">
          {labels.showing.replace('{v}', String(totalCount))}
          <span class="filter-result-total">· {labels.total.replace('{t}', String(totalCount))}</span>
        </p>

      </aside>

      <!-- ── 유물 목록 ── -->
      <div class="relics-list-wrap">
        <div id="relic-container" class="relics-list">
          {relicSets.map((set) => (
            <div
              class="relic-card"
              data-relic-card
              data-name={set.name.toLowerCase()}
              data-category={set.isPlanar ? 'planar' : 'relic'}
            >
              <!-- 아이콘 + 이름 헤더 -->
              <div class="relic-card-header">
                <div class="relic-icon-wrap">
                  <img
                    src={toAssetUrl(set.icon)}
                    alt={set.name}
                    width="44" height="44"
                    loading="lazy"
                    decoding="async"
                    class="relic-icon"
                  />
                </div>
                <div class="relic-header-info">
                  <span class={`relic-type-badge ${set.isPlanar ? 'relic-type-badge--planar' : 'relic-type-badge--relic'}`}>
                    {set.isPlanar
                      ? (lang === 'kr' ? '차원 장신구' : 'Planar')
                      : (lang === 'kr' ? '터널 유물' : 'Relic')}
                  </span>
                  <h2 class="relic-name">{set.name}</h2>
                </div>
              </div>

              <!-- 세트 효과 -->
              <div class="relic-effects">
                {set.desc.map((d: string, idx: number) => (
                  <div class="relic-effect-row">
                    <span class={`relic-pc-tag ${idx === 0 ? 'relic-pc-tag--2' : 'relic-pc-tag--4'}`}>
                      {idx === 0 ? labels.pc2 : labels.pc4}
                    </span>
                    <p class="relic-effect-text" set:html={highlightNumbers(d)} />
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>

        <!-- 검색 결과 없음 -->
        <div id="relic-filter-empty" class="filter-empty hidden" role="status">
          <Icon name="lucide:search-x" size="2.5rem" />
          <p>{labels.noMatch}</p>
        </div>
      </div>

    </div>
  </div>

  <script is:inline define:vars={{ labelShowing: labels.showing, labelTotal: labels.total, totalCount }}>
  ;(function () {
    function init() {
      var cards       = Array.prototype.slice.call(document.querySelectorAll('[data-relic-card]'))
      var search      = document.getElementById('relicSearch')
      var countLine   = document.getElementById('relic-count-line')
      var countBadge  = document.getElementById('relic-count-badge')
      var empty       = document.getElementById('relic-filter-empty')
      var resetBtn    = document.getElementById('relic-filter-reset')
      var catBtns     = Array.prototype.slice.call(document.querySelectorAll('[data-category-filter]'))

      var activeCategory = 'all'

      function updatePressed() {
        catBtns.forEach(function (btn) {
          var v = btn.getAttribute('data-category-filter') || 'all'
          var on = v === activeCategory
          btn.setAttribute('aria-pressed', on ? 'true' : 'false')
          btn.classList.toggle('fchip--active', on)
        })
      }

      function apply() {
        var q = search ? search.value.trim().toLowerCase() : ''
        var visible = 0
        cards.forEach(function (card) {
          var name = card.getAttribute('data-name') || ''
          var cat  = card.getAttribute('data-category') || ''
          var show =
            (activeCategory === 'all' || cat === activeCategory) &&
            (!q || name.indexOf(q) !== -1)
          card.classList.toggle('hidden', !show)
          if (show) visible++
        })
        var showStr = labelShowing.replace('{v}', String(visible))
        var totStr  = labelTotal.replace('{t}', String(totalCount))
        if (countLine)  countLine.innerHTML  = showStr + ' <span class="filter-result-total">· ' + totStr + '</span>'
        if (countBadge) countBadge.textContent = String(visible)
        if (empty) empty.classList.toggle('hidden', visible !== 0)
      }

      catBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          activeCategory = btn.getAttribute('data-category-filter') || 'all'
          updatePressed()
          apply()
        }, { passive: true })
      })

      if (search) {
        search.addEventListener('input',  apply, { passive: true })
        search.addEventListener('search', apply, { passive: true })
      }

      if (resetBtn) {
        resetBtn.addEventListener('click', function () {
          activeCategory = 'all'
          if (search) { search.value = ''; search.focus() }
          updatePressed()
          apply()
        }, { passive: true })
      }

      apply()
    }
    document.addEventListener('DOMContentLoaded', init)
    document.addEventListener('astro:page-load', init)
  })()
  </script>
</DefaultLayout>

<style is:global>
.hl-num {
  color: var(--c-accent) !important;
  font-family: var(--font-mono) !important;
  font-weight: 700 !important;
  font-size: 0.95em;
}
/* ── 페이지 ── */
.relics-page {
  min-height: 100vh;
  background: var(--c-bg);
  color: var(--foreground-color);
  font-family: var(--font-body);
}

/* ── 헤더 ── */
.relics-header {
  border-bottom: 1px solid var(--c-border);
  background: var(--c-surface);
  padding: 2rem 0 1.5rem;
}
.relics-header-inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--c-muted);
}
.breadcrumb a { color: inherit; text-decoration: none; transition: color var(--anim-fast); }
.breadcrumb a:hover { color: var(--c-accent); }
.breadcrumb .sep { opacity: 0.4; }
.breadcrumb .current { color: var(--c-accent); }

.relics-title-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 1rem;
}
.relics-title {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  text-transform: uppercase;
  line-height: 1;
}
.relics-subtitle {
  margin-top: 0.4rem;
  font-size: 0.82rem;
  color: var(--c-muted);
}
.relics-count-badge {
  font-family: var(--font-mono);
  font-size: 2rem;
  font-weight: 900;
  color: var(--c-accent);
  opacity: 0.5;
  line-height: 1;
  flex-shrink: 0;
}

/* ── 바디 ── */
.relics-body {
  max-width: 1400px;
  margin: 0 auto;
  padding: 1.5rem;
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 1.5rem;
  align-items: start;
}
@media (max-width: 900px) {
  .relics-body { grid-template-columns: 1fr; }
}

/* ── 필터 패널 (characters.astro와 동일) ── */
.filter-panel {
  position: sticky;
  top: 72px;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-lg);
  padding: 1.25rem;
}
@media (max-width: 900px) {
  .filter-panel { position: static; }
}

.filter-group { display: flex; flex-direction: column; gap: 0.6rem; }
.filter-label {
  font-size: 0.6rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--c-muted);
}

.search-wrap { position: relative; display: flex; align-items: center; }
.search-icon {
  position: absolute; left: 0.7rem;
  color: var(--c-muted); pointer-events: none;
}
.search-input {
  width: 100%;
  padding: 0.5rem 0.75rem 0.5rem 2.1rem;
  border: 1px solid var(--c-border);
  border-radius: var(--radius-sm);
  background: var(--c-surface2);
  color: var(--foreground-color);
  font-size: 0.78rem;
  font-family: var(--font-body);
  outline: none;
  transition: border-color var(--anim-fast);
}
.search-input::placeholder { color: var(--c-muted); }
.search-input:focus { border-color: var(--c-accent); }

.filter-chips { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.fchip {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  padding: 0.35rem 0.7rem;
  border: 1px solid var(--c-border);
  border-radius: var(--radius-sm);
  background: var(--c-surface2);
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  color: var(--c-muted);
  cursor: pointer;
  transition: border-color var(--anim-fast), color var(--anim-fast), background var(--anim-fast);
  min-height: 32px;
}
.fchip:hover { border-color: var(--c-border-hi); color: var(--foreground-color); }
.fchip--active {
  border-color: var(--c-accent);
  background: var(--c-accent-glow);
  color: var(--c-accent);
}

.reset-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.4rem 0.8rem;
  border: 1px solid var(--c-border);
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--c-muted);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  cursor: pointer;
  transition: border-color var(--anim-fast), color var(--anim-fast);
  align-self: flex-start;
}
.reset-btn:hover { border-color: var(--c-accent); color: var(--c-accent); }

.filter-result {
  font-size: 0.65rem;
  font-weight: 700;
  color: var(--c-accent);
  letter-spacing: 0.04em;
}
.filter-result-total { color: var(--c-muted); font-weight: 500; }

/* ── 유물 리스트 ── */
.relics-list-wrap { min-width: 0; }
.relics-list {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

/* ── 유물 카드 ── */
.relic-card {
  border: 1px solid var(--c-border);
  border-radius: var(--radius-lg);
  background: var(--c-surface);
  overflow: hidden;
  transition: border-color var(--anim-fast);
  content-visibility: auto;
  contain-intrinsic-size: 0 140px;
}
.relic-card:hover { border-color: var(--c-border-hi); }

/* 카드 헤더 */
.relic-card-header {
  display: flex;
  align-items: center;
  gap: 0.9rem;
  padding: 1rem 1.1rem;
  border-bottom: 1px solid var(--c-border);
  background: var(--c-surface2);
}

.relic-icon-wrap {
  flex-shrink: 0;
  width: 48px; height: 48px;
  border-radius: var(--radius-md);
  border: 1px solid var(--c-border-hi);
  background: var(--c-bg);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; padding: 4px;
}
.relic-icon { width: 100%; height: 100%; object-fit: contain; }

.relic-header-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.relic-type-badge {
  display: inline-flex;
  align-self: flex-start;
  font-size: 0.58rem;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border-radius: 4px;
  padding: 0.15em 0.5em;
  border: 1px solid;
}
.relic-type-badge--relic {
  color: #60a5fa;
  background: rgba(96,165,250,0.1);
  border-color: rgba(96,165,250,0.3);
}
.relic-type-badge--planar {
  color: #a78bfa;
  background: rgba(167,139,250,0.1);
  border-color: rgba(167,139,250,0.3);
}

.relic-name {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: 0.01em;
  line-height: 1.2;
  word-break: keep-all;
}

/* 세트 효과 */
.relic-effects {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.relic-effect-row {
  display: flex;
  align-items: flex-start;
  gap: 0.8rem;
  padding: 0.75rem 1.1rem;
  border-bottom: 1px solid var(--c-border);
}
.relic-effect-row:last-child { border-bottom: none; }

.relic-pc-tag {
  flex-shrink: 0;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  font-weight: 900;
  border-radius: 5px;
  padding: 0.2em 0.5em;
  margin-top: 0.1rem;
  border: 1px solid;
  white-space: nowrap;
}
.relic-pc-tag--2 {
  color: var(--c-accent);
  background: var(--c-accent-glow);
  border-color: color-mix(in srgb, var(--c-accent) 35%, transparent);
}
.relic-pc-tag--4 {
  color: #a78bfa;
  background: rgba(167,139,250,0.1);
  border-color: rgba(167,139,250,0.3);
}

.relic-effect-text {
  font-size: 0.8rem;
  line-height: 1.75;
  color: var(--c-muted);
  word-break: keep-all;
  flex: 1;
}

/* 검색 결과 없음 */
.filter-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  padding: 5rem 2rem;
  color: var(--c-muted);
  text-align: center;
  border: 1px dashed var(--c-border);
  border-radius: var(--radius-lg);
  font-size: 0.85rem;
  font-weight: 600;
}
.filter-empty svg { opacity: 0.3; }
.hidden { display: none !important; }

h1, h2, h3, p { word-break: keep-all; }
</style>