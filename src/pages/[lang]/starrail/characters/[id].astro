              <div class="eidolons-grid">
                {eidolons.map((eidolon, index) => (
                  <div class="eidolon-card">
                    <span class="eidolon-rank">E{index + 1}</span>
                    <div class="eidolon-body">
                      <p class="eidolon-name">{cleanText(eidolon.name)}</p>
                      <p
                        class="eidolon-desc"
                        set:html={formatGameDesc(
                          eidolon.desc,
                          Array.isArray(eidolon.params?.[0]) ? eidolon.params[0] : eidolon.params,
