---
// src/components/ToolExtraContent.astro
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

interface Props {
  introSummary?: string
  contextUsage?: { title: string; desc: string }[]
  howto?: { step: string; description: string }[]
  why?: string[]
  faq?: { q: string; a: string }[]
  technicalSpecs?: { quality: string; size: string; useCase: string }[]
  troubleshooting?: string[]
  proTips?: string[]
  keywords?: string[]
}

const { introSummary, contextUsage, howto, why, faq, technicalSpecs, troubleshooting, proTips, keywords } = Astro.props
---

<div class="mt-20 flex flex-col gap-20">
  {
    howto && howto.length > 0 && (
      <section>
        <Heading level="h2" size="h4" class="mb-8">
          How to Use
        </Heading>
        <div class="grid gap-6 md:grid-cols-3">
          {howto.map((item, index) => (
            <div class="relative rounded-2xl border border-[var(--border-color-subtle)] bg-[var(--background-color-subtle)] p-6">
              <span class="absolute -top-3 -left-3 flex h-8 w-8 items-center justify-center rounded-full bg-[var(--brand-primary)] text-sm font-bold text-white">
                {index + 1}
              </span>
              <h3 class="mb-2 text-base font-bold">{item.step}</h3>
              <p class="text-sm leading-relaxed opacity-70">{item.description}</p>
            </div>
          ))}
        </div>
      </section>
    )
  }

  {
    why && why.length > 0 && (
      <section>
        <Heading level="h2" size="h4" class="mb-8 text-center">
          Why Use Our Tool?
        </Heading>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {why.map((reason) => (
            <div class="flex items-start gap-3 rounded-xl border border-[var(--border-color-subtle)] p-5">
              <Icon name="lucide:check-circle" size="1.25rem" class="mt-0.5 shrink-0 text-green-500" />
              <span class="text-sm font-medium opacity-80">{reason}</span>
            </div>
          ))}
        </div>
      </section>
    )
  }
  {
    contextUsage && contextUsage.length > 0 && (
      <section>
        <Heading level="h2" size="h4" class="mb-8">
          Real-World Use Cases
        </Heading>
        <div class="grid gap-4 sm:grid-cols-3">
          {contextUsage.map((item) => (
            <div class="rounded-2xl border border-[var(--border-color-subtle)] bg-[var(--background-color-subtle)]/30 p-6">
              <h3 class="mb-2 text-base font-bold text-[var(--brand-primary)]">{item.title}</h3>
              <p class="text-sm leading-relaxed opacity-70">{item.desc}</p>
            </div>
          ))}
        </div>
      </section>
    )
  }
  {
    technicalSpecs && technicalSpecs.length > 0 && (
      <section>
        <Heading level="h2" size="h4" class="mb-8">
          Technical Specifications
        </Heading>
        <div class="overflow-hidden rounded-2xl border border-[var(--border-color-subtle)]">
          <table class="w-full text-left text-sm">
            <thead class="bg-[var(--background-color-subtle)] opacity-60">
              <tr>
                <th class="px-5 py-4 font-semibold">Quality</th>
                <th class="px-5 py-4 font-semibold">Resolution</th>
                <th class="px-5 py-4 font-semibold">Best Use Case</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[var(--border-color-subtle)]">
              {technicalSpecs.map((spec) => (
                <tr class="transition-colors hover:bg-[var(--background-color-subtle)]/30">
                  <td class="px-5 py-4 font-medium">{spec.quality}</td>
                  <td class="px-5 py-4 font-mono opacity-70">{spec.size}</td>
                  <td class="px-5 py-4 leading-relaxed opacity-70">{spec.useCase}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )
  }

  <div class="grid gap-10 lg:grid-cols-2">
    {
      troubleshooting && troubleshooting.length > 0 && (
        <section>
          <Heading level="h2" size="h5" class="mb-6 flex items-center gap-2">
            <Icon name="lucide:alert-circle" size="1.5rem" class="text-orange-500" />
            Troubleshooting
          </Heading>
          <div class="space-y-3">
            {troubleshooting.map((tip) => (
              <div class="rounded-xl border border-orange-500/10 bg-orange-500/5 px-5 py-4 text-sm leading-snug opacity-80">
                {tip}
              </div>
            ))}
          </div>
        </section>
      )
    }

    {
      proTips && proTips.length > 0 && (
        <section>
          <Heading level="h2" size="h5" class="mb-6 flex items-center gap-2">
            <Icon name="lucide:lightbulb" size="1.5rem" class="text-yellow-500" />
            Pro Tips for Creators
          </Heading>
          <div class="space-y-3">
            {proTips.map((tip) => (
              <div class="rounded-xl border border-yellow-500/10 bg-yellow-500/5 px-5 py-4 text-sm leading-snug opacity-80">
                {tip}
              </div>
            ))}
          </div>
        </section>
      )
    }
  </div>

  {
    faq && faq.length > 0 && (
      <section>
        <Heading level="h2" size="h4" class="mb-8">
          Frequently Asked Questions
        </Heading>
        <div class="grid gap-4">
          {faq.map((item) => (
            <details class="group rounded-2xl border border-[var(--border-color-subtle)] bg-[var(--background-color-subtle)]/20 px-6 py-4 transition-all hover:border-[var(--brand-primary)]">
              <summary class="flex cursor-pointer list-none items-center justify-between font-semibold">
                {item.q}
                <Icon
                  name="lucide:chevron-down"
                  size="1.25rem"
                  class="opacity-40 transition-transform group-open:rotate-180"
                />
              </summary>
              <p class="mt-4 border-t border-[var(--border-color-subtle)] pt-4 text-sm leading-relaxed opacity-70">
                {item.a}
              </p>
            </details>
          ))}
        </div>
      </section>
    )
  }
  {
    introSummary && (
      <section class="mt-10 border-t border-[var(--border-color-subtle)] pt-10">
        <p class="max-w-3xl text-sm leading-relaxed italic opacity-50">{introSummary}</p>
      </section>
    )
  }
  {
    keywords && keywords.length > 0 && (
      <section class="border-t border-[var(--border-color-subtle)] pt-10">
        <p class="mb-4 text-[10px] font-bold tracking-widest uppercase opacity-40">Search Keywords</p>
        <div class="flex flex-wrap gap-x-6 gap-y-2">
          {keywords.map((tag) => (
            <span class="cursor-default text-xs opacity-40 hover:text-[var(--brand-primary)]">
              #{tag.replace(/\s+/g, '')}
            </span>
          ))}
        </div>
      </section>
    )
  }
</div>
