                          {stat.suffix
                            ? `${stat.val % 1 === 0 ? Math.round(stat.val) : stat.val.toFixed(1)}${stat.suffix}`
                            : Math.floor(stat.val)}
                        </span>
                      </div>
                    ))}
                  </div>
                  <p class="stats-note">{labels.statsCurveNote}</p>
                </div>
              )}

              {ascensionMaterials.length > 0 && ascensionTiersJson && ascensionTierCount > 0 && (
                <div class="asc-panel-inner">
                  <div class="panel-header" style="margin-top:2rem">
                    <div class="panel-accent" aria-hidden="true" />
                    <h2 class="panel-title">{labels.ascensionMats}</h2>
                  </div>
                  <label class="lv-control" for="ascension-range-m">
                    <span class="lv-label">{labels.ascensionStep}</span>
                    <span class="lv-val" id="ascension-step-value-m">
                      {ascensionTierCount}
                    </span>
                    <input
                      id="ascension-range-m"
                      type="range"
                      min="1"
                      max={ascensionTierCount}
                      value={ascensionTierCount}
                      class="range-input"
                    />
                  </label>
                  <ul class="mat-list" id="ascension-mats-list-m">
                    {ascensionMaterials.map((m) => (
                      <li class="mat-row">
                        <div class="mat-icon-wrap">
                          {m.icon ? (
                            <img
                              src={m.icon}
                              alt={m.name}
                              width="36"
                              height="36"
                              loading="lazy"
                              decoding="async"
                              class="mat-icon-img"
                            />
                          ) : (
                            <Icon name="lucide:package" size="1.2rem" class="mat-placeholder" />
                          )}
                        </div>
                        <span class="mat-name">{m.name}</span>
                        <span class="mat-num">×{m.num}</span>
