        {/* ── RELICS PANEL ── */}
        {
          hasSections.relics && (
            <section class="tab-panel hidden" id="panel-relics" role="tabpanel" aria-labelledby="tab-btn-relics">
              <div class="panel-header">
                <div class="panel-accent" aria-hidden="true" />
                <h2 class="panel-title">{labels.nav.relics}</h2>
              </div>
