---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Icon } from 'astro-icon/components'
import { Heading } from 'accessible-astro-components'

export async function getStaticPaths() {
  const languages = ['kr', 'en', 'jp', 'cn', 'fr', 'de', 'es', 'id', 'pt', 'ru', 'th', 'vi', 'cht']
  return languages.map((lang) => ({ params: { lang } }))
}

const { lang } = Astro.params

/** 1. 데이터 로드 **/
import tierMocRaw from '../../../tierlist_output/cleaned/final_tierlist_moc.json'
import tierPfRaw from '../../../tierlist_output/cleaned/final_tierlist_pf.json'
import tierAsRaw from '../../../tierlist_output/cleaned/final_tierlist_as.json'

const charModule = await import(`../../data/${lang}/characters.json`);
const characters = charModule.default;

const allModes = {
  MOC: tierMocRaw,
  PF: tierPfRaw,
  AS: tierAsRaw
}

/** 2. 유틸리티 **/
const cleanText = (text: string) => {
  if (!text) return ''
  return text.replace(/\{RUBY_B#([^}]+)\}([^\{]+)\{RUBY_E\#\}/g, '$1').trim()
}

const toAssetUrl = (rel: string) =>
  !rel ? '' : rel.startsWith('/') ? rel : `/assets/${rel.replace(/^\//, '')}`

const tierOrder = ['SS', 'S+', 'S', 'A+', 'A', 'B', 'C', 'D']

// 티어별 배경색상 매핑 객체
const tierColors: Record<string, string> = {
  'SS': 'bg-red-500',
  'S+': 'bg-orange-500',
  'S': 'bg-amber-500',
  'A+': 'bg-purple-500',
  'A': 'bg-indigo-500',
  'B': 'bg-blue-500',
  'C': 'bg-emerald-500',
  'D': 'bg-zinc-500'
};

/** 3. 다국어 레이블 **/
const labels = lang === 'kr' ? {
  title: '티어 리스트',
  subtitle: '최신 메타를 반영한 콘텐츠별 캐릭터 성능 순위입니다.',
  tabMoc: '혼돈의 기억',
  tabPf: '허구 이야기',
  tabAs: '종말의 환영',
  filterRole: '역할분담',
  filterElement: '속성',
  noData: '해당 조건에 맞는 캐릭터가 없습니다.',
} : {
  title: 'Tier List',
  subtitle: 'Character rankings by game mode based on the current meta.',
  tabMoc: 'MOC',
  tabPf: 'PF',
  tabAs: 'AS',
  filterRole: 'Roles',
  filterElement: 'Elements',
  noData: 'No characters found for the selected filters.',
}

const clientTierData = JSON.stringify(allModes);
---

<DefaultLayout title={`${labels.title} | Star Rail DB`}>
  <section class="py-12 bg-zinc-50 dark:bg-black min-h-screen">
    <div class="container">
      <div class="mb-10">
        <nav class="mb-4 flex items-center gap-2 text-xs font-bold tracking-widest uppercase opacity-40">
          <a href={`/${lang}`} class="hover:text-[var(--action-color)] transition-colors">Home</a>
          <Icon name="lucide:chevron-right" size="0.6rem" />
          <span class="text-[var(--action-color)]">{labels.title}</span>
        </nav>
        <Heading level="h1" size="h2" class="italic uppercase tracking-tighter leading-none mb-4">{labels.title}</Heading>
        <p class="text-sm opacity-60">{labels.subtitle}</p>
      </div>

      <div class="flex flex-wrap gap-2 mb-8 p-1.5 rounded-2xl bg-black/5 dark:bg-white/5 w-fit">
        {Object.keys(allModes).map((mode) => (
          <button 
            class="mode-tab-btn px-6 py-2.5 rounded-xl text-sm font-black uppercase tracking-tight transition-all aria-selected:bg-white aria-selected:shadow-md dark:aria-selected:bg-zinc-800" 
            data-mode={mode}
            aria-selected={mode === 'MOC' ? 'true' : 'false'}
          >
            {(labels as any)[`tab${mode.charAt(0) + mode.slice(1).toLowerCase()}`]}
          </button>
        ))}
      </div>

      <div class="mb-12 space-y-6 rounded-3xl border border-[var(--border-color-subtle)] bg-black/[0.02] p-6 dark:bg-white/[0.02]">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <p class="mb-3 text-[10px] font-black uppercase tracking-widest opacity-40">{labels.filterRole}</p>
            <div class="flex flex-wrap gap-2">
              {['DPS', 'Amplifier', 'Sustain'].map(role => (
                <button class="filter-btn role-filter px-4 py-2 rounded-xl border border-[var(--border-color-subtle)] bg-white dark:bg-zinc-900 text-[11px] font-bold transition-all aria-pressed:bg-[var(--action-color)] aria-pressed:text-white" data-value={role} aria-pressed="false">{role}</button>
              ))}
            </div>
          </div>
          <div>
            <p class="mb-3 text-[10px] font-black uppercase tracking-widest opacity-40">{labels.filterElement}</p>
            <div class="flex flex-wrap gap-2">
              {['Physical', 'Fire', 'Ice', 'Thunder', 'Wind', 'Quantum', 'Imaginary'].map(el => (
                <button class="filter-btn element-filter p-2 rounded-xl border border-[var(--border-color-subtle)] bg-white dark:bg-zinc-900 transition-all aria-pressed:border-[var(--action-color)] aria-pressed:ring-2 aria-pressed:ring-[var(--action-color)]" data-value={el} aria-pressed="false" title={el}>
                  <img src={`/assets/icon/element/${el}.webp`} class="w-5 h-5 object-contain" alt={el} />
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div id="tier-list-container" class="space-y-12">
        {tierOrder.map(tier => (
          <div class="tier-group" data-tier={tier}>
            <div class="flex items-center gap-4 mb-6">
              <div class={`w-12 h-12 flex items-center justify-center rounded-2xl text-xl font-black shadow-lg shadow-current/20 text-white ${tierColors[tier]}`}>
                {tier}
              </div>
              <div class="h-px flex-1 bg-gradient-to-r from-[var(--border-color-subtle)] to-transparent"></div>
            </div>
            
            <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 xl:grid-cols-10 gap-4 character-grid">
              {allModes.MOC.list.filter(c => c.tier === tier).map(item => {
                const charMeta = characters[item.id];
                const localizedName = charMeta ? cleanText(charMeta.name) : item.name;
                return (
                  <a href={`/${lang}/character/${item.id}`} 
                     class="char-node group relative flex flex-col items-center" 
                     data-role={item.role} 
                     data-element={item.element}>
                    <div class="relative w-full aspect-square rounded-2xl overflow-hidden border-2 border-[var(--border-color-subtle)] bg-zinc-200 dark:bg-zinc-800 transition-all group-hover:border-[var(--action-color)] group-hover:-translate-y-1 group-hover:shadow-xl">
                      <img src={toAssetUrl(charMeta?.icon || '')} alt={localizedName} class="w-full h-full object-cover" loading="lazy" />
                      <div class="absolute top-1 left-1 w-5 h-5 p-0.5 rounded-lg bg-black/40 backdrop-blur-sm">
                        <img src={`/assets/icon/element/${item.element}.webp`} alt="" class="w-full h-full object-contain" />
                      </div>
                    </div>
                    <span class="mt-2 text-[11px] font-bold text-center leading-tight opacity-80 group-hover:opacity-100">{localizedName}</span>
                  </a>
                )
              })}
            </div>
          </div>
        ))}
      </div>

      <div id="empty-message" class="hidden py-32 text-center opacity-40">
        <Icon name="lucide:search-x" size="3rem" class="mx-auto mb-4" />
        <p class="font-bold">{labels.noData}</p>
      </div>
    </div>
  </section>
</DefaultLayout>

<script is:inline define:vars={{ clientTierData, characters, lang }}>
  const tierData = JSON.parse(clientTierData);
  let currentMode = 'MOC';
  let activeFilters = { role: null, element: null };

  const emptyMsg = document.getElementById('empty-message');
  const modeBtns = document.querySelectorAll('.mode-tab-btn');
  const filterBtns = document.querySelectorAll('.filter-btn');

  function renderTierList() {
    const modeList = tierData[currentMode].list;
    const tierGroups = document.querySelectorAll('.tier-group');
    let totalVisible = 0;

    tierGroups.forEach(group => {
      const tier = group.dataset.tier;
      const grid = group.querySelector('.character-grid');
      
      const filtered = modeList.filter(c => {
        const matchTier = c.tier === tier;
        const matchRole = !activeFilters.role || c.role === activeFilters.role;
        const matchElement = !activeFilters.element || c.element === activeFilters.element;
        return matchTier && matchRole && matchElement;
      });

      if (filtered.length === 0) {
        group.classList.add('hidden');
      } else {
        group.classList.remove('hidden');
        grid.innerHTML = filtered.map(item => {
          const charMeta = characters[item.id];
          const iconUrl = charMeta?.icon ? (charMeta.icon.startsWith('/') ? charMeta.icon : `/assets/${charMeta.icon}`) : '';
          const localizedName = charMeta ? charMeta.name.replace(/\{RUBY_B#([^}]+)\}([^\{]+)\{RUBY_E\#\}/g, '$1') : item.name;

          return `
            <a href="/${lang}/character/${item.id}" class="char-node group relative flex flex-col items-center animate-in fade-in slide-in-from-bottom-2 duration-300">
              <div class="relative w-full aspect-square rounded-2xl overflow-hidden border-2 border-zinc-200 dark:border-zinc-800 bg-zinc-200 dark:bg-zinc-800 transition-all hover:border-[#ff3a55] hover:-translate-y-1 hover:shadow-xl">
                <img src="${iconUrl}" alt="${localizedName}" class="w-full h-full object-cover" />
                <div class="absolute top-1 left-1 w-5 h-5 p-0.5 rounded-lg bg-black/40 backdrop-blur-sm">
                  <img src="/assets/icon/element/${item.element}.webp" alt="" class="w-full h-full object-contain" />
                </div>
              </div>
              <span class="mt-2 text-[11px] font-bold text-center leading-tight opacity-80">${localizedName}</span>
            </a>
          `;
        }).join('');
        totalVisible += filtered.length;
      }
    });

    emptyMsg.classList.toggle('hidden', totalVisible > 0);
  }

  modeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      currentMode = btn.dataset.mode;
      modeBtns.forEach(b => b.setAttribute('aria-selected', b === btn));
      renderTierList();
    });
  });

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.classList.contains('role-filter') ? 'role' : 'element';
      const val = btn.dataset.value;
      if (activeFilters[type] === val) {
        activeFilters[type] = null;
        btn.setAttribute('aria-pressed', 'false');
      } else {
        document.querySelectorAll(`.${type}-filter`).forEach(b => b.setAttribute('aria-pressed', 'false'));
        activeFilters[type] = val;
        btn.setAttribute('aria-pressed', 'true');
      }
      renderTierList();
    });
  });

  renderTierList();
</script>

<style>
  .mode-tab-btn[aria-selected="true"] { color: var(--action-color); }
  .animate-in { animation: animate-in 0.3s ease-out; }
  @keyframes animate-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  h1, h2 { word-break: keep-all; }
</style>