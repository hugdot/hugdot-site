---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import Hero from '@components/Hero.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

const categories = [
  {
    label: 'Text Tools',
    icon: 'lucide:type',
    href: '/tools/text',
    tools: [
      { label: 'Word Counter', href: '/tools/text/word-counter', description: 'Count words, characters & sentences' },
    ],
  },
  {
    label: 'Image Tools',
    icon: 'lucide:image',
    href: '/tools/image',
    tools: [
      {
        label: 'Image Compressor',
        href: '/tools/image/compressor',
        description: 'Compress images without quality loss',
      },
      { label: 'Image Resizer', href: '/tools/image/resizer', description: 'Resize images to any dimension' },
      { label: 'Image Blur', href: '/tools/image/blur', description: 'Blur entire image or specific areas' },
      { label: 'Image Crop', href: '/tools/image/crop', description: 'Crop images with touch support' },
      { label: 'Image to PDF', href: '/tools/image/to-pdf', description: 'Convert images to a PDF file' },
      { label: 'EXIF Remover', href: '/tools/image/exif-remover', description: 'Remove hidden metadata from photos' },
    ],
  },
  {
    label: 'PDF Tools',
    icon: 'lucide:file-text',
    href: '/tools/pdf',
    tools: [
      { label: 'PDF Merger', href: '/tools/pdf/merger', description: 'Merge multiple PDFs into one file' },
      { label: 'PDF Splitter', href: '/tools/pdf/splitter', description: 'Split PDF into separate pages' },
      { label: 'PDF to Image', href: '/tools/pdf/to-image', description: 'Convert PDF pages to images' },
    ],
  },
  {
    label: 'Generators',
    icon: 'lucide:wand',
    href: '/tools/generator',
    tools: [
      {
        label: 'QR Code Generator',
        href: '/tools/generator/qr-code',
        description: 'Generate QR codes for any URL or text',
      },
    ],
  },
]
---

<DefaultLayout title="HugDot" useTitleTemplate={true}>
  <Hero />

  <!-- Category Overview Grid -->
  <section class="my-16">
    <div class="container">
      <Heading level="h2" class="mb-8 text-center text-2xl font-bold">Tool Categories</Heading>
      <ul class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
        {
          categories.map((cat) => (
            <li>
              <a
                href={cat.href}
                class="category-card flex flex-col items-center gap-3 rounded-xl border border-[var(--border-color-subtle)] p-6 text-center text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)] hover:shadow-md"
              >
                <Icon aria-hidden="true" name={cat.icon} size="2rem" class="text-[var(--action-color)]" />
                <span class="text-sm font-semibold">{cat.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Tool Lists by Category -->
  <section id="tools" class="my-16 scroll-mt-8">
    <div class="container flex flex-col gap-20">
      {
        categories.map((category) => (
          <div data-category={category.label.toLowerCase()}>
            <div class="mb-6 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <Icon aria-hidden="true" name={category.icon} size="1.5rem" class="text-[var(--action-color)]" />
                <Heading level="h2" size="h4">
                  {category.label}
                </Heading>
              </div>
              <a href={category.href} class="text-sm text-[var(--action-color)] underline-offset-4 hover:underline">
                See all →
              </a>
            </div>
            <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
              {category.tools.map((tool) => (
                <li>
                  <a
                    href={tool.href}
                    class="tool-card flex h-full flex-col gap-2 rounded-xl border border-[var(--border-color-subtle)] p-5 text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)] hover:shadow-md"
                    data-tool-name={tool.label.toLowerCase()}
                  >
                    <span class="font-semibold">{tool.label}</span>
                    <span class="text-sm opacity-60">{tool.description}</span>
                    <span class="mt-auto pt-2 text-xs font-medium text-[var(--action-color)]">Open →</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>
</DefaultLayout>

<style>
  .tool-card,
  .category-card {
    color: var(--foreground-color) !important;
    text-decoration: none !important;
  }

  .tool-card:where(:hover, :focus-visible),
  .category-card:where(:hover, :focus-visible) {
    color: var(--foreground-color) !important;
  }
</style>
