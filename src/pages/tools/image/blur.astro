---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import seoData from '@data/seo/en/image-blur.json'
import { tools, getToolHref } from '@data/tools/index'

const relatedTools = tools.filter((t) => t.category === 'image' && t.id !== 'image-blur' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="MultimediaApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">
      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/image" class="breadcrumb-link hover:underline">Image Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Blur your entire image or draw areas to blur with your finger. Your images never leave your device — 100%
          private.
        </p>
      </div>

      <!-- Drop Zone -->
      <div
        id="drop-zone"
        class="flex cursor-pointer flex-col items-center justify-center gap-4 rounded-2xl border-2 border-dashed border-[var(--border-color-subtle)] p-12 text-center transition-all hover:border-[var(--action-color)]"
      >
        <Icon aria-hidden="true" name="lucide:image-plus" size="3rem" class="opacity-30" />
        <div>
          <p class="font-semibold">Open an image</p>
          <p class="text-sm opacity-50">or tap to choose</p>
        </div>
        <p class="text-xs opacity-40">Supports JPG, PNG, WebP</p>
        <input id="file-input" type="file" accept="image/*" class="hidden" aria-label="Open image" />
      </div>

      <!-- Editor -->
      <div id="editor-panel" class="mt-6 hidden flex-col gap-4">
        <!-- Mode Tabs -->
        <div class="flex gap-2">
          <button
            class="mode-btn flex-1 rounded-xl border-2 border-[var(--action-color)] bg-[var(--action-color)] px-4 py-3 text-sm font-semibold text-white transition-all"
            data-mode="area"
          >
            Area Blur
          </button>
          <button
            class="mode-btn flex-1 rounded-xl border-2 border-[var(--border-color-subtle)] px-4 py-3 text-sm font-semibold transition-all hover:border-[var(--action-color)]"
            data-mode="full"
          >
            Full Blur
          </button>
        </div>

        <!-- Blur Strength -->
        <div class="flex flex-col gap-2">
          <div class="flex items-center justify-between">
            <label class="text-sm opacity-60">Blur strength</label>
            <span id="blur-value" class="text-sm font-bold text-[var(--action-color)]">20</span>
          </div>
          <input
            id="blur-slider"
            type="range"
            min="2"
            max="50"
            step="1"
            value="20"
            class="w-full accent-[var(--action-color)]"
          />
        </div>

        <!-- Area Blur Hint -->
        <div
          id="area-hint"
          class="flex items-center gap-2 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm opacity-60"
        >
          <Icon aria-hidden="true" name="lucide:hand" size="1rem" class="shrink-0" />
          <span>Draw rectangles on the image to blur specific areas. Tap a blurred area to remove it.</span>
        </div>

        <!-- Canvas Wrapper -->
        <div
          class="relative w-full overflow-hidden rounded-2xl border border-[var(--border-color-subtle)]"
          id="canvas-wrapper"
        >
          <canvas id="canvas-display" class="w-full cursor-crosshair touch-none"></canvas>
        </div>

        <!-- Area Controls -->
        <div id="area-controls" class="flex gap-2">
          <button
            id="undo-btn"
            class="flex flex-1 items-center justify-center gap-2 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]"
          >
            <Icon aria-hidden="true" name="lucide:undo" size="1rem" />
            Undo
          </button>
          <button
            id="clear-btn"
            class="flex flex-1 items-center justify-center gap-2 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]"
          >
            <Icon aria-hidden="true" name="lucide:trash-2" size="1rem" />
            Clear All
          </button>
        </div>

        <!-- Save Button -->
        <button
          id="save-btn"
          class="flex w-full items-center justify-center gap-2 rounded-2xl bg-[var(--action-color)] px-6 py-4 font-semibold text-white transition-opacity hover:opacity-80"
        >
          <Icon aria-hidden="true" name="lucide:save" size="1.25rem" />
          Save Image
        </button>

        <!-- Open Another -->
        <button
          id="reset-btn"
          class="flex w-full items-center justify-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-6 py-4 text-sm font-medium transition-all hover:border-[var(--action-color)]"
        >
          <Icon aria-hidden="true" name="lucide:refresh-cw" size="1rem" />
          Open Another Image
        </button>
      </div>

      <!-- Privacy Badge -->
      <div
        class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60"
      >
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Your images never leave your device. No data is sent to any server.</span>
      </div>
      
      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="mt-12">
          <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {relatedTools.map((tool) => (
              <a href={getToolHref(tool.category, tool.slug)}
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]">
                {tool.label} →
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</DefaultLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const dropZone = document.getElementById('drop-zone') as HTMLDivElement
    const fileInput = document.getElementById('file-input') as HTMLInputElement
    const editorPanel = document.getElementById('editor-panel') as HTMLDivElement
    const canvasDisplay = document.getElementById('canvas-display') as HTMLCanvasElement
    const blurSlider = document.getElementById('blur-slider') as HTMLInputElement
    const blurValue = document.getElementById('blur-value') as HTMLSpanElement
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement
    const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement
    const undoBtn = document.getElementById('undo-btn') as HTMLButtonElement
    const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement
    const areaHint = document.getElementById('area-hint') as HTMLDivElement
    const areaControls = document.getElementById('area-controls') as HTMLDivElement

    let originalImage: HTMLImageElement | null = null
    let originalFile: File | null = null
    let activeMode = 'area'
    let blurRegions: { x: number; y: number; w: number; h: number; strength: number }[] = []
    let isDrawing = false
    let startX = 0
    let startY = 0
    let currentRect = { x: 0, y: 0, w: 0, h: 0 }

    const ctx = canvasDisplay.getContext('2d')!

    // Mode switching
    document.querySelectorAll<HTMLButtonElement>('.mode-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        activeMode = btn.dataset.mode ?? 'area'
        document.querySelectorAll<HTMLButtonElement>('.mode-btn').forEach((b) => {
          const isActive = b.dataset.mode === activeMode
          b.classList.toggle('bg-[var(--action-color)]', isActive)
          b.classList.toggle('text-white', isActive)
          b.classList.toggle('border-[var(--action-color)]', isActive)
          b.classList.toggle('border-[var(--border-color-subtle)]', !isActive)
        })
        areaHint.classList.toggle('hidden', activeMode === 'full')
        areaControls.classList.toggle('hidden', activeMode === 'full')
        redraw()
      })
    })

    // Blur slider
    blurSlider.addEventListener('input', () => {
      blurValue.textContent = blurSlider.value
      redraw()
    })

    // Load image
    const loadImage = (file: File) => {
      if (!file.type.startsWith('image/')) return
      originalFile = file
      const url = URL.createObjectURL(file)
      const img = new Image()
      img.onload = () => {
        originalImage = img
        canvasDisplay.width = img.width
        canvasDisplay.height = img.height
        blurRegions = []
        redraw()
        dropZone.style.display = 'none'
        editorPanel.classList.remove('hidden')
        editorPanel.classList.add('flex')
      }
      img.src = url
    }

    // Redraw canvas
    const redraw = () => {
      if (!originalImage) return
      const strength = parseInt(blurSlider.value)

      ctx.clearRect(0, 0, canvasDisplay.width, canvasDisplay.height)

      if (activeMode === 'full') {
        // Full blur
        ctx.filter = `blur(${strength}px)`
        ctx.drawImage(originalImage, 0, 0)
        ctx.filter = 'none'
      } else {
        // Draw original
        ctx.filter = 'none'
        ctx.drawImage(originalImage, 0, 0)

        // Apply each blur region
        blurRegions.forEach((region) => {
          applyBlurRegion(region.x, region.y, region.w, region.h, region.strength)
        })

        // Draw current selection
        if (isDrawing) {
          ctx.strokeStyle = 'rgba(255,255,255,0.8)'
          ctx.lineWidth = 2
          ctx.setLineDash([6, 3])
          ctx.strokeRect(currentRect.x, currentRect.y, currentRect.w, currentRect.h)
          ctx.setLineDash([])
        }
      }
    }

    const applyBlurRegion = (x: number, y: number, w: number, h: number, strength: number) => {
      if (w === 0 || h === 0) return
      const rx = Math.min(x, x + w)
      const ry = Math.min(y, y + h)
      const rw = Math.abs(w)
      const rh = Math.abs(h)

      ctx.save()
      ctx.beginPath()
      ctx.rect(rx, ry, rw, rh)
      ctx.clip()
      ctx.filter = `blur(${strength}px)`
      // Draw slightly larger to avoid edge artifacts
      ctx.drawImage(
        originalImage!,
        rx - strength,
        ry - strength,
        rw + strength * 2,
        rh + strength * 2,
        rx - strength,
        ry - strength,
        rw + strength * 2,
        rh + strength * 2,
      )
      ctx.filter = 'none'
      ctx.restore()

      // Subtle overlay
      ctx.fillStyle = 'rgba(0,0,0,0.05)'
      ctx.fillRect(rx, ry, rw, rh)
    }

    // Get position relative to canvas (handles scaling)
    const getPos = (clientX: number, clientY: number) => {
      const rect = canvasDisplay.getBoundingClientRect()
      const scaleX = canvasDisplay.width / rect.width
      const scaleY = canvasDisplay.height / rect.height
      return {
        x: (clientX - rect.left) * scaleX,
        y: (clientY - rect.top) * scaleY,
      }
    }

    // Mouse events
    canvasDisplay.addEventListener('mousedown', (e) => {
      if (activeMode !== 'area') return
      const pos = getPos(e.clientX, e.clientY)
      startX = pos.x
      startY = pos.y
      isDrawing = true
    })

    canvasDisplay.addEventListener('mousemove', (e) => {
      if (!isDrawing || activeMode !== 'area') return
      const pos = getPos(e.clientX, e.clientY)
      currentRect = { x: startX, y: startY, w: pos.x - startX, h: pos.y - startY }
      redraw()
    })

    canvasDisplay.addEventListener('mouseup', (e) => {
      if (!isDrawing || activeMode !== 'area') return
      isDrawing = false
      const pos = getPos(e.clientX, e.clientY)
      const w = pos.x - startX
      const h = pos.y - startY
      if (Math.abs(w) > 10 && Math.abs(h) > 10) {
        blurRegions.push({ x: startX, y: startY, w, h, strength: parseInt(blurSlider.value) })
      }
      currentRect = { x: 0, y: 0, w: 0, h: 0 }
      redraw()
    })

    // Touch events
    canvasDisplay.addEventListener(
      'touchstart',
      (e) => {
        if (activeMode !== 'area') return
        e.preventDefault()
        const touch = e.touches[0]
        const pos = getPos(touch.clientX, touch.clientY)
        startX = pos.x
        startY = pos.y
        isDrawing = true
      },
      { passive: false },
    )

    canvasDisplay.addEventListener(
      'touchmove',
      (e) => {
        if (!isDrawing || activeMode !== 'area') return
        e.preventDefault()
        const touch = e.touches[0]
        const pos = getPos(touch.clientX, touch.clientY)
        currentRect = { x: startX, y: startY, w: pos.x - startX, h: pos.y - startY }
        redraw()
      },
      { passive: false },
    )

    canvasDisplay.addEventListener(
      'touchend',
      (e) => {
        if (!isDrawing || activeMode !== 'area') return
        e.preventDefault()
        isDrawing = false
        if (Math.abs(currentRect.w) > 10 && Math.abs(currentRect.h) > 10) {
          blurRegions.push({
            x: startX,
            y: startY,
            w: currentRect.w,
            h: currentRect.h,
            strength: parseInt(blurSlider.value),
          })
        }
        currentRect = { x: 0, y: 0, w: 0, h: 0 }
        redraw()
      },
      { passive: false },
    )

    // Undo
    undoBtn.addEventListener('click', () => {
      blurRegions.pop()
      redraw()
    })

    // Clear all
    clearBtn.addEventListener('click', () => {
      blurRegions = []
      redraw()
    })

    // Save
    saveBtn.addEventListener('click', () => {
      if (!originalFile) return
      const ext = originalFile.name.split('.').pop()?.toLowerCase() ?? 'jpg'
      const mimeType = ext === 'png' ? 'image/png' : 'image/jpeg'
      const name = originalFile.name.replace(/\.[^/.]+$/, '')
      canvasDisplay.toBlob(
        (blob) => {
          if (!blob) return
          const url = URL.createObjectURL(blob)
          const a = document.createElement('a')
          a.href = url
          a.download = `${name}-blurred.${ext}`
          a.click()
          URL.revokeObjectURL(url)
        },
        mimeType,
        0.95,
      )
    })

    // Reset
    resetBtn.addEventListener('click', () => {
      originalImage = null
      originalFile = null
      blurRegions = []
      fileInput.value = ''
      editorPanel.classList.add('hidden')
      editorPanel.classList.remove('flex')
      dropZone.style.display = 'flex'
    })

    // Drop zone
    dropZone.addEventListener('click', () => fileInput.click())
    fileInput.addEventListener('change', () => {
      if (fileInput.files?.[0]) loadImage(fileInput.files[0])
    })

    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault()
      dropZone.classList.add('border-[var(--action-color)]')
    })
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-[var(--action-color)]'))
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault()
      dropZone.classList.remove('border-[var(--action-color)]')
      if (e.dataTransfer?.files?.[0]) loadImage(e.dataTransfer.files[0])
    })
  })
</script>
