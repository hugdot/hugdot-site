---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools, getToolHref } from '@data/tools/index'
import seoData from '@data/seo/en/coin-flipper.json'

const relatedTools = tools.filter((t) => t.category === 'generator' && t.id !== 'coin-flipper' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="UtilitiesApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">

      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/generator" class="breadcrumb-link hover:underline">Generator Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Flip a coin or roll dice instantly. Perfect for decisions, games, and settling disputes.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:wifi-off" size="0.875rem" class="text-[var(--action-color)]" />
            Works Offline
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:zap" size="0.875rem" class="text-[var(--action-color)]" />
            Instant
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:infinity" size="0.875rem" class="text-[var(--action-color)]" />
            No Limits
          </span>
        </div>
      </div>

      <!-- Tool -->
      <div class="flex flex-col gap-6 rounded-2xl border border-[var(--border-color-subtle)] p-6">

        <!-- Mode Tabs -->
        <div class="flex rounded-full border border-[var(--border-color-subtle)] p-1">
          <button id="tab-coin" class="tab-btn flex-1 rounded-full py-2 text-sm font-medium transition-all">
            🪙 Coin Flip
          </button>
          <button id="tab-dice" class="tab-btn flex-1 rounded-full py-2 text-sm font-medium transition-all">
            🎲 Dice Roller
          </button>
        </div>

        <!-- Coin Flip Panel -->
        <div id="panel-coin" class="flex flex-col items-center gap-6">

          <!-- Coin -->
          <div id="coin" class="relative flex h-40 w-40 cursor-pointer items-center justify-center rounded-full border-4 border-[var(--action-color)] text-6xl shadow-lg transition-transform active:scale-95 select-none">
            <span id="coin-face">🪙</span>
          </div>

          <!-- Result -->
          <div id="coin-result" class="text-center">
            <p id="coin-result-text" class="text-2xl font-bold opacity-20">Tap to flip!</p>
          </div>

          <!-- Flip Button -->
          <button
            id="btn-flip"
            class="flex w-full items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-4 text-base font-semibold text-white transition-opacity hover:opacity-90"
          >
            <Icon aria-hidden="true" name="lucide:refresh-cw" size="1.25rem" />
            Flip Coin
          </button>

          <!-- Stats -->
          <div class="grid w-full grid-cols-3 gap-3">
            <div class="flex flex-col items-center rounded-xl border border-[var(--border-color-subtle)] px-4 py-3">
              <span id="stat-heads" class="text-xl font-bold text-[var(--action-color)]">0</span>
              <span class="text-xs opacity-50">Heads</span>
            </div>
            <div class="flex flex-col items-center rounded-xl border border-[var(--border-color-subtle)] px-4 py-3">
              <span id="stat-tails" class="text-xl font-bold text-[var(--action-color)]">0</span>
              <span class="text-xs opacity-50">Tails</span>
            </div>
            <div class="flex flex-col items-center rounded-xl border border-[var(--border-color-subtle)] px-4 py-3">
              <span id="stat-total" class="text-xl font-bold opacity-40">0</span>
              <span class="text-xs opacity-50">Total</span>
            </div>
          </div>

          <!-- History -->
          <div id="coin-history" class="flex w-full flex-wrap gap-2"></div>

        </div>

        <!-- Dice Roller Panel -->
        <div id="panel-dice" class="hidden flex-col items-center gap-6">

          <!-- Dice Type -->
          <div class="flex w-full flex-wrap gap-2">
            {['D4', 'D6', 'D8', 'D10', 'D12', 'D20'].map((d) => (
              <button
                data-dice={d}
                class="dice-type-btn flex-1 rounded-xl border border-[var(--border-color-subtle)] py-3 text-sm font-bold transition-all hover:border-[var(--action-color)]"
              >
                {d}
              </button>
            ))}
          </div>

          <!-- Number of Dice -->
          <div class="flex w-full items-center justify-between gap-4">
            <span class="text-sm font-medium">Number of Dice</span>
            <div class="flex items-center gap-3">
              <button id="dice-minus" class="flex h-8 w-8 items-center justify-center rounded-full border border-[var(--border-color-subtle)] font-bold transition-all hover:border-[var(--action-color)]">−</button>
              <span id="dice-count" class="w-6 text-center font-bold">1</span>
              <button id="dice-plus" class="flex h-8 w-8 items-center justify-center rounded-full border border-[var(--border-color-subtle)] font-bold transition-all hover:border-[var(--action-color)]">+</button>
            </div>
          </div>

          <!-- Dice Result Display -->
          <div id="dice-faces" class="flex min-h-[80px] w-full flex-wrap justify-center gap-3"></div>

          <!-- Total -->
          <div id="dice-total-wrap" class="hidden w-full flex-col items-center rounded-2xl border border-[var(--border-color-subtle)] py-5">
            <span class="text-xs opacity-50">Total</span>
            <span id="dice-total" class="text-4xl font-bold text-[var(--action-color)]">0</span>
          </div>

          <!-- Roll Button -->
          <button
            id="btn-roll"
            class="flex w-full items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-4 text-base font-semibold text-white transition-opacity hover:opacity-90"
          >
            <Icon aria-hidden="true" name="lucide:dices" size="1.25rem" />
            Roll Dice
          </button>

          <!-- Dice History -->
          <div id="dice-history" class="flex w-full flex-col gap-2"></div>

        </div>

      </div>

      <!-- Privacy Badge -->
      <div class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60">
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>All results are generated locally in your browser. No data is sent to any server.</span>
      </div>

      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="mt-12">
          <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {relatedTools.map((tool) => (
              <a href={getToolHref(tool.category, tool.slug)}
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]">
                {tool.label} →
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</DefaultLayout>

<style>
  .tab-btn.active {
    background-color: var(--action-color);
    color: white;
  }
  .dice-type-btn.active {
    background-color: var(--action-color);
    color: white;
    border-color: var(--action-color);
  }
  #coin.flipping {
    animation: coinFlip 0.5s ease-in-out;
  }
  @keyframes coinFlip {
    0% { transform: rotateY(0deg) scale(1); }
    50% { transform: rotateY(90deg) scale(0.8); }
    100% { transform: rotateY(0deg) scale(1); }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const tabCoin = document.getElementById('tab-coin') as HTMLButtonElement
    const tabDice = document.getElementById('tab-dice') as HTMLButtonElement
    const panelCoin = document.getElementById('panel-coin') as HTMLElement
    const panelDice = document.getElementById('panel-dice') as HTMLElement

    // Coin
    const coin = document.getElementById('coin') as HTMLElement
    const coinFace = document.getElementById('coin-face') as HTMLElement
    const coinResultText = document.getElementById('coin-result-text') as HTMLElement
    const btnFlip = document.getElementById('btn-flip') as HTMLButtonElement
    const statHeads = document.getElementById('stat-heads') as HTMLElement
    const statTails = document.getElementById('stat-tails') as HTMLElement
    const statTotal = document.getElementById('stat-total') as HTMLElement
    const coinHistory = document.getElementById('coin-history') as HTMLElement

    // Dice
    const diceTypeBtns = document.querySelectorAll('.dice-type-btn') as NodeListOf<HTMLButtonElement>
    const diceMinus = document.getElementById('dice-minus') as HTMLButtonElement
    const dicePlus = document.getElementById('dice-plus') as HTMLButtonElement
    const diceCount = document.getElementById('dice-count') as HTMLElement
    const diceFaces = document.getElementById('dice-faces') as HTMLElement
    const diceTotalWrap = document.getElementById('dice-total-wrap') as HTMLElement
    const diceTotal = document.getElementById('dice-total') as HTMLElement
    const btnRoll = document.getElementById('btn-roll') as HTMLButtonElement
    const diceHistory = document.getElementById('dice-history') as HTMLElement

    let headsCount = 0
    let tailsCount = 0
    let coinHistoryArr: string[] = []
    let currentDice = 'D6'
    let numDice = 1
    let diceHistoryArr: string[] = []
    let isFlipping = false

    // Tab switching
    const setTab = (tab: string) => {
      tabCoin.classList.toggle('active', tab === 'coin')
      tabDice.classList.toggle('active', tab === 'dice')
      panelCoin.style.display = tab === 'coin' ? 'flex' : 'none'
      panelDice.style.display = tab === 'dice' ? 'flex' : 'none'
    }

    tabCoin.addEventListener('click', () => setTab('coin'))
    tabDice.addEventListener('click', () => setTab('dice'))
    setTab('coin')

    // Coin flip
    const flip = () => {
      if (isFlipping) return
      isFlipping = true
      coin.classList.add('flipping')

      setTimeout(() => {
        const result = Math.random() < 0.5 ? 'Heads' : 'Tails'
        coinFace.textContent = result === 'Heads' ? '👑' : '🌕'
        coinResultText.textContent = result
        coinResultText.style.opacity = '1'
        coinResultText.style.color = 'var(--action-color)'

        if (result === 'Heads') headsCount++
        else tailsCount++

        statHeads.textContent = String(headsCount)
        statTails.textContent = String(tailsCount)
        statTotal.textContent = String(headsCount + tailsCount)

        coinHistoryArr.unshift(result === 'Heads' ? '👑' : '🌕')
        if (coinHistoryArr.length > 20) coinHistoryArr.pop()
        coinHistory.innerHTML = coinHistoryArr.map((c) => `<span class="text-2xl">${c}</span>`).join('')

        coin.classList.remove('flipping')
        isFlipping = false
      }, 250)
    }

    btnFlip.addEventListener('click', flip)
    coin.addEventListener('click', flip)

    // Dice
    const setDiceType = (type: string) => {
      currentDice = type
      diceTypeBtns.forEach((btn) => {
        btn.classList.toggle('active', btn.dataset.dice === type)
      })
    }

    diceTypeBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (btn.dataset.dice) setDiceType(btn.dataset.dice)
      })
    })

    setDiceType('D6')

    diceMinus.addEventListener('click', () => {
      numDice = Math.max(1, numDice - 1)
      diceCount.textContent = String(numDice)
    })

    dicePlus.addEventListener('click', () => {
      numDice = Math.min(10, numDice + 1)
      diceCount.textContent = String(numDice)
    })

    const getDiceFace = (value: number, max: number): string => {
      if (max === 6) {
        const faces = ['⚀', '⚁', '⚂', '⚃', '⚄', '⚅']
        return faces[value - 1]
      }
      return String(value)
    }

    const roll = () => {
      const max = parseInt(currentDice.replace('D', ''))
      const results = Array.from({ length: numDice }, () => Math.floor(Math.random() * max) + 1)
      const total = results.reduce((a, b) => a + b, 0)

      diceFaces.innerHTML = results.map((r) => `
        <div class="flex h-16 w-16 items-center justify-center rounded-2xl border-2 border-[var(--action-color)] text-2xl font-bold text-[var(--action-color)]">
          ${getDiceFace(r, max)}
        </div>
      `).join('')

      diceTotal.textContent = String(total)
      diceTotalWrap.style.display = numDice > 1 ? 'flex' : 'none'

      const historyItem = `${currentDice}: ${results.join(', ')}${numDice > 1 ? ` = ${total}` : ''}`
      diceHistoryArr.unshift(historyItem)
      if (diceHistoryArr.length > 10) diceHistoryArr.pop()

      diceHistory.innerHTML = diceHistoryArr.map((h, i) => `
        <div class="flex items-center gap-2 rounded-xl border border-[var(--border-color-subtle)] px-4 py-2 text-sm ${i === 0 ? 'opacity-100' : 'opacity-40'}">
          ${h}
        </div>
      `).join('')
    }

    btnRoll.addEventListener('click', roll)

    if (typeof (window as any).gtag === 'function') {
      // 1. 동전 던지기 추적 (버튼이나 동전 클릭 시)
      const trackCoin = () => {
        (window as any).gtag('event', 'tool_use', {
          'tool_id': 'coin-flipper',
          'action': 'flip',
          'page_language': 'en'
        });
      };
      btnFlip.addEventListener('click', trackCoin);
      coin.addEventListener('click', trackCoin);

      // 2. 주사위 굴리기 추적
      btnRoll.addEventListener('click', () => {
        (window as any).gtag('event', 'tool_use', {
          'tool_id': 'dice-roller',
          'action': 'roll',
          'dice_type': currentDice,
          'dice_count': numDice,
          'page_language': 'en'
        });
      });
    }
  })
</script>