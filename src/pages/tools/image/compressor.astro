---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools } from '@data/tools'
import seoData from '@data/seo/en/image-compressor.json'

const relatedTools = tools.filter((t) => t.category === 'image' && t.id !== 'image-compressor' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="MultimediaApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">

      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/image" class="breadcrumb-link hover:underline">Image Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Compress up to 20 images at once. 100% private — your photos never leave your device.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:shield-check" size="0.875rem" class="text-[var(--action-color)]" />
            No Upload
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:user-x" size="0.875rem" class="text-[var(--action-color)]" />
            No Login
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:layers" size="0.875rem" class="text-[var(--action-color)]" />
            Batch up to 20
          </span>
        </div>
      </div>

      <!-- Tool -->
      <div class="flex flex-col gap-6">

        <!-- Drop Zone -->
        <div
          id="drop-zone"
          class="flex cursor-pointer flex-col items-center justify-center gap-4 rounded-2xl border-2 border-dashed border-[var(--border-color-subtle)] p-12 text-center transition-all hover:border-[var(--action-color)]"
        >
          <Icon aria-hidden="true" name="lucide:image-plus" size="3rem" class="opacity-30" />
          <div>
            <p class="font-semibold">Open images</p>
            <p class="text-sm opacity-50">or drag & drop here</p>
          </div>
          <p class="text-xs opacity-40">JPG, PNG, WebP — up to 20 files</p>
          <input id="file-input" type="file" accept="image/*" multiple class="hidden" />
        </div>

        <!-- Settings Panel -->
        <div id="settings-panel" class="hidden flex-col gap-4">
          <div class="flex flex-col gap-3">
            <div class="flex items-center justify-between">
              <label class="text-sm font-medium" for="target-slider">Target size per image</label>
              <span id="target-value" class="text-lg font-bold text-[var(--action-color)]">1.0 MB</span>
            </div>
            <input
              id="target-slider"
              type="range"
              min="0.1"
              max="5"
              step="0.1"
              value="1"
              class="w-full accent-[var(--action-color)]"
            />
            <div class="flex justify-between text-xs opacity-40">
              <span>0.1 MB</span>
              <span>5 MB</span>
            </div>
          </div>
        </div>

        <!-- Loading -->
        <div id="loading" class="hidden flex-col items-center gap-3">
          <div class="h-8 w-8 animate-spin rounded-full border-4 border-[var(--border-color-subtle)] border-t-[var(--action-color)]"></div>
          <p id="loading-text" class="text-sm opacity-50">Compressing...</p>
        </div>

        <!-- Result Panel -->
        <div id="result-panel" class="hidden flex-col gap-6">

          <!-- Summary Stats -->
          <div class="grid grid-cols-3 gap-3">
            <div class="flex flex-col items-center rounded-2xl border border-[var(--border-color-subtle)] px-4 py-4">
              <span class="mb-1 text-xs opacity-50">Original</span>
              <span id="size-original" class="text-lg font-bold"></span>
            </div>
            <div class="flex flex-col items-center rounded-2xl border border-[var(--border-color-subtle)] px-4 py-4">
              <span class="mb-1 text-xs opacity-50">Compressed</span>
              <span id="size-compressed" class="text-lg font-bold text-[var(--action-color)]"></span>
            </div>
            <div class="flex flex-col items-center rounded-2xl border border-[var(--border-color-subtle)] px-4 py-4">
              <span class="mb-1 text-xs opacity-50">Saved</span>
              <span id="savings-text" class="text-lg font-bold text-green-500"></span>
            </div>
          </div>

          <!-- Preview (first image) -->
          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-2">
              <p class="text-sm font-medium opacity-60">Original</p>
              <img id="preview-original" src="" alt="Original" class="w-full rounded-2xl border border-[var(--border-color-subtle)] object-cover aspect-square" />
            </div>
            <div class="flex flex-col gap-2">
              <p class="text-sm font-medium opacity-60">Compressed</p>
              <img id="preview-compressed" src="" alt="Compressed" class="w-full rounded-2xl border border-[var(--border-color-subtle)] object-cover aspect-square" />
            </div>
          </div>

          <!-- Batch Grid -->
          <div id="batch-grid" class="grid grid-cols-2 gap-3 sm:grid-cols-3"></div>

          <!-- Actions -->
          <div class="flex gap-3">
            <button
              id="save-btn"
              class="flex flex-1 items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
            >
              <Icon aria-hidden="true" name="lucide:save" size="1rem" />
              Save All
            </button>
            <button
              id="reset-btn"
              class="flex items-center justify-center gap-2 rounded-full border border-[var(--border-color-subtle)] px-6 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]"
            >
              <Icon aria-hidden="true" name="lucide:refresh-cw" size="1rem" />
              Reset
            </button>
          </div>

        </div>

      </div>

      <!-- Privacy Badge -->
      <div class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60">
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Your images never leave your device. No data is sent to any server.</span>
      </div>

      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="mt-12">
          <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {relatedTools.map((tool) => (
              <a href={tool.href}
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]">
                {tool.label} →
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</DefaultLayout>

<script>
  import imageCompression from 'browser-image-compression'
  import JSZip from 'jszip'

  type ProcessingState = 'idle' | 'processing' | 'done'

  let cleanupListeners: (() => void) | null = null

  document.addEventListener('astro:page-load', () => {
    cleanupListeners?.()
    cleanupListeners = initCompressor()
  })

  function initCompressor(): () => void {
    let state: ProcessingState = 'idle'
    let originalFiles: File[] = []
    let compressedResults: File[] = []
    let previewUrls: string[] = []
    let gridUrls: string[] = []
    let downloadUrls: string[] = []
    let debounceTimer: ReturnType<typeof setTimeout> | null = null
    let jobToken = 0

    const MAX_FILES = 20
    const CONCURRENCY = navigator.hardwareConcurrency <= 4 ? 2 : 3

    const dropZone = document.getElementById('drop-zone')!
    const fileInput = document.getElementById('file-input') as HTMLInputElement
    const settingsPanel = document.getElementById('settings-panel')!
    const resultPanel = document.getElementById('result-panel')!
    const loading = document.getElementById('loading')!
    const loadingText = document.getElementById('loading-text')!
    const saveBtn = document.getElementById('save-btn')!
    const resetBtn = document.getElementById('reset-btn')!
    const previewOriginal = document.getElementById('preview-original') as HTMLImageElement
    const previewCompressed = document.getElementById('preview-compressed') as HTMLImageElement
    const sizeOriginal = document.getElementById('size-original')!
    const sizeCompressed = document.getElementById('size-compressed')!
    const savingsText = document.getElementById('savings-text')!
    const targetSlider = document.getElementById('target-slider') as HTMLInputElement
    const targetValue = document.getElementById('target-value')!
    const batchGrid = document.getElementById('batch-grid')!

    const formatSize = (bytes: number) =>
      bytes < 1024 * 1024
        ? `${(bytes / 1024).toFixed(1)} KB`
        : `${(bytes / 1024 / 1024).toFixed(2)} MB`

    const revokeList = (list: string[]) => {
      list.forEach((u) => URL.revokeObjectURL(u))
      list.length = 0
    }

    const show = (el: HTMLElement) => (el.style.display = 'flex')
    const hide = (el: HTMLElement) => (el.style.display = 'none')

    const cleanup = () => {
      jobToken++
      state = 'idle'
      if (debounceTimer) clearTimeout(debounceTimer)
      revokeList(previewUrls)
      revokeList(gridUrls)
      revokeList(downloadUrls)
      batchGrid.innerHTML = ''
      previewOriginal.src = ''
      previewCompressed.src = ''
      originalFiles = []
      compressedResults = []
      hide(resultPanel)
      hide(settingsPanel)
      hide(loading)
      dropZone.style.display = 'flex'
    }

    const compressSingle = async (file: File) => {
      try {
        return await imageCompression(file, {
          maxSizeMB: parseFloat(targetSlider.value),
          useWebWorker: true,
          initialQuality: file.size > 5 * 1024 * 1024 ? 0.82 : 0.92,
        })
      } catch {
        return null
      }
    }

    const renderBatchGrid = () => {
      revokeList(gridUrls)
      batchGrid.innerHTML = ''
      compressedResults.forEach((file, i) => {
        const url = URL.createObjectURL(file)
        gridUrls.push(url)
        const card = document.createElement('div')
        card.className = 'rounded-xl border border-[var(--border-color-subtle)] overflow-hidden'
        card.innerHTML = `
          <img src="${url}" alt="${originalFiles[i].name}" class="aspect-square w-full object-cover" />
          <div class="px-3 py-2">
            <p class="truncate text-xs font-medium">${originalFiles[i].name}</p>
            <p class="text-xs opacity-50">${formatSize(originalFiles[i].size)} → ${formatSize(file.size)}</p>
          </div>
        `
        batchGrid.appendChild(card)
      })
    }

    const compressBatch = async () => {
      const currentToken = ++jobToken
      state = 'processing'
      compressedResults = []
      hide(resultPanel)
      show(loading)

      let totalOriginal = 0
      let totalCompressed = 0

      for (let i = 0; i < originalFiles.length; i += CONCURRENCY) {
        if (currentToken !== jobToken) return
        const chunk = originalFiles.slice(i, i + CONCURRENCY)
        const results = await Promise.all(chunk.map(compressSingle))
        if (currentToken !== jobToken) return
        results.forEach((r, idx) => {
          if (r) {
            compressedResults.push(r)
            totalOriginal += chunk[idx].size
            totalCompressed += r.size
          }
        })
        const processed = Math.min(i + CONCURRENCY, originalFiles.length)
        const percent = Math.round((processed / originalFiles.length) * 100)
        loadingText.textContent = `Compressing... (${processed}/${originalFiles.length}) · ${percent}%`
      }

      revokeList(previewUrls)
      const originalUrl = URL.createObjectURL(originalFiles[0])
      const compressedUrl = URL.createObjectURL(compressedResults[0])
      previewUrls.push(originalUrl, compressedUrl)
      previewOriginal.src = originalUrl
      previewCompressed.src = compressedUrl

      renderBatchGrid()

      sizeOriginal.textContent = formatSize(totalOriginal)
      sizeCompressed.textContent = formatSize(totalCompressed)
      const saved = totalOriginal - totalCompressed
      const percent = Math.round((saved / totalOriginal) * 100)
      savingsText.textContent = `${percent}%`

      hide(loading)
      show(resultPanel)
      state = 'done'
    }

    const buildOutputName = (name: string, type: string) => {
      const base = name.replace(/\.[^/.]+$/, '')
      const ext = type.includes('webp') ? 'webp' : name.split('.').pop()
      return `${base}-compressed.${ext}`
    }

    const downloadResults = async () => {
      revokeList(downloadUrls)
      if (compressedResults.length === 1) {
        const url = URL.createObjectURL(compressedResults[0])
        downloadUrls.push(url)
        const link = document.createElement('a')
        link.href = url
        link.download = buildOutputName(originalFiles[0].name, compressedResults[0].type)
        link.click()
        return
      }
      const zip = new JSZip()
      compressedResults.forEach((file, i) => {
        zip.file(buildOutputName(originalFiles[i].name, file.type), file)
      })
      const blob = await zip.generateAsync({ type: 'blob' })
      const url = URL.createObjectURL(blob)
      downloadUrls.push(url)
      const link = document.createElement('a')
      link.href = url
      link.download = 'hugdot-compressed-images.zip'
      link.click()
    }

    const handleFiles = async (files: FileList) => {
      cleanup()
      originalFiles = Array.from(files)
        .filter((f) => f.type.startsWith('image/'))
        .slice(0, MAX_FILES)
      if (!originalFiles.length) return
      hide(dropZone)
      settingsPanel.style.display = 'flex'
      await compressBatch()
    }

    const onSliderInput = () => {
      targetValue.textContent = `${parseFloat(targetSlider.value).toFixed(1)} MB`
      if (debounceTimer) clearTimeout(debounceTimer)
      debounceTimer = setTimeout(() => {
        if (state !== 'idle') compressBatch()
      }, 400)
    }

    dropZone.addEventListener('click', () => fileInput.click())
    dropZone.addEventListener('dragover', (e) => e.preventDefault())
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault()
      if (e.dataTransfer?.files) handleFiles(e.dataTransfer.files)
    })
    fileInput.addEventListener('change', () => {
      if (fileInput.files) handleFiles(fileInput.files)
    })
    targetSlider.addEventListener('input', onSliderInput)
    saveBtn.addEventListener('click', downloadResults)
    resetBtn.addEventListener('click', cleanup)

    return () => cleanup()
  }
</script>