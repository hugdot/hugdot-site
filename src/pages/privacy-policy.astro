---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
---

<DefaultLayout
  title="Privacy Policy"
  description="Privacy Policy for our free online tools. We do not collect, store, or transmit any of your data."
>
  <section class="py-12">
    <div class="container max-w-3xl">

      <div class="mb-8">
        <Heading level="h1" size="h2">Privacy Policy</Heading>
        <p class="mt-2 opacity-60">Last updated: March 2026</p>
      </div>

      <div class="flex flex-col gap-8 leading-relaxed">

        <!-- TL;DR -->
        <div class="flex items-start gap-3 rounded-2xl border border-[var(--border-color-subtle)] bg-[var(--background-color)] px-6 py-5">
          <span class="text-2xl">🔒</span>
          <div>
            <p class="font-semibold">The short version</p>
            <p class="mt-1 opacity-60">All tools on this site run entirely in your browser. Your files, text, and data never leave your device. We do not collect, store, or transmit any of your personal data or files.</p>
          </div>
        </div>

        <!-- Section 1 -->
        <div>
          <Heading level="h2" size="h4">1. No Data Collection</Heading>
          <p class="mt-3 opacity-70">
            We do not collect any personal information from users of this site. All tools operate entirely on your device using your browser's built-in capabilities. No files, images, documents, or text you process with our tools are ever uploaded to any server.
          </p>
        </div>

        <!-- Section 2 -->
        <div>
          <Heading level="h2" size="h4">2. How Our Tools Work</Heading>
          <p class="mt-3 opacity-70">
            Every tool on this site is built using client-side technologies (HTML, CSS, JavaScript). When you use a tool — such as compressing an image, merging PDFs, or generating a QR code — all processing happens locally in your browser. Your data never leaves your device.
          </p>
        </div>

        <!-- Section 3 -->
        <div>
          <Heading level="h2" size="h4">3. Cookies & Local Storage</Heading>
          <p class="mt-3 opacity-70">
            We do not use tracking cookies. We may use your browser's local storage solely to remember your preferences (such as dark mode settings). This data stays on your device and is never transmitted to us.
          </p>
        </div>

        <!-- Section 4 -->
        <div>
          <Heading level="h2" size="h4">4. Third-Party Advertising</Heading>
          <p class="mt-3 opacity-70">
            This site may display advertisements served by Google AdSense. Google may use cookies to serve ads based on your prior visits to this website or other websites. You can opt out of personalized advertising by visiting <a href="https://www.google.com/settings/ads" target="_blank" rel="noopener noreferrer" class="text-[var(--action-color)] underline">Google Ads Settings</a>.
          </p>
        </div>

        <!-- Section 5 -->
        <div>
          <Heading level="h2" size="h4">5. Analytics</Heading>
          <p class="mt-3 opacity-70">
            We may use anonymized analytics tools to understand general usage patterns (such as which tools are most popular). This data does not include any personally identifiable information or the content of files you process.
          </p>
        </div>

        <!-- Section 6 -->
        <div>
          <Heading level="h2" size="h4">6. Children's Privacy</Heading>
          <p class="mt-3 opacity-70">
            Our site is not directed at children under the age of 13. We do not knowingly collect personal information from children.
          </p>
        </div>

        <!-- Section 7 -->
        <div>
          <Heading level="h2" size="h4">7. Changes to This Policy</Heading>
          <p class="mt-3 opacity-70">
            We may update this Privacy Policy from time to time. Any changes will be posted on this page with an updated date. Continued use of the site after changes constitutes acceptance of the new policy.
          </p>
        </div>

        <!-- Section 8 -->
        <div>
          <Heading level="h2" size="h4">8. Contact</Heading>
          <p class="mt-3 opacity-70">
            If you have any questions about this Privacy Policy, please contact us through the <a href="/contact" class="text-[var(--action-color)] underline">Contact page</a>.
          </p>
        </div>

      </div>
    </div>
  </section>
</DefaultLayout>