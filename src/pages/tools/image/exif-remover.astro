---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import seoData from '@data/seo/en/exif-remover.json'
import { tools, getToolHref } from '@data/tools/index'
const relatedTools = tools.filter((t) => t.category === 'image' && t.id !== 'exif-remover' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="MultimediaApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">

      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/image" class="breadcrumb-link hover:underline">Image Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Remove hidden metadata from your photos — including GPS location, camera model, and shooting date. Batch process up to 20 images at once.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:shield-check" size="0.875rem" class="text-[var(--action-color)]" />
            No Upload
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:user-x" size="0.875rem" class="text-[var(--action-color)]" />
            No Login
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:layers" size="0.875rem" class="text-[var(--action-color)]" />
            Batch up to 20
          </span>
        </div>
      </div>

      <!-- Privacy Warning -->
      <div class="mb-6 flex items-start gap-3 rounded-2xl border border-yellow-500/30 bg-yellow-500/10 px-5 py-4 text-sm">
        <Icon aria-hidden="true" name="lucide:alert-triangle" size="1.25rem" class="mt-0.5 shrink-0 text-yellow-500" />
        <div>
          <p class="font-semibold text-yellow-500">Your photos may contain hidden data</p>
          <p class="mt-1 opacity-70">Photos taken on smartphones often include your exact GPS location, device model, and more. This data is visible to anyone who receives the file.</p>
        </div>
      </div>

      <!-- Drop Zone -->
      <div
        id="drop-zone"
        class="flex cursor-pointer flex-col items-center justify-center gap-4 rounded-2xl border-2 border-dashed border-[var(--border-color-subtle)] p-12 text-center transition-all hover:border-[var(--action-color)]"
      >
        <Icon aria-hidden="true" name="lucide:image-plus" size="3rem" class="opacity-30" />
        <div>
          <p class="font-semibold">Open images</p>
          <p class="text-sm opacity-50">or drag & drop here</p>
        </div>
        <p class="text-xs opacity-40">JPG, PNG, WebP — up to 20 files</p>
        <input id="file-input" type="file" accept="image/*" multiple class="hidden" aria-label="Open images" />
      </div>

      <!-- Loading -->
      <div id="loading" class="mt-6 hidden flex-col items-center gap-3">
        <div class="h-8 w-8 animate-spin rounded-full border-4 border-[var(--border-color-subtle)] border-t-[var(--action-color)]"></div>
        <p id="loading-text" class="text-sm opacity-50">Processing...</p>
      </div>

      <!-- Result Panel -->
      <div id="result-panel" class="mt-6 hidden flex-col gap-6">

        <!-- Summary Stats -->
        <div class="grid grid-cols-3 gap-3">
          <div class="flex flex-col items-center rounded-2xl border border-[var(--border-color-subtle)] px-4 py-4">
            <span class="mb-1 text-xs opacity-50">Files</span>
            <span id="stat-files" class="text-lg font-bold"></span>
          </div>
          <div class="flex flex-col items-center rounded-2xl border border-[var(--border-color-subtle)] px-4 py-4">
            <span class="mb-1 text-xs opacity-50">EXIF Found</span>
            <span id="stat-exif" class="text-lg font-bold text-red-500"></span>
          </div>
          <div class="flex flex-col items-center rounded-2xl border border-[var(--border-color-subtle)] px-4 py-4">
            <span class="mb-1 text-xs opacity-50">Clean</span>
            <span id="stat-clean" class="text-lg font-bold text-green-500"></span>
          </div>
        </div>

        <!-- Batch Grid -->
        <div id="batch-grid" class="flex flex-col gap-3"></div>

        <!-- Actions -->
        <div class="flex gap-3">
          <button
            id="save-btn"
            class="flex flex-1 items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
          >
            <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
            Save All Clean Images
          </button>
          <button
            id="reset-btn"
            class="flex items-center justify-center gap-2 rounded-full border border-[var(--border-color-subtle)] px-6 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]"
          >
            <Icon aria-hidden="true" name="lucide:refresh-cw" size="1rem" />
            Reset
          </button>
        </div>

      </div>

      <!-- Privacy Badge -->
      <div class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60">
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Your images never leave your device. No data is sent to any server.</span>
      </div>

      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="mt-12">
          <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {relatedTools.map((tool) => (
              <a href={getToolHref(tool.category, tool.slug)}>
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]">
                {tool.label} →
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</DefaultLayout>

<script>
  import exifr from 'exifr'
  import JSZip from 'jszip'

  let cleanupFn: (() => void) | null = null

  document.addEventListener('astro:page-load', () => {
    cleanupFn?.()
    cleanupFn = initExifRemover()
  })

  function initExifRemover(): () => void {
    const MAX_FILES = 20
    const CONCURRENCY = navigator.hardwareConcurrency <= 4 ? 2 : 3

    let originalFiles: File[] = []
    let cleanedBlobs: Blob[] = []
    let jobToken = 0

    const dropZone = document.getElementById('drop-zone') as HTMLElement
    const fileInput = document.getElementById('file-input') as HTMLInputElement
    const loading = document.getElementById('loading') as HTMLElement
    const loadingText = document.getElementById('loading-text') as HTMLElement
    const resultPanel = document.getElementById('result-panel') as HTMLElement
    const batchGrid = document.getElementById('batch-grid') as HTMLElement
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement
    const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement
    const statFiles = document.getElementById('stat-files') as HTMLElement
    const statExif = document.getElementById('stat-exif') as HTMLElement
    const statClean = document.getElementById('stat-clean') as HTMLElement

    const EXIF_LABELS: Record<string, string> = {
      Make: '📷 Camera make',
      Model: '📷 Camera model',
      Software: '🛠 Software',
      DateTime: '📅 Date taken',
      DateTimeOriginal: '📅 Date original',
      GPSLatitude: '📍 GPS Latitude',
      GPSLongitude: '📍 GPS Longitude',
      GPSAltitude: '📍 GPS Altitude',
      GPSLatitudeRef: '📍 GPS Lat ref',
      GPSLongitudeRef: '📍 GPS Lng ref',
      ExposureTime: '⚙️ Exposure time',
      FNumber: '⚙️ F-number',
      ISO: '⚙️ ISO',
      FocalLength: '⚙️ Focal length',
      LensModel: '🔭 Lens model',
      Artist: '👤 Artist',
      Copyright: '©️ Copyright',
    }

    const formatSize = (bytes: number) =>
      bytes < 1024 * 1024
        ? `${(bytes / 1024).toFixed(1)} KB`
        : `${(bytes / 1024 / 1024).toFixed(2)} MB`

    const show = (el: HTMLElement) => (el.style.display = 'flex')
    const hide = (el: HTMLElement) => (el.style.display = 'none')

    const removeExifFromJpeg = (buffer: ArrayBuffer): ArrayBuffer => {
      const data = new Uint8Array(buffer)
      const chunks: Uint8Array[] = []
      let i = 0
      chunks.push(data.slice(0, 2))
      i = 2
      while (i < data.length - 1) {
        if (data[i] !== 0xff) break
        const marker = data[i + 1]
        if (marker >= 0xe0 && marker <= 0xef) {
          const segLen = (data[i + 2] << 8) | data[i + 3]
          if (marker === 0xe0) chunks.push(data.slice(i, i + 2 + segLen))
          i += 2 + segLen
          continue
        }
        if (marker === 0xda) {
          chunks.push(data.slice(i))
          break
        }
        const segLen = (data[i + 2] << 8) | data[i + 3]
        chunks.push(data.slice(i, i + 2 + segLen))
        i += 2 + segLen
      }
      const totalLength = chunks.reduce((acc, c) => acc + c.length, 0)
      const result = new Uint8Array(totalLength)
      let offset = 0
      chunks.forEach((c) => { result.set(c, offset); offset += c.length })
      return result.buffer
    }

    const processFile = async (file: File): Promise<{ blob: Blob; hasExif: boolean; exifData: Record<string, any> }> => {
      const isJpeg = file.type === 'image/jpeg' || /\.(jpg|jpeg)$/i.test(file.name)
      const arrayBuffer = await file.arrayBuffer()

      let exifData: Record<string, any> = {}
      try {
        exifData = await exifr.parse(arrayBuffer, { pick: Object.keys(EXIF_LABELS), gps: true }) ?? {}
      } catch { /* ignore */ }

      const hasExif = Object.keys(exifData).length > 0

      let cleanedBuffer: ArrayBuffer
      if (isJpeg) {
        cleanedBuffer = removeExifFromJpeg(arrayBuffer)
      } else {
        const blob = new Blob([arrayBuffer], { type: file.type })
        const url = URL.createObjectURL(blob)
        const img = new Image()
        await new Promise<void>((resolve) => { img.onload = () => resolve(); img.src = url })
        const canvas = document.createElement('canvas')
        canvas.width = img.naturalWidth
        canvas.height = img.naturalHeight
        canvas.getContext('2d')!.drawImage(img, 0, 0)
        URL.revokeObjectURL(url)
        cleanedBuffer = await new Promise<ArrayBuffer>((resolve) => {
          canvas.toBlob((b) => b!.arrayBuffer().then(resolve), file.type, 1.0)
        })
      }

      return {
        blob: new Blob([cleanedBuffer], { type: file.type }),
        hasExif,
        exifData,
      }
    }

    const processBatch = async () => {
      const currentToken = ++jobToken
      cleanedBlobs = []
      batchGrid.innerHTML = ''
      hide(resultPanel)
      show(loading)

      let exifCount = 0
      const results: { blob: Blob; hasExif: boolean; exifData: Record<string, any> }[] = []

      for (let i = 0; i < originalFiles.length; i += CONCURRENCY) {
        if (currentToken !== jobToken) return
        const chunk = originalFiles.slice(i, i + CONCURRENCY)
        const chunkResults = await Promise.all(chunk.map(processFile))
        if (currentToken !== jobToken) return
        results.push(...chunkResults)
        const processed = Math.min(i + CONCURRENCY, originalFiles.length)
        loadingText.textContent = `Processing... (${processed}/${originalFiles.length})`
      }

      results.forEach((r, i) => {
        cleanedBlobs.push(r.blob)
        if (r.hasExif) exifCount++

        const hasGPS = r.exifData.GPSLatitude || r.exifData.GPSLongitude
        const card = document.createElement('div')
        card.className = 'rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4'
        card.innerHTML = `
          <div class="flex items-center justify-between gap-3">
            <div class="flex items-center gap-3 min-w-0">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full ${r.hasExif ? 'bg-red-500/10' : 'bg-green-500/10'}">
                <span class="text-lg">${r.hasExif ? '⚠️' : '✅'}</span>
              </div>
              <div class="min-w-0">
                <p class="truncate text-sm font-medium">${originalFiles[i].name}</p>
                <p class="text-xs opacity-50">${formatSize(originalFiles[i].size)} → ${formatSize(r.blob.size)}</p>
              </div>
            </div>
            <span class="shrink-0 rounded-full px-3 py-1 text-xs font-medium ${r.hasExif ? 'bg-red-500/10 text-red-500' : 'bg-green-500/10 text-green-500'}">
              ${r.hasExif ? `${Object.keys(r.exifData).length} fields` : 'Clean'}
            </span>
          </div>
          ${hasGPS ? `
          <div class="mt-3 flex items-center gap-2 rounded-xl border border-red-500/20 bg-red-500/5 px-3 py-2 text-xs text-red-500">
            <span>📍 GPS location detected — will be removed</span>
          </div>` : ''}
          ${r.hasExif ? `
          <div class="mt-3 flex flex-wrap gap-2">
            ${Object.keys(r.exifData).slice(0, 5).map((k) => `
              <span class="rounded-full border border-[var(--border-color-subtle)] px-2 py-0.5 text-xs opacity-60">${EXIF_LABELS[k] ?? k}</span>
            `).join('')}
            ${Object.keys(r.exifData).length > 5 ? `<span class="rounded-full border border-[var(--border-color-subtle)] px-2 py-0.5 text-xs opacity-40">+${Object.keys(r.exifData).length - 5} more</span>` : ''}
          </div>` : ''}
        `
        batchGrid.appendChild(card)
      })

      statFiles.textContent = String(originalFiles.length)
      statExif.textContent = String(exifCount)
      statClean.textContent = String(originalFiles.length - exifCount)

      hide(loading)
      show(resultPanel)
    }

    const handleFiles = async (files: FileList) => {
      originalFiles = Array.from(files)
        .filter((f) => f.type.startsWith('image/'))
        .slice(0, MAX_FILES)
      if (!originalFiles.length) return
      hide(dropZone)
      await processBatch()
    }

    const downloadAll = async () => {
      if (!cleanedBlobs.length) return
      if (cleanedBlobs.length === 1) {
        const url = URL.createObjectURL(cleanedBlobs[0])
        const a = document.createElement('a')
        a.href = url
        a.download = `${originalFiles[0].name.replace(/\.[^/.]+$/, '')}-clean.${originalFiles[0].name.split('.').pop()}`
        a.click()
        URL.revokeObjectURL(url)
        return
      }
      const zip = new JSZip()
      cleanedBlobs.forEach((blob, i) => {
        const ext = originalFiles[i].name.split('.').pop()
        const name = originalFiles[i].name.replace(/\.[^/.]+$/, '')
        zip.file(`${name}-clean.${ext}`, blob)
      })
      const blob = await zip.generateAsync({ type: 'blob' })
      const url = URL.createObjectURL(blob)
      const a = document.createElement('a')
      a.href = url
      a.download = 'hugdot-clean-images.zip'
      a.click()
      URL.revokeObjectURL(url)
    }

    const reset = () => {
      jobToken++
      originalFiles = []
      cleanedBlobs = []
      fileInput.value = ''
      batchGrid.innerHTML = ''
      hide(resultPanel)
      hide(loading)
      show(dropZone)
    }

    dropZone.addEventListener('click', () => fileInput.click())
    dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-[var(--action-color)]') })
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-[var(--action-color)]'))
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault()
      dropZone.classList.remove('border-[var(--action-color)]')
      if (e.dataTransfer?.files) handleFiles(e.dataTransfer.files)
    })
    fileInput.addEventListener('change', () => { if (fileInput.files) handleFiles(fileInput.files) })
    saveBtn.addEventListener('click', downloadAll)
    resetBtn.addEventListener('click', reset)

    return reset
  }
</script>