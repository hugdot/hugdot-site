---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools } from '@data/tools'
import seoData from '@data/seo/en/image-compressor.json'

const relatedTools = tools.filter((t) => t.category === 'image' && t.id !== 'image-compressor' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  faq={seoData.faq}
  category="MultimediaApplication"
>
  <section class="py-12">
    <div class="container max-w-3xl">
      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/image" class="breadcrumb-link hover:underline">Image Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Compress images instantly without losing quality. Your images never leave your device — 100% private.
        </p>
        <!-- Badges -->
        <div class="mt-4 flex flex-wrap gap-2">
          <span
            class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium"
          >
            <Icon aria-hidden="true" name="lucide:shield-check" size="0.875rem" class="text-[var(--action-color)]" />
            No Upload
          </span>
          <span
            class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium"
          >
            <Icon aria-hidden="true" name="lucide:user-x" size="0.875rem" class="text-[var(--action-color)]" />
            No Login
          </span>
          <span
            class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium"
          >
            <Icon aria-hidden="true" name="lucide:infinity" size="0.875rem" class="text-[var(--action-color)]" />
            No Limits
          </span>
        </div>
      </div>

      <!-- Tool -->
      <div
        id="drop-zone"
        class="flex cursor-pointer flex-col items-center justify-center gap-4 rounded-2xl border-2 border-dashed border-[var(--border-color-subtle)] p-12 text-center transition-all hover:border-[var(--action-color)]"
      >
        <Icon aria-hidden="true" name="lucide:image-plus" size="3rem" class="opacity-30" />
        <div>
          <p class="font-semibold">Open an image</p>
          <p class="text-sm opacity-50">or tap to choose</p>
        </div>
        <p class="text-xs opacity-40">Supports JPG, PNG, WebP, GIF — up to 30MB</p>
        <input id="file-input" type="file" accept="image/*" class="hidden" aria-label="Open image" />
      </div>

      <div id="settings-panel" class="mt-6 hidden flex-col gap-4">
        <div
          id="webp-hint"
          class="hidden items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm opacity-60"
        >
          <Icon aria-hidden="true" name="lucide:lightbulb" size="1rem" />
          <span>Tip: Converting to WebP would make this file even smaller.</span>
        </div>
        <div class="flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <label class="text-sm font-medium" for="target-slider">Target size</label>
            <span id="target-value" class="text-lg font-bold text-[var(--action-color)]">— MB</span>
          </div>
          <input
            id="target-slider"
            type="range"
            min="0.1"
            max="10"
            step="0.1"
            value="2"
            class="w-full accent-[var(--action-color)]"
            aria-label="Target file size"
          />
          <div class="flex justify-between text-xs opacity-40">
            <span id="slider-min-label">0.1 MB</span>
            <span id="slider-max-label">30 MB</span>
          </div>
        </div>
        <button
          id="compress-btn"
          class="flex items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
        >
          <Icon aria-hidden="true" name="lucide:zap" size="1rem" />
          Compress
        </button>
      </div>

      <div id="loading" class="mt-8 hidden flex-col items-center gap-3">
        <div
          class="h-8 w-8 animate-spin rounded-full border-4 border-[var(--border-color-subtle)] border-t-[var(--action-color)]"
        >
        </div>
        <p class="text-sm opacity-50">Compressing...</p>
      </div>

      <div id="result-panel" class="mt-8 hidden flex-col gap-6">
        <div class="grid grid-cols-2 gap-4">
          <div class="flex flex-col gap-2">
            <p class="text-sm font-medium opacity-60">Original</p>
            <img
              id="preview-original"
              src=""
              alt="Original image"
              class="w-full rounded-2xl border border-[var(--border-color-subtle)] object-cover"
            />
            <p id="size-original" class="text-sm opacity-50"></p>
          </div>
          <div class="flex flex-col gap-2">
            <p class="text-sm font-medium opacity-60">Compressed</p>
            <img
              id="preview-compressed"
              src=""
              alt="Compressed image"
              class="w-full rounded-2xl border border-[var(--border-color-subtle)] object-cover"
            />
            <p id="size-compressed" class="text-sm opacity-50"></p>
          </div>
        </div>
        <div
          class="flex items-center justify-center gap-3 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-center"
        >
          <Icon aria-hidden="true" name="lucide:trending-down" size="1.25rem" class="text-[var(--action-color)]" />
          <span id="savings-text" class="font-semibold"></span>
        </div>
        <button
          id="save-btn"
          class="flex items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
        >
          <Icon aria-hidden="true" name="lucide:save" size="1rem" />
          Save Compressed Image
        </button>
        <button
          id="reset-btn"
          class="flex items-center justify-center gap-2 rounded-full border border-[var(--border-color-subtle)] px-8 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]"
        >
          <Icon aria-hidden="true" name="lucide:refresh-cw" size="1rem" />
          Open Another Image
        </button>
      </div>

      <!-- Privacy Badge -->
      <div
        class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60"
      >
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Your images never leave your device. No data is sent to any server.</span>
      </div>

      <!-- How to Use -->
      <div class="mt-16">
        <Heading level="h2" size="h4" class="mb-6">How to Compress Images</Heading>
        <div class="flex flex-col gap-4">
          {
            seoData.howto.map((item, index) => (
              <div class="flex gap-4 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--action-color)] text-sm font-bold text-white">
                  {index + 1}
                </span>
                <div>
                  <p class="font-semibold">{item.step}</p>
                  <p class="mt-1 text-sm opacity-60">{item.description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Why Use -->
      <div class="mt-12">
        <Heading level="h2" size="h4" class="mb-6">Why Use This Tool</Heading>
        <div class="flex flex-col gap-3">
          {
            seoData.why.map((reason) => (
              <div class="flex items-center gap-3 rounded-xl border border-[var(--border-color-subtle)] px-5 py-4">
                <Icon
                  aria-hidden="true"
                  name="lucide:check-circle"
                  size="1.25rem"
                  class="shrink-0 text-[var(--action-color)]"
                />
                <span class="text-sm">{reason}</span>
              </div>
            ))
          }
        </div>
      </div>

      <!-- FAQ -->
      <div class="mt-12">
        <Heading level="h2" size="h4" class="mb-6">Frequently Asked Questions</Heading>
        <div class="flex flex-col gap-3">
          {
            seoData.faq.map((item) => (
              <details class="rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4">
                <summary class="cursor-pointer font-semibold">{item.q}</summary>
                <p class="mt-3 text-sm opacity-60">{item.a}</p>
              </details>
            ))
          }
        </div>
      </div>
      <div class="mt-16 border-t border-[var(--border-color-subtle)] pt-8">
        <p class="mb-4 text-[10px] font-bold tracking-widest uppercase opacity-40">Related Keywords</p>
        <div class="flex flex-wrap gap-x-6 gap-y-3">
          {seoData.keywords.map((tag) => <span class="text-xs opacity-50">#{tag.toLowerCase()}</span>)}
        </div>
      </div>

      <!-- Related Tools -->
      <div class="mt-12">
        <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
          {
            relatedTools.map((tool) => (
              <a
                href={tool.href}
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]"
              >
                {tool.label} →
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>


<script>
  import imageCompression from 'browser-image-compression';
  document.addEventListener('astro:page-load', () => {
    initCompressor();
    function initCompressor() {
      let originalFile: File | null = null
      let compressedBlob: Blob | null = null

      const dropZone = document.getElementById('drop-zone') as HTMLElement
      const fileInput = document.getElementById('file-input') as HTMLInputElement
      const settingsPanel = document.getElementById('settings-panel') as HTMLElement
      const resultPanel = document.getElementById('result-panel') as HTMLElement
      const loading = document.getElementById('loading') as HTMLElement
      const targetSlider = document.getElementById('target-slider') as HTMLInputElement
      const targetValue = document.getElementById('target-value') as HTMLElement
      const sliderMinLabel = document.getElementById('slider-min-label') as HTMLElement
      const sliderMaxLabel = document.getElementById('slider-max-label') as HTMLElement
      const compressBtn = document.getElementById('compress-btn') as HTMLButtonElement
      const previewOriginal = document.getElementById('preview-original') as HTMLImageElement
      const previewCompressed = document.getElementById('preview-compressed') as HTMLImageElement
      const sizeOriginal = document.getElementById('size-original') as HTMLElement
      const sizeCompressed = document.getElementById('size-compressed') as HTMLElement
      const savingsText = document.getElementById('savings-text') as HTMLElement
      const saveBtn = document.getElementById('save-btn') as HTMLButtonElement
      const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement
      const webpHint = document.getElementById('webp-hint') as HTMLElement

      const formatSize = (bytes: number): string => {
        if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`
        return `${(bytes / (1024 * 1024)).toFixed(2)} MB`
      }

      const show = (el: HTMLElement) => (el.style.display = 'flex')
      const hide = (el: HTMLElement) => (el.style.display = 'none')

      const setupSlider = (file: File) => {
        const fileSizeMB = file.size / (1024 * 1024)
        const minMB = 0.1
        const maxMB = Math.max(parseFloat((fileSizeMB * 0.95).toFixed(1)), 0.2)
        const defaultMB = Math.min(2, maxMB)
        targetSlider.min = String(minMB)
        targetSlider.max = String(maxMB)
        targetSlider.value = String(defaultMB)
        targetSlider.step = maxMB > 10 ? '0.5' : '0.1'
        sliderMinLabel.textContent = `${minMB} MB`
        sliderMaxLabel.textContent = `${fileSizeMB.toFixed(1)} MB (original)`
        targetValue.textContent = `${defaultMB} MB`
        if (file.type === 'image/png') show(webpHint)
        else hide(webpHint)
      }

      const compress = async () => {
        if (!originalFile) return
        hide(resultPanel)
        show(loading)
        const targetMB = parseFloat(targetSlider.value)
        const options = { maxSizeMB: targetMB, useWebWorker: true, fileType: originalFile.type, initialQuality: 0.95 }
        try {
          const compressed = await imageCompression(originalFile, options)
          compressedBlob = compressed
          previewOriginal.src = URL.createObjectURL(originalFile)
          previewCompressed.src = URL.createObjectURL(compressed)
          const savedBytes = originalFile.size - compressed.size
          const savedPercent = Math.round((savedBytes / originalFile.size) * 100)
          sizeOriginal.textContent = formatSize(originalFile.size)
          sizeCompressed.textContent = formatSize(compressed.size)
          savingsText.textContent =
            savedPercent > 0
              ? `Saved ${formatSize(savedBytes)} (${savedPercent}% smaller)`
              : 'Image is already at optimal size'
          hide(loading)
          show(resultPanel)
        } catch (e) {
          console.error('Compression failed', e)
          hide(loading)
        }
      }

      targetSlider.addEventListener('input', () => {
        targetValue.textContent = `${parseFloat(targetSlider.value).toFixed(1)} MB`
      })
      compressBtn?.addEventListener('click', compress)
      dropZone.addEventListener('click', () => fileInput.click())
      dropZone.addEventListener('dragover', (e) => {
        e.preventDefault()
        dropZone.classList.add('border-[var(--action-color)]')
      })
      dropZone.addEventListener('dragleave', () => {
        dropZone.classList.remove('border-[var(--action-color)]')
      })
      dropZone.addEventListener('drop', (e) => {
        e.preventDefault()
        dropZone.classList.remove('border-[var(--action-color)]')
        const file = e.dataTransfer?.files[0]
        if (file && file.type.startsWith('image/')) {
          originalFile = file
          hide(dropZone)
          setupSlider(file)
          show(settingsPanel)
        }
      })
      fileInput.addEventListener('change', () => {
        const file = fileInput.files?.[0]
        if (file) {
          originalFile = file
          hide(dropZone)
          setupSlider(file)
          show(settingsPanel)
        }
      })
      saveBtn.addEventListener('click', () => {
        if (!compressedBlob || !originalFile) return
        const ext = originalFile.name.split('.').pop() ?? 'jpg'
        const name = originalFile.name.replace(/\.[^/.]+$/, '')
        const link = document.createElement('a')
        link.download = `${name}-compressed.${ext}`
        link.href = URL.createObjectURL(compressedBlob)
        link.click()
      })
      resetBtn.addEventListener('click', () => {
        originalFile = null
        compressedBlob = null
        fileInput.value = ''
        hide(resultPanel)
        hide(settingsPanel)
        hide(loading)
        hide(webpHint)
        dropZone.style.display = 'flex'
      })
    }
  })
</script>
