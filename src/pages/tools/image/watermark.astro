---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools, getToolHref } from '@data/tools/index'
import seoData from '@data/seo/en/image-watermark.json'

const relatedTools = tools.filter((t) => t.category === 'image' && t.id !== 'image-watermark' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="MultimediaApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">

      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/image" class="breadcrumb-link hover:underline">Image Tools</a>
          <span>/</span>
          <span>Image Watermark Tool</span>
        </div>
        <Heading level="h1" size="h2">Image Watermark Tool</Heading>
        <p class="mt-2 opacity-60">
          Add text or image watermarks to your photos instantly. Batch process up to 20 images at once.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:shield-check" size="0.875rem" class="text-[var(--action-color)]" />
            No Upload
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:user-x" size="0.875rem" class="text-[var(--action-color)]" />
            No Login
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:layers" size="0.875rem" class="text-[var(--action-color)]" />
            Batch up to 20
          </span>
        </div>
      </div>

      <!-- Tool -->
      <div class="flex flex-col gap-6">

        <!-- Drop Zone -->
        <div
          id="drop-zone"
          class="flex cursor-pointer flex-col items-center justify-center gap-4 rounded-2xl border-2 border-dashed border-[var(--border-color-subtle)] p-12 text-center transition-all hover:border-[var(--action-color)]"
        >
          <Icon aria-hidden="true" name="lucide:image-plus" size="3rem" class="opacity-30" />
          <div>
            <p class="font-semibold">Open images</p>
            <p class="text-sm opacity-50">or drag & drop here</p>
          </div>
          <p class="text-xs opacity-40">JPG, PNG, WebP — up to 20 files</p>
          <input id="file-input" type="file" accept="image/*" multiple class="hidden" />
        </div>

        <!-- Settings Panel -->
        <div id="settings-panel" class="hidden flex-col gap-6 rounded-2xl border border-[var(--border-color-subtle)] p-6">

          <!-- File Count -->
          <div class="flex items-center gap-2 text-sm opacity-60">
            <Icon aria-hidden="true" name="lucide:images" size="1rem" />
            <span id="file-count"></span>
          </div>

          <!-- Watermark Type -->
          <div class="flex flex-col gap-3">
            <p class="text-sm font-medium">Watermark Type</p>
            <div class="flex rounded-full border border-[var(--border-color-subtle)] p-1">
              <button id="type-text" class="type-btn flex-1 rounded-full py-2 text-sm font-medium transition-all">
                Text
              </button>
              <button id="type-image" class="type-btn flex-1 rounded-full py-2 text-sm font-medium transition-all">
                Image / Logo
              </button>
            </div>
          </div>

          <!-- Text Watermark Settings -->
          <div id="text-settings" class="flex flex-col gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium opacity-60" for="wm-text">Watermark Text</label>
              <input
                id="wm-text"
                type="text"
                value="© HugDot"
                maxlength="50"
                class="rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-4 py-3 text-sm outline-none focus:border-[var(--action-color)]"
              />
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div class="flex flex-col gap-1.5">
                <label class="text-xs font-medium opacity-60" for="wm-font-size">Font Size</label>
                <div class="flex items-center gap-2">
                  <input
                    id="wm-font-size"
                    type="range"
                    min="12"
                    max="120"
                    value="36"
                    class="flex-1 accent-[var(--action-color)]"
                  />
                  <span id="font-size-value" class="w-10 text-right text-sm font-medium">36px</span>
                </div>
              </div>
              <div class="flex flex-col gap-1.5">
                <label class="text-xs font-medium opacity-60" for="wm-color">Color</label>
                <div class="flex items-center gap-2">
                  <input id="wm-color" type="color" value="#ffffff" class="h-10 w-10 cursor-pointer rounded-lg border border-[var(--border-color-subtle)]" />
                  <span class="text-sm opacity-60">Text color</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Image Watermark Settings -->
          <div id="image-settings" class="hidden flex-col gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium opacity-60">Watermark Image / Logo</label>
              <label for="wm-image-input"
                class="flex cursor-pointer items-center gap-3 rounded-xl border border-dashed border-[var(--border-color-subtle)] px-4 py-3 text-sm opacity-50 transition-all hover:border-[var(--action-color)] hover:opacity-100">
                <Icon aria-hidden="true" name="lucide:image" size="1.25rem" />
                <span id="wm-image-label">Open watermark image</span>
              </label>
              <input id="wm-image-input" type="file" accept="image/*" class="hidden" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium opacity-60">Watermark Size</label>
              <div class="flex items-center gap-2">
                <input
                  id="wm-image-size"
                  type="range"
                  min="5"
                  max="50"
                  value="20"
                  class="flex-1 accent-[var(--action-color)]"
                />
                <span id="wm-image-size-value" class="w-12 text-right text-sm font-medium">20%</span>
              </div>
            </div>
          </div>

          <!-- Common Settings -->
          <div class="flex flex-col gap-4">

            <!-- Opacity -->
            <div class="flex flex-col gap-1.5">
              <div class="flex items-center justify-between">
                <label class="text-xs font-medium opacity-60">Opacity</label>
                <span id="opacity-value" class="text-sm font-medium">70%</span>
              </div>
              <input
                id="wm-opacity"
                type="range"
                min="10"
                max="100"
                value="70"
                class="w-full accent-[var(--action-color)]"
              />
            </div>

            <!-- Position -->
            <div class="flex flex-col gap-2">
              <label class="text-xs font-medium opacity-60">Position</label>
              <div class="grid grid-cols-3 gap-2">
                {['Top Left', 'Top Center', 'Top Right', 'Middle Left', 'Center', 'Middle Right', 'Bottom Left', 'Bottom Center', 'Bottom Right'].map((pos) => (
                  <button
                    data-position={pos}
                    class="position-btn rounded-xl border border-[var(--border-color-subtle)] py-2 text-xs font-medium transition-all hover:border-[var(--action-color)]"
                  >
                    {pos}
                  </button>
                ))}
              </div>
            </div>

            <!-- Tile Option -->
            <label class="flex cursor-pointer items-center gap-3">
              <input id="wm-tile" type="checkbox" class="accent-[var(--action-color)]" />
              <div>
                <p class="text-sm font-medium">Tile watermark</p>
                <p class="text-xs opacity-50">Repeat watermark across the entire image</p>
              </div>
            </label>

          </div>

          <!-- Preview -->
          <div class="flex flex-col gap-2">
            <p class="text-xs font-medium opacity-60">Preview (first image)</p>
            <canvas id="preview-canvas" class="w-full rounded-2xl border border-[var(--border-color-subtle)]"></canvas>
          </div>

          <!-- Apply Button -->
          <button
            id="apply-btn"
            class="flex items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
          >
            <Icon aria-hidden="true" name="lucide:stamp" size="1rem" />
            Apply to All & Save
          </button>

        </div>

        <!-- Loading -->
        <div id="loading" class="hidden flex-col items-center gap-3">
          <div class="h-8 w-8 animate-spin rounded-full border-4 border-[var(--border-color-subtle)] border-t-[var(--action-color)]"></div>
          <p id="loading-text" class="text-sm opacity-50">Processing...</p>
        </div>

        <!-- Result Panel -->
        <div id="result-panel" class="hidden flex-col gap-4">
          <div id="result-list" class="flex flex-col gap-2"></div>
          <div class="flex gap-3">
            <button
              id="save-btn"
              class="flex flex-1 items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
            >
              <Icon aria-hidden="true" name="lucide:save" size="1rem" />
              <span id="save-btn-text">Save</span>
            </button>
            <button
              id="reset-btn"
              class="flex items-center justify-center gap-2 rounded-full border border-[var(--border-color-subtle)] px-6 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)]"
            >
              <Icon aria-hidden="true" name="lucide:refresh-cw" size="1rem" />
              Reset
            </button>
          </div>
        </div>

      </div>

      <!-- Privacy Badge -->
      <div class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60">
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Your images never leave your device. No data is sent to any server.</span>
      </div>

      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="mt-12">
          <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {relatedTools.map((tool) => (
              
              <a href={getToolHref(tool.category, tool.slug)}
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]"
              >
                {tool.label} →
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</DefaultLayout>

<style>
  .type-btn.active {
    background-color: var(--action-color);
    color: white;
  }
  .position-btn.active {
    background-color: var(--action-color);
    color: white;
    border-color: var(--action-color);
  }
</style>

<script>
  import JSZip from 'jszip'

  let cleanupFn: (() => void) | null = null

  document.addEventListener('astro:page-load', () => {
    cleanupFn?.()
    cleanupFn = initWatermark()
  })

  function initWatermark(): () => void {
    const MAX_FILES = 20
    const CONCURRENCY = navigator.hardwareConcurrency <= 4 ? 2 : 3

    let originalFiles: File[] = []
    let resultBlobs: { blob: Blob; name: string }[] = []
    let wmType: 'text' | 'image' = 'text'
    let selectedPosition = 'Bottom Right'
    let wmImageEl: HTMLImageElement | null = null
    let jobToken = 0
    let previewUrl: string | null = null

    const dropZone = document.getElementById('drop-zone') as HTMLElement
    const fileInput = document.getElementById('file-input') as HTMLInputElement
    const settingsPanel = document.getElementById('settings-panel') as HTMLElement
    const loading = document.getElementById('loading') as HTMLElement
    const loadingText = document.getElementById('loading-text') as HTMLElement
    const resultPanel = document.getElementById('result-panel') as HTMLElement
    const resultList = document.getElementById('result-list') as HTMLElement
    const fileCount = document.getElementById('file-count') as HTMLElement
    const typeBtns = document.querySelectorAll('.type-btn') as NodeListOf<HTMLButtonElement>
    const textSettings = document.getElementById('text-settings') as HTMLElement
    const imageSettings = document.getElementById('image-settings') as HTMLElement
    const wmText = document.getElementById('wm-text') as HTMLInputElement
    const wmColor = document.getElementById('wm-color') as HTMLInputElement
    const wmFontSize = document.getElementById('wm-font-size') as HTMLInputElement
    const fontSizeValue = document.getElementById('font-size-value') as HTMLElement
    const wmImageInput = document.getElementById('wm-image-input') as HTMLInputElement
    const wmImageLabel = document.getElementById('wm-image-label') as HTMLElement
    const wmImageSize = document.getElementById('wm-image-size') as HTMLInputElement
    const wmImageSizeValue = document.getElementById('wm-image-size-value') as HTMLElement
    const wmOpacity = document.getElementById('wm-opacity') as HTMLInputElement
    const opacityValue = document.getElementById('opacity-value') as HTMLElement
    const wmTile = document.getElementById('wm-tile') as HTMLInputElement
    const positionBtns = document.querySelectorAll('.position-btn') as NodeListOf<HTMLButtonElement>
    const previewCanvas = document.getElementById('preview-canvas') as HTMLCanvasElement
    const applyBtn = document.getElementById('apply-btn') as HTMLButtonElement
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement
    const saveBtnText = document.getElementById('save-btn-text') as HTMLElement
    const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement

    const show = (el: HTMLElement) => (el.style.display = 'flex')
    const hide = (el: HTMLElement) => (el.style.display = 'none')

    const formatSize = (bytes: number) =>
      bytes < 1024 * 1024
        ? `${(bytes / 1024).toFixed(1)} KB`
        : `${(bytes / 1024 / 1024).toFixed(2)} MB`

    const setType = (type: 'text' | 'image') => {
      wmType = type
      typeBtns.forEach((btn) => btn.classList.toggle('active', btn.id === `type-${type}`))
      textSettings.style.display = type === 'text' ? 'flex' : 'none'
      imageSettings.style.display = type === 'image' ? 'flex' : 'none'
      updatePreview()
    }

    const setPosition = (pos: string) => {
      selectedPosition = pos
      positionBtns.forEach((btn) => btn.classList.toggle('active', btn.dataset.position === pos))
      updatePreview()
    }

    const getPositionXY = (
      canvasW: number, canvasH: number,
      wmW: number, wmH: number,
      pos: string,
      padding: number
    ): { x: number; y: number } => {
      const map: Record<string, { x: number; y: number }> = {
        'Top Left':      { x: padding, y: padding },
        'Top Center':    { x: (canvasW - wmW) / 2, y: padding },
        'Top Right':     { x: canvasW - wmW - padding, y: padding },
        'Middle Left':   { x: padding, y: (canvasH - wmH) / 2 },
        'Center':        { x: (canvasW - wmW) / 2, y: (canvasH - wmH) / 2 },
        'Middle Right':  { x: canvasW - wmW - padding, y: (canvasH - wmH) / 2 },
        'Bottom Left':   { x: padding, y: canvasH - wmH - padding },
        'Bottom Center': { x: (canvasW - wmW) / 2, y: canvasH - wmH - padding },
        'Bottom Right':  { x: canvasW - wmW - padding, y: canvasH - wmH - padding },
      }
      return map[pos] ?? map['Bottom Right']
    }

    const drawWatermark = (
      ctx: CanvasRenderingContext2D,
      canvasW: number,
      canvasH: number,
    ) => {
      const opacity = parseInt(wmOpacity.value) / 100
      ctx.globalAlpha = opacity
      const isTile = wmTile.checked
      const padding = Math.max(canvasW, canvasH) * 0.02

      if (wmType === 'text') {
        const fontSize = parseInt(wmFontSize.value)
        ctx.font = `bold ${fontSize}px sans-serif`
        ctx.fillStyle = wmColor.value
        const metrics = ctx.measureText(wmText.value)
        const textW = metrics.width
        const textH = fontSize

        if (isTile) {
          const gapX = textW * 1.5
          const gapY = textH * 3
          for (let y = 0; y < canvasH + gapY; y += gapY) {
            for (let x = -gapX; x < canvasW + gapX; x += gapX) {
              ctx.save()
              ctx.translate(x, y)
              ctx.rotate(-Math.PI / 6)
              ctx.fillText(wmText.value, 0, 0)
              ctx.restore()
            }
          }
        } else {
          const { x, y } = getPositionXY(canvasW, canvasH, textW, textH, selectedPosition, padding)
          ctx.fillText(wmText.value, x, y + textH)
        }
      } else if (wmType === 'image' && wmImageEl) {
        const sizeRatio = parseInt(wmImageSize.value) / 100
        const wmW = canvasW * sizeRatio
        const wmH = (wmImageEl.naturalHeight / wmImageEl.naturalWidth) * wmW

        if (isTile) {
          const gapX = wmW * 1.5
          const gapY = wmH * 2
          for (let y = 0; y < canvasH + gapY; y += gapY) {
            for (let x = -gapX; x < canvasW + gapX; x += gapX) {
              ctx.save()
              ctx.translate(x, y)
              ctx.rotate(-Math.PI / 6)
              ctx.drawImage(wmImageEl, 0, 0, wmW, wmH)
              ctx.restore()
            }
          }
        } else {
          const { x, y } = getPositionXY(canvasW, canvasH, wmW, wmH, selectedPosition, padding)
          ctx.drawImage(wmImageEl, x, y, wmW, wmH)
        }
      }

      ctx.globalAlpha = 1
    }

    const applyToCanvas = (img: HTMLImageElement, canvas: HTMLCanvasElement) => {
      canvas.width = img.naturalWidth
      canvas.height = img.naturalHeight
      const ctx = canvas.getContext('2d')!
      ctx.drawImage(img, 0, 0)
      drawWatermark(ctx, canvas.width, canvas.height)
    }

    const updatePreview = () => {
      if (!originalFiles.length) return
      const file = originalFiles[0]
      if (previewUrl) URL.revokeObjectURL(previewUrl)
      previewUrl = URL.createObjectURL(file)
      const img = new Image()
      img.onload = () => {
        applyToCanvas(img, previewCanvas)
        URL.revokeObjectURL(previewUrl!)
        previewUrl = null
      }
      img.src = previewUrl
    }

    const processFile = (file: File): Promise<Blob | null> => {
      return new Promise((resolve) => {
        const url = URL.createObjectURL(file)
        const img = new Image()
        img.onload = () => {
          const canvas = document.createElement('canvas')
          applyToCanvas(img, canvas)
          URL.revokeObjectURL(url)
          const mimeType = file.type || 'image/jpeg'
          canvas.toBlob((blob) => resolve(blob), mimeType, 0.92)
        }
        img.onerror = () => { URL.revokeObjectURL(url); resolve(null) }
        img.src = url
      })
    }

    const runApply = async () => {
      if (wmType === 'image' && !wmImageEl) {
        alert('Please select a watermark image first.')
        return
      }

      const currentToken = ++jobToken
      resultBlobs = []
      resultList.innerHTML = ''
      hide(resultPanel)
      show(loading)

      const results: { blob: Blob | null; file: File }[] = []

      for (let i = 0; i < originalFiles.length; i += CONCURRENCY) {
        if (currentToken !== jobToken) return
        const chunk = originalFiles.slice(i, i + CONCURRENCY)
        const chunkResults = await Promise.all(
          chunk.map(async (file) => ({ blob: await processFile(file), file }))
        )
        if (currentToken !== jobToken) return
        results.push(...chunkResults)
        const processed = Math.min(i + CONCURRENCY, originalFiles.length)
        loadingText.textContent = `Processing... (${processed}/${originalFiles.length})`
      }

      results.forEach(({ blob, file }) => {
        const ext = file.name.split('.').pop() ?? 'jpg'
        const name = `${file.name.replace(/\.[^/.]+$/, '')}-watermark.${ext}`

        if (blob) {
          resultBlobs.push({ blob, name })
          const previewUrl = URL.createObjectURL(blob)
          const item = document.createElement('div')
          item.className = 'flex items-center gap-3 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3'
          item.innerHTML = `
            <img src="${previewUrl}" alt="${file.name}" class="h-12 w-12 shrink-0 rounded-lg object-cover" />
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm font-medium">${name}</p>
              <p class="text-xs opacity-50">${formatSize(file.size)} → ${formatSize(blob.size)}</p>
            </div>
            <span class="shrink-0 rounded-full bg-green-500/10 px-3 py-1 text-xs font-medium text-green-500">✓</span>
          `
          resultList.appendChild(item)
        }
      })

      saveBtnText.textContent = resultBlobs.length === 1 ? 'Save Image' : 'Download All (ZIP)'
      hide(loading)
      show(resultPanel)
    }

    const downloadAll = async () => {
      if (!resultBlobs.length) return
      if (resultBlobs.length === 1) {
        const { blob, name } = resultBlobs[0]
        const url = URL.createObjectURL(blob)
        const link = document.createElement('a')
        link.href = url
        link.download = name
        link.click()
        URL.revokeObjectURL(url)
        return
      }
      const zip = new JSZip()
      resultBlobs.forEach(({ blob, name }) => zip.file(name, blob))
      const zipBlob = await zip.generateAsync({ type: 'blob' })
      const url = URL.createObjectURL(zipBlob)
      const link = document.createElement('a')
      link.href = url
      link.download = 'hugdot-watermarked.zip'
      link.click()
      URL.revokeObjectURL(url)
    }

    const handleFiles = (files: FileList) => {
      originalFiles = Array.from(files).filter((f) => f.type.startsWith('image/')).slice(0, MAX_FILES)
      if (!originalFiles.length) return
      fileCount.textContent = `${originalFiles.length} image${originalFiles.length > 1 ? 's' : ''} selected`
      hide(dropZone)
      hide(resultPanel)
      settingsPanel.style.display = 'flex'
      updatePreview()
    }

    // Event listeners
    document.getElementById('type-text')?.addEventListener('click', () => setType('text'))
    document.getElementById('type-image')?.addEventListener('click', () => setType('image'))

    positionBtns.forEach((btn) => {
      btn.addEventListener('click', () => { if (btn.dataset.position) setPosition(btn.dataset.position) })
    })

    wmText.addEventListener('input', updatePreview)
    wmColor.addEventListener('input', updatePreview)
    wmFontSize.addEventListener('input', () => {
      fontSizeValue.textContent = `${wmFontSize.value}px`
      updatePreview()
    })
    wmOpacity.addEventListener('input', () => {
      opacityValue.textContent = `${wmOpacity.value}%`
      updatePreview()
    })
    wmImageSize.addEventListener('input', () => {
      wmImageSizeValue.textContent = `${wmImageSize.value}%`
      updatePreview()
    })
    wmTile.addEventListener('change', updatePreview)

    wmImageInput.addEventListener('change', () => {
      const file = wmImageInput.files?.[0]
      if (!file) return
      const url = URL.createObjectURL(file)
      const img = new Image()
      img.onload = () => {
        wmImageEl = img
        wmImageLabel.textContent = file.name
        updatePreview()
      }
      img.src = url
    })

    dropZone.addEventListener('click', () => fileInput.click())
    dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-[var(--action-color)]') })
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-[var(--action-color)]'))
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault()
      dropZone.classList.remove('border-[var(--action-color)]')
      if (e.dataTransfer?.files) handleFiles(e.dataTransfer.files)
    })
    fileInput.addEventListener('change', () => { if (fileInput.files) handleFiles(fileInput.files) })

    applyBtn.addEventListener('click', runApply)
    saveBtn.addEventListener('click', downloadAll)
    resetBtn.addEventListener('click', () => {
      jobToken++
      originalFiles = []
      resultBlobs = []
      wmImageEl = null
      fileInput.value = ''
      wmImageInput.value = ''
      wmImageLabel.textContent = 'Open watermark image'
      resultList.innerHTML = ''
      hide(resultPanel)
      hide(loading)
      hide(settingsPanel)
      show(dropZone)
    })

    // Init
    setType('text')
