---
import Logo from './Logo.astro'
import { Heading, Link } from 'accessible-astro-components'
import { tools, getToolHref, getToolsByCategory } from '@data/tools/index'

const currentYear = new Date().getFullYear()
const textTools = getToolsByCategory('text')
const imageTools = getToolsByCategory('image')
const pdfTools = getToolsByCategory('pdf')
const generatorTools = getToolsByCategory('generator')
const snsTools = getToolsByCategory('sns')
const calculatorTools = getToolsByCategory('calculator')
---

<footer>
  <section class="py-16">
    <Heading level="h2" class="sr-only">Footer</Heading>
    <div class="container grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
      
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">Text Tools</Heading>
        <ul class="flex flex-col gap-2">
          {textTools.map((tool) => (
            <li><Link href={getToolHref(tool.category, tool.slug)}>{tool.label}</Link></li>
          ))}
        </ul>
      </div>

      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">Image Tools</Heading>
        <ul class="flex flex-col gap-2">
          {imageTools.map((tool) => (
            <li><Link href={getToolHref(tool.category, tool.slug)}>{tool.label}</Link></li>
          ))}
        </ul>
      </div>

      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">PDF Tools</Heading>
        <ul class="flex flex-col gap-2">
          {pdfTools.map((tool) => (
            <li><Link href={getToolHref(tool.category, tool.slug)}>{tool.label}</Link></li>
          ))}
        </ul>
      </div>

      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">Generators</Heading>
        <ul class="flex flex-col gap-2">
          {generatorTools.map((tool) => (
            <li><Link href={getToolHref(tool.category, tool.slug)}>{tool.label}</Link></li>
          ))}
        </ul>
      </div>

      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">SNS Tools</Heading>
        <ul class="flex flex-col gap-2">
          {snsTools.map((tool) => (
            <li><Link href={getToolHref(tool.category, tool.slug)}>{tool.label}</Link></li>
          ))}
        </ul>
      </div>

      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">Calculators</Heading>
        <ul class="flex flex-col gap-2">
          {calculatorTools.map((tool) => (
            <li><Link href={getToolHref(tool.category, tool.slug)}>{tool.label}</Link></li>
          ))}
        </ul>
      </div>

    </div>
  </section>

  <section class="py-8">
    <div class="container flex flex-col gap-4 md:flex-row md:justify-between">
      <div class="flex items-center gap-6">
        <Logo loading="lazy" />
        <ul class="flex gap-4">
          <li><Link href="/">Home</Link></li>
          <li><Link href="/contact">Contact</Link></li>
          <li><Link href="/privacy-policy">Privacy Policy</Link></li>
        </ul>
      </div>
      <p class="text-sm opacity-75">&copy; {currentYear} hugdot. All rights reserved.</p>
    </div>
  </section>
</footer>

<style>
  section {
    border-top: 1px solid var(--border-color-subtle);
  }
</style>
