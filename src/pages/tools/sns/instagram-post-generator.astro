---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import seoData from '@data/seo/en/instagram-post-generator.json'
import { tools, getToolHref } from '@data/tools/index'

const relatedTools = tools.filter((t) => t.category === 'sns' && t.id !== 'instagram-post-generator' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  category="SocialNetworkingApplication"
  {...seoData}
>
  <section class="py-12">
    <div class="container max-w-3xl">
      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/sns" class="breadcrumb-link hover:underline">SNS Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Create realistic-looking fake Instagram posts instantly. 100% private — your photos never leave your device.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:shield-check" size="0.875rem" class="text-[var(--action-color)]" />
            No Upload
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:user-x" size="0.875rem" class="text-[var(--action-color)]" />
            No Login
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:infinity" size="0.875rem" class="text-[var(--action-color)]" />
            No Limits
          </span>
        </div>
      </div>

      <!-- Tool -->
      <div class="flex flex-col gap-8">

        <!-- Controls -->
        <div class="flex flex-col gap-4 rounded-2xl border border-[var(--border-color-subtle)] p-6">

          <!-- Theme Toggle -->
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium">Theme</span>
            <div class="flex rounded-full border border-[var(--border-color-subtle)] p-1">
              <button id="theme-light" class="theme-btn rounded-full px-4 py-1.5 text-xs font-medium transition-all">Light</button>
              <button id="theme-dark" class="theme-btn rounded-full px-4 py-1.5 text-xs font-medium transition-all">Dark</button>
            </div>
          </div>

          <!-- Username + Verified -->
          <div class="flex gap-3">
            <div class="flex flex-1 flex-col gap-1.5">
              <label class="text-xs font-medium opacity-60" for="input-username">Username</label>
              <input id="input-username" type="text" value="username" maxlength="30"
                class="rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-3 py-2 text-sm outline-none focus:border-[var(--action-color)]" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium opacity-60">Verified</label>
              <button id="toggle-verified"
                class="flex h-[38px] w-[38px] items-center justify-center rounded-xl border border-[var(--border-color-subtle)] transition-all">
                <Icon aria-hidden="true" name="lucide:badge-check" size="1.25rem" />
              </button>
            </div>
          </div>

          <!-- Location -->
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-medium opacity-60" for="input-location">Location (optional)</label>
            <input id="input-location" type="text" placeholder="New York, USA" maxlength="50"
              class="rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-3 py-2 text-sm outline-none focus:border-[var(--action-color)]" />
          </div>

          <!-- Caption -->
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-medium opacity-60" for="input-caption">Caption</label>
            <textarea id="input-caption" rows="3" maxlength="300"
              placeholder="Write a caption... #hashtags @mentions supported"
              class="resize-none rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-3 py-2 text-sm outline-none focus:border-[var(--action-color)]"></textarea>
          </div>

          <!-- Likes + Comments -->
          <div class="grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium opacity-60" for="input-likes">Likes</label>
              <input id="input-likes" type="number" value="1234" min="0" max="9999999"
                class="rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-3 py-2 text-sm outline-none focus:border-[var(--action-color)]" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium opacity-60" for="input-comments">Comments</label>
              <input id="input-comments" type="number" value="42" min="0" max="9999999"
                class="rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-3 py-2 text-sm outline-none focus:border-[var(--action-color)]" />
            </div>
          </div>

          <!-- Time -->
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-medium opacity-60" for="input-time">Post Time</label>
            <input id="input-time" type="text" value="2 hours ago" maxlength="30"
              class="rounded-xl border border-[var(--border-color-subtle)] bg-transparent px-3 py-2 text-sm outline-none focus:border-[var(--action-color)]" />
          </div>

          <!-- Avatar + Post Image -->
          <div class="grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium opacity-60">Avatar (optional)</label>
              <label for="input-avatar"
                class="flex cursor-pointer flex-col items-center justify-center gap-1 rounded-xl border border-dashed border-[var(--border-color-subtle)] py-4 text-xs opacity-50 transition-all hover:border-[var(--action-color)] hover:opacity-100">
                <Icon aria-hidden="true" name="lucide:user-round" size="1.25rem" />
                <span>Open</span>
              </label>
              <input id="input-avatar" type="file" accept="image/*" class="hidden" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium opacity-60">Post Image</label>
              <label for="input-post-image"
                class="flex cursor-pointer flex-col items-center justify-center gap-1 rounded-xl border border-dashed border-[var(--border-color-subtle)] py-4 text-xs opacity-50 transition-all hover:border-[var(--action-color)] hover:opacity-100">
                <Icon aria-hidden="true" name="lucide:image" size="1.25rem" />
                <span>Open</span>
              </label>
              <input id="input-post-image" type="file" accept="image/*" class="hidden" />
            </div>
          </div>

        </div>

        <!-- Preview -->
        <div>
          <p class="mb-3 text-sm font-medium opacity-60">Preview</p>
          <div id="ig-post" class="ig-light mx-auto w-full max-w-sm overflow-hidden rounded-2xl border border-[var(--border-color-subtle)]">

            <!-- Header -->
            <div class="ig-header flex items-center gap-3 px-4 py-3">
              <div id="ig-avatar" class="h-9 w-9 shrink-0 overflow-hidden rounded-full bg-gradient-to-tr from-yellow-400 via-pink-500 to-purple-600">
                <img id="ig-avatar-img" src="" alt="" class="hidden h-full w-full object-cover" />
              </div>
              <div class="flex flex-1 flex-col">
                <div class="flex items-center gap-1">
                  <span id="ig-username" class="text-sm font-semibold">username</span>
                  <svg id="ig-verified" class="hidden h-4 w-4 text-blue-500" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <span id="ig-location" class="hidden text-xs opacity-60"></span>
              </div>
              <svg class="h-5 w-5 opacity-60" viewBox="0 0 24 24" fill="currentColor">
                <circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/>
              </svg>
            </div>

            <!-- Post Image -->
            <div id="ig-image-wrap" class="ig-image-placeholder aspect-square w-full bg-gray-200 flex items-center justify-center">
              <Icon aria-hidden="true" name="lucide:image" size="3rem" class="opacity-20" />
            </div>

            <!-- Actions -->
            <div class="ig-body px-4 py-3">
              <div class="mb-3 flex items-center gap-4">
                <svg id="ig-heart" class="h-6 w-6 cursor-pointer" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                </svg>
                <svg class="ml-auto h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                </svg>
              </div>

              <!-- Likes -->
              <p class="mb-1 text-sm font-semibold"><span id="ig-likes">1,234</span> likes</p>

              <!-- Caption -->
              <p class="mb-1 text-sm">
                <span class="font-semibold" id="ig-caption-username">username</span>
                <span id="ig-caption" class="ml-1"></span>
              </p>

              <!-- Comments -->
              <p class="mb-1 text-xs opacity-50">View all <span id="ig-comments">42</span> comments</p>

              <!-- Time -->
              <p class="text-xs opacity-40" id="ig-time">2 hours ago</p>
            </div>
          </div>
        </div>

        <!-- Save Button -->
        <button id="save-btn"
          class="flex items-center justify-center gap-2 rounded-full bg-[var(--action-color)] px-8 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90">
          <Icon aria-hidden="true" name="lucide:save" size="1rem" />
          Save as Image
        </button>

      </div>

      <!-- Privacy Badge -->
      <div class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60">
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Your photos never leave your device. No data is sent to any server.</span>
      </div>
      
      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="mt-12">
          <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {relatedTools.map((tool) => (
              <a href={getToolHref(tool.category, tool.slug)}
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium text-[var(--foreground-color)] no-underline transition-all hover:border-[var(--action-color)]">
                {tool.label} →
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</DefaultLayout>

<style>
  .ig-light {
    background: #ffffff;
    color: #000000;
  }
  .ig-dark {
    background: #000000;
    color: #ffffff;
  }
  .ig-light .ig-body,
  .ig-light .ig-header {
    background: #ffffff;
  }
  .ig-dark .ig-body,
  .ig-dark .ig-header {
    background: #000000;
  }
  .theme-btn.active {
    background-color: var(--action-color);
    color: white;
  }
  .ig-caption a {
    color: #0095f6;
  }
</style>

<script>
  import { toPng } from 'html-to-image'

  document.addEventListener('astro:page-load', () => {
    // Elements - Controls
    const inputUsername = document.getElementById('input-username') as HTMLInputElement
    const inputLocation = document.getElementById('input-location') as HTMLInputElement
    const inputCaption = document.getElementById('input-caption') as HTMLTextAreaElement
    const inputLikes = document.getElementById('input-likes') as HTMLInputElement
    const inputComments = document.getElementById('input-comments') as HTMLInputElement
    const inputTime = document.getElementById('input-time') as HTMLInputElement
    const inputAvatar = document.getElementById('input-avatar') as HTMLInputElement
    const inputPostImage = document.getElementById('input-post-image') as HTMLInputElement
    const toggleVerified = document.getElementById('toggle-verified') as HTMLButtonElement
    const themeBtns = document.querySelectorAll('.theme-btn') as NodeListOf<HTMLButtonElement>
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement

    // Elements - Preview
    const igPost = document.getElementById('ig-post') as HTMLElement
    const igUsername = document.getElementById('ig-username') as HTMLElement
    const igCaptionUsername = document.getElementById('ig-caption-username') as HTMLElement
    const igLocation = document.getElementById('ig-location') as HTMLElement
    const igVerified = document.getElementById('ig-verified') as HTMLElement
    const igAvatarImg = document.getElementById('ig-avatar-img') as HTMLImageElement
    const igImageWrap = document.getElementById('ig-image-wrap') as HTMLElement
    const igCaption = document.getElementById('ig-caption') as HTMLElement
    const igLikes = document.getElementById('ig-likes') as HTMLElement
    const igComments = document.getElementById('ig-comments') as HTMLElement
    const igTime = document.getElementById('ig-time') as HTMLElement
    const igHeart = document.getElementById('ig-heart') as HTMLElement

    let isVerified = false
    let isLiked = false
    let currentTheme = 'light'

    // Format number
    const formatNum = (n: number): string => {
      if (n >= 1000000) return `${(n / 1000000).toFixed(1)}M`
      if (n >= 1000) return `${(n / 1000).toFixed(1)}K`
      return n.toLocaleString()
    }

    // Format caption (hashtags, mentions, links)
    const formatCaption = (text: string): string => {
      return text
        .replace(/#(\w+)/g, '<span style="color:#0095f6">#$1</span>')
        .replace(/@(\w+)/g, '<span style="color:#0095f6">@$1</span>')
        .replace(/(https?:\/\/[^\s]+)/g, '<span style="color:#0095f6">$1</span>')
    }

    // Theme
    const setTheme = (theme: string) => {
      currentTheme = theme
      igPost.classList.remove('ig-light', 'ig-dark')
      igPost.classList.add(theme === 'dark' ? 'ig-dark' : 'ig-light')
      themeBtns.forEach((btn) => {
        btn.classList.toggle('active', btn.id === `theme-${theme}`)
      })
      // Update heart/icon colors
      const strokeColor = theme === 'dark' ? '#ffffff' : '#000000'
      igPost.querySelectorAll('svg').forEach((svg) => {
        svg.style.stroke = strokeColor
      })
      igHeart.style.stroke = isLiked ? 'none' : strokeColor
      igHeart.style.fill = isLiked ? '#ff3040' : 'none'
    }

    // Init theme
    setTheme('light')
    document.getElementById('theme-light')?.classList.add('active')

    // Inputs
    inputUsername.addEventListener('input', () => {
      igUsername.textContent = inputUsername.value || 'username'
      igCaptionUsername.textContent = inputUsername.value || 'username'
    })

    inputLocation.addEventListener('input', () => {
      const val = inputLocation.value.trim()
      if (val) {
        igLocation.textContent = val
        igLocation.classList.remove('hidden')
      } else {
        igLocation.classList.add('hidden')
      }
    })

    inputCaption.addEventListener('input', () => {
      igCaption.innerHTML = formatCaption(inputCaption.value)
    })

    inputLikes.addEventListener('input', () => {
      igLikes.textContent = formatNum(parseInt(inputLikes.value) || 0)
    })

    inputComments.addEventListener('input', () => {
      igComments.textContent = formatNum(parseInt(inputComments.value) || 0)
    })

    inputTime.addEventListener('input', () => {
      igTime.textContent = inputTime.value
    })

    // Verified toggle
    toggleVerified.addEventListener('click', () => {
      isVerified = !isVerified
      igVerified.classList.toggle('hidden', !isVerified)
      toggleVerified.style.borderColor = isVerified ? 'var(--action-color)' : ''
    })

    // Heart toggle
    igHeart.addEventListener('click', () => {
      isLiked = !isLiked
      const strokeColor = currentTheme === 'dark' ? '#ffffff' : '#000000'
      igHeart.style.fill = isLiked ? '#ff3040' : 'none'
      igHeart.style.stroke = isLiked ? 'none' : strokeColor
    })

    // Theme buttons
    document.getElementById('theme-light')?.addEventListener('click', () => setTheme('light'))
    document.getElementById('theme-dark')?.addEventListener('click', () => setTheme('dark'))

    // Avatar upload
    inputAvatar.addEventListener('change', () => {
      const file = inputAvatar.files?.[0]
      if (file) {
        const url = URL.createObjectURL(file)
        igAvatarImg.src = url
        igAvatarImg.classList.remove('hidden')
      }
    })

    // Post image upload
    inputPostImage.addEventListener('change', () => {
      const file = inputPostImage.files?.[0]
      if (file) {
        const url = URL.createObjectURL(file)
        igImageWrap.innerHTML = `<img src="${url}" alt="Post image" style="width:100%;aspect-ratio:1/1;object-fit:cover;" />`
      }
    })

    // Save
    saveBtn.addEventListener('click', async () => {
      try {
        saveBtn.textContent = 'Saving...'
        const dataUrl = await toPng(igPost, { cacheBust: true, pixelRatio: 2 })
        const link = document.createElement('a')
        link.download = 'instagram-post.png'
        link.href = dataUrl
        link.click()
      } catch (e) {
        console.error('Failed to save', e)
      } finally {
        saveBtn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Save as Image`
      }
    })
  })
</script>