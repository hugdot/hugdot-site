---
import { Icon } from 'astro-icon/components'
---

<section class="hero">
  <div class="container flex min-h-[60vh] flex-col items-center justify-center gap-6 text-center">
    <h1 class="text-3xl font-bold lg:text-5xl">
      Your Device. <span class="text-gradient">Your Tools.</span>
    </h1>
    <p class="text-base font-semibold tracking-wide opacity-50">No Upload. No Login. No Limits.</p>

    <div class="relative w-full max-w-2xl">
      <Icon
        aria-hidden="true"
        name="lucide:search"
        size="1.25rem"
        class="absolute top-1/2 left-5 -translate-y-1/2 opacity-40"
        style="z-index: 1;"
      />
      <input
        id="tool-search"
        type="text"
        placeholder="Search tools..."
        autocomplete="off"
        spellcheck="false"
        class="w-full rounded-full border-2 border-[var(--border-color-subtle)] bg-[var(--background-color)] py-4 pr-6 pl-14 text-lg shadow-sm transition-all outline-none focus:border-[var(--brand-primary)] focus:shadow-md"
        aria-label="Search tools"
      />
      <!-- Search results dropdown -->
      <ul
        id="search-results"
        class="absolute top-full right-0 left-0 z-50 mt-2 hidden max-h-80 overflow-y-auto rounded-2xl border border-[var(--border-color-subtle)] bg-[var(--background-color)] shadow-lg"
        role="listbox"
        aria-label="Search results"
      >
      </ul>
    </div>
  </div>
</section>

<style lang="scss">
  .text-gradient {
    background: linear-gradient(
      315deg,
      light-dark(var(--color-primary-300), var(--color-secondary-100)) 25%,
      light-dark(var(--color-secondary-300), var(--color-primary-200))
    );
    background-clip: border-box;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  #search-results li a,
  #search-results li a:link,
  #search-results li a:visited,
  #search-results li a:hover,
  #search-results li a:focus {
    color: var(--foreground-color) !important;
    text-decoration: none !important;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const searchInput = document.getElementById('tool-search') as HTMLInputElement | null
    const searchResults = document.getElementById('search-results') as HTMLUListElement | null
    if (!searchInput || !searchResults) return

    // Build tool list from the page's data-tool-name elements
    const buildToolList = () => {
      const cards = document.querySelectorAll<HTMLElement>('[data-tool-name]')
      const tools: { label: string; href: string; category: string }[] = []
      cards.forEach((card) => {
        const label = card.querySelector('span.font-semibold')?.textContent ?? ''
        const href = card.getAttribute('href') ?? ''
        const category = card.closest('[data-category]')?.getAttribute('data-category') ?? ''
        if (label && href) tools.push({ label, href, category })
      })
      return tools
    }

    const showResults = (tools: { label: string; href: string; category: string }[]) => {
      searchResults.innerHTML = ''
      if (tools.length === 0) {
        searchResults.innerHTML = `
          <li class="px-5 py-4 text-sm opacity-50">No tools found</li>
        `
      } else {
        tools.forEach((tool) => {
          const li = document.createElement('li')
          li.innerHTML = `
            <a href="${tool.href}" class="flex items-center gap-3 px-5 py-3 transition-colors hover:bg-[var(--border-color-subtle)]">
              <span class="text-sm font-semibold">${tool.label}</span>
              <span class="ml-auto text-xs opacity-40">${tool.category}</span>
            </a>
          `
          searchResults.appendChild(li)
        })
      }
      searchResults.classList.remove('hidden')
    }

    const hideResults = () => {
      searchResults.classList.add('hidden')
      searchResults.innerHTML = ''
    }

    searchInput.addEventListener('input', () => {
      const query = searchInput.value.toLowerCase().trim()
      if (!query) {
        hideResults()
        return
      }

      const allTools = buildToolList()
      const matched = allTools.filter((t) => t.label.toLowerCase().includes(query))
      showResults(matched)
    })

    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (!searchInput.contains(e.target as Node) && !searchResults.contains(e.target as Node)) {
        hideResults()
      }
    })

    // Close on Escape
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        hideResults()
        searchInput.value = ''
      }
    })
  })
</script>
