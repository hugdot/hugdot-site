---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { tools } from '@data/tools'
import seoData from '@data/seo/en/word-counter.json'

const relatedTools = tools.filter(t => t.category === 'text' && t.id !== 'word-counter' && t.available)
---

<DefaultLayout
  title={seoData.metaTitle}
  description={seoData.metaDescription}
  useTitleTemplate={false}
  faq={seoData.faq}
  howto={seoData.howto}
  why={seoData.why}
  category="UtilitiesApplication"
>
  <section class="py-12">
    <div class="container max-w-3xl">

      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-2 text-sm opacity-50">
          <a href="/" class="breadcrumb-link hover:underline">Home</a>
          <span>/</span>
          <a href="/tools/text" class="breadcrumb-link hover:underline">Text Tools</a>
          <span>/</span>
          <span>{seoData.metaTitle.split(' — ')[0]}</span>
        </div>
        <Heading level="h1" size="h2">{seoData.metaTitle.split(' — ')[0]}</Heading>
        <p class="mt-2 opacity-60">
          Count words, characters, sentences and paragraphs instantly.
          Everything runs in your browser — your text never leaves your device.
        </p>
        <!-- Badges -->
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:shield-check" size="0.875rem" class="text-[var(--action-color)]" />
            No Upload
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:user-x" size="0.875rem" class="text-[var(--action-color)]" />
            No Login
          </span>
          <span class="flex items-center gap-1.5 rounded-full border border-[var(--border-color-subtle)] px-3 py-1.5 text-xs font-medium">
            <Icon aria-hidden="true" name="lucide:infinity" size="0.875rem" class="text-[var(--action-color)]" />
            No Limits
          </span>
        </div>
      </div>

      <!-- Textarea -->
      <div class="relative">
        <textarea
          id="input-text"
          placeholder="Type or paste your text here..."
          rows="10"
          class="w-full resize-y rounded-2xl border-2 border-[var(--border-color-subtle)] bg-[var(--background-color)] p-5 text-base leading-relaxed outline-none transition-all focus:border-[var(--action-color)]"
          aria-label="Text input for word counting"
        ></textarea>
        <button
          id="clear-btn"
          class="absolute top-3 right-3 hidden rounded-full p-1.5 opacity-40 transition-opacity hover:opacity-100"
          aria-label="Clear text"
        >
          <Icon aria-hidden="true" name="lucide:x" size="1rem" />
        </button>
      </div>

      <!-- Platform Limits -->
      <div class="mt-8">
        <Heading level="h2" size="h6" class="mb-4 opacity-60">Platform character limits</Heading>
        <div class="flex flex-col gap-2">
          {[
            { name: 'Twitter / X', limit: 280, icon: 'lucide:twitter' },
            { name: 'Instagram Bio', limit: 150, icon: 'lucide:instagram' },
            { name: 'TikTok Bio', limit: 80, icon: 'lucide:music' },
            { name: 'YouTube Title', limit: 100, icon: 'lucide:youtube' },
            { name: 'SMS', limit: 160, icon: 'lucide:message-square' },
          ].map((platform) => (
            <div class="flex items-center gap-3 rounded-xl border border-[var(--border-color-subtle)] px-4 py-3">
              <Icon aria-hidden="true" name={platform.icon} size="1.25rem" class="shrink-0 opacity-60" />
              <span class="w-32 text-sm">{platform.name}</span>
              <div class="relative h-2 flex-1 overflow-hidden rounded-full bg-[var(--border-color-subtle)]">
                <div
                  class="platform-bar absolute left-0 top-0 h-full rounded-full bg-[var(--action-color)] transition-all"
                  style="width: 0%"
                  data-limit={platform.limit}
                ></div>
              </div>
              <span class="platform-remaining w-20 text-right text-sm opacity-60" data-limit={platform.limit}>
                {platform.limit} left
              </span>
            </div>
          ))}
        </div>
      </div>

      <!-- Stats Grid -->
      <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-4">
        <div class="flex flex-col items-center gap-1 rounded-2xl border border-[var(--border-color-subtle)] p-5 text-center">
          <span id="word-count" class="text-4xl font-bold text-[var(--action-color)]">0</span>
          <span class="text-sm opacity-60">Words</span>
        </div>
        <div class="flex flex-col items-center gap-1 rounded-2xl border border-[var(--border-color-subtle)] p-5 text-center">
          <span id="char-count" class="text-4xl font-bold text-[var(--action-color)]">0</span>
          <span class="text-sm opacity-60">Characters</span>
        </div>
        <div class="flex flex-col items-center gap-1 rounded-2xl border border-[var(--border-color-subtle)] p-5 text-center">
          <span id="sentence-count" class="text-4xl font-bold text-[var(--action-color)]">0</span>
          <span class="text-sm opacity-60">Sentences</span>
        </div>
        <div class="flex flex-col items-center gap-1 rounded-2xl border border-[var(--border-color-subtle)] p-5 text-center">
          <span id="para-count" class="text-4xl font-bold text-[var(--action-color)]">0</span>
          <span class="text-sm opacity-60">Paragraphs</span>
        </div>
      </div>

      <!-- Extra Stats -->
      <div class="mt-4 grid grid-cols-2 gap-4">
        <div class="flex items-center justify-between rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4">
          <span class="text-sm opacity-60">Characters (no spaces)</span>
          <span id="char-no-space" class="font-bold">0</span>
        </div>
        <div class="flex items-center justify-between rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4">
          <span class="text-sm opacity-60">Reading time</span>
          <span id="reading-time" class="font-bold">0 sec</span>
        </div>
      </div>
      
      <!-- Privacy Badge -->
      <div class="mt-8 flex items-center gap-2 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4 text-sm opacity-60">
        <Icon aria-hidden="true" name="lucide:shield-check" size="1rem" />
        <span>Your text never leaves your device. No data is sent to any server.</span>
      </div>
      
      <!-- How to Use -->
      <div class="mt-16">
        <Heading level="h2" size="h4" class="mb-6">How to Count Words</Heading>
        <div class="flex flex-col gap-4">
          {seoData.howto.map((item, index) => (
            <div class="flex gap-4 rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--action-color)] text-sm font-bold text-white">
                {index + 1}
              </span>
              <div>
                <p class="font-semibold">{item.step}</p>
                <p class="mt-1 text-sm opacity-60">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Why Use -->
      <div class="mt-12">
        <Heading level="h2" size="h4" class="mb-6">Why Use This Tool</Heading>
        <div class="flex flex-col gap-3">
          {seoData.why.map((reason) => (
            <div class="flex items-center gap-3 rounded-xl border border-[var(--border-color-subtle)] px-5 py-4">
              <Icon aria-hidden="true" name="lucide:check-circle" size="1.25rem" class="shrink-0 text-[var(--action-color)]" />
              <span class="text-sm">{reason}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- FAQ -->
      <div class="mt-12">
        <Heading level="h2" size="h4" class="mb-6">Frequently Asked Questions</Heading>
        <div class="flex flex-col gap-3">
          {seoData.faq.map((item) => (
            <details class="rounded-2xl border border-[var(--border-color-subtle)] px-5 py-4">
              <summary class="cursor-pointer font-semibold">{item.q}</summary>
              <p class="mt-3 text-sm opacity-60">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
      
      <div class="mt-16 border-t border-[var(--border-color-subtle)] pt-8">
        <p class="mb-4 text-[10px] font-bold uppercase tracking-widest opacity-40">Related Keywords</p>
        <div class="flex flex-wrap gap-x-6 gap-y-3"> {seoData.keywords.map((tag) => (
            <span class="text-xs opacity-50">#{tag.toLowerCase()}</span> 
          ))}
        </div>
      </div>

      {relatedTools.length > 0 && (
        <div class="mt-12">
          ...
        </div>
      )}

      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="mt-12">
          <Heading level="h2" size="h4" class="mb-6">Related Tools</Heading>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {relatedTools.map((tool) => (
              <a
                href={tool.href}
                class="rounded-xl border border-[var(--border-color-subtle)] px-4 py-3 text-sm font-medium transition-all hover:border-[var(--action-color)] text-[var(--foreground-color)] no-underline"
              >
                {tool.label} →
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</DefaultLayout>


<script>
  document.addEventListener('astro:page-load', () => {
    const input = document.getElementById('input-text') as HTMLTextAreaElement | null
    const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement | null
    if (!input || !clearBtn) return

    const wordCount = document.getElementById('word-count')!
    const charCount = document.getElementById('char-count')!
    const sentenceCount = document.getElementById('sentence-count')!
    const paraCount = document.getElementById('para-count')!
    const charNoSpace = document.getElementById('char-no-space')!
    const readingTime = document.getElementById('reading-time')!

    const platformBars = document.querySelectorAll<HTMLElement>('.platform-bar')
    const platformRemaining = document.querySelectorAll<HTMLElement>('.platform-remaining')

    const update = () => {
      const text = input.value

      // Counts
      const words = text.trim() === '' ? 0 : text.trim().split(/\s+/).length
      const chars = text.length
      const sentences = text.trim() === '' ? 0 : (text.match(/[^.!?]*[.!?]/g) ?? []).length
      const paras = text.trim() === '' ? 0 : text.split(/\n\s*\n/).filter((p) => p.trim() !== '').length || (text.trim() !== '' ? 1 : 0)
      const charsNoSpace = text.replace(/\s/g, '').length
      const minutes = Math.floor(words / 200)
      const seconds = Math.round((words % 200) / 200 * 60)
      const timeStr = minutes > 0 ? `${minutes} min ${seconds} sec` : `${seconds} sec`

      wordCount.textContent = words.toLocaleString()
      charCount.textContent = chars.toLocaleString()
      sentenceCount.textContent = sentences.toLocaleString()
      paraCount.textContent = paras.toLocaleString()
      charNoSpace.textContent = charsNoSpace.toLocaleString()
      readingTime.textContent = timeStr

      // Platform bars
      platformBars.forEach((bar) => {
        const limit = parseInt(bar.dataset.limit ?? '0')
        const pct = Math.min((chars / limit) * 100, 100)
        bar.style.width = pct + '%'
        bar.style.backgroundColor = pct >= 100 ? '#ef4444' : 'var(--action-color)'
      })

      platformRemaining.forEach((el) => {
        const limit = parseInt(el.dataset.limit ?? '0')
        const remaining = limit - chars
        el.textContent = remaining >= 0 ? `${remaining.toLocaleString()} left` : `${Math.abs(remaining).toLocaleString()} over`
        el.style.color = remaining < 0 ? '#ef4444' : ''
      })

      // Clear button
      clearBtn.classList.toggle('hidden', text === '')
    }

    const clear = () => {
      input.value = ''
      update()
      input.focus()
    }

    input.addEventListener('input', update)
    clearBtn.addEventListener('click', clear)
    update()
  })
</script>
