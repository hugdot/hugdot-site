---
// src/pages/[lang]/starrail/simulated-universe.astro
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Icon } from 'astro-icon/components'

const allData = import.meta.glob('/src/data/starrail/**/*.json', { eager: true })

export async function getStaticPaths() {
  const languages = ['kr', 'en', 'jp', 'cn', 'fr', 'de', 'es', 'id', 'pt', 'ru', 'th', 'vi', 'cht']
  return languages.map((lang) => ({ params: { lang } }))
}

const { lang } = Astro.params

const toAssetUrl = (rel: string) => {
  if (!rel) return ''
  let p = rel.replace(/^\//, '').replace(/^starrail\/assets\//, '')
  if (p.includes('icon/character/')) p = p.replace('icon/character/', 'icon/avatar/')
  return `/starrail/assets/${p}`
}

const baseDir = `/src/data/starrail/${lang}`
const blessingsRaw: Record<string, any> = (allData[`${baseDir}/simulated_blessings.json`] as any)?.default ?? {}
const curiosRaw:    Record<string, any> = (allData[`${baseDir}/simulated_curios.json`]    as any)?.default ?? {}
const blocksRaw:    Record<string, any> = (allData[`${baseDir}/simulated_blocks.json`]    as any)?.default ?? {}

const PATH_ICON: Record<string, string> = {
  Preservation: '/starrail/assets/icon/path/PreservationSmall.webp',
  Remembrance:  '/starrail/assets/icon/path/Memory.webp',
  Nihility:     '/starrail/assets/icon/path/NihilitySmall.webp',
  Abundance:    '/starrail/assets/icon/path/AbundanceSmall.webp',
  Hunt:         '/starrail/assets/icon/path/HuntSmall.webp',
  Destruction:  '/starrail/assets/icon/path/DestructionSmall.webp',
  Erudition:    '/starrail/assets/icon/path/EruditionSmall.webp',
  Elation:      '/starrail/assets/icon/path/ElationSmall.webp',
  Propagation:  '',
}

const PATH_COLOR: Record<string, string> = {
  Preservation: '#60a5fa', Remembrance: '#a78bfa', Nihility: '#94a3b8',
  Abundance: '#4ade80', Hunt: '#f97316', Destruction: '#f87171',
  Erudition: '#fbbf24', Elation: '#f472b6', Propagation: '#34d399',
}

const PATH_ORDER = [120, 121, 122, 123, 124, 125, 128, 126, 127]

const allBlessings = Object.values(blessingsRaw).filter((b: any) => b.name?.trim())

const pathGroups = new Map<string, any>()
for (const b of allBlessings as any[]) {
  const key = b.path_key ?? 'All'
  if (key === 'All') continue
  if (!pathGroups.has(key)) {
    pathGroups.set(key, {
      key, name: b.path_name ?? key,
      pathType: b.path_type ?? 100,
      icon: PATH_ICON[key] ?? '',
      color: PATH_COLOR[key] ?? '#7c9dfc',
      legendary: [], rare: [], common: [],
    })
  }
  const g = pathGroups.get(key)!
  const cat = (b.category ?? 'Common').toLowerCase()
  if (cat === 'legendary') g.legendary.push(b)
  else if (cat === 'rare') g.rare.push(b)
  else g.common.push(b)
}

const sortedPaths = PATH_ORDER
  .map(pt => [...pathGroups.values()].find(g => g.pathType === pt))
  .filter(Boolean)

const commonBlessings = (allBlessings as any[]).filter(b => (b.path_key ?? 'All') === 'All')
const curios = Object.values(curiosRaw).filter((c: any) => c.name?.trim()).sort((a: any, b: any) => +a.id - +b.id)
const blocks = Object.values(blocksRaw).filter((b: any) => b.name?.trim()).sort((a: any, b: any) => +a.id - +b.id)

const totalBlessings = allBlessings.length
const totalCurios    = curios.length
const totalBlocks    = blocks.length

// 모달용 전체 블레싱 배열 (JSON으로 넘길 것)
const blessingList = allBlessings.map((b: any) => ({
  id:       b.id,
  name:     b.name,
  desc:     b.desc,
  enhanced: b.enhanced_desc ?? '',
  path:     b.path_name ?? '',
  pathKey:  b.path_key ?? 'All',
  category: b.category ?? 'Common',
  color:    PATH_COLOR[b.path_key] ?? '#7c9dfc',
}))

const L = lang === 'kr'
  ? { title:'시뮬레이션 우주', subtitle:'축복, 기물, 구역 정보',
      tabB:'축복', tabC:'기물', tabD:'구역',
      search:'이름 검색…', all:'전체', reset:'초기화',
      showing:'{v}개 표시', total:'전체 {t}개', noMatch:'조건에 맞는 항목이 없습니다.',
      legendary:'전설', rare:'희귀', common:'일반', commonPath:'공통',
      enhanced:'강화 효과', lore:'로어', close:'닫기', canEnhance:'강화 가능' }
  : { title:'Simulated Universe', subtitle:'Blessings, Curios and Domains',
      tabB:'Blessings', tabC:'Curios', tabD:'Domains',
      search:'Search…', all:'All', reset:'Reset',
      showing:'{v} shown', total:'{t} total', noMatch:'No items match.',
      legendary:'Legendary', rare:'Rare', common:'Common', commonPath:'Common',
      enhanced:'Enhanced', lore:'Lore', close:'Close', canEnhance:'Enhanceable' }
---

<DefaultLayout title={`${L.title} | Star Rail DB`} description="Honkai: Star Rail Simulated Universe blessings, curios and domains.">
<div class="su-page">

  <!-- ── 헤더 ── -->
  <div class="su-header">
    <div class="su-wrap">
      
      <div class="title-row">
        <div>
          <h1 class="su-title">{L.title}</h1>
          <p class="su-sub">{L.subtitle}</p>
        </div>
        <div class="su-stats">
          <div class="stat"><span class="sv">{totalBlessings}</span><span class="sl">{L.tabB}</span></div>
          <div class="stat"><span class="sv">{totalCurios}</span><span class="sl">{L.tabC}</span></div>
          <div class="stat"><span class="sv">{totalBlocks}</span><span class="sl">{L.tabD}</span></div>
        </div>
      </div>
      <div class="main-tabs" role="tablist">
        <button class="mtab mtab--on" data-tab="blessings" role="tab" aria-selected="true">
          <Icon name="lucide:sparkles" size="0.8rem"/>{L.tabB}<span class="tc">{totalBlessings}</span>
        </button>
        <button class="mtab" data-tab="curios" role="tab" aria-selected="false">
          <Icon name="lucide:gem" size="0.8rem"/>{L.tabC}<span class="tc">{totalCurios}</span>
        </button>
        <button class="mtab" data-tab="blocks" role="tab" aria-selected="false">
          <Icon name="lucide:map" size="0.8rem"/>{L.tabD}<span class="tc">{totalBlocks}</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ── 블레싱 패널 ── -->
  <div id="panel-blessings" class="panel su-wrap">
    <div class="search-bar">
      <div class="sw"><Icon name="lucide:search" size="0.85rem" class="si"/><input type="search" id="blessSearch" placeholder={L.search} autocomplete="off" class="sinput"/></div>
      <button class="rbtn" id="blessReset" type="button"><Icon name="lucide:rotate-ccw" size="0.7rem"/>{L.reset}</button>
      <p class="scount" id="blessCount" aria-live="polite">
        {L.showing.replace('{v}', String(totalBlessings))} <span class="mu">· {L.total.replace('{t}', String(totalBlessings))}</span>
      </p>
    </div>

    <!-- Path 탭 -->
    <div class="path-nav" role="tablist">
      <button class="ptab ptab--on" data-ptab="all" role="tab" aria-selected="true">
        {L.all}<span class="ptc">{totalBlessings}</span>
      </button>
      {(sortedPaths as any[]).map(pg => (
        <button class="ptab" data-ptab={pg.key} role="tab" aria-selected="false" style={`--pc:${pg.color}`}>
          {pg.icon && <img src={pg.icon} alt={pg.name} width="16" height="16" loading="lazy" class="pticon"/>}
          {pg.name}<span class="ptc">{pg.legendary.length + pg.rare.length + pg.common.length}</span>
        </button>
      ))}
      {commonBlessings.length > 0 && (
        <button class="ptab" data-ptab="ALL" role="tab" aria-selected="false">
          {L.commonPath}<span class="ptc">{commonBlessings.length}</span>
        </button>
      )}
    </div>

    <!-- 블레싱 섹션 -->
    <div id="bless-sections">
      {(sortedPaths as any[]).map(pg => (
        <section class="psec" data-psec={pg.key}>
          <div class="psec-hd" style={`--pc:${pg.color}`}>
            {pg.icon && <img src={pg.icon} alt={pg.name} width="24" height="24" loading="lazy" class="psec-icon"/>}
            <h2 class="psec-name">{pg.name}</h2>
            <span class="psec-cnt">{pg.legendary.length + pg.rare.length + pg.common.length}</span>
          </div>

          {pg.legendary.length > 0 && (
            <div class="rg" data-rg>
              <p class="rl rl--l">{L.legendary}</p>
              <div class="bgrid">
                {pg.legendary.map((b: any) => (
                  <button class="bc bc--l" data-bc data-id={b.id} data-name={b.name.toLowerCase()} data-pk={b.path_key} aria-label={b.name}>
                    <div class="bc-top">
                      <span class="dot dot--l"/>
                      <p class="bc-name">{b.name}</p>
                      {b.enhanced_desc && <span class="enh-badge">{L.canEnhance}</span>}
                    </div>
                    <p class="bc-simple">{b.simple_desc || b.desc}</p>
                  </button>
                ))}
              </div>
            </div>
          )}
          {pg.rare.length > 0 && (
            <div class="rg" data-rg>
              <p class="rl rl--r">{L.rare}</p>
              <div class="bgrid">
                {pg.rare.map((b: any) => (
                  <button class="bc bc--r" data-bc data-id={b.id} data-name={b.name.toLowerCase()} data-pk={b.path_key} aria-label={b.name}>
                    <div class="bc-top">
                      <span class="dot dot--r"/>
                      <p class="bc-name">{b.name}</p>
                      {b.enhanced_desc && <span class="enh-badge">{L.canEnhance}</span>}
                    </div>
                    <p class="bc-simple">{b.simple_desc || b.desc}</p>
                  </button>
                ))}
              </div>
            </div>
          )}
          {pg.common.length > 0 && (
            <div class="rg" data-rg>
              <p class="rl rl--c">{L.common}</p>
              <div class="bgrid">
                {pg.common.map((b: any) => (
                  <button class="bc bc--c" data-bc data-id={b.id} data-name={b.name.toLowerCase()} data-pk={b.path_key} aria-label={b.name}>
                    <div class="bc-top">
                      <span class="dot dot--c"/>
                      <p class="bc-name">{b.name}</p>
                      {b.enhanced_desc && <span class="enh-badge">{L.canEnhance}</span>}
                    </div>
                    <p class="bc-simple">{b.simple_desc || b.desc}</p>
                  </button>
                ))}
              </div>
            </div>
          )}
        </section>
      ))}

      {commonBlessings.length > 0 && (
        <section class="psec" data-psec="ALL">
          <div class="psec-hd" style="--pc:#7c9dfc">
            <h2 class="psec-name">{L.commonPath}</h2>
            <span class="psec-cnt">{commonBlessings.length}</span>
          </div>
          <div class="rg" data-rg>
            <div class="bgrid">
              {commonBlessings.map((b: any) => (
                <button class="bc bc--c" data-bc data-id={b.id} data-name={b.name.toLowerCase()} data-pk="ALL" aria-label={b.name}>
                  <div class="bc-top">
                    <span class="dot dot--c"/>
                    <p class="bc-name">{b.name}</p>
                    {b.enhanced_desc && <span class="enh-badge">{L.canEnhance}</span>}
                  </div>
                  <p class="bc-simple">{b.simple_desc || b.desc}</p>
                </button>
              ))}
            </div>
          </div>
        </section>
      )}
    </div>

    <div id="blessEmpty" class="empty hidden"><Icon name="lucide:search-x" size="2.5rem"/><p>{L.noMatch}</p></div>
  </div>

  <!-- ── 큐리오 패널 ── -->
  <div id="panel-curios" class="panel su-wrap hidden">
    <div class="search-bar">
      <div class="sw"><Icon name="lucide:search" size="0.85rem" class="si"/><input type="search" id="curioSearch" placeholder={L.search} autocomplete="off" class="sinput"/></div>
      <p class="scount" id="curioCount" aria-live="polite">
        {L.showing.replace('{v}', String(totalCurios))} <span class="mu">· {L.total.replace('{t}', String(totalCurios))}</span>
      </p>
    </div>
    <div class="cgrid">
      {(curios as any[]).map(c => (
        <div class="cc" data-cc data-name={c.name.toLowerCase()}>
          <div class="cc-hd">
            {c.icon && <div class="cc-icon"><img src={toAssetUrl(c.icon)} alt={c.name} width="44" height="44" loading="lazy" decoding="async"/></div>}
            <p class="cc-name">{c.name}</p>
          </div>
          <p class="cc-desc">{c.desc}</p>
          {c.bg_desc && <div class="cc-lore"><span class="ltag">{L.lore}</span><p class="ltext">{c.bg_desc}</p></div>}
        </div>
      ))}
    </div>
    <div id="curioEmpty" class="empty hidden"><Icon name="lucide:search-x" size="2.5rem"/><p>{L.noMatch}</p></div>
  </div>

  <!-- ── 구역 패널 ── -->
  <div id="panel-blocks" class="panel su-wrap hidden">
    <div class="dgrid">
      {(blocks as any[]).map(b => (
        <div class="dc" style={`--bc:${b.color ?? '#7c9dfc'}`}>
          <div class="dc-hd">
            {b.icon_board && <div class="dc-icon"><img src={toAssetUrl(b.icon_board)} alt={b.name} width="36" height="36" loading="lazy" decoding="async"/></div>}
            <p class="dc-name">{b.name}</p>
          </div>
          <p class="dc-desc">{b.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- ── 블레싱 상세 모달 ── -->
  <div id="bless-modal" class="modal-backdrop hidden" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <div class="modal-box">
      <div class="modal-header" id="modal-header">
        <div class="modal-title-group">
          <span class="modal-path-tag" id="modal-path-tag"></span>
          <span class="modal-cat-tag" id="modal-cat-tag"></span>
        </div>
        <h3 class="modal-title" id="modal-title"></h3>
      </div>
      <div class="modal-body">
        <div class="modal-section">
          <p class="modal-desc" id="modal-desc"></p>
        </div>
        <div class="modal-section modal-enhanced hidden" id="modal-enhanced-wrap">
          <div class="modal-enhanced-header">
            <Icon name="lucide:zap" size="0.8rem" class="enh-icon"/>
            <span id="modal-enhanced-label"></span>
          </div>
          <p class="modal-desc modal-enhanced-desc" id="modal-enhanced-desc"></p>
        </div>
      </div>
      <button class="modal-close" id="modal-close" aria-label="닫기">
        <Icon name="lucide:x" size="1rem"/>
      </button>
    </div>
  </div>

</div>

<script is:inline define:vars={{
  lShowing: L.showing, lTotal: L.total,
  totalBlessings, totalCurios,
  blessingList,
  labelEnhanced: L.enhanced,
}}>
;(function () {
    function init() {
  // 블레싱 맵 (id → 데이터)
  var blessMap = {}
  blessingList.forEach(function(b){ blessMap[b.id] = b })

  

    // ── 메인 탭 ──
    var mtabs = [].slice.call(document.querySelectorAll('.mtab'))
    mtabs.forEach(function(btn){
      btn.addEventListener('click', function(){
        var t = btn.dataset.tab
        mtabs.forEach(function(b){ b.classList.toggle('mtab--on',b===btn); b.setAttribute('aria-selected',b===btn?'true':'false') })
        ;['blessings','curios','blocks'].forEach(function(id){
          var el=document.getElementById('panel-'+id); if(el) el.classList.toggle('hidden',id!==t)
        })
      },{passive:true})
    })

    // ── Path 탭 ──
    var ptabs   = [].slice.call(document.querySelectorAll('.ptab'))
    var psecs   = [].slice.call(document.querySelectorAll('.psec'))
    var activePk = 'all'

    function switchPk(k){
      activePk = k
      ptabs.forEach(function(t){ var on=t.dataset.ptab===k; t.classList.toggle('ptab--on',on); t.setAttribute('aria-selected',on?'true':'false') })
      psecs.forEach(function(s){ s.style.display = k==='all'||s.dataset.psec===k ? '' : 'none' })
      applyBS()
    }
    ptabs.forEach(function(t){ t.addEventListener('click',function(){ switchPk(t.dataset.ptab||'all') },{passive:true}) })

    // ── 블레싱 검색 ──
    var bsInput = document.getElementById('blessSearch')
    var bsCount = document.getElementById('blessCount')
    var bsEmpty = document.getElementById('blessEmpty')
    var bsReset = document.getElementById('blessReset')
    var bcards  = [].slice.call(document.querySelectorAll('[data-bc]'))
    var rgs     = [].slice.call(document.querySelectorAll('[data-rg]'))

    function applyBS(){
      var q = bsInput ? bsInput.value.trim().toLowerCase() : ''
      var v = 0
      bcards.forEach(function(c){
        var mp = activePk==='all' || c.dataset.pk===activePk
        var mq = !q || c.dataset.name.indexOf(q)!==-1
        var show = mp && mq
        c.classList.toggle('hidden',!show)
        if(show) v++
      })
      rgs.forEach(function(rg){ var vis=rg.querySelectorAll('[data-bc]:not(.hidden)'); rg.style.display=vis.length===0?'none':'' })
      psecs.forEach(function(s){
        if(activePk!=='all'&&s.dataset.psec!==activePk){ s.style.display='none'; return }
        var vis=s.querySelectorAll('[data-bc]:not(.hidden)')
        if(activePk==='all') s.style.display=vis.length===0?'none':''
      })
      var ss=lShowing.replace('{v}',String(v)), ts=lTotal.replace('{t}',String(totalBlessings))
      if(bsCount) bsCount.innerHTML=ss+' <span class="mu">· '+ts+'</span>'
      if(bsEmpty) bsEmpty.classList.toggle('hidden',v!==0)
    }

    if(bsInput){ bsInput.addEventListener('input',applyBS,{passive:true}); bsInput.addEventListener('search',applyBS,{passive:true}) }
    if(bsReset){ bsReset.addEventListener('click',function(){ if(bsInput){bsInput.value='';bsInput.focus()} switchPk('all') },{passive:true}) }

    // ── 모달 ──
    var modal       = document.getElementById('bless-modal')
    var modalTitle  = document.getElementById('modal-title')
    var modalDesc   = document.getElementById('modal-desc')
    var modalPath   = document.getElementById('modal-path-tag')
    var modalCat    = document.getElementById('modal-cat-tag')
    var modalEnhW   = document.getElementById('modal-enhanced-wrap')
    var modalEnhD   = document.getElementById('modal-enhanced-desc')
    var modalEnhL   = document.getElementById('modal-enhanced-label')
    var modalClose  = document.getElementById('modal-close')
    var modalHeader = document.getElementById('modal-header')

    var CAT_COLOR = { Legendary:'#fbbf24', Rare:'#a78bfa', Common:'#60a5fa' }

    function openModal(id){
      var b = blessMap[id]; if(!b) return
      if(modalTitle) modalTitle.textContent = b.name
      if(modalDesc)  modalDesc.textContent  = b.desc
      if(modalPath){ modalPath.textContent = b.path; modalPath.style.color = b.color; modalPath.style.borderColor = b.color; modalPath.style.background = b.color+'22' }
      if(modalCat){
        var cc = CAT_COLOR[b.category] || '#60a5fa'
        modalCat.textContent = b.category
        modalCat.style.color = cc; modalCat.style.borderColor = cc; modalCat.style.background = cc+'22'
      }
      if(modalHeader) modalHeader.style.setProperty('--mc', b.color)
      if(b.enhanced && modalEnhW && modalEnhD && modalEnhL){
        modalEnhD.textContent = b.enhanced
        modalEnhL.textContent = labelEnhanced
        modalEnhW.classList.remove('hidden')
      } else if(modalEnhW) modalEnhW.classList.add('hidden')
      if(modal) modal.classList.remove('hidden')
      document.body.style.overflow = 'hidden'
    }

    function closeModal(){
      if(modal) modal.classList.add('hidden')
      document.body.style.overflow = ''
    }

    bcards.forEach(function(c){
      c.addEventListener('click', function(){ openModal(c.dataset.id) }, {passive:true})
    })
    if(modalClose) modalClose.addEventListener('click', closeModal, {passive:true})
    if(modal) modal.addEventListener('click', function(e){ if(e.target===modal) closeModal() }, {passive:true})
    document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeModal() })

    // ── 큐리오 검색 ──
    var csInput = document.getElementById('curioSearch')
    var csCount = document.getElementById('curioCount')
    var csEmpty = document.getElementById('curioEmpty')
    var ccards  = [].slice.call(document.querySelectorAll('[data-cc]'))

    function applyCS(){
      var q=csInput?csInput.value.trim().toLowerCase():'', v=0
      ccards.forEach(function(c){ var show=!q||c.dataset.name.indexOf(q)!==-1; c.classList.toggle('hidden',!show); if(show)v++ })
      var ss=lShowing.replace('{v}',String(v)),ts=lTotal.replace('{t}',String(totalCurios))
      if(csCount) csCount.innerHTML=ss+' <span class="mu">· '+ts+'</span>'
      if(csEmpty) csEmpty.classList.toggle('hidden',v!==0)
    }
    if(csInput){ csInput.addEventListener('input',applyCS,{passive:true}); csInput.addEventListener('search',applyCS,{passive:true}) }

    applyBS()
  }
  document.addEventListener('DOMContentLoaded', init)
  document.addEventListener('astro:page-load', init)

})()

</script>
</DefaultLayout>

<style>
.su-page { min-height:100vh; background:var(--c-bg); color:var(--foreground-color); font-family:var(--font-body); }
.su-wrap { max-width:1400px; margin:0 auto; padding:0 1.5rem; }

/* 헤더 */
.su-header { border-bottom:1px solid var(--c-border); background:var(--c-surface); padding:2rem 0 0; }
.breadcrumb { display:flex; align-items:center; gap:.4rem; font-size:.68rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--c-muted); margin-bottom:1rem; }
.breadcrumb a { color:inherit; text-decoration:none; transition:color var(--anim-fast); }
.breadcrumb a:hover { color:var(--c-accent); }
.breadcrumb span { opacity:.4; }
.breadcrumb .cur { color:var(--c-accent); opacity:1; }
.title-row { display:flex; align-items:flex-end; justify-content:space-between; gap:1rem; flex-wrap:wrap; }
.su-title { font-family:var(--font-display); font-size:clamp(1.8rem,4vw,2.8rem); font-weight:700; letter-spacing:-.03em; text-transform:uppercase; line-height:1; }
.su-sub { margin-top:.4rem; font-size:.82rem; color:var(--c-muted); }
.su-stats { display:flex; gap:.6rem; }
